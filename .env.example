# Database
DB_NAME=mib
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_DIALECT=mysql

# Session & JWT (generate strong random values for production)
SESSION_SECRET=change_me_to_a_long_random_string
JWT_SECRET=change_me_to_a_long_random_string

# YubiKey API (optional — https://upgrade.yubico.com/getapikey/)
YUBIKEY_CLIENT_ID=
YUBIKEY_SECRET_KEY=

# WebAuthn (set to your domain in production)
RPID=localhost
ORIGIN=http://localhost:3000

# TOTP (optional)
TOTP_SECRET=

# Email (optional — for notifications)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# Server
NODE_ENV=development
PORT=3000
