<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raw Material Stock</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .search-box {
            position: relative;
            max-width: 300px;
            width: 100%;
        }

        .search-input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(27, 94, 32, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            font-size: 1rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
            color: white;
        }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5c636a;
            transform: translateY(-1px);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .btn {
                font-size: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .table-responsive {
                margin: 0 -1rem;
            }

            .table {
                margin: 0 1rem;
            }

            .table td {
                white-space: normal;
                min-width: 120px;
            }

            .table td:first-child {
                position: sticky;
                left: 0;
                background-color: white;
                z-index: 1;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger fade-in" style="border-radius: 8px; padding: 1rem; margin-bottom: 1rem; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem; background-color: #f8d7da; border: 1px solid #f5c2c7; color: #842029;">
                <i class="bi bi-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>
        <div class="page-header fade-in">
            <div>
                <h1 class="page-title">
                    <i class="bi bi-box2"></i>
                    Raw Material Stock
                </h1>
                <p class="page-subtitle">Overview of all raw materials and their stock levels</p>
            </div>
            <div class="search-box">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="search-input" placeholder="Search raw materials...">
            </div>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-list"></i>
                    Raw Material List
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Form</th>
                                <th>Density</th>
                                <th>Stock (Kg)</th>
                                <th>Stock (Pcs)</th>
                                <th>Stock (L)</th>
                                <% if (userRole !== 'Raw Material Warehouse') { %>
                                    <th>Vendor Prices in KG</th>
                                    <th>Vendor Prices in L</th>
                                <% } %>
                                <th>Last Updated</th>
                                <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                    <th>Actions</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% rawMaterials.forEach(material => { %>
                                <tr class="fade-in">
                                    <td>#<%= material.id %></td>
                                    <td><%= material.name %></td>
                                    <td><%= material.form %></td>
                                    <td><%= material.density %> gr/ml</td>
                                    <td><%= material.stock %></td>
                                    <td><%= material.stock %></td>
                                    <td><%= (material.stock / material.density).toFixed(2) %></td>
                                    <% if (userRole !== 'Raw Material Warehouse') { %>
                                        <td>
                                            <% if (material.Vendors && material.Vendors.length > 0) { %>
                                                <% material.Vendors.forEach(vendor => { %>
                                                    <div class="vendor-price-item">
                                                        <strong><%= vendor.name %>:</strong> 
                                                        <% if (vendor.vendorPrice) { %>
                                                            Rp <%= parseFloat(vendor.vendorPrice).toLocaleString('id-ID') %>
                                                        <% } else if (vendor.RawMaterialVendor && vendor.RawMaterialVendor.price) { %>
                                                            Rp <%= parseFloat(vendor.RawMaterialVendor.price).toLocaleString('id-ID') %>
                                                        <% } else { %>
                                                            <span class="text-muted">N/A</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted">No vendors assigned</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (material.Vendors && material.Vendors.length > 0) { %>
                                                <% material.Vendors.forEach(vendor => { %>
                                                    <div class="vendor-price-item">
                                                        <strong><%= vendor.name %>:</strong> 
                                                        <% if (vendor.vendorPrice) { %>
                                                            Rp <%= parseFloat(vendor.vendorPrice * material.density).toLocaleString('id-ID') %>
                                                        <% } else if (vendor.RawMaterialVendor && vendor.RawMaterialVendor.price) { %>
                                                            Rp <%= parseFloat(vendor.RawMaterialVendor.price * material.density).toLocaleString('id-ID') %>
                                                        <% } else { %>
                                                            <span class="text-muted">N/A</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted">No vendors assigned</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                    <td>
                                        <% 
                                            // Get the updatedAt timestamp
                                            const updatedDate = new Date(material.updatedAt);
                                            
                                            // Format date: DD-MM-YYYY HH:MM:SS
                                            const day = updatedDate.getDate().toString().padStart(2, '0');
                                            const month = (updatedDate.getMonth() + 1).toString().padStart(2, '0');
                                            const year = updatedDate.getFullYear();
                                            const hours = updatedDate.getHours().toString().padStart(2, '0');
                                            const minutes = updatedDate.getMinutes().toString().padStart(2, '0');
                                            const seconds = updatedDate.getSeconds().toString().padStart(2, '0');
                                            
                                            const formattedDate = `${day}-${month}-${year} ${hours}:${minutes}:${seconds} WIB`;
                                        %>
                                        <%= formattedDate %>
                                    </td>
                                    <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                        <td>
                                            <div class="action-buttons">
                                                <a href="/rawMaterials/edit/<%= material.id %>" class="btn btn-primary">
                                                    <i class="bi bi-pencil"></i>
                                                    Edit
                                                </a>
                                                <form action="/rawMaterials/delete/<%= material.id %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this raw material?');">
                                                        <i class="bi bi-trash"></i>
                                                        Delete
                                                    </button>
                                                </form>
                                                <% if (userRole === 'Purchase') { %>
                                                <a href="/rawMaterials/assignVendor/<%= material.id %>" class="btn btn-secondary">
                                                    <i class="bi bi-building"></i>
                                                    Assign Vendor
                                                </a>
                                                <% } %>
                                            </div>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                            <tr class="table-dark">
                                <td colspan="4"><strong>Total Stock</strong></td>
                                <td>
                                    <% const totalStockKg = rawMaterials.reduce((sum, material) => sum + material.stock, 0); %>
                                    <strong><%= totalStockKg.toFixed(2) %></strong>
                                </td>
                                <td>
                                    <strong><%= totalStockKg.toFixed(2) %></strong>
                                </td>
                                <td>
                                    <% const totalStockL = rawMaterials.reduce((sum, material) => sum + (material.stock / material.density), 0); %>
                                    <strong><%= totalStockL.toFixed(2) %></strong>
                                </td>
                                <% if (userRole !== 'Raw Material Warehouse') { %>
                                    <td colspan="2"></td>
                                <% } %>
                                <td></td>
                                <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                    <td></td>
                                <% } %>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="btn-group mt-4">
            <% if (userRole === 'Purchase') { %>
                <a href="/dashboard/purchase" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } else if (userRole === 'PPIC') { %>
                <a href="/dashboard/ppic" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } else if (userRole === 'Raw Material Warehouse') { %>
                <a href="/dashboard/raw-material-warehouse" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);

            // Format prices
            document.querySelectorAll('.price-format').forEach(function(element) {
                const value = parseFloat(element.textContent).toFixed(2)
                    .replace(/\d(?=(\d{3})+\.)/g, '$&,')
                    .replace(/\.00$/, '');
                element.textContent = value;
            });

            // Handle search
            const searchInput = document.querySelector('.search-input');
            searchInput.addEventListener('input', function() {
                const searchTerm = this.value.toLowerCase();
                const rows = document.querySelectorAll('tbody tr');

                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(searchTerm) ? '' : 'none';
                });
            });
        });
    </script>
</body>
</html>
