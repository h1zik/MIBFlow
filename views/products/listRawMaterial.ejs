<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Raw Material Stock' }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }
        .vendor-price-item { font-size: 0.82rem; line-height: 1.4; }
        .vendor-price-item + .vendor-price-item { margin-top: 0.15rem; }
        .table tfoot td { background: var(--mib-surface-2); font-weight: 700; border-top: 2px solid var(--mib-border-strong); }
        .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/rawMaterials/rawMaterialStock' }) %>

    <%
        const list = (typeof rawMaterials !== 'undefined' && rawMaterials) ? rawMaterials : [];
        const showVendorCols = userRole !== 'Raw Material Warehouse';
        const showActions = (userRole === 'Raw Material Warehouse' || userRole === 'Purchase');

        const totalStockKg = list.reduce((sum, material) => sum + material.stock, 0);
        const totalStockL = list.reduce((sum, material) => sum + (material.stock / material.density), 0);
        // base columns: ID, Name, Form, Density, Kg, Pcs, L  (7)
        let colCount = 7;
        if (showVendorCols) colCount += 2;
        colCount += 1; // Last Updated
        if (showActions) colCount += 1;
    %>

    <div class="content content-wide">

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= error %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-box2"></i> Raw Material Stock</h1>
                <p class="page-subtitle">Overview of all raw materials and their stock levels</p>
            </div>
        </div>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-boxes"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Materials</div>
                    <div class="stat-value"><%= list.length %></div>
                    <span class="stat-sub">Distinct raw materials</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-droplet-half"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Stock (Kg)</div>
                    <div class="stat-value"><%= totalStockKg.toFixed(2) %></div>
                    <span class="stat-sub">Across all materials</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-cup-straw"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Stock (L)</div>
                    <div class="stat-value"><%= totalStockL.toFixed(2) %></div>
                    <span class="stat-sub">Volume equivalent</span>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control search-input" placeholder="Search raw materials…" autocomplete="off">
            </div>
        </div>

        <!-- Table -->
        <div class="table-card fade-in">
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Form</th>
                            <th>Density</th>
                            <th class="text-end">Stock (Kg)</th>
                            <th class="text-end">Stock (Pcs)</th>
                            <th class="text-end">Stock (L)</th>
                            <% if (showVendorCols) { %>
                                <th>Vendor Prices in KG</th>
                                <th>Vendor Prices in L</th>
                            <% } %>
                            <th>Last Updated</th>
                            <% if (showActions) { %>
                                <th class="text-end">Actions</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (list.length > 0) { %>
                            <% list.forEach(material => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= material.id %></span></td>
                                    <td data-label="Name"><span class="cell-strong"><%= material.name %></span></td>
                                    <td data-label="Form"><%= material.form %></td>
                                    <td data-label="Density"><%= material.density %> gr/ml</td>
                                    <td data-label="Stock (Kg)" class="text-end num"><%= material.stock %></td>
                                    <td data-label="Stock (Pcs)" class="text-end num"><%= material.stock %></td>
                                    <td data-label="Stock (L)" class="text-end num"><%= (material.stock / material.density).toFixed(2) %></td>
                                    <% if (showVendorCols) { %>
                                        <td data-label="Vendor Prices in KG">
                                            <% if (material.Vendors && material.Vendors.length > 0) { %>
                                                <% material.Vendors.forEach(vendor => { %>
                                                    <div class="vendor-price-item">
                                                        <strong><%= vendor.name %>:</strong>
                                                        <% if (vendor.vendorPrice) { %>
                                                            Rp <%= parseFloat(vendor.vendorPrice).toLocaleString('id-ID') %>
                                                        <% } else if (vendor.RawMaterialVendor && vendor.RawMaterialVendor.price) { %>
                                                            Rp <%= parseFloat(vendor.RawMaterialVendor.price).toLocaleString('id-ID') %>
                                                        <% } else { %>
                                                            <span class="text-muted-2">N/A</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted-2">No vendors assigned</span>
                                            <% } %>
                                        </td>
                                        <td data-label="Vendor Prices in L">
                                            <% if (material.Vendors && material.Vendors.length > 0) { %>
                                                <% material.Vendors.forEach(vendor => { %>
                                                    <div class="vendor-price-item">
                                                        <strong><%= vendor.name %>:</strong>
                                                        <% if (vendor.vendorPrice) { %>
                                                            Rp <%= parseFloat(vendor.vendorPrice * material.density).toLocaleString('id-ID') %>
                                                        <% } else if (vendor.RawMaterialVendor && vendor.RawMaterialVendor.price) { %>
                                                            Rp <%= parseFloat(vendor.RawMaterialVendor.price * material.density).toLocaleString('id-ID') %>
                                                        <% } else { %>
                                                            <span class="text-muted-2">N/A</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted-2">No vendors assigned</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                    <td data-label="Last Updated">
                                        <%
                                            // Get the updatedAt timestamp
                                            const updatedDate = new Date(material.updatedAt);

                                            // Format date: DD-MM-YYYY HH:MM:SS
                                            const day = updatedDate.getDate().toString().padStart(2, '0');
                                            const month = (updatedDate.getMonth() + 1).toString().padStart(2, '0');
                                            const year = updatedDate.getFullYear();
                                            const hours = updatedDate.getHours().toString().padStart(2, '0');
                                            const minutes = updatedDate.getMinutes().toString().padStart(2, '0');
                                            const seconds = updatedDate.getSeconds().toString().padStart(2, '0');

                                            const formattedDate = `${day}-${month}-${year} ${hours}:${minutes}:${seconds} WIB`;
                                        %>
                                        <span class="cell-sub"><%= formattedDate %></span>
                                    </td>
                                    <% if (showActions) { %>
                                        <td data-label="Actions" class="text-end">
                                            <div class="action-buttons justify-content-end">
                                                <a href="/rawMaterials/edit/<%= material.id %>" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-pencil"></i>
                                                    Edit
                                                </a>
                                                <form action="/rawMaterials/delete/<%= material.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this raw material?');">
                                                        <i class="bi bi-trash"></i>
                                                        Delete
                                                    </button>
                                                </form>
                                                <% if (userRole === 'Purchase') { %>
                                                <a href="/rawMaterials/assignVendor/<%= material.id %>" class="btn btn-sm btn-soft">
                                                    <i class="bi bi-building"></i>
                                                    Assign Vendor
                                                </a>
                                                <% } %>
                                            </div>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="<%= colCount %>">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No raw materials</h4>
                                        <p>Raw materials and their stock levels will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                    <% if (list.length > 0) { %>
                    <tfoot>
                        <tr>
                            <td colspan="4" data-label="Total"><strong>Total Stock</strong></td>
                            <td data-label="Stock (Kg)" class="text-end num"><strong><%= totalStockKg.toFixed(2) %></strong></td>
                            <td data-label="Stock (Pcs)" class="text-end num"><strong><%= totalStockKg.toFixed(2) %></strong></td>
                            <td data-label="Stock (L)" class="text-end num"><strong><%= totalStockL.toFixed(2) %></strong></td>
                            <% if (showVendorCols) { %>
                                <td colspan="2"></td>
                            <% } %>
                            <td></td>
                            <% if (showActions) { %>
                                <td></td>
                            <% } %>
                        </tr>
                    </tfoot>
                    <% } %>
                </table>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <% if (userRole === 'Purchase') { %>
                <a href="/dashboard/purchase" class="btn btn-soft">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } else if (userRole === 'PPIC') { %>
                <a href="/dashboard/ppic" class="btn btn-soft">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } else if (userRole === 'Raw Material Warehouse') { %>
                <a href="/dashboard/raw-material-warehouse" class="btn btn-soft">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            <% } %>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Format prices
            document.querySelectorAll('.price-format').forEach(function(element) {
                const value = parseFloat(element.textContent).toFixed(2)
                    .replace(/\d(?=(\d{3})+\.)/g, '$&,')
                    .replace(/\.00$/, '');
                element.textContent = value;
            });

            // Handle search
            const searchInput = document.querySelector('.search-input');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase();
                    const rows = document.querySelectorAll('tbody tr');

                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        row.style.display = text.includes(searchTerm) ? '' : 'none';
                    });
                });
            }
        });
    </script>
</body>
</html>
