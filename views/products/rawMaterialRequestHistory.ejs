<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raw Material Request History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .form-select {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 16px 12px;
        }

        .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .quantity-input {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .quantity-input .form-control {
            width: 100px;
            text-align: right;
            padding-right: 0.5rem;
        }

        .quantity-input .form-select {
            width: 80px;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .status-badge {
            padding: 0.35rem 0.65rem;
            font-size: 0.75rem;
            font-weight: 500;
            border-radius: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .status-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .status-completed {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .status-cancelled {
            background-color: #f8d7da;
            color: #842029;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control, .form-select {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .table-responsive {
                margin: 0 -1rem;
            }

            .table {
                margin: 0 1rem;
            }

            .table td {
                white-space: normal;
                min-width: 120px;
            }

            .table td:first-child {
                position: sticky;
                left: 0;
                background-color: white;
                z-index: 1;
            }

            .quantity-input {
                flex-direction: column;
                align-items: stretch;
            }

            .quantity-input .form-control,
            .quantity-input .form-select {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-clock-history"></i>
                Raw Material Request History
            </h1>
            <p class="page-subtitle">View and manage raw material request history</p>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-funnel"></i>
                    Filter Options
                </h2>
            </div>
            <div class="card-body">
                <form method="GET" action="/finance/rawMaterialRequestHistory">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label" for="startDate">Start Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startDate %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label" for="endDate">End Date</label>
                                <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endDate %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label" for="sortOrder">Sort Order</label>
                                <select class="form-select" id="sortOrder" name="sortOrder">
                                    <option value="asc" <%= sortOrder === 'asc' ? 'selected' : '' %>>Ascending</option>
                                    <option value="desc" <%= sortOrder === 'desc' ? 'selected' : '' %>>Descending</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                            Apply Filters
                        </button>
                    </div>
                </form>
            </div>
        </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-clock"></i>
                        Unpaid requests
                    </h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Material Name</th>
                                    <th>PO Number</th>
                                    <th>Quantity</th>
                                    <th>Real Quantity</th>
                                    <th>Tax</th>
                                    <th>Status</th>
                                    <th>Vendor</th>
                                    <th>Payment Type</th>
                                    <th>Created At</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (topRequests && topRequests.length > 0) { %>
                                    <% topRequests.forEach(request => { %>
                                        <tr class="fade-in">
                                            <td>#<%= request.id %></td>
                                            <td><%= request.RawMaterialRequest.materialName %></td>
                                            <td><%= request.ponumber || 'N/A' %></td>
                                            <td>
                                                <div class="quantity-input">
                                                    <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control">
                                                    <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                        <option value="Kg">Kg</option>
                                                        <option value="L">L</option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="quantity-input">
                                                    <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control">
                                                    <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                        <option value="Kg">Kg</option>
                                                        <option value="L">L</option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td><%= request.tax %>%</td>
                                            <td>
                                                <span class="status-badge status-<%= request.status.toLowerCase() %>">
                                                    <i class="bi bi-circle-fill"></i>
                                                    <%= request.status %>
                                                </span>
                                            </td>
                                            <td><%= request.Vendor.name %></td>
                                            <td><%= request.paymentType %></td>
                                            <td><%= request.createdAt.toLocaleDateString() %></td>
                                            <td>
                                                <% if (!request.RawMaterialRequest.isPaid && userRole === 'Finance') { %>
                                                    <form action="/finance/markRawMaterialPaid/<%= request.id %>" method="POST" style="display: inline;">
                                                        <button type="submit" class="btn btn-success">
                                                            <i class="bi bi-check-circle"></i>
                                                            Paid
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="10" class="text-center py-4 text-muted">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No requests with payment type TOP found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-clock"></i>
                    Paid Requests
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Material Name</th>
                                <th>PO Number</th>
                                <th>Quantity</th>
                                <th>Real Quantity</th>
                                <th>Tax</th>
                                <th>Status</th>
                                <th>Vendor</th>
                                <th>Payment Type</th>
                                    <th>Created At</th>
                                    <th>Actions</th>
                                </tr>
                        </thead>
                        <tbody>
                            <% if (otherRequests && otherRequests.length > 0) { %>
                                <% otherRequests.forEach(request => { %>
                                    <tr class="fade-in">
                                        <td>#<%= request.id %></td>
                                        <td><%= request.RawMaterialRequest.materialName %></td>
                                        <td><%= request.ponumber || 'N/A' %></td>
                                        <td>
                                            <div class="quantity-input">
                                                <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control">
                                                <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                    <option value="Kg">Kg</option>
                                                    <option value="L">L</option>
                                                </select>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="quantity-input">
                                                <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control">
                                                <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                    <option value="Kg">Kg</option>
                                                    <option value="L">L</option>
                                                </select>
                                            </div>
                                        </td>
                                        <td><%= request.tax %></td>
                                        <td>
                                            <span class="status-badge status-<%= request.status.toLowerCase() %>">
                                                <i class="bi bi-circle-fill"></i>
                                                <%= request.status %>
                                            </span>
                                        </td>
                                        <td><%= request.Vendor.name %></td>
                                        <td><%= request.paymentType %></td>
                                        <td><%= request.createdAt.toLocaleDateString() %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                        <td colspan="10" class="text-center py-4 text-muted">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No raw material requests found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <% if (userRole !== 'Purchase') { %>
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-calendar-check"></i>
                        Payment Due
                    </h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Material Name</th>
                                    <th>PO Number</th>
                                    <th>Quantity</th>
                                    <th>Real Quantity</th>
                                    <th>Tax</th>
                                    <th>Status</th>
                                    <th>Vendor</th>
                                    <th>Payment Type</th>
                                    <th>Payment Due</th>
                                    <th>Created At</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (topRequests && topRequests.length > 0) { %>
                                    <% topRequests.filter(request => request.paymentDueDate && new Date(request.paymentDueDate) >= new Date()).forEach(request => { %>
                                        <tr class="fade-in">
                                            <td>#<%= request.id %></td>
                                            <td><%= request.RawMaterialRequest.materialName %></td>
                                            <td><%= request.ponumber || 'N/A' %></td>
                                            <td>
                                                <div class="quantity-input">
                                                    <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control">
                                                    <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                        <option value="Kg">Kg</option>
                                                        <option value="L">L</option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="quantity-input">
                                                    <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control">
                                                    <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select">
                                                        <option value="Kg">Kg</option>
                                                        <option value="L">L</option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td><%= request.tax %>%</td>
                                            <td>
                                                <span class="status-badge status-<%= request.status.toLowerCase() %>">
                                                    <i class="bi bi-circle-fill"></i>
                                                    <%= request.status %>
                                                </span>
                                            </td>
                                            <td><%= request.Vendor.name %></td>
                                            <td><%= request.paymentType %></td>
                                            <td><%= request.paymentDueDate.toLocaleDateString() %></td>
                                            <td><%= request.createdAt.toLocaleDateString() %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="11" class="text-center py-4 text-muted">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No upcoming payment dues found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });

        function updateQuantity(id, density) {
            const splitUnit = document.getElementById(`splitUnit_${id}`).value;
            const realUnit = document.getElementById(`realUnit_${id}`).value;
            const splitQuantityInput = document.getElementById(`splitQuantity_${id}`);
            const realQuantityInput = document.getElementById(`realQuantity_${id}`);

            // Update splitQuantity only when its unit is changed
            if (event.target.id === `splitUnit_${id}`) {
                if (splitUnit === 'L') {
                    splitQuantityInput.value = (splitQuantityInput.value / density).toFixed(2);
                } else {
                    splitQuantityInput.value = (splitQuantityInput.value * density).toFixed(2);
                }
            }

            // Update realQuantity only when its unit is changed
            if (event.target.id === `realUnit_${id}`) {
                if (realUnit === 'L') {
                    realQuantityInput.value = (realQuantityInput.value / density).toFixed(2);
                } else {
                    realQuantityInput.value = (realQuantityInput.value * density).toFixed(2);
                }
            }
        }
    </script>
</body>
</html>
