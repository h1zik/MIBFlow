<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Raw Material Request History' }) %>
    <style>
        /* Page-scoped flourishes — built on the shared mibflow.css tokens only */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }

        /* Inline qty + unit editor (logic preserved from original) */
        .quantity-input { display: flex; align-items: center; gap: 0.4rem; }
        .quantity-input .form-control { width: 92px; text-align: right; }
        .quantity-input .form-select { width: 78px; }
        @media (max-width: 768px) {
            .quantity-input { justify-content: flex-end; }
            .quantity-input .form-control { width: 90px; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/rawMaterial/history' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const topList   = (typeof topRequests !== 'undefined' && topRequests) ? topRequests : [];
        const otherList = (typeof otherRequests !== 'undefined' && otherRequests) ? otherRequests : [];
        const sStart    = (typeof startDate !== 'undefined' && startDate) ? startDate : '';
        const sEnd      = (typeof endDate !== 'undefined' && endDate) ? endDate : '';
        const sSort     = (typeof sortOrder !== 'undefined' && sortOrder) ? sortOrder : 'asc';

        const dueList = topList.filter(r => r.paymentDueDate && new Date(r.paymentDueDate) >= new Date());

        /* status badge helper */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
    %>

    <div class="content content-wide">

        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-clock-history"></i> Raw Material Request History</h1>
                <p class="page-subtitle">View and manage raw material request history</p>
            </div>
        </div>

        <%- include('../partials/flash') %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Unpaid (TOP)</div>
                    <div class="stat-value"><%= topList.length %></div>
                    <span class="stat-sub">Awaiting payment</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check2-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Paid Requests</div>
                    <div class="stat-value"><%= otherList.length %></div>
                    <span class="stat-sub">Settled procurement</span>
                </div>
            </div>
            <% if (userRole !== 'Purchase') { %>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Payment Due</div>
                    <div class="stat-value"><%= dueList.length %></div>
                    <span class="stat-sub">Upcoming dues</span>
                </div>
            </div>
            <% } %>
        </div>

        <!-- ===================== Filter card ===================== -->
        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-funnel"></i> Filter Options</h2>
            </div>
            <div class="card-body">
                <form method="GET" action="/finance/rawMaterialRequestHistory">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="startDate">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= sStart %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="endDate">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= sEnd %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="sortOrder">Sort Order</label>
                            <select class="form-select" id="sortOrder" name="sortOrder">
                                <option value="asc" <%= sSort === 'asc' ? 'selected' : '' %>>Ascending</option>
                                <option value="desc" <%= sSort === 'desc' ? 'selected' : '' %>>Descending</option>
                            </select>
                        </div>
                    </div>
                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Apply Filters</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===================== Unpaid requests ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-hourglass-split"></i> Unpaid Requests</h2>
                <span class="status-badge status-pending"><%= topList.length %> total</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>PO Number</th>
                            <th>Quantity</th>
                            <th>Real Quantity</th>
                            <th>Tax</th>
                            <th>Status</th>
                            <th>Vendor</th>
                            <th>Payment Type</th>
                            <th>Created At</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (topList.length > 0) { %>
                            <% topList.forEach(request => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><%= request.RawMaterialRequest.materialName %></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Real Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Tax"><%= request.tax %>%</td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Vendor"><%= request.Vendor.name %></td>
                                    <td data-label="Payment Type"><%= request.paymentType %></td>
                                    <td data-label="Created At"><%= request.createdAt.toLocaleDateString() %></td>
                                    <td data-label="Action" class="text-end">
                                        <% if (!request.RawMaterialRequest.isPaid && userRole === 'Finance') { %>
                                            <form action="/finance/markRawMaterialPaid/<%= request.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-circle"></i> Paid</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="11"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No unpaid requests</h4><p>No requests with payment type TOP found.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===================== Paid requests ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-check2-circle"></i> Paid Requests</h2>
                <span class="status-badge status-completed"><%= otherList.length %> total</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>PO Number</th>
                            <th>Quantity</th>
                            <th>Real Quantity</th>
                            <th>Tax</th>
                            <th>Status</th>
                            <th>Vendor</th>
                            <th>Payment Type</th>
                            <th>Created At</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (otherList.length > 0) { %>
                            <% otherList.forEach(request => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><%= request.RawMaterialRequest.materialName %></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Real Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Tax"><%= request.tax %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Vendor"><%= request.Vendor.name %></td>
                                    <td data-label="Payment Type"><%= request.paymentType %></td>
                                    <td data-label="Created At"><%= request.createdAt.toLocaleDateString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="10"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No raw material requests</h4><p>Paid raw material requests appear here.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <% if (userRole !== 'Purchase') { %>
        <!-- ===================== Payment due ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-calendar-check"></i> Payment Due</h2>
                <span class="status-badge status-scheduled"><%= dueList.length %> upcoming</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>PO Number</th>
                            <th>Quantity</th>
                            <th>Real Quantity</th>
                            <th>Tax</th>
                            <th>Status</th>
                            <th>Vendor</th>
                            <th>Payment Type</th>
                            <th>Payment Due</th>
                            <th>Created At</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (topList.length > 0) { %>
                            <% topList.filter(request => request.paymentDueDate && new Date(request.paymentDueDate) >= new Date()).forEach(request => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><%= request.RawMaterialRequest.materialName %></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="splitQuantity_<%= request.id %>" value="<%= request.splitQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="splitUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Real Quantity">
                                        <div class="quantity-input">
                                            <input type="number" id="realQuantity_<%= request.id %>" value="<%= request.RawMaterialRequest.realQuantity %>" readonly class="form-control form-control-sm">
                                            <select id="realUnit_<%= request.id %>" onchange="updateQuantity('<%= request.id %>', '<%= request.RawMaterialRequest.RawMaterial.density %>')" class="form-select form-select-sm">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </div>
                                    </td>
                                    <td data-label="Tax"><%= request.tax %>%</td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Vendor"><%= request.Vendor.name %></td>
                                    <td data-label="Payment Type"><%= request.paymentType %></td>
                                    <td data-label="Payment Due"><%= request.paymentDueDate.toLocaleDateString() %></td>
                                    <td data-label="Created At"><%= request.createdAt.toLocaleDateString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="11"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No upcoming payment dues</h4><p>Requests with an upcoming due date appear here.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

    </div>

    <script>
        function updateQuantity(id, density) {
            const splitUnit = document.getElementById(`splitUnit_${id}`).value;
            const realUnit = document.getElementById(`realUnit_${id}`).value;
            const splitQuantityInput = document.getElementById(`splitQuantity_${id}`);
            const realQuantityInput = document.getElementById(`realQuantity_${id}`);

            // Update splitQuantity only when its unit is changed
            if (event.target.id === `splitUnit_${id}`) {
                if (splitUnit === 'L') {
                    splitQuantityInput.value = (splitQuantityInput.value / density).toFixed(2);
                } else {
                    splitQuantityInput.value = (splitQuantityInput.value * density).toFixed(2);
                }
            }

            // Update realQuantity only when its unit is changed
            if (event.target.id === `realUnit_${id}`) {
                if (realUnit === 'L') {
                    realQuantityInput.value = (realQuantityInput.value / density).toFixed(2);
                } else {
                    realQuantityInput.value = (realQuantityInput.value * density).toFixed(2);
                }
            }
        }
    </script>
</body>
</html>
