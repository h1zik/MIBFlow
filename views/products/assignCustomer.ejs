<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assign Customer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-select {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 16px 12px;
        }

        .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .customer-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .customer-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: white;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            box-shadow: var(--shadow);
            transition: var(--transition);
            animation: fadeIn 0.3s ease-in-out;
        }

        .customer-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.1);
        }

        .customer-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .customer-name {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

        .last-updated {
            font-size: 0.8rem;
            color: #6c757d;
        }

        .customer-actions {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
            color: white;
            padding: 0.5rem;
            width: auto;
        }

        .btn-danger:hover {
            background-color: #c82333;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-select {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .btn-group {
                display: flex;
                gap: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            .customer-item {
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-people"></i>
                Assign Customer
            </h1>
            <p class="page-subtitle">Manage customer pricing for <%= product.name %></p>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-plus-circle"></i>
                    Add New Customer Pricing
                </h2>
            </div>
            <div class="card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <form action="/productCustomer/assignCustomer/<%= product.id %>" method="POST">
                    <% if (typeof _csrf !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= _csrf %>">
                    <% } %>
                    <div class="form-group">
                        <label class="form-label" for="customer">Select Customer</label>
                        <select class="form-select" name="customerId" id="customer" required>
                            <option value="" selected disabled>Choose a customer</option>
                            <% customers.forEach(customer => { %>
                                <option value="<%= customer.id %>"><%= customer.perusahaan %> — <%= customer.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group mt-3">
                        <label class="form-label" for="price">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input type="number" class="form-control" name="price" id="price" min="0" step="0.01" placeholder="Enter price" required>
                        </div>
                        <small class="form-text text-muted">Enter the special price for this product for this customer</small>
                    </div>
                    <div class="btn-group mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-lg"></i>
                            Assign Customer
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-list-check"></i>
                    Assigned Customers
                </h2>
            </div>
            <div class="card-body">
                <% if (product.Customers && product.Customers.length > 0) { %>
                    <ul class="customer-list">
                        <% product.Customers.forEach(customer => { %>
                            <li class="customer-item fade-in">
                                <div class="customer-info">
                                    <div class="customer-name">
                                        <i class="bi bi-person"></i>
                                        <%= customer.name %>
                                        <span class="badge bg-success ms-2 price-display-<%= customer.id %>">
                                            Rp <%= customer.ProductCustomer && customer.ProductCustomer.price ? customer.ProductCustomer.price.toLocaleString('id-ID') : '0' %>
                                        </span>
                                    </div>
                                    <% if (customer.ProductCustomer && customer.ProductCustomer.updatedAt) { %>
                                        <div class="last-updated">
                                            <small class="text-muted">
                                                <i class="bi bi-clock-history"></i> Last updated: 
                                                <%= new Date(customer.ProductCustomer.updatedAt).toLocaleString('en-US', { 
                                                    year: 'numeric', 
                                                    month: 'short', 
                                                    day: 'numeric',
                                                    hour: '2-digit',
                                                    minute: '2-digit'
                                                }) %>
                                            </small>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="customer-actions">
                                    <button type="button" class="btn btn-sm btn-primary me-2 edit-price-btn" 
                                            data-customer-id="<%= customer.id %>"
                                            data-product-id="<%= product.id %>"
                                            data-price="<%= customer.ProductCustomer && customer.ProductCustomer.price ? customer.ProductCustomer.price : 0 %>"
                                            data-customer-name="<%= customer.name %>">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form action="/productCustomer/removeCustomer/<%= product.id %>/<%= customer.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Remove customer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <div class="text-center text-muted">
                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                        No customers assigned yet
                    </div>
                <% } %>
            </div>
        </div>

        <div class="btn-group mt-4">
            <a href="/products/listProduct" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i>
                Back to Products
            </a>
        </div>
    </div>

    <!-- Global Edit Price Modal -->
    <div class="modal fade" id="globalEditPriceModal" tabindex="-1" aria-labelledby="globalEditPriceModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="globalEditPriceModalLabel">Edit Price</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="priceEditForm" method="POST">
                    <% if (typeof _csrf !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= _csrf %>">
                    <% } %>
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="editPriceInput" class="form-label">Price</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" class="form-control" id="editPriceInput" 
                                    name="price" value="0" 
                                    min="0" step="0.01" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Get the global modal
            const modal = document.getElementById('globalEditPriceModal');
            const modalTitle = modal.querySelector('.modal-title');
            const priceInput = document.getElementById('editPriceInput');
            const form = document.getElementById('priceEditForm');
            
            // Get all edit price buttons
            const editButtons = document.querySelectorAll('.edit-price-btn');
            
            // Add click event to each edit button
            editButtons.forEach(button => {
                button.addEventListener('click', function() {
                    // Get data from button attributes
                    const customerId = this.getAttribute('data-customer-id');
                    const productId = this.getAttribute('data-product-id');
                    const price = this.getAttribute('data-price');
                    const customerName = this.getAttribute('data-customer-name');
                    
                    // Update modal title
                    modalTitle.textContent = `Edit Price for ${customerName}`;
                    
                    // Set form action
                    form.action = `/productCustomer/updateCustomerPrice/${productId}/${customerId}`;
                    
                    // Set input value
                    priceInput.value = price;
                    
                    // Show modal using Bootstrap API
                    const bsModal = new bootstrap.Modal(modal);
                    bsModal.show();
                });
            });
        });
    </script>
</body>
</html>
