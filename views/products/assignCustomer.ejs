<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Assign Customer' }) %>
    <style>
        .price-pill {
            display: inline-flex; align-items: center; gap: 0.3rem;
            background: var(--mib-success-soft); color: #166534;
            border-radius: var(--mib-radius-pill); padding: 0.2rem 0.7rem;
            font-size: 0.82rem; font-weight: 700; font-variant-numeric: tabular-nums;
        }
        .assign-grid { display: grid; grid-template-columns: minmax(320px, 420px) 1fr; gap: 1.25rem; align-items: start; }
        @media (max-width: 991px) { .assign-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/products/listProduct' }) %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Assign Customer',
              pageIcon: 'bi-people-fill',
              pageSubtitle: 'Manage customer-specific pricing for ' + product.name,
              breadcrumb: [{ label: 'Products', href: '/products/listProduct' }, { label: product.name }],
              actionsHtml: '<a href="/products/listProduct" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Products</a>'
        }) %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= error %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="assign-grid fade-in">
            <!-- Add new pricing -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title"><i class="bi bi-plus-circle"></i> Add Customer Pricing</h2>
                </div>
                <div class="card-body">
                    <form action="/productCustomer/assignCustomer/<%= product.id %>" method="POST">
                        <% if (typeof _csrf !== 'undefined') { %>
                        <input type="hidden" name="_csrf" value="<%= _csrf %>">
                        <% } %>
                        <div class="mb-3">
                            <label class="form-label" for="customer">Select Customer</label>
                            <select class="form-select" name="customerId" id="customer" required>
                                <option value="" selected disabled>Choose a customer</option>
                                <% customers.forEach(customer => { %>
                                    <option value="<%= customer.id %>"><%= customer.perusahaan %> — <%= customer.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="price">Price</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" class="form-control" name="price" id="price" min="0" step="0.01" placeholder="Enter price" required>
                            </div>
                            <small class="form-text">Special price for this product for the selected customer.</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> Assign Customer</button>
                    </form>
                </div>
            </div>

            <!-- Assigned customers -->
            <div class="table-card">
                <div class="card-header">
                    <h2 class="card-title"><i class="bi bi-list-check"></i> Assigned Customers
                        <% if (product.Customers && product.Customers.length > 0) { %>
                            <span class="pill ms-2"><%= product.Customers.length %></span>
                        <% } %>
                    </h2>
                </div>
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th>Price</th>
                                <th>Last Updated</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (product.Customers && product.Customers.length > 0) { %>
                                <% product.Customers.forEach(customer => { %>
                                    <tr>
                                        <td data-label="Customer"><span class="cell-strong"><i class="bi bi-person"></i> <%= customer.name %></span></td>
                                        <td data-label="Price">
                                            <span class="price-pill price-display-<%= customer.id %>">Rp <%= customer.ProductCustomer && customer.ProductCustomer.price ? customer.ProductCustomer.price.toLocaleString('id-ID') : '0' %></span>
                                        </td>
                                        <td data-label="Last Updated">
                                            <% if (customer.ProductCustomer && customer.ProductCustomer.updatedAt) { %>
                                                <span class="cell-sub"><i class="bi bi-clock-history"></i> <%= new Date(customer.ProductCustomer.updatedAt).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                                            <% } else { %>
                                                <span class="cell-sub">—</span>
                                            <% } %>
                                        </td>
                                        <td data-label="Actions" class="text-end">
                                            <div class="d-flex gap-1 justify-content-end">
                                                <button type="button" class="btn btn-icon btn-sm btn-soft edit-price-btn"
                                                        data-customer-id="<%= customer.id %>"
                                                        data-product-id="<%= product.id %>"
                                                        data-price="<%= customer.ProductCustomer && customer.ProductCustomer.price ? customer.ProductCustomer.price : 0 %>"
                                                        data-customer-name="<%= customer.name %>"
                                                        aria-label="Edit price">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form action="/productCustomer/removeCustomer/<%= product.id %>/<%= customer.id %>" method="POST" class="d-inline">
                                                    <% if (typeof _csrf !== 'undefined') { %><input type="hidden" name="_csrf" value="<%= _csrf %>"><% } %>
                                                    <button type="submit" class="btn btn-icon btn-sm btn-outline-danger" title="Remove customer" aria-label="Remove customer"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr class="is-empty-row">
                                    <td colspan="4">
                                        <div class="empty-state"><i class="bi bi-inbox"></i><h4>No customers assigned</h4><p>Assign a customer and set their special price to get started.</p></div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Global Edit Price Modal -->
    <div class="modal fade" id="globalEditPriceModal" tabindex="-1" aria-labelledby="globalEditPriceModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="globalEditPriceModalLabel">Edit Price</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="priceEditForm" method="POST">
                    <% if (typeof _csrf !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= _csrf %>">
                    <% } %>
                    <div class="modal-body">
                        <div class="mb-2">
                            <label for="editPriceInput" class="form-label">Price</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" class="form-control" id="editPriceInput" name="price" value="0" min="0" step="0.01" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const modal = document.getElementById('globalEditPriceModal');
            const modalTitle = modal.querySelector('.modal-title');
            const priceInput = document.getElementById('editPriceInput');
            const form = document.getElementById('priceEditForm');

            document.querySelectorAll('.edit-price-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const customerId = this.getAttribute('data-customer-id');
                    const productId = this.getAttribute('data-product-id');
                    const price = this.getAttribute('data-price');
                    const customerName = this.getAttribute('data-customer-name');

                    modalTitle.textContent = `Edit Price for ${customerName}`;
                    form.action = `/productCustomer/updateCustomerPrice/${productId}/${customerId}`;
                    priceInput.value = price;

                    bootstrap.Modal.getOrCreateInstance(modal).show();
                });
            });
        });
    </script>
</body>
</html>
