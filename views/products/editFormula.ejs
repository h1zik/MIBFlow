<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Formula</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .form-control:disabled,
        .form-control[readonly] {
            background-color: var(--background-light);
            cursor: not-allowed;
        }

        .formula-group {
            background-color: var(--background-light);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }

        .formula-group:last-child {
            margin-bottom: 0;
        }

        .formula-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1rem;
            color: var(--primary-color);
            font-weight: 600;
        }

        .formula-inputs {
            display: grid;
            gap: 1rem;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .btn-group {
                display: flex;
                gap: 1rem;
            }

            .formula-inputs {
                grid-template-columns: 1fr auto;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            .formula-inputs {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-pencil-square"></i>
                Edit Formula
            </h1>
            <p class="page-subtitle">Update formula for <%= product.name %></p>
        </div>

        <form action="/products/<%= product.id %>/editFormula" method="POST">
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-gear"></i>
                        Basic Properties
                    </h2>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label" for="density">Density (gr/ml)</label>
                        <input type="number" class="form-control" id="density" name="density" value="<%= product.density %>" step="0.0001" required>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-list-check"></i>
                        Raw Materials
                    </h2>
                </div>
                <div class="card-body">
                    <% product.ProductFormulas.forEach((formula, index) => { %>
                        <div class="formula-group fade-in">
                            <div class="formula-header">
                                <i class="bi bi-box2"></i>
                                Raw Material <%= index + 1 %>
                            </div>
                            <div class="formula-inputs">
                                <div class="form-group">
                                    <label class="form-label">Material Name</label>
                                    <input type="hidden" name="formulas[<%= index %>][id]" value="<%= formula.id %>">
                                    <input type="hidden" name="formulas[<%= index %>][rawMaterialId]" value="<%= formula.rawMaterialId %>">
                                    <input type="text" class="form-control" value="<%= formula.RawMaterial.name %>" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Percentage (%)</label>
                                    <input type="number" class="form-control" name="formulas[<%= index %>][percentage]" value="<%= formula.percentage %>" step="0.001" required>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="btn-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i>
                    Save Changes
                </button>
                <a href="/products/listProduct" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i>
                    Cancel
                </a>
            </div>
        </form>

        <!-- Blending Guide template (per product, authored once). Separate form so it
             does not interfere with the percentage form above. -->
        <form action="/products/<%= product.id %>/blendingGuideTemplate" method="POST" enctype="multipart/form-data" class="mt-4">
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-file-earmark-spreadsheet"></i>
                        Blending Guide Template
                    </h2>
                </div>
                <div class="card-body">
                    <p class="page-subtitle" style="margin-top:0;">
                        Upload template Blending Guide (xlsx) untuk produk ini — berisi bagian naratif
                        (Pelindung Diri, Persiapan, Cara Produksi, QC, Kemasan, Label). Cukup diisi sekali;
                        saat produksi sistem otomatis mengisi Batch/Tank/Jumlah/Tanggal &amp; resep ke template ini.
                    </p>
                    <% if (product.blendingGuideTemplate) { %>
                        <div class="form-group">
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle"></i>
                                Template terpasang: <%= product.blendingGuideTemplate %>
                            </span>
                        </div>
                    <% } else { %>
                        <div class="form-group">
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-exclamation-triangle"></i>
                                Belum ada template — Blending Guide akan memakai format standar sistem.
                            </span>
                        </div>
                    <% } %>
                    <div class="form-group">
                        <label class="form-label" for="bgTemplate">Pilih file (.xlsx)</label>
                        <input type="file" class="form-control" id="bgTemplate" name="bgTemplate" accept=".xlsx" required>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload"></i>
                        <%= product.blendingGuideTemplate ? 'Ganti Template' : 'Upload Template' %>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);

            // Form validation
            const form = document.querySelector('form');
            form.addEventListener('submit', function(event) {
                const percentageInputs = document.querySelectorAll('input[name$="[percentage]"]');
                let total = 0;

                percentageInputs.forEach(input => {
                    total += parseFloat(input.value) || 0;
                });

                if (Math.abs(total - 100) > 0.01) {
                    event.preventDefault();
                    alert(`Total percentage must equal 100%. Current total: ${total.toFixed(2)}%`);
                }
            });
        });
    </script>
</body>
</html>
