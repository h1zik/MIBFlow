<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'COGS Calculator' }) %>
    <style>
        /* COGS Calculator — page-scoped flourishes on the shared mibflow.css system */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }

        .raw-material-group {
            background-color: var(--mib-surface-2);
            border: 1px solid var(--mib-border);
            padding: 1rem;
            border-radius: var(--mib-radius-sm);
            margin-bottom: 1rem;
            position: relative;
            opacity: 1;
            transition: opacity 0.3s ease;
            display: flex;
            gap: 1rem;
        }
        .raw-material-group.loading { opacity: 0.5; pointer-events: none; }
        .raw-material-group:last-child { margin-bottom: 0; }
        .raw-material-group > div { flex: 1; min-width: 0; }

        .raw-material-total {
            background-color: var(--mib-surface-2);
            border: 1px solid var(--mib-border);
            padding: 0.9rem 1rem;
            border-radius: var(--mib-radius-sm);
            margin-top: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
        }
        .raw-material-total.invalid { background-color: var(--mib-danger-soft); color: #991b1b; border-color: #fecaca; }
        .raw-material-total.valid   { background-color: var(--mib-success-soft); color: #166534; border-color: #bbf7d0; }

        .loading-overlay {
            position: absolute; inset: 0;
            background: rgba(255, 255, 255, 0.8);
            display: flex; align-items: center; justify-content: center;
            border-radius: var(--mib-radius-sm); z-index: 10;
        }
        .loading-spinner {
            width: 2rem; height: 2rem;
            border: 3px solid var(--mib-surface-2);
            border-top-color: var(--mib-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        .error-message {
            padding: 0.9rem 1rem;
            background-color: var(--mib-danger-soft);
            color: #991b1b;
            border: 1px solid #fecaca;
            border-radius: var(--mib-radius-sm);
            margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.5rem;
        }

        /* Result cards */
        .result-card {
            background: var(--mib-surface);
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow);
            padding: 1.5rem;
            text-align: center;
            height: 100%;
        }
        .result-label { font-size: 0.82rem; color: var(--mib-text-muted); margin-bottom: 0.5rem; font-weight: 600; }
        .result-value { font-size: 2rem; font-weight: 700; color: var(--mib-text); font-variant-numeric: tabular-nums; }
        .result-value.cogs  { color: var(--mib-primary-dark); }
        .result-value.final { color: var(--mib-primary); }

        .details-list { list-style: none; padding: 0; margin: 0; }
        .details-item {
            display: flex; justify-content: space-between; gap: 1rem;
            padding: 0.75rem 0; border-bottom: 1px solid var(--mib-border);
        }
        .details-item:last-child { border-bottom: none; }
        .details-label { color: var(--mib-text-muted); }
        .details-value { font-weight: 600; color: var(--mib-text); font-variant-numeric: tabular-nums; }

        .calculation-result { margin-top: 2rem; padding-top: 0.5rem; }

        @media (max-width: 768px) {
            .raw-material-group { display: grid; }
            .result-value { font-size: 1.5rem; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/overhead/cogs-calculator' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const productList       = (typeof products !== 'undefined' && products) ? products : [];
        const packagingList     = (typeof packagingOptions !== 'undefined' && packagingOptions) ? packagingOptions : [];
        const rawMaterialList   = (typeof rawMaterial !== 'undefined' && rawMaterial) ? rawMaterial : [];
        const productFormulaList = (typeof productFormulas !== 'undefined' && productFormulas) ? productFormulas : [];
        const selProductType    = (typeof selectedProductType !== 'undefined' && selectedProductType) ? selectedProductType : 'existing';
        const selProductName    = (typeof selectedProductName !== 'undefined' && selectedProductName) ? selectedProductName : '';
        const calcResult        = (typeof calculationResult !== 'undefined') ? calculationResult : null;
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'COGS Calculator',
              pageIcon: 'bi-calculator',
              pageSubtitle: 'Calculate the Cost of Goods Sold for your products.'
        }) %>

        <form action="/overhead/calculate-cogs" method="POST" id="cogsForm">
            <!-- ===================== Product Information ===================== -->
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-box-seam"></i> Product Information</h2>
                <p class="form-section-desc">Choose an existing product or define a new one, plus its packaging.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="productType">Product Type</label>
                        <select class="form-select" id="productType" name="productType" required>
                            <option value="" selected disabled>Select product type</option>
                            <option value="existing" <%= selProductType === 'existing' ? 'selected' : '' %>>Existing Product</option>
                            <option value="new" <%= selProductType === 'new' ? 'selected' : '' %>>New Product</option>
                        </select>
                    </div>

                    <div class="col-md-6" id="productNameSection" style="<%= selProductType === 'existing' ? '' : 'display: none;' %>">
                        <label class="form-label" for="productName">Product Name</label>
                        <select class="form-select" id="productName" name="productName" <%= selProductType === 'existing' ? 'required' : '' %>>
                            <option value="" selected disabled>Select product</option>
                            <% productList.forEach(product => { %>
                                <option value="<%= product.name %>" <%= (product.name === selProductName) ? 'selected' : '' %>><%= product.name %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="col-md-6" id="newProductSection" style="<%= selProductType === 'new' ? '' : 'display: none;' %>">
                        <label class="form-label" for="newProductName">New Product Name</label>
                        <input type="text" class="form-control" id="newProductName" name="newProductName" <%= selProductType === 'new' ? 'required' : '' %>>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="packagingId">Packaging</label>
                        <select class="form-select" id="packagingId" name="packagingId" required>
                            <option value="" selected disabled>Select packaging</option>
                            <% packagingList.forEach(packaging => { %>
                                <option value="<%= packaging.id %>"><%= packaging.name %> - <%= packaging.volume %>L</option>
                            <% }); %>
                        </select>
                    </div>
                </div>
            </div>

            <!-- ===================== Label Information ===================== -->
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-tag"></i> Label Information</h2>
                <p class="form-section-desc">Label dimensions and paper price for sticker cost.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="labelWidth">Label Width (mm)</label>
                        <input type="number" class="form-control" id="labelWidth" name="labelWidth" min="0" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="labelHeight">Label Height (mm)</label>
                        <input type="number" class="form-control" id="labelHeight" name="labelHeight" min="0" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="paperPrice">A3 Paper Price</label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input type="number" class="form-control" id="paperPrice" name="paperPrice" min="0" required>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== Production Information ===================== -->
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-gear"></i> Production Information</h2>
                <p class="form-section-desc">Batch and production details used to spread overhead.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="batchMonth">Batch/Month</label>
                        <input type="number" class="form-control" id="batchMonth" name="batchMonth" step="0.01" min="0" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="batchSize">Batch Size (L)</label>
                        <input type="number" class="form-control" id="batchSize" name="batchSize" step="0.01" min="0" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="productionTime">Production Time (hours)</label>
                        <input type="number" class="form-control" id="productionTime" name="productionTime" step="0.01" min="0" required>
                    </div>
                </div>
            </div>

            <!-- ===================== Raw Materials ===================== -->
            <div class="form-section fade-in" id="rawMaterialsSection">
                <h2 class="form-section-title"><i class="bi bi-box2"></i> Raw Materials</h2>
                <p class="form-section-desc">Formula composition. For new products, percentages must total 100%.</p>
                <div id="rawMaterialFields">
                    <% if (selProductType === 'existing' && productFormulaList.length > 0) { %>
                        <% productFormulaList.forEach((formula, index) => { %>
                            <div class="raw-material-group">
                                <div>
                                    <label class="form-label">Raw Material</label>
                                    <input type="text" class="form-control" value="<%= formula.RawMaterial.name %>" readonly>
                                    <input type="hidden" name="rawMaterials[<%= index %>][id]" value="<%= formula.rawMaterialId %>">
                                </div>
                                <div>
                                    <label class="form-label">Percentage (%)</label>
                                    <input type="number" class="form-control percentage-input" name="rawMaterials[<%= index %>][percentage]" value="<%= formula.percentage %>" readonly>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>

                <div id="rawMaterialTotal" class="raw-material-total" style="display: none;">
                    <span>Total Percentage:</span>
                    <span id="totalPercentage">0%</span>
                </div>

                <div id="apiError" class="error-message" style="display: none;">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>Error loading product formulas. Please try again.</span>
                </div>

                <button type="button" class="btn btn-outline-primary mt-3" id="addRawMaterialBtn" style="display: <%= selProductType === 'new' ? 'inline-flex' : 'none' %>;">
                    <i class="bi bi-plus-lg"></i> Add Raw Material
                </button>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg" id="calculateBtn">
                    <i class="bi bi-calculator"></i> Calculate COGS
                </button>
            </div>
        </form>

        <% if (calcResult) { %>
            <div class="calculation-result fade-in">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="result-card">
                            <div class="result-label">Cost of Goods Sold</div>
                            <div class="result-value cogs">Rp <%= calcResult.finalProductCost.toFixed(2) %></div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="result-card">
                            <div class="result-label">Margin (%)</div>
                            <input type="number" id="margin" class="form-control text-center" value="30" min="0" step="0.01">
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="result-card">
                            <div class="result-label">Final Price with Margin</div>
                            <div class="result-value final" id="finalPrice">Rp 0.00</div>
                        </div>
                    </div>
                </div>

                <div class="card mt-4 fade-in">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-list-ul"></i> Cost Breakdown</h3>
                    </div>
                    <div class="card-body">
                        <ul class="details-list">
                            <li class="details-item">
                                <span class="details-label">Raw Material Cost per Product</span>
                                <span class="details-value">Rp <%= (typeof rawMatCostPerProduct !== 'undefined' && rawMatCostPerProduct ? rawMatCostPerProduct.toFixed(2) : "0.00") %></span>
                            </li>
                            <li class="details-item">
                                <span class="details-label">Packaging Price per Liter</span>
                                <span class="details-value">Rp <%= (typeof packagingPricePerLiter !== 'undefined' && packagingPricePerLiter ? packagingPricePerLiter.toFixed(2) : "0.00") %></span>
                            </li>
                            <li class="details-item">
                                <span class="details-label">Sticker Price per Pcs</span>
                                <span class="details-value">Rp <%= (typeof stickerPrice !== 'undefined' && stickerPrice ? stickerPrice.toFixed(2) : "0.00") %></span>
                            </li>
                            <li class="details-item">
                                <span class="details-label">Overhead Cost per Kg</span>
                                <span class="details-value">Rp <%= (typeof cogsPerUnit !== 'undefined' && cogsPerUnit ? cogsPerUnit.toFixed(2) : "0.00") %></span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Form validation
            const form = document.getElementById('cogsForm');
            const calculateBtn = document.getElementById('calculateBtn');
            const rawMaterialFields = document.getElementById('rawMaterialFields');
            const rawMaterialTotal = document.getElementById('rawMaterialTotal');
            const totalPercentageSpan = document.getElementById('totalPercentage');
            const apiError = document.getElementById('apiError');

            function updateTotalPercentage() {
                if (selectedProductType === 'new') {
                    const inputs = rawMaterialFields.querySelectorAll('.percentage-input');
                    let total = 0;
                    inputs.forEach(input => {
                        total += parseFloat(input.value) || 0;
                    });

                    totalPercentageSpan.textContent = total.toFixed(2) + '%';
                    rawMaterialTotal.style.display = 'flex';
                    rawMaterialTotal.className = 'raw-material-total ' + (Math.abs(total - 100) < 0.01 ? 'valid' : 'invalid');

                    return Math.abs(total - 100) < 0.01;
                }
                return true;
            }

            form.addEventListener('submit', function(event) {
                const inputs = form.querySelectorAll('input[type="number"]');
                let isValid = true;
                let message = '';

                inputs.forEach(input => {
                    if (input.value < 0) {
                        isValid = false;
                        message = `${input.previousElementSibling.textContent.trim()} cannot be negative`;
                    }
                });

                if (!updateTotalPercentage()) {
                    isValid = false;
                    message = 'Total percentage must equal 100%';
                }

                if (!isValid) {
                    event.preventDefault();
                    alert(message);
                }
            });

            // Product type handling
            const productTypeElement = document.getElementById('productType');
            const productNameSection = document.getElementById('productNameSection');
            const newProductSection = document.getElementById('newProductSection');
            const addRawMaterialBtn = document.getElementById('addRawMaterialBtn');
            let selectedProductType = productTypeElement.value;

            if (productTypeElement) {
                productTypeElement.addEventListener('change', function() {
                    selectedProductType = this.value;
                    productNameSection.style.display = (selectedProductType === 'existing') ? 'block' : 'none';
                    newProductSection.style.display = (selectedProductType === 'new') ? 'block' : 'none';
                    addRawMaterialBtn.style.display = (selectedProductType === 'new') ? 'inline-flex' : 'none';
                    rawMaterialFields.innerHTML = '';
                    rawMaterialTotal.style.display = 'none';
                });
            }

            // Product name handling
            const productNameElement = document.getElementById('productName');
            if (productNameElement) {
                productNameElement.addEventListener('change', async function() {
                    const productName = this.value;
                    if (rawMaterialFields) {
                        try {
                            rawMaterialFields.innerHTML = '<div class="loading-overlay"><div class="loading-spinner"></div></div>';
                            apiError.style.display = 'none';

                            const response = await fetch(`/overhead/api/product-formulas?productName=${encodeURIComponent(productName)}`);
                            if (!response.ok) throw new Error('Failed to fetch product formulas');

                            const productFormulas = await response.json();
                            rawMaterialFields.innerHTML = '';

                            productFormulas.forEach((formula, index) => {
                                const newField = document.createElement('div');
                                newField.classList.add('raw-material-group', 'fade-in');
                                newField.innerHTML = `
                                    <div>
                                        <label class="form-label">Raw Material</label>
                                        <input type="text" class="form-control" value="${formula.name}" readonly>
                                        <input type="hidden" name="rawMaterials[${index}][id]" value="${formula.id}">
                                    </div>
                                    <div>
                                        <label class="form-label">Percentage (%)</label>
                                        <input type="number" class="form-control percentage-input" value="${formula.percentage}" readonly>
                                    </div>
                                `;
                                rawMaterialFields.appendChild(newField);
                            });
                        } catch (error) {
                            console.error('Error fetching product formulas:', error);
                            apiError.style.display = 'flex';
                            rawMaterialFields.innerHTML = '';
                        }
                    }
                });
            }

            // Add raw material button handling
            if (addRawMaterialBtn) {
                addRawMaterialBtn.addEventListener('click', function() {
                    const index = rawMaterialFields.children.length;
                    const newField = document.createElement('div');
                    newField.classList.add('raw-material-group', 'fade-in');
                    newField.innerHTML = `
                        <div>
                            <label class="form-label">Raw Material</label>
                            <select class="form-select" name="rawMaterials[${index}][id]" required>
                                <option value="" selected disabled>Select raw material</option>
                                <% rawMaterialList.forEach(material => { %>
                                    <option value="<%= material.id %>"><%= material.name %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Percentage (%)</label>
                            <input type="number" class="form-control percentage-input" name="rawMaterials[${index}][percentage]" step="0.01" min="0" required>
                        </div>
                    `;
                    rawMaterialFields.appendChild(newField);

                    // Add event listener to new percentage input
                    const newInput = newField.querySelector('.percentage-input');
                    newInput.addEventListener('input', updateTotalPercentage);
                });
            }

            // Margin calculation
            const marginElement = document.getElementById('margin');
            const finalPriceElement = document.getElementById('finalPrice');
            const cogs = parseFloat('<%= calcResult ? calcResult.finalProductCost : 0 %>');

            if (marginElement && finalPriceElement) {
                marginElement.addEventListener('input', function() {
                    const marginPercent = parseFloat(this.value) / 100;
                    const finalPrice = cogs + (marginPercent * cogs);
                    finalPriceElement.textContent = `Rp ${finalPrice.toFixed(2)}`;
                });

                // Initial calculation
                marginElement.dispatchEvent(new Event('input'));
            }
        });
    </script>
</body>
</html>
