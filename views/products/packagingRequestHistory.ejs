<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Packaging Request History' }) %>
    <style>
        /* Page-scoped flourishes — built on the shared mibflow.css tokens only */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/packaging-request/history' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const pkgList = (typeof packagingRequests !== 'undefined' && packagingRequests) ? packagingRequests : [];

        /* QC status badge helper (Pass / Fail / Reject Sebagian / Pending) */
        const qcMeta = (s) => {
            if (s === 'Pass')           return { cls: 'status-completed', icon: 'bi-check-circle', label: 'Pass' };
            if (s === 'Fail')           return { cls: 'status-declined',  icon: 'bi-x-circle',     label: 'Fail' };
            if (s === 'Reject Sebagian')return { cls: 'status-partially-delivered', icon: 'bi-exclamation-triangle', label: 'Partially Rejected' };
            return { cls: 'status-pending', icon: 'bi-clock', label: 'Pending' };
        };

        /* general status badge helper */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };

        const passCount = pkgList.filter(r => r.qcStatus === 'Pass').length;
        const pendingCount = pkgList.filter(r => !['Pass','Fail','Reject Sebagian'].includes(r.qcStatus)).length;
    %>

    <div class="content content-wide">

        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-box2"></i> Packaging Request History</h1>
                <p class="page-subtitle">View history of all packaging requests</p>
            </div>
        </div>

        <%- include('../partials/flash') %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-list-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Requests</div>
                    <div class="stat-value"><%= pkgList.length %></div>
                    <span class="stat-sub">All packaging requests</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">QC Passed</div>
                    <div class="stat-value"><%= passCount %></div>
                    <span class="stat-sub">Cleared quality check</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-clock-history"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending QC</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-sub">Awaiting inspection</span>
                </div>
            </div>
        </div>

        <!-- ===================== Request history ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-list-check"></i> Request History List</h2>
                <span class="status-badge status-neutral"><%= pkgList.length %> total</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>PO Number</th>
                            <th>Packaging</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Vendor</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Reject Comment</th>
                            <th>Reject Quantity</th>
                            <th>Created Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pkgList.length > 0) { %>
                            <% pkgList.forEach(function(request) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Packaging"><span class="cell-strong"><%= request.PackagingRequest.Packaging.name %></span></td>
                                    <td data-label="Quantity"><%= request.splitQuantity %> pcs</td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Vendor"><%= request.Vendor.name %></td>
                                    <td data-label="QC Status">
                                        <% const qc = qcMeta(request.qcStatus); %>
                                        <span class="status-badge <%= qc.cls %>"><i class="bi <%= qc.icon %>"></i> <%= qc.label %></span>
                                    </td>
                                    <td data-label="QC Comment"><%= request.qcComment || '-' %></td>
                                    <td data-label="Reject Comment"><%= request.rejectComment || '-' %></td>
                                    <td data-label="Reject Quantity"><%= request.rejectQuantity ? request.rejectQuantity + ' pcs' : '-' %></td>
                                    <td data-label="Created Date"><%= new Date(request.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="11"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No packaging requests</h4><p>Packaging request history will appear here.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</body>
</html>
