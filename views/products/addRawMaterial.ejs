<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Add Raw Material' }) %>
    <style>
        /* Add Raw Material — page-scoped flourishes on the shared design system */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .calc-card {
            background: var(--mib-grad-surface, var(--mib-surface-2));
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            padding: 1rem 1.15rem;
            display: flex;
            align-items: center;
            gap: 0.9rem;
        }
        .calc-card .calc-ico {
            flex-shrink: 0; width: 40px; height: 40px; border-radius: 12px;
            display: grid; place-items: center; font-size: 1.15rem;
            color: var(--mib-primary); background: var(--mib-primary-soft);
        }
        .calc-card .calc-label {
            font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 0.04em; color: var(--mib-text-muted); margin: 0;
        }
        .calc-card .calc-number {
            font-size: 1.4rem; font-weight: 750; color: var(--mib-text);
            line-height: 1.1; font-variant-numeric: tabular-nums;
        }
        .form-actions { display: flex; flex-wrap: wrap; gap: 0.6rem; }
        @media (max-width: 575.98px) { .form-actions { display: grid; } }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/products/addRawMaterial' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Add Raw Material',
              pageIcon: 'bi-plus-circle',
              pageSubtitle: 'Create a new raw material in the system',
              actionsHtml: '<a href="/rawMaterials/rawMaterialStock" class="btn btn-light"><i class="bi bi-boxes"></i> Check Stock</a>'
            }) %>

        <% if (typeof success !== 'undefined' && success === 'true') { %>
            <div class="mib-flash mib-flash-success fade-in" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>Raw material has been successfully added to the system</span>
            </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mib-flash mib-flash-error fade-in" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= error %></span>
            </div>
        <% } %>

        <form action="/products/addRawMaterial" method="POST" class="fade-in">
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-box-seam"></i> Raw Material Information</h2>
                <p class="form-section-desc">Provide the material's name, physical form and current stock. Density is required only for liquids.</p>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="name">Raw Material Name</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="e.g. Sodium Lauryl Sulfate" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="form">Form</label>
                        <select class="form-select" id="form" name="form" required>
                            <option value="" selected disabled>Select form</option>
                            <option value="Solid">Solid</option>
                            <option value="Liquid">Liquid</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="density">Density (gr/ml)</label>
                        <input type="number" class="form-control" id="density" name="density" step="0.0001" placeholder="Enter density" disabled>
                        <div class="form-text">Enabled when Form is set to Liquid.</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="stock">Stock</label>
                        <input type="number" class="form-control" id="stock" name="stock" placeholder="Enter stock quantity" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="unit">Unit</label>
                        <select class="form-select" id="unit" name="unit" required>
                            <option value="" selected disabled>Select unit</option>
                            <option value="KG">KG</option>
                            <option value="L">L</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <div class="calc-card">
                            <span class="calc-ico"><i class="bi bi-calculator"></i></span>
                            <div>
                                <p class="calc-label">Calculated Quantity (KG)</p>
                                <div class="calc-number" id="quantityDisplay">0.00</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-actions mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Add Raw Material
                    </button>
                    <a href="/dashboard/raw-material-warehouse" class="btn btn-light">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Form handling — calculated quantity preview
            const formSelect = document.getElementById('form');
            const densityInput = document.getElementById('density');
            const stockInput = document.getElementById('stock');
            const unitSelect = document.getElementById('unit');
            const quantityDisplay = document.getElementById('quantityDisplay');

            formSelect.addEventListener('change', function() {
                const isLiquid = this.value === 'Liquid';
                densityInput.disabled = !isLiquid;
                densityInput.required = isLiquid;

                if (!isLiquid) {
                    densityInput.value = '';
                }

                updateQuantityDisplay();
            });

            function updateQuantityDisplay() {
                const stock = parseFloat(stockInput.value) || 0;
                const density = parseFloat(densityInput.value) || 1;
                const unit = unitSelect.value;
                let quantity = stock;

                if (unit === 'L' && formSelect.value === 'Liquid') {
                    quantity = stock * density;
                }

                quantityDisplay.textContent = quantity.toFixed(2);
            }

            stockInput.addEventListener('input', updateQuantityDisplay);
            densityInput.addEventListener('input', updateQuantityDisplay);
            unitSelect.addEventListener('change', updateQuantityDisplay);
        });
    </script>
</body>
</html>
