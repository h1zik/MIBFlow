<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Completed Requests' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/rawMaterial/completed' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const completedList = (typeof completedRawMaterialRequests !== 'undefined' && completedRawMaterialRequests) ? completedRawMaterialRequests : [];

        /* status badge helper */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };

        const vendorName = (r) => (r && r.Vendor && r.Vendor.name) ? r.Vendor.name : (r && (r.vendorId || r.vendorId === 0) ? ('Vendor #' + r.vendorId) : '—');
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Completed Requests',
              pageIcon: 'bi-check2-circle',
              pageSubtitle: 'All completed raw material requests',
              actionsHtml: '<a href="/dashboard/purchase" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check2-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Completed Requests</div>
                    <div class="stat-value"><%= completedList.length %></div>
                    <span class="stat-sub">Raw material requests fulfilled</span>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Search by material, vendor or ID…" autocomplete="off">
            </div>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-list-check"></i> Request History</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="completedTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Vendor</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (completedList.length > 0) { %>
                            <% completedList.forEach(request => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><%= request.materialName %></td>
                                    <td data-label="Quantity" class="num"><%= request.quantity %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Vendor"><%= vendorName(request) %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="5">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No completed requests</h4>
                                        <p>Completed raw material requests will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Live search across rows
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('searchInput');
            const rows = document.querySelectorAll('#completedTable tbody tr');
            if (input) {
                input.addEventListener('input', function () {
                    const q = this.value.trim().toLowerCase();
                    rows.forEach(row => {
                        if (row.classList.contains('is-empty-row')) return;
                        row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                    });
                });
            }
        });
    </script>
</body>
</html>
