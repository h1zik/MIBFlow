<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'Add Product',
        extraStylesheets: ['https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css'],
        extraScripts: ['https://code.jquery.com/jquery-3.6.0.min.js', 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js']
    }) %>
    <style>
        /* ---- Select2 tuned to the MIB design system ---- */
        .select2-container--default .select2-selection--single {
            height: auto;
            min-height: 42px;
            padding: 0.5rem 0.9rem;
            border: 1.5px solid var(--mib-border-strong);
            border-radius: var(--mib-radius-sm);
            background: var(--mib-surface);
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 1.4;
            color: var(--mib-text);
            padding: 0;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow { height: 40px; }
        .select2-container--default.select2-container--focus .select2-selection--single,
        .select2-container--default.select2-container--open .select2-selection--single {
            border-color: var(--mib-primary);
            box-shadow: var(--mib-ring);
        }
        .select2-dropdown {
            border: 1px solid var(--mib-border-strong);
            border-radius: var(--mib-radius-sm);
            box-shadow: var(--mib-shadow-md);
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: var(--mib-primary);
        }
        .select2-container { width: 100% !important; }

        /* ---- Raw material rows ---- */
        .raw-material-group {
            background: var(--mib-surface-2);
            border: 1px solid var(--mib-border);
            padding: 1rem;
            border-radius: var(--mib-radius-sm);
            margin-bottom: 1rem;
            position: relative;
        }
        .raw-material-group:last-child { margin-bottom: 0; }
        .remove-material {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            background: none;
            border: none;
            color: var(--mib-danger);
            cursor: pointer;
            padding: 0.25rem 0.4rem;
            border-radius: 6px;
            line-height: 1;
            transition: background var(--mib-transition);
        }
        .remove-material:hover { background: var(--mib-danger-soft); }

        /* ---- File upload field ---- */
        .file-upload { position: relative; }
        .file-upload .form-control { padding-left: 2.5rem; }
        .file-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--mib-text-faint);
            pointer-events: none;
            z-index: 4;
        }

        @media (max-width: 768px) {
            .raw-material-group { padding-top: 2.5rem; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/products/addProduct' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
            pageTitle: 'Add Product',
            pageIcon: 'bi-plus-circle',
            pageSubtitle: 'Create a new product with raw materials and specifications'
        }) %>

        <form id="addProductForm" action="/products/addProduct" method="POST" enctype="multipart/form-data">
            <!-- ===================== Basic Information ===================== -->
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-box-seam"></i> Basic Information</h2>
                <p class="form-section-desc">Core product details and reference documents.</p>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label" for="name">Product Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label" for="density">Density (gr/ml)</label>
                        <input type="number" class="form-control" id="density" name="density" step="0.0001" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="tds">TDS File (PDF)</label>
                        <div class="file-upload">
                            <i class="bi bi-file-earmark-pdf file-icon"></i>
                            <input type="file" class="form-control" id="tds" name="tds" accept="application/pdf">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label" for="msds">MSDS File (PDF)</label>
                        <div class="file-upload">
                            <i class="bi bi-file-earmark-pdf file-icon"></i>
                            <input type="file" class="form-control" id="msds" name="msds" accept="application/pdf">
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================== Raw Materials ===================== -->
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-list-check"></i> Raw Materials</h2>
                <p class="form-section-desc">Add raw materials with their percentages — the total must equal 100%.</p>

                <div id="rawMaterials">
                    <div class="raw-material-group">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Raw Material 1</label>
                                <select name="rawMaterials[0][id]" class="form-select" required>
                                    <option value="" selected disabled>Select raw material</option>
                                    <% rawMaterials.forEach(material => { %>
                                        <option value="<%= material.id %>"><%= material.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Percentage (%)</label>
                                <input type="number" name="rawMaterials[0][percentage]" class="form-control raw-material-percentage" required step="0.001">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="button" class="btn btn-outline-primary" onclick="addRawMaterial()">
                        <i class="bi bi-plus-lg"></i> Add Another Raw Material
                    </button>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Product</button>
                <a href="/dashboard/rd" class="btn btn-light"><i class="bi bi-x-lg"></i> Cancel</a>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Select2 for all raw material selects
            $('.form-select').select2({
                placeholder: 'Search raw material...',
                width: '100%'
            });
        });

        let rawMaterialIndex = 1;

        function addRawMaterial() {
            const rawMaterialsDiv = document.getElementById('rawMaterials');
            const newRawMaterialDiv = document.createElement('div');
            newRawMaterialDiv.classList.add('raw-material-group', 'fade-in');

            newRawMaterialDiv.innerHTML = `
                <button type="button" class="remove-material" onclick="this.parentElement.remove(); updatePercentages();">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Raw Material ${rawMaterialIndex + 1}</label>
                        <select name="rawMaterials[${rawMaterialIndex}][id]" class="form-select" required>
                            <option value="" selected disabled>Select raw material</option>
                            <% rawMaterials.forEach(material => { %>
                                <option value="<%= material.id %>"><%= material.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Percentage (%)</label>
                        <input type="number" name="rawMaterials[${rawMaterialIndex}][percentage]"
                            class="form-control raw-material-percentage" required step="0.001">
                    </div>
                </div>
            `;

            rawMaterialsDiv.appendChild(newRawMaterialDiv);

            // Initialize Select2 for the new select element
            $(newRawMaterialDiv).find('.form-select').select2({
                placeholder: 'Search raw material...',
                width: '100%'
            });

            rawMaterialIndex++;
        }

        function updatePercentages() {
            const percentageInputs = document.querySelectorAll('.raw-material-percentage');
            let total = 0;

            percentageInputs.forEach(input => {
                const value = parseFloat(input.value) || 0;
                total += value;
            });

            percentageInputs.forEach(input => {
                input.style.borderColor = total > 100 ? 'var(--mib-danger)' : '';
            });
        }

        document.getElementById('addProductForm').addEventListener('submit', function(event) {
            let totalPercentage = 0;
            const percentageInputs = document.querySelectorAll('.raw-material-percentage');

            percentageInputs.forEach(input => {
                const percentage = parseFloat(input.value) || 0;
                totalPercentage += percentage;
            });

            totalPercentage = Math.round(totalPercentage * 1000) / 1000;

            if (totalPercentage !== 100) {
                event.preventDefault();
                alert(`Total percentage must equal 100%. Current total: ${totalPercentage}%`);
                percentageInputs.forEach(input => {
                    input.style.borderColor = 'var(--mib-danger)';
                });
            }
        });

        // Update percentages on input
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('raw-material-percentage')) {
                updatePercentages();
            }
        });
    </script>
</body>
</html>
