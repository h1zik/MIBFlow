<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        /* Select2 Custom Styles */
        .select2-container--default .select2-selection--single {
            height: 42px;
            padding: 0.375rem 0.75rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 24px;
            color: var(--text-color);
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 40px;
        }
        .select2-container--default .select2-search--dropdown .select2-search__field {
            padding: 8px;
            border-radius: 4px;
        }
        .select2-dropdown {
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            box-shadow: var(--shadow);
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: var(--primary-color);
        }
    </style>
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .form-select {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 16px 12px;
        }

        .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .raw-material-group {
            background-color: var(--background-light);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            position: relative;
        }

        .raw-material-group:last-child {
            margin-bottom: 0;
        }

        .remove-material {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            background: none;
            border: none;
            color: #dc3545;
            cursor: pointer;
            padding: 0.25rem;
            border-radius: 4px;
            transition: var(--transition);
        }

        .remove-material:hover {
            background-color: rgba(220, 53, 69, 0.1);
        }

        .file-upload {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .file-upload .form-control {
            padding-left: 2.5rem;
        }

        .file-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .btn-outline {
            background: none;
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
        }

        .btn-outline:hover {
            background-color: var(--primary-color);
            color: white;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control, .form-select {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .btn-group {
                display: flex;
                gap: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            .raw-material-group {
                padding-top: 2.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-plus-circle"></i>
                Add Product
            </h1>
            <p class="page-subtitle">Create a new product with raw materials and specifications</p>
        </div>

        <form id="addProductForm" action="/products/addProduct" method="POST" enctype="multipart/form-data">
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-box-seam"></i>
                        Basic Information
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="form-label" for="name">Product Name</label>
                                <input type="text" class="form-control" id="name" name="name" required>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-group">
                                <label class="form-label" for="density">Density (gr/ml)</label>
                                <input type="number" class="form-control" id="density" name="density" step="0.0001" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="tds">TDS File (PDF)</label>
                                <div class="file-upload">
                                    <i class="bi bi-file-earmark-pdf file-icon"></i>
                                    <input type="file" class="form-control" id="tds" name="tds" accept="application/pdf">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="msds">MSDS File (PDF)</label>
                                <div class="file-upload">
                                    <i class="bi bi-file-earmark-pdf file-icon"></i>
                                    <input type="file" class="form-control" id="msds" name="msds" accept="application/pdf">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-list-check"></i>
                        Raw Materials
                    </h2>
                </div>
                <div class="card-body">
                    <div id="rawMaterials">
                        <div class="raw-material-group">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label class="form-label">Raw Material 1</label>
                                        <select name="rawMaterials[0][id]" class="form-select" required>
                                            <option value="" selected disabled>Select raw material</option>
                                            <% rawMaterials.forEach(material => { %>
                                                <option value="<%= material.id %>"><%= material.name %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label">Percentage (%)</label>
                                        <input type="number" name="rawMaterials[0][percentage]" class="form-control raw-material-percentage" required step="0.001">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="btn-group mt-4">
                        <button type="button" class="btn btn-outline" onclick="addRawMaterial()">
                            <i class="bi bi-plus-lg"></i>
                            Add Another Raw Material
                        </button>
                    </div>
                </div>
            </div>

            <div class="btn-group mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i>
                    Create Product
                </button>
                <a href="/dashboard/rd" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i>
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Select2 for all raw material selects
            $('.form-select').select2({
                placeholder: 'Search raw material...',
                width: '100%'
            });

            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });

        let rawMaterialIndex = 1;

        function addRawMaterial() {
            const rawMaterialsDiv = document.getElementById('rawMaterials');
            const newRawMaterialDiv = document.createElement('div');
            newRawMaterialDiv.classList.add('raw-material-group', 'fade-in');
            
            newRawMaterialDiv.innerHTML = `
                <button type="button" class="remove-material" onclick="this.parentElement.remove(); updatePercentages();">
                    <i class="bi bi-x-lg"></i>
                </button>
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">Raw Material ${rawMaterialIndex + 1}</label>
                            <select name="rawMaterials[${rawMaterialIndex}][id]" class="form-select" required>
                                <option value="" selected disabled>Select raw material</option>
                                <% rawMaterials.forEach(material => { %>
                                    <option value="<%= material.id %>"><%= material.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Percentage (%)</label>
                            <input type="number" name="rawMaterials[${rawMaterialIndex}][percentage]" 
                                class="form-control raw-material-percentage" required step="0.001">
                        </div>
                    </div>
                </div>
            `;
            
            rawMaterialsDiv.appendChild(newRawMaterialDiv);
            
            // Initialize Select2 for the new select element
            $(newRawMaterialDiv).find('.form-select').select2({
                placeholder: 'Search raw material...',
                width: '100%'
            });
            
            rawMaterialIndex++;
        }

        function updatePercentages() {
            const percentageInputs = document.querySelectorAll('.raw-material-percentage');
            let total = 0;
            
            percentageInputs.forEach(input => {
                const value = parseFloat(input.value) || 0;
                total += value;
            });

            percentageInputs.forEach(input => {
                input.style.borderColor = total > 100 ? '#dc3545' : '';
            });
        }

        document.getElementById('addProductForm').addEventListener('submit', function(event) {
            let totalPercentage = 0;
            const percentageInputs = document.querySelectorAll('.raw-material-percentage');

            percentageInputs.forEach(input => {
                const percentage = parseFloat(input.value) || 0;
                totalPercentage += percentage;
            });

            totalPercentage = Math.round(totalPercentage * 1000) / 1000;

            if (totalPercentage !== 100) {
                event.preventDefault();
                alert(`Total percentage must equal 100%. Current total: ${totalPercentage}%`);
                percentageInputs.forEach(input => {
                    input.style.borderColor = '#dc3545';
                });
            }
        });

        // Update percentages on input
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('raw-material-percentage')) {
                updatePercentages();
            }
        });
    </script>
</body>
</html>
