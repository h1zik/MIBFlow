<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
        pageTitle: 'Formula Requests',
        extraStylesheets: ['https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css'],
        extraScripts: [
            'https://code.jquery.com/jquery-3.6.0.min.js',
            'https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js',
            'https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js'
        ]
    }) %>
    <style>
        /* loading spinner on submit buttons */
        .btn.loading { pointer-events: none; color: transparent !important; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        /* keep DataTables controls on-brand */
        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            background: var(--mib-primary); border-color: var(--mib-primary); color: #fff !important;
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/formula-requests/list' }) %>

    <%
        const reqList = (typeof formulaRequests !== 'undefined' && formulaRequests) ? formulaRequests : [];
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
        const pendingCount  = reqList.filter(r => r.status === 'Pending').length;
        const approvedCount = reqList.filter(r => r.status === 'Approved').length;
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
            pageTitle: 'Formula Requests',
            pageIcon: 'bi-file-text',
            pageSubtitle: 'Review, approve and track formula requests'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-collection"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Requests</div>
                    <div class="stat-value"><%= reqList.length %></div>
                    <span class="stat-sub">All formula requests</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-sub">Awaiting decision</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Approved</div>
                    <div class="stat-value"><%= approvedCount %></div>
                    <span class="stat-sub">Formulas delivered</span>
                </div>
            </div>
        </div>

        <!-- ===================== Requests table ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-droplet-fill"></i> All Formula Requests</h2>
                <div class="toolbar mb-0">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" class="form-control form-control-sm" id="searchInput" placeholder="Search requests…">
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="requestsTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Product</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Formula</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reqList.length > 0) { %>
                            <% reqList.forEach(function(request) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Product"><span class="cell-strong"><%= request.Product ? request.Product.name : '—' %></span></td>
                                    <td data-label="Date"><%= new Date(request.createdAt).toLocaleDateString() %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Formula">
                                        <% if (request.formula) { %>
                                            <a href="/uploads/<%= request.formula %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-pdf"></i> View Formula</a>
                                        <% } else { %>
                                            <span class="text-muted-2"><i class="bi bi-dash-circle"></i> No Formula</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Actions" class="text-end">
                                        <div class="action-buttons d-flex gap-1 justify-content-end flex-wrap">
                                            <a href="/formulaRequests/<%= request.id %>" class="btn btn-sm btn-primary"><i class="bi bi-eye"></i> View</a>
                                            <% if (request.status === 'Pending' && userRole === 'R&D') { %>
                                                <form action="/formulaRequests/approve/<%= request.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Approve</button>
                                                </form>
                                                <form action="/formulaRequests/reject/<%= request.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Reject</button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No formula requests found</h4><p>There are no formula requests at the moment.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let table = null;
            // Initialize DataTable (only when there are real data rows)
            if (document.querySelector('#requestsTable tbody td[data-label]')) {
                table = $('#requestsTable').DataTable({
                    order: [[0, 'desc']],
                    pageLength: 10,
                    language: {
                        search: "",
                        searchPlaceholder: "Search requests..."
                    },
                    dom: "<'row'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                         "<'row'<'col-sm-12'tr>>" +
                         "<'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
                });
            }

            // Wire the header search box to DataTables search
            const searchInput = document.getElementById('searchInput');
            if (searchInput && table) {
                searchInput.addEventListener('input', function() {
                    table.search(this.value).draw();
                });
            }

            // Loading state on form submissions
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function() {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.classList.add('loading');
                        submitBtn.disabled = true;
                    }
                });
            });
        });
    </script>
</body>
</html>
