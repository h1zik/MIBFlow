<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Edit Customer' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/customers/list' }) %>

    <div class="content">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <ul class="mib-breadcrumb"><li><a href="/customers/list">Customers</a></li><li>Edit</li></ul>
                <h1 class="page-title"><i class="bi bi-person-gear"></i> Edit Customer</h1>
                <p class="page-subtitle">Update customer information.</p>
            </div>
        </div>

        <form action="/customers/edit/<%= customer.id %>" method="POST" class="needs-validation" novalidate>
            <div class="form-section">
                <h3 class="form-section-title"><i class="bi bi-building me-1"></i> Company Information</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="perusahaan">Company Name</label>
                        <input type="text" class="form-control" id="perusahaan" name="perusahaan" value="<%= customer.perusahaan %>" required>
                        <div class="invalid-feedback">Please enter company name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="alamat">Company Address</label>
                        <input type="text" class="form-control" id="alamat" name="alamat" value="<%= customer.alamat %>" required>
                        <div class="invalid-feedback">Please enter company address.</div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title"><i class="bi bi-person me-1"></i> Contact Information</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="name">Customer Name</label>
                        <input type="text" class="form-control" id="name" name="name" value="<%= customer.name %>" required>
                        <div class="invalid-feedback">Please enter customer name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="cp">Contact Person</label>
                        <input type="text" class="form-control" id="cp" name="cp" value="<%= customer.cp %>" required>
                        <div class="invalid-feedback">Please enter contact person name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="phone">Phone Number</label>
                        <input type="tel" class="form-control" id="phone" name="phone" value="<%= customer.phone %>" required>
                        <div class="invalid-feedback">Please enter a valid phone number.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="email">Email Address</label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= customer.email %>" required>
                        <div class="invalid-feedback">Please enter a valid email address.</div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/customers/list" class="btn btn-light"><i class="bi bi-x-lg"></i> Cancel</a>
                <button type="submit" class="btn btn-primary" id="submitBtn"><i class="bi bi-check-lg"></i> Update Customer</button>
            </div>
        </form>
    </div>

    <script>
        (function () {
            'use strict';
            document.querySelectorAll('.needs-validation').forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
                    else { const b = document.getElementById('submitBtn'); if (b) b.disabled = true; }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
</body>
</html>
