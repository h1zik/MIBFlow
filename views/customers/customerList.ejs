<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Customer List', extraStylesheets: ['https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css'] }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/customers/list' }) %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Customer List',
              pageIcon: 'bi-people-fill',
              pageSubtitle: customers.length + ' customer' + (customers.length === 1 ? '' : 's') + ' registered.',
              actionsHtml: '<a href="/orders/addCustomer" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add New Customer</a>'
        }) %>

        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-people-fill"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Customers</div>
                    <div class="stat-value"><%= customers.length %></div>
                    <span class="stat-sub">Registered in the directory</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-building"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Companies</div>
                    <div class="stat-value"><%= new Set(customers.map(c => (c.perusahaan || '').trim()).filter(Boolean)).size %></div>
                    <span class="stat-sub">Distinct organisations</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-envelope-at"></i></div>
                <div class="stat-body">
                    <div class="stat-label">With Email</div>
                    <div class="stat-value"><%= customers.filter(c => (c.email || '').trim()).length %></div>
                    <span class="stat-sub">Reachable by email</span>
                </div>
            </div>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <% if (!customers.length) { %>
                    <div class="empty-state"><i class="bi bi-people"></i><h4>No customers yet</h4><p>Add your first customer to get started.</p><a href="/orders/addCustomer" class="btn btn-primary btn-sm"><i class="bi bi-person-plus"></i> Add Customer</a></div>
                <% } else { %>
                <table class="table align-middle" id="customersTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Contact Person</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Address</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% customers.forEach(customer => { %>
                            <tr>
                                <td data-label="ID" class="cell-sub">#<%= customer.id %></td>
                                <td data-label="Name" class="cell-strong"><%= customer.name %></td>
                                <td data-label="Company"><%= customer.perusahaan %></td>
                                <td data-label="Contact Person"><%= customer.cp %></td>
                                <td data-label="Phone"><a href="tel:<%= customer.phone %>" class="text-decoration-none"><i class="bi bi-telephone me-1"></i><%= customer.phone %></a></td>
                                <td data-label="Email"><a href="mailto:<%= customer.email %>" class="text-decoration-none"><i class="bi bi-envelope me-1"></i><%= customer.email %></a></td>
                                <td data-label="Address" class="cell-sub"><%= customer.alamat %></td>
                                <td data-label="Actions" class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="/customers/edit/<%= customer.id %>" class="btn btn-sm btn-soft"><i class="bi bi-pencil"></i> Edit</a>
                                        <form action="/customers/delete/<%= customer.id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this customer?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            if (document.getElementById('customersTable')) {
                $('#customersTable').DataTable({
                    responsive: true,
                    pageLength: 10,
                    order: [[0, 'desc']],
                    language: { search: "", searchPlaceholder: "Search customers...", lengthMenu: "_MENU_ per page" },
                    columnDefs: [{ orderable: false, targets: -1 }]
                });
                $('.dataTables_filter input').addClass('form-control form-control-sm');
                $('.dataTables_length select').addClass('form-select form-select-sm');
            }
        });
    </script>
</body>
</html>
