<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Add Customer' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/orders/addCustomer' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Add New Customer',
              pageIcon: 'bi-person-plus-fill',
              pageSubtitle: 'Fill in the customer details below.',
              breadcrumb: [{ label: 'Customers', href: '/customers/list' }, { label: 'Add' }]
        }) %>

        <form action="/orders/addCustomer" method="POST" class="needs-validation" novalidate>
            <div class="form-section fade-in">
                <h3 class="form-section-title"><i class="bi bi-building me-1"></i> Company Information</h3>
                <p class="form-section-desc">The company this customer represents.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="perusahaan">Company Name</label>
                        <input type="text" class="form-control" id="perusahaan" name="perusahaan" required>
                        <div class="invalid-feedback">Please enter company name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="alamat">Company Address</label>
                        <input type="text" class="form-control" id="alamat" name="alamat" required>
                        <div class="invalid-feedback">Please enter company address.</div>
                    </div>
                </div>
            </div>

            <div class="form-section fade-in">
                <h3 class="form-section-title"><i class="bi bi-person me-1"></i> Contact Information</h3>
                <p class="form-section-desc">How to reach the customer’s contact person.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="name">Customer Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                        <div class="invalid-feedback">Please enter customer name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="cp">Contact Person</label>
                        <input type="text" class="form-control" id="cp" name="cp" required>
                        <div class="invalid-feedback">Please enter contact person name.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="phone">Phone Number</label>
                        <input type="tel" class="form-control" id="phone" name="phone" required>
                        <div class="invalid-feedback">Please enter a phone number.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="email">Email Address</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                        <div class="invalid-feedback">Please enter a valid email address.</div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/dashboard/marketing" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back</a>
                <button type="submit" class="btn btn-primary" id="submitBtn"><i class="bi bi-check-lg"></i> Add Customer</button>
            </div>
        </form>
    </div>

    <script>
        (function () {
            'use strict';
            document.querySelectorAll('.needs-validation').forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
                    else { const b = document.getElementById('submitBtn'); if (b) b.disabled = true; }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
</body>
</html>
