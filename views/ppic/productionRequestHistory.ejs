<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Production Request History' }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/production/productionRequest/history' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const historyList = (typeof completedRequests !== 'undefined' && completedRequests) ? completedRequests : [];

        /* status badge helper (per spec) */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };

        /* aggregate quantity for the stat row (best-effort, purely cosmetic) */
        let totalQty = 0;
        historyList.forEach(r => { const q = parseFloat(r.quantity); if (!isNaN(q)) totalQty += q; });
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Production Request History',
              pageIcon: 'bi-clock-history',
              pageSubtitle: 'Overview of completed production requests with their details',
              actionsHtml: '<a href="/dashboard/ppic" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>' }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check2-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Completed Requests</div>
                    <div class="stat-value"><%= historyList.length %></div>
                    <span class="stat-sub">In the production history</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-droplet-half"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Quantity</div>
                    <div class="stat-value"><%= totalQty %></div>
                    <span class="stat-sub">Kilograms produced</span>
                </div>
            </div>
        </div>

        <!-- ===================== History table ===================== -->
        <div class="table-card fade-in">
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>Request ID</th>
                            <th>SO Number</th>
                            <th>Product</th>
                            <th class="text-end">Quantity (Kg)</th>
                            <th>Status</th>
                            <th>Completion Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (historyList.length > 0) { %>
                            <% historyList.forEach(request => { %>
                                <tr>
                                    <td data-label="Request ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="SO Number">#<%= request.sonumber %></td>
                                    <td data-label="Product"><%= request.product %></td>
                                    <td data-label="Quantity (Kg)" class="text-end num"><%= request.quantity %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                    <td data-label="Completion Date"><%= new Date(request.updatedAt).toLocaleDateString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="6">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No completed production requests</h4>
                                        <p>Completed production requests will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
