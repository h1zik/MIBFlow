<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Production Request History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            text-align: center;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
        }

        .page-subtitle {
            color: #6c757d;
            margin: 0.5rem 0 0 0;
            font-size: 0.875rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-body {
            padding: 1rem;
        }

        /* Desktop Table */
        .desktop-table {
            display: none;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        /* Mobile Cards */
        .mobile-card {
            background: white;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow);
        }

        .mobile-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .mobile-card-title {
            font-weight: 600;
            color: var(--primary-color);
            margin: 0;
            font-size: 0.875rem;
        }

        .mobile-card-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            gap: 1rem;
        }

        .mobile-card-row:last-child {
            border-bottom: none;
        }

        .mobile-card-label {
            color: #6c757d;
            font-size: 0.75rem;
            font-weight: 500;
            flex-shrink: 0;
            width: 100px;
        }

        .mobile-card-value {
            font-size: 0.875rem;
            text-align: right;
            word-break: break-word;
        }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.75rem;
            font-weight: 500;
            white-space: nowrap;
        }

        .status-completed {
            background-color: #d4edda;
            color: #155724;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .table td, .table th {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .desktop-table {
                display: block;
            }

            .mobile-view {
                display: none;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .desktop-table {
                display: none;
            }

            .mobile-view {
                display: block;
            }

            .mobile-card-row {
                flex-direction: column;
                align-items: flex-start;
            }

            .mobile-card-value {
                width: 100%;
                text-align: left;
                margin-top: 0.25rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-clock-history"></i>
                Production Request History
            </h1>
            <p class="page-subtitle">Overview of completed production requests with their details</p>
        </div>

        <div class="card fade-in">
            <div class="card-body">
                <!-- Desktop View -->
                <div class="table-responsive desktop-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Request ID</th>
                                <th>SO Number</th>
                                <th>Product</th>
                                <th>Quantity (Kg)</th>
                                <th>Status</th>
                                <th>Completion Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (completedRequests.length > 0) { %>
                                <% completedRequests.forEach(request => { %>
                                    <tr>
                                        <td>#<%= request.id %></td>
                                        <td>#<%= request.sonumber %></td>
                                        <td><%= request.product %></td>
                                        <td><%= request.quantity %></td>
                                        <td>
                                            <span class="status-badge status-completed">
                                                <%= request.status %>
                                            </span>
                                        </td>
                                        <td><%= new Date(request.updatedAt).toLocaleDateString() %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center">No completed production requests found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View -->
                <div class="mobile-view">
                    <% if (completedRequests.length > 0) { %>
                        <% completedRequests.forEach(request => { %>
                            <div class="mobile-card fade-in">
                                <div class="mobile-card-header">
                                    <h3 class="mobile-card-title">Request #<%= request.id %></h3>
                                    <span class="status-badge status-completed">
                                        <%= request.status %>
                                    </span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Order ID</span>
                                    <span class="mobile-card-value">#<%= request.orderId %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Product</span>
                                    <span class="mobile-card-value"><%= request.product %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Quantity</span>
                                    <span class="mobile-card-value"><%= request.quantity %> Kg</span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Completed</span>
                                    <span class="mobile-card-value"><%= new Date(request.updatedAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No completed production requests found
                        </div>
                    <% } %>
                </div>

                <div class="mt-4">
                    <a href="/dashboard/ppic" class="btn btn-primary">
                        <i class="bi bi-arrow-left"></i>
                        Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
