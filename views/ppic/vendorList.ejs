<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Vendor List' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/vendorList' }) %>

    <%
        const vendorList = (typeof vendors !== 'undefined' && vendors) ? vendors : [];
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Vendor List',
              pageIcon: 'bi-building',
              pageSubtitle: 'Manage suppliers used across raw material and packaging requests.',
              actionsHtml: '<a href="/ppic/addVendor" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add New Vendor</a>'
        }) %>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="mib-flash mib-flash-error fade-in" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span><%= error %></span>
        </div>
        <% } %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-people"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Vendors</div>
                    <div class="stat-value"><%= vendorList.length %></div>
                    <span class="stat-sub">Registered suppliers</span>
                </div>
            </div>
        </div>

        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-building"></i> Vendors</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Address</th>
                            <th>Contact</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (vendorList.length > 0) { %>
                            <% vendorList.forEach(function(vendor) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= vendor.id %></span></td>
                                    <td data-label="Name"><span class="cell-strong"><%= vendor.name %></span></td>
                                    <td data-label="Address"><%= vendor.address %></td>
                                    <td data-label="Contact"><%= vendor.contact %></td>
                                    <td data-label="Actions" class="text-end">
                                        <div class="d-flex gap-2 justify-content-end flex-wrap">
                                            <a href="/edit/<%= vendor.id %>" class="btn btn-sm btn-soft">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <form action="/delete/<%= vendor.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this vendor?')">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No vendors found</h4>
                                        <p>Add your first vendor to start assigning purchase requests.</p>
                                        <a href="/ppic/addVendor" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Add New Vendor</a>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3">
            <a href="/dashboard/purchase" class="btn btn-light">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</body>
</html>
