<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vendor List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-body {
            padding: 1rem;
        }

        /* Desktop Table */
        .desktop-table {
            display: none;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        /* Mobile Cards */
        .mobile-card {
            background: white;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow);
        }

        .mobile-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .mobile-card-title {
            font-weight: 600;
            color: var(--primary-color);
            margin: 0;
            font-size: 0.875rem;
        }

        .mobile-card-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            gap: 1rem;
        }

        .mobile-card-row:last-child {
            border-bottom: none;
        }

        .mobile-card-label {
            color: #6c757d;
            font-size: 0.75rem;
            font-weight: 500;
            flex-shrink: 0;
            width: 100px;
        }

        .mobile-card-value {
            font-size: 0.875rem;
            text-align: right;
            word-break: break-word;
        }

        .mobile-card-actions {
            display: grid;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
            color: white;
        }

        .btn-danger:hover {
            background-color: #c82333;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .table td, .table th {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .desktop-table {
                display: block;
            }

            .mobile-view {
                display: none;
            }

            .btn-group {
                display: flex;
                gap: 0.5rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .desktop-table {
                display: none;
            }

            .mobile-view {
                display: block;
            }

            .mobile-card-row {
                flex-direction: column;
                align-items: flex-start;
            }

            .mobile-card-value {
                width: 100%;
                text-align: left;
                margin-top: 0.25rem;
            }

            .btn-group {
                display: grid;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger fade-in" style="border-radius: 8px; padding: 1rem; margin-bottom: 1rem; font-size: 0.875rem; display: flex; align-items: center; gap: 0.5rem; background-color: #f8d7da; border: 1px solid #f5c2c7; color: #842029;">
                <i class="bi bi-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-building"></i>
                Vendor List
            </h1>
            <div class="btn-group">
                <a href="/ppic/addVendor" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New Vendor
                </a>
            </div>
        </div>

        <div class="card fade-in">
            <div class="card-body">
                <!-- Desktop View -->
                <div class="table-responsive desktop-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Address</th>
                                <th>Contact</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (vendors && vendors.length > 0) { %>
                                <% vendors.forEach(function(vendor) { %>
                                    <tr>
                                        <td>#<%= vendor.id %></td>
                                        <td><%= vendor.name %></td>
                                        <td><%= vendor.address %></td>
                                        <td><%= vendor.contact %></td>
                                        <td>
                                            <div class="btn-group">
                                                <a href="/edit/<%= vendor.id %>" class="btn btn-primary">
                                                    <i class="bi bi-pencil"></i>
                                                    Edit
                                                </a>
                                                <form action="/delete/<%= vendor.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this vendor?')">
                                                        <i class="bi bi-trash"></i>
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center">No vendors found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View -->
                <div class="mobile-view">
                    <% if (vendors && vendors.length > 0) { %>
                        <% vendors.forEach(function(vendor) { %>
                            <div class="mobile-card fade-in">
                                <div class="mobile-card-header">
                                    <h3 class="mobile-card-title">Vendor #<%= vendor.id %></h3>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Name</span>
                                    <span class="mobile-card-value"><%= vendor.name %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Address</span>
                                    <span class="mobile-card-value"><%= vendor.address %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Contact</span>
                                    <span class="mobile-card-value"><%= vendor.contact %></span>
                                </div>
                                <div class="mobile-card-actions">
                                    <a href="/ppic/vendors/edit/<%= vendor.id %>" class="btn btn-primary">
                                        <i class="bi bi-pencil"></i>
                                        Edit Vendor
                                    </a>
                                    <form action="/ppic/vendors/delete/<%= vendor.id %>" method="POST">
                                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this vendor?')">
                                            <i class="bi bi-trash"></i>
                                            Delete Vendor
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No vendors found
                        </div>
                    <% } %>
                </div>

                <div class="mt-4">
                    <a href="/dashboard/ppic" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i>
                        Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
