<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Add Vendor' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/ppic/addVendor' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Add New Vendor',
              pageIcon: 'bi-building-add',
              pageSubtitle: 'Register a new supplier for raw materials and packaging.',
              actionsHtml: '<a href="/vendorList" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back to Vendor List</a>'
        }) %>

        <form action="/ppic/addVendor" method="POST">
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-person-vcard me-1"></i> Vendor Information</h2>
                <p class="form-section-desc">All fields are required. This vendor becomes available for raw material and packaging assignment.</p>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="name">Vendor Name</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="e.g. PT Sumber Kimia" required>
                    </div>

                    <div class="col-12">
                        <label class="form-label" for="address">Vendor Address</label>
                        <input type="text" class="form-control" id="address" name="address" placeholder="Full address" required>
                    </div>

                    <div class="col-12">
                        <label class="form-label" for="contact">Vendor Contact</label>
                        <input type="text" class="form-control" id="contact" name="contact" placeholder="Phone or email" required>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Add Vendor
                </button>
                <a href="/vendorList" class="btn btn-light">
                    <i class="bi bi-arrow-left"></i> Back to Vendor List
                </a>
            </div>
        </form>
    </div>
</body>
</html>
