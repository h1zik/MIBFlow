<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Create Order' }) %>
    <style>
        /* page-specific components */
        .nav-tabs { border: none; gap: 0.25rem; margin-bottom: 1.25rem; flex-wrap: nowrap; overflow-x: auto; }
        .nav-tabs .nav-link {
            border: none; color: var(--mib-text-muted); font-weight: 550; font-size: 0.9rem;
            padding: 0.7rem 1rem; border-radius: var(--mib-radius-sm); white-space: nowrap;
        }
        .nav-tabs .nav-link:hover { color: var(--mib-primary); background: var(--mib-primary-soft); }
        .nav-tabs .nav-link.active { color: var(--mib-primary); background: var(--mib-primary-soft); }
        .product-card { position: relative; }
        .remove-product {
            position: absolute; top: 1rem; right: 1rem; color: var(--mib-danger);
            cursor: pointer; padding: 0.4rem; border-radius: 50%; transition: var(--mib-transition);
        }
        .remove-product:hover { background: var(--mib-danger-soft); }
        .packaging-row { background: var(--mib-surface-2); padding: 1rem; border-radius: var(--mib-radius-sm); border: 1px solid var(--mib-border); }
        .consumables-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 0.5rem; }
        .form-check { padding: 0.6rem 0.75rem; border-radius: var(--mib-radius-sm); margin: 0; transition: var(--mib-transition); }
        .form-check:hover { background: var(--mib-surface-2); }
        .floating-action-btn { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 1040; }
        .floating-action-btn .btn { width: 54px; height: 54px; border-radius: 50%; padding: 0; box-shadow: var(--mib-shadow-lg); }
        .floating-action-btn .btn i { font-size: 1.35rem; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/orders/create' }) %>

    <div class="content content-wide">
        <% if (locals.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div><strong>Error creating order:</strong> <%= error %></div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="page-header fade-in">
            <div class="page-header__main">
                <ul class="mib-breadcrumb"><li><a href="/dashboard/marketing">Dashboard</a></li><li>Create Order</li></ul>
                <h1 class="page-title"><i class="bi bi-cart-plus"></i> Create Order</h1>
                <p class="page-subtitle">Add customer, products and packaging, then submit.</p>
            </div>
            <div class="page-actions">
                <a href="/dashboard/marketing" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back</a>
                <button type="submit" form="orderForm" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create Order</button>
            </div>
        </div>

        <form id="orderForm" action="/orders/create" method="POST" enctype="multipart/form-data">
            <ul class="nav nav-tabs fade-in" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#customer-info"><i class="bi bi-person"></i> Customer Info</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#products-tab"><i class="bi bi-box-seam"></i> Products</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#additional-info"><i class="bi bi-info-circle"></i> Additional Info</a></li>
            </ul>

            <div class="tab-content">
                <!-- Customer Info Tab -->
                <div class="tab-pane fade show active fade-in" id="customer-info">
                    <div class="card">
                        <div class="card-header"><h2 class="card-title"><i class="bi bi-person-badge"></i> Customer Details</h2></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="customerId">Company Name</label>
                                    <select class="form-select" id="customerId" name="customerId" required onchange="loadCustomerProducts(this.value)">
                                        <option value="" disabled selected>Select a customer</option>
                                        <% customers.forEach(customer => { %>
                                            <option value="<%= customer.id %>"><%= customer.perusahaan %> — <%= customer.name %></option>
                                        <% }) %>
                                    </select>
                                    <div class="form-text">Products available depend on the selected customer.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Products Tab -->
                <div class="tab-pane fade fade-in" id="products-tab">
                    <div id="productsPlaceholder" class="card"><div class="empty-state">
                        <i class="bi bi-box-seam"></i>
                        <h4>Select a customer first</h4>
                        <p>Go to the <strong>Customer Info</strong> tab and choose a customer. Products that have been <strong>assigned to that customer</strong> will load here automatically.</p>
                    </div></div>
                    <div id="products"></div>
                </div>

                <!-- Additional Info Tab -->
                <div class="tab-pane fade fade-in" id="additional-info">
                    <div class="card">
                        <div class="card-header"><h2 class="card-title"><i class="bi bi-info-circle"></i> Order Details</h2></div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">Consumables</label>
                                    <div class="consumables-grid">
                                        <% consumables.forEach(consumable => { %>
                                            <div class="form-check">
                                                <input type="checkbox" class="form-check-input" id="<%= consumable.name.toLowerCase() %>" name="consumables[]" value="<%= consumable.name %>">
                                                <label class="form-check-label" for="<%= consumable.name.toLowerCase() %>"><%= consumable.name %></label>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Deadline</label>
                                    <div class="d-flex gap-3 align-items-center">
                                        <div class="form-check"><input class="form-check-input" type="radio" id="deadlineNo" name="deadlineOption" value="no" checked><label class="form-check-label" for="deadlineNo">No</label></div>
                                        <div class="form-check"><input class="form-check-input" type="radio" id="deadlineYes" name="deadlineOption" value="yes"><label class="form-check-label" for="deadlineYes">Yes</label></div>
                                    </div>
                                    <input type="date" class="form-control mt-2" id="deadlineDate" name="deadlineDate" disabled style="max-width:240px">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="paymentType">Payment Type</label>
                                    <select class="form-select" id="paymentType" name="paymentType" required>
                                        <option value="CBD">CBD (Cash Before Delivery)</option>
                                        <option value="DP">DP (Down Payment)</option>
                                        <option value="TOP15">TOP 15 days</option>
                                        <option value="TOP30">TOP 30 days</option>
                                        <option value="TOP45">TOP 45 days</option>
                                        <option value="TOP60">TOP 60 days</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="tax">Tax</label>
                                    <select class="form-select" id="tax" name="tax" required>
                                        <option value="PPN 11%">PPN 11%</option>
                                        <option value="Non Pajak">Non Pajak</option>
                                        <option value="PPh 23">PPh 23</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="notes">Notes</label>
                                    <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="po">PO (PDF)</label>
                                    <input type="file" class="form-control" id="po" name="po" accept="application/pdf" required>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <div class="floating-action-btn">
            <button type="button" class="btn btn-primary" onclick="addProduct()" aria-label="Add product"><i class="bi bi-plus-lg"></i></button>
        </div>
    </div>

    <script>
        let productIndex = 0;
        let customerProducts = [];

        function loadCustomerProducts(customerId) {
            if (!customerId) return;
            customerProducts = [];
            document.getElementById('products').innerHTML = '';
            productIndex = 0;
            document.querySelector('.floating-action-btn button').disabled = true;
            fetch(`/orders/customer-products/${customerId}`)
                .then(response => { if (!response.ok) throw new Error('Failed to load customer products'); return response.json(); })
                .then(products => {
                    customerProducts = products;
                    updateProductDropdowns();
                    document.querySelector('.floating-action-btn button').disabled = false;
                    const placeholder = document.getElementById('productsPlaceholder');
                    if (products.length === 0) {
                        if (placeholder) {
                            placeholder.style.display = '';
                            placeholder.innerHTML = '<div class="empty-state"><i class="bi bi-link-45deg"></i><h4>This customer has no products linked</h4><p>Selecting a customer here is not the same as assigning products to them.<br>Open <strong>Product List</strong>, click <strong>Assign</strong> on a product, and choose this customer — then come back and reselect the customer.</p><a href="/products/listProduct" class="btn btn-soft btn-sm"><i class="bi bi-box-seam"></i> Go to Product List</a></div>';
                        }
                    } else {
                        if (placeholder) placeholder.style.display = 'none';
                        if (document.querySelectorAll('.product-card').length === 0) addProduct();
                    }
                })
                .catch(error => { console.error('Error loading customer products:', error); alert('Error loading products for this customer. Please try again.'); });
        }

        function updateProductDropdowns() {
            document.querySelectorAll('.product-select').forEach(select => {
                const currentValue = select.value;
                select.innerHTML = '';
                if (customerProducts.length === 0) {
                    const option = document.createElement('option');
                    option.value = ''; option.disabled = true; option.selected = true;
                    option.textContent = 'No products available for this customer';
                    select.appendChild(option);
                } else {
                    const option = document.createElement('option');
                    option.value = ''; option.disabled = true; option.selected = true;
                    option.textContent = 'Select a product';
                    select.appendChild(option);
                    customerProducts.forEach(product => {
                        const o = document.createElement('option');
                        o.value = product.id;
                        o.setAttribute('data-density', product.density);
                        o.setAttribute('data-price', product.price);
                        o.textContent = product.name;
                        select.appendChild(o);
                        if (product.id.toString() === currentValue) o.selected = true;
                    });
                }
                select.dispatchEvent(new Event('change'));
            });
        }

        function createProductCard() {
            return `
                <div class="card product-card fade-in" data-product-index="${productIndex}">
                    <div class="card-header">
                        <h2 class="card-title"><i class="bi bi-box"></i> Product ${productIndex + 1}</h2>
                        <i class="bi bi-x-lg remove-product" onclick="removeProduct(this)"></i>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Product</label>
                                <select class="form-select product-select" name="products[${productIndex}][productId]" onchange="updateCalculations(this.closest('.row').querySelector('input[type=number]'))" required>
                                    <option value="" disabled selected>${customerProducts.length > 0 ? 'Select a product' : 'No products available for this customer'}</option>
                                    ${customerProducts.map(product => `<option value="${product.id}" data-density="${product.density}" data-price="${product.price}">${product.name}</option>`).join('')}
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Quantity</label>
                                <input type="number" step="any" class="form-control" name="products[${productIndex}][quantity]" onchange="updateCalculations(this)" required min="0.01">
                                <small class="text-muted calculation-result" style="display: none;"></small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Units</label>
                                <select class="form-select" name="products[${productIndex}][satuan]" onchange="updateCalculations(this.closest('.row').querySelector('input[type=number]'))" required>
                                    <option value="L">Liters (L)</option>
                                    <option value="KG">Kilograms (KG)</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h6 class="mb-3 fw-medium">Packaging Options</h6>
                            <div class="packaging-calculation" style="display: none;">
                                <div class="alert alert-info mb-2">
                                    Total Packaging Volume: <span class="total-volume">0</span> L<br>
                                    Required Volume: <span class="required-volume">0</span> L<br>
                                    Difference: <span class="volume-difference">0</span> L
                                </div>
                                <div class="alert alert-warning minimality-warning" style="display: none;"></div>
                                <div class="alert alert-danger insufficient-volume-warning" style="display: none;"></div>
                            </div>
                            <div class="packaging-list">
                                <div class="packaging-row">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Packaging</label>
                                            <select class="form-select" name="products[${productIndex}][packaging][0][packagingId]" onchange="handlePackagingChange(this)" required>
                                                <% packagings.forEach(packaging => { %>
                                                    <option value="<%= packaging.id %>" data-volume="<%= packaging.volume %>"><%= packaging.name %> (<%= packaging.volume %> L)</option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Quantity</label>
                                            <input type="number" class="form-control" name="products[${productIndex}][packaging][0][quantity]" onchange="handlePackagingChange(this)" required min="1" value="1">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-light btn-sm mt-3" onclick="addPackaging(this)"><i class="bi bi-plus-lg"></i> Add Packaging</button>
                        </div>
                    </div>
                </div>
            `;
        }

        function addProduct() {
            if (customerProducts.length === 0) { alert('Please select a customer with assigned products first.'); return; }
            const ph = document.getElementById('productsPlaceholder');
            if (ph) ph.style.display = 'none';
            const productContainer = document.getElementById('products');
            productIndex++;
            const tempContainer = document.createElement('div');
            tempContainer.innerHTML = createProductCard();
            const productCard = tempContainer.firstElementChild;
            productContainer.appendChild(productCard);
            const packagingQuantityInput = productCard.querySelector('input[name*="[packaging][0][quantity]"]');
            if (packagingQuantityInput) packagingQuantityInput.value = 1;
            const productsTab = document.querySelector('a[href="#products-tab"]');
            if (productsTab) new bootstrap.Tab(productsTab).show();
        }

        function removeProduct(element) { element.closest('.product-card').remove(); }

        function addPackaging(element) {
            const productCard = element.closest('.product-card');
            if (!productCard) return;
            const productIdx = productCard.getAttribute('data-product-index');
            if (!productIdx) return;
            const packagingList = productCard.querySelector('.packaging-list');
            const newRowIndex = packagingList.querySelectorAll('.packaging-row').length;
            const newPackagingRow = document.createElement('div');
            newPackagingRow.className = 'packaging-row mt-3';
            newPackagingRow.innerHTML = `
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Packaging</label>
                        <select class="form-select" name="products[${productIdx}][packaging][${newRowIndex}][packagingId]" onchange="handlePackagingChange(this)" required>
                            <% packagings.forEach(packaging => { %>
                                <option value="<%= packaging.id %>" data-volume="<%= packaging.volume %>"><%= packaging.name %> (<%= packaging.volume %> L)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Quantity</label>
                        <input type="number" class="form-control" name="products[${productIdx}][packaging][${newRowIndex}][quantity]" onchange="handlePackagingChange(this)" required min="1" value="1">
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-danger" onclick="removePackaging(this)"><i class="bi bi-trash"></i></button>
                    </div>
                </div>`;
            packagingList.appendChild(newPackagingRow);
            handlePackagingChange(newPackagingRow.querySelector('select'));
        }

        function removePackaging(button) {
            const packagingRow = button.closest('.packaging-row');
            const productCard = packagingRow.closest('.product-card');
            packagingRow.remove();
            updatePackagingCalculations(productCard);
        }

        function updatePackagingCalculations(element) {
            const card = element.closest('.product-card');
            if (card) updatePackagingCalculationsCard(card);
        }

        function updatePackagingCalculationsCard(card) {
            const productSelect = card.querySelector('.product-select');
            const unitSelect = card.querySelector('select[name*="satuan"]');
            if (!productSelect || !unitSelect) return;
            const selectedProductOption = productSelect.options[productSelect.selectedIndex];
            if (!selectedProductOption || selectedProductOption.disabled) return;
            const density = parseFloat(selectedProductOption.getAttribute('data-density'));
            const unit = unitSelect.value;
            const inputQuantity = parseFloat(card.querySelector('input[name*="[quantity]"]').value);
            const packagingCalculation = card.querySelector('.packaging-calculation');
            if (!packagingCalculation) return;
            if (inputQuantity > 0) {
                const requiredVolume = (unit === 'KG') ? inputQuantity / density : inputQuantity;
                let exactTotalPackagingVolume = 0;
                const packagingRows = card.querySelectorAll('.packaging-row');
                packagingRows.forEach((row) => {
                    const packagingSelect = row.querySelector('select');
                    if (!packagingSelect) return;
                    const selectedPackagingOption = packagingSelect.options[packagingSelect.selectedIndex];
                    if (!selectedPackagingOption) return;
                    const packVol = parseFloat(selectedPackagingOption.getAttribute('data-volume')) || 0;
                    const packQty = parseFloat(row.querySelector('input[type="number"]').value) || 0;
                    exactTotalPackagingVolume += packVol * packQty;
                });
                const displayTotal = Math.round(exactTotalPackagingVolume * 100) / 100;
                const displayRequired = Math.round(requiredVolume * 100) / 100;
                const displayDifference = Math.round((exactTotalPackagingVolume - requiredVolume) * 100) / 100;
                const totalVolumeSpan = packagingCalculation.querySelector('.total-volume');
                const requiredVolumeSpan = packagingCalculation.querySelector('.required-volume');
                const volumeDifferenceSpan = packagingCalculation.querySelector('.volume-difference');
                if (totalVolumeSpan) totalVolumeSpan.textContent = displayTotal.toFixed(2);
                if (requiredVolumeSpan) requiredVolumeSpan.textContent = displayRequired.toFixed(2);
                if (volumeDifferenceSpan) volumeDifferenceSpan.textContent = displayDifference.toFixed(2);
                packagingCalculation.style.display = 'block';
                const insufficientWarningDiv = packagingCalculation.querySelector('.insufficient-volume-warning');
                if (insufficientWarningDiv) {
                    if (exactTotalPackagingVolume < requiredVolume) {
                        insufficientWarningDiv.textContent = `Warning: Packaging volume is insufficient. Required: ${requiredVolume.toFixed(2)} L, Provided: ${exactTotalPackagingVolume.toFixed(2)} L.`;
                        insufficientWarningDiv.style.display = 'block';
                    } else { insufficientWarningDiv.style.display = 'none'; }
                }
                let minimalityIssue = false;
                packagingRows.forEach(row => {
                    const packagingSelect = row.querySelector('select');
                    if (!packagingSelect) return;
                    const selectedPackagingOption = packagingSelect.options[packagingSelect.selectedIndex];
                    if (!selectedPackagingOption) return;
                    const packVol = parseFloat(selectedPackagingOption.getAttribute('data-volume'));
                    const packQty = parseFloat(row.querySelector('input[type="number"]').value);
                    if (packQty > 0 && (exactTotalPackagingVolume - packVol) >= requiredVolume) minimalityIssue = true;
                });
                const minimalityWarningDiv = packagingCalculation.querySelector('.minimality-warning');
                if (minimalityWarningDiv) {
                    if (minimalityIssue) {
                        minimalityWarningDiv.textContent = `Warning: The packaging configuration is not minimal. Please reduce the packaging quantity to the minimum required.`;
                        minimalityWarningDiv.style.display = 'block';
                    } else { minimalityWarningDiv.style.display = 'none'; }
                }
            } else { packagingCalculation.style.display = 'none'; }
        }

        function handlePackagingChange(element) {
            const productCard = element.closest('.product-card');
            if (productCard) updatePackagingCalculationsCard(productCard);
        }

        function updateCalculations(quantityInput) {
            if (!quantityInput || !quantityInput.value) return;
            const card = quantityInput.closest('.product-card');
            const row = quantityInput.closest('.row');
            const productSelect = row.querySelector('.product-select');
            const unitSelect = row.querySelector('select[name*="satuan"]');
            const calculationResult = row.querySelector('.calculation-result');
            if (!productSelect || !unitSelect) return;
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            if (!selectedOption || selectedOption.disabled) return;
            const density = parseFloat(selectedOption.getAttribute('data-density')) || 1;
            const customerPrice = parseFloat(selectedOption.getAttribute('data-price')) || 0;
            const quantity = parseFloat(quantityInput.value) || 0;
            const unit = unitSelect.value;
            if (unit === 'KG' && !isNaN(density) && density > 0) {
                let resultText = `Equivalent to ${(quantity / density).toFixed(2)} L`;
                if (customerPrice > 0) resultText += ` | Total: Rp ${(quantity * customerPrice).toLocaleString('id-ID')}`;
                calculationResult.textContent = resultText; calculationResult.style.display = 'block';
            } else if (unit === 'L' && !isNaN(density) && density > 0) {
                let resultText = `Equivalent to ${(quantity * density).toFixed(2)} KG`;
                if (customerPrice > 0) resultText += ` | Total: Rp ${(quantity * customerPrice).toLocaleString('id-ID')}`;
                calculationResult.textContent = resultText; calculationResult.style.display = 'block';
            } else { calculationResult.style.display = 'none'; }
            updatePackagingCalculationsCard(card);
        }

        document.querySelectorAll('input[name="deadlineOption"]').forEach((elem) => {
            elem.addEventListener("change", function () {
                document.getElementById('deadlineDate').disabled = this.value === "no";
            });
        });

        // Products load after a customer is selected — no auto-add on page load.

        // Validation: packaging minimality + sufficiency
        document.getElementById('orderForm').addEventListener('submit', function (event) {
            const productCards = document.querySelectorAll('.product-card');
            for (const card of productCards) {
                const productSelect = card.querySelector('select[name*="[productId]"]');
                const selectedProductOption = productSelect.options[productSelect.selectedIndex];
                const density = parseFloat(selectedProductOption.getAttribute('data-density'));
                const unit = card.querySelector('select[name*="satuan"]').value;
                const inputQuantity = parseFloat(card.querySelector('input[name*="[quantity]"]').value);
                const requiredVolume = (unit === 'KG') ? inputQuantity / density : inputQuantity;
                let totalPackagingVolume = 0;
                const packagingRows = card.querySelectorAll('.packaging-row');
                packagingRows.forEach(row => {
                    const selectedPackagingOption = row.querySelector('select').options[row.querySelector('select').selectedIndex];
                    const packVol = parseFloat(selectedPackagingOption.getAttribute('data-volume'));
                    const packQty = parseFloat(row.querySelector('input[type="number"]').value);
                    totalPackagingVolume += packVol * packQty;
                });
                if (totalPackagingVolume < requiredVolume) {
                    alert(`For product ${selectedProductOption.text.trim()}: Total packaging volume (${totalPackagingVolume} L) is less than required volume (${requiredVolume.toFixed(2)} L).`);
                    event.preventDefault(); return false;
                }
                let minimalityIssue = false;
                packagingRows.forEach(row => {
                    const selectedPackagingOption = row.querySelector('select').options[row.querySelector('select').selectedIndex];
                    const packVol = parseFloat(selectedPackagingOption.getAttribute('data-volume'));
                    const packQty = parseFloat(row.querySelector('input[type="number"]').value);
                    if (packQty > 0 && (totalPackagingVolume - packVol) >= requiredVolume) minimalityIssue = true;
                });
                if (minimalityIssue) {
                    alert(`For product ${selectedProductOption.text.trim()}: The packaging configuration is not minimal. Please reduce the packaging quantity to the minimum required.`);
                    event.preventDefault(); return false;
                }
            }
        });

        // Validation: required selections
        document.getElementById('orderForm').addEventListener('submit', function (event) {
            const customerId = document.getElementById('customerId').value;
            if (!customerId) { event.preventDefault(); alert('Please select a customer.'); return; }
            const productCards = document.querySelectorAll('.product-card');
            if (productCards.length === 0) { event.preventDefault(); alert('Please add at least one product.'); return; }
            let hasInvalidProduct = false;
            productCards.forEach((card) => {
                const productSelect = card.querySelector('.product-select');
                const quantityInput = card.querySelector('input[name*="[quantity]"]');
                if (productSelect && quantityInput) {
                    const productId = productSelect.value;
                    const quantity = parseFloat(quantityInput.value);
                    if (!productId || isNaN(quantity) || quantity <= 0) hasInvalidProduct = true;
                    card.querySelectorAll('.packaging-row').forEach((row) => {
                        const packagingQty = parseFloat(row.querySelector('input[type="number"]').value);
                        if (isNaN(packagingQty) || packagingQty <= 0) hasInvalidProduct = true;
                    });
                } else { hasInvalidProduct = true; }
            });
            if (hasInvalidProduct) {
                event.preventDefault();
                alert('Please select a valid product and quantity for all product entries and ensure all packaging has valid quantities.');
                return;
            }
            let insufficientPackaging = false;
            productCards.forEach(card => {
                const packagingCalculation = card.querySelector('.packaging-calculation');
                if (packagingCalculation && packagingCalculation.style.display !== 'none') {
                    const insufficientWarning = packagingCalculation.querySelector('.insufficient-volume-warning');
                    if (insufficientWarning && insufficientWarning.style.display !== 'none') insufficientPackaging = true;
                }
            });
            if (insufficientPackaging && !confirm('Some products have insufficient packaging volume. Do you want to continue anyway?')) {
                event.preventDefault();
            }
        });
    </script>
</body>
</html>
