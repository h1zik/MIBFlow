<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Order History' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/orders/delivered' }) %>

    <div class="content content-wide">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-truck"></i> Delivered Orders</h1>
                <p class="page-subtitle">Filter and view details of delivered orders.</p>
            </div>
            <% if (userRole === 'Marketing' || userRole === 'PPIC') { %>
            <div class="page-actions">
                <a href="/dashboard/<%= userRole.toLowerCase() %>" class="btn btn-light"><i class="bi bi-arrow-left"></i> Dashboard</a>
            </div>
            <% } %>
        </div>

        <div class="card fade-in">
            <div class="card-header"><h2 class="card-title"><i class="bi bi-funnel"></i> Filter Orders</h2></div>
            <div class="card-body">
                <form action="/orders/delivered" method="GET">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="startDate" class="form-label">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startDate %>">
                        </div>
                        <div class="col-md-4">
                            <label for="endDate" class="form-label">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endDate %>">
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Apply Filter</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="table-card fade-in">
            <div class="card-header"><h2 class="card-title"><i class="bi bi-list-check"></i> Delivered Orders</h2></div>
            <div class="table-responsive">
                <% if (orders.length > 0) { %>
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Products</th>
                            <th>PO File</th>
                            <% if (userRole === 'Finance') { %><th>Payment Type</th><th>Payment Due</th><% } %>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                        <tr>
                            <td data-label="SO Number" class="cell-strong"><%= order.sonumber %></td>
                            <td data-label="Customer"><%= order.customerName %></td>
                            <td data-label="Date"><%= new Date(order.createdAt).toLocaleDateString() %></td>
                            <td data-label="Products"><span class="cell-sub"><% order.products.forEach((product, index) => { %><%= product.name %> (<%= product.quantity %> <%= product.satuan %>)<% if (index < order.products.length - 1) { %>, <% } %><% }) %></span></td>
                            <td data-label="PO File">
                                <% if (order.po) { %><a href="/uploads/<%= order.po %>" target="_blank" class="text-decoration-none"><i class="bi bi-file-earmark-pdf"></i> PDF</a><% } else { %><span class="cell-sub">—</span><% } %>
                            </td>
                            <% if (userRole === 'Finance') { %>
                            <td data-label="Payment Type"><%= order.paymentType %></td>
                            <td data-label="Payment Due">
                                <%= order.paymentDueDate ? new Date(order.paymentDueDate).toISOString().split('T')[0] : 'N/A' %>
                                <% if (order.paymentDueDate && new Date() >= new Date(order.paymentDueDate)) { %><span class="status-badge status-declined ms-1"><i class="bi bi-exclamation-circle"></i> Due</span><% } %>
                            </td>
                            <% } %>
                            <td data-label="Actions" class="text-end">
                                <a href="/orders/<%= order.id %>" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                <div class="empty-state"><i class="bi bi-inbox"></i><h4>No delivered orders found</h4><p>Try adjusting the date filter above.</p></div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
