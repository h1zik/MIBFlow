<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivered Orders - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-dark: #1b5e20;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --danger-color: #dc3545;
            --danger-bg: #f8d7da;
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            margin: 0.5rem 0 0 0;
            font-size: 0.875rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            padding: 1rem;
        }

        .card-title {
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-label {
            font-weight: 500;
            color: #2c3e50;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control, .form-select {
            border-radius: 8px;
            border: 1px solid rgba(0,0,0,0.1);
            padding: 0.75rem 1rem;
            transition: var(--transition);
            font-size: 0.875rem;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
        }

        /* Desktop Table */
        .desktop-table {
            display: none;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        /* Mobile Cards */
        .mobile-card {
            background: white;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow);
        }

        .mobile-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }

        .mobile-card-title {
            font-weight: 600;
            color: var(--primary-dark);
            margin: 0;
            font-size: 0.875rem;
        }

        .mobile-card-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            gap: 1rem;
        }

        .mobile-card-label {
            color: #6c757d;
            font-size: 0.75rem;
            font-weight: 500;
            flex-shrink: 0;
            width: 100px;
        }

        .mobile-card-value {
            font-size: 0.875rem;
            text-align: right;
            word-break: break-word;
        }

        .mobile-card-actions {
            display: grid;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
        }

        .file-link {
            color: var(--primary-color);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.875rem;
        }

        .file-link:hover {
            color: var(--primary-dark);
            text-decoration: none;
        }

        .payment-due {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 500;
            background-color: var(--danger-bg);
            color: var(--danger-color);
            white-space: nowrap;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control, .form-select {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .desktop-table {
                display: block;
            }

            .mobile-view {
                display: none;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .desktop-table {
                display: none;
            }

            .mobile-view {
                display: block;
            }

            .filter-form .row {
                row-gap: 1rem;
            }

            .btn-group {
                display: grid;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-truck"></i>
                Delivered Orders
            </h1>
            <p class="page-subtitle">Filter and view details of delivered orders below.</p>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-funnel"></i>
                    Filter Orders
                </h2>
            </div>
            <div class="card-body">
                <form action="/orders/delivered" method="GET" class="filter-form">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="startDate" class="form-label">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startDate %>">
                        </div>
                        <div class="col-md-4">
                            <label for="endDate" class="form-label">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endDate %>">
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i>
                                Apply Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-list-check"></i>
                    Delivered Orders List
                </h2>
            </div>
            <div class="card-body">
                <!-- Desktop View -->
                <div class="table-responsive desktop-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>SO Number</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Products</th>
                                <th>PO File</th>
                                <% if (userRole === 'Finance') { %>
                                    <th>Payment Type</th>
                                    <th>Payment Due</th>
                                <% } %>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td><%= order.sonumber %></td>
                                        <td><%= order.customerName %></td>
                                        <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
                                        <td>
                                            <% order.products.forEach((product, index) => { %>
                                                <%= product.name %> (<%= product.quantity %> <%= product.satuan %>)<% if (index < order.products.length - 1) { %>, <% } %>
                                            <% }) %>
                                        </td>
                                        <td>
                                            <% if (order.po) { %>
                                                <a href="/uploads/<%= order.po %>" target="_blank" class="file-link">
                                                    <i class="bi bi-file-pdf"></i>
                                                    Download PDF
                                                </a>
                                            <% } else { %>
                                                <span class="text-muted">No PO uploaded</span>
                                            <% } %>
                                        </td>
                                        <% if (userRole === 'Finance') { %>
                                            <td><%= order.paymentType %></td>
                                            <td>
                                                <%= order.paymentDueDate ? new Date(order.paymentDueDate).toISOString().split('T')[0] : 'N/A' %>
                                                <% if (order.paymentDueDate && new Date() >= new Date(order.paymentDueDate)) { %>
                                                    <span class="payment-due">
                                                        <i class="bi bi-exclamation-circle"></i>
                                                        Payment Due
                                                    </span>
                                                <% } %>
                                            </td>
                                        <% } %>
                                        <td>
                                            <a href="/orders/<%= order.id %>" class="btn btn-primary btn-sm">
                                                <i class="bi bi-eye"></i>
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="<%= userRole === 'Finance' ? 8 : 6 %>" class="text-center">No delivered orders found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View -->
                <div class="mobile-view">
                    <% if (orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <div class="mobile-card fade-in">
                                <div class="mobile-card-header">
                                    <h3 class="mobile-card-title">#<%= order.id %></h3>
                                    <% if (userRole === 'Finance' && order.paymentDueDate && new Date() >= new Date(order.paymentDueDate)) { %>
                                        <span class="payment-due">
                                            <i class="bi bi-exclamation-circle"></i>
                                            Payment Due
                                        </span>
                                    <% } %>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Customer</span>
                                    <span class="mobile-card-value"><%= order.customerName %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Date</span>
                                    <span class="mobile-card-value"><%= new Date(order.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Products</span>
                                    <span class="mobile-card-value">
                                        <% order.products.forEach((product, index) => { %>
                                            <%= product.name %> (<%= product.quantity %> <%= product.satuan %>)<% if (index < order.products.length - 1) { %>, <% } %>
                                        <% }) %>
                                    </span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">PO File</span>
                                    <span class="mobile-card-value">
                                        <% if (order.po) { %>
                                            <a href="/uploads/<%= order.po %>" target="_blank" class="file-link">
                                                <i class="bi bi-file-pdf"></i>
                                                Download PDF
                                            </a>
                                        <% } else { %>
                                            <span class="text-muted">No PO uploaded</span>
                                        <% } %>
                                    </span>
                                </div>
                                <% if (userRole === 'Finance') { %>
                                    <div class="mobile-card-row">
                                        <span class="mobile-card-label">Payment Type</span>
                                        <span class="mobile-card-value"><%= order.paymentType %></span>
                                    </div>
                                    <div class="mobile-card-row">
                                        <span class="mobile-card-label">Payment Due</span>
                                        <span class="mobile-card-value">
                                            <%= order.paymentDueDate ? new Date(order.paymentDueDate).toISOString().split('T')[0] : 'N/A' %>
                                        </span>
                                    </div>
                                <% } %>
                                <div class="mobile-card-actions">
                                    <a href="/orders/<%= order.id %>" class="btn btn-primary">
                                        <i class="bi bi-eye"></i>
                                        View Details
                                    </a>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No delivered orders found
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <% if (userRole === 'Marketing' || userRole === 'PPIC') { %>
            <div class="btn-group">
                <a href="/dashboard/<%= userRole.toLowerCase() %>" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
