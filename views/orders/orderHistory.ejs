<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Selling History' }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }
        .stagger > *:nth-child(3) { animation-delay: 0.19s; }
        .stagger > *:nth-child(4) { animation-delay: 0.26s; }
        .stat-sub { display: block; font-size: 0.76rem; color: var(--mib-text-muted); margin-top: 0.45rem; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/finance/orderHistory' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const unpaidList = (typeof topOrders !== 'undefined' && topOrders) ? topOrders : [];
        const paidList   = (typeof otherOrders !== 'undefined' && otherOrders) ? otherOrders : [];
        const role       = (typeof userRole !== 'undefined') ? userRole : '';
        const startVal   = (typeof startDate !== 'undefined' && startDate) ? startDate : '';
        const endVal     = (typeof endDate !== 'undefined' && endDate) ? endDate : '';
        const sortVal    = (typeof sortOrder !== 'undefined' && sortOrder) ? sortOrder : 'desc';

        /* status badge helper (shared design-system mapping) */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
        const fmtDate = (d) => { try { return new Date(d).toLocaleDateString(); } catch (e) { return '-'; } };

        const dueList = unpaidList.filter(o => o.paymentDueDate && new Date(o.paymentDueDate) >= new Date());
        const totalUnpaid = unpaidList.reduce((s, o) => s + (Number(o.total) || 0), 0);
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Selling History',
              pageIcon: 'bi-cash-coin',
              pageSubtitle: 'Track unpaid, paid and upcoming payment dues across all selling orders.'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Unpaid Orders</div>
                    <div class="stat-value"><%= unpaidList.length %></div>
                    <span class="stat-sub">Payment type TOP, not yet paid</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-cash-stack"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Paid Orders</div>
                    <div class="stat-value"><%= paidList.length %></div>
                    <span class="stat-sub">Settled payments</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Upcoming Due</div>
                    <div class="stat-value"><%= dueList.length %></div>
                    <span class="stat-sub">Payment dues ahead</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-wallet2"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Outstanding Value</div>
                    <div class="stat-value" title="Rp <%= totalUnpaid.toLocaleString('id-ID') %>" style="font-size:1.5rem;">Rp <%= totalUnpaid.toLocaleString('id-ID') %></div>
                    <span class="stat-sub">Across unpaid orders</span>
                </div>
            </div>
        </div>

        <!-- Filter -->
        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-funnel"></i> Filter Orders</h2>
            </div>
            <div class="card-body">
                <form method="GET" action="/finance/orderHistory">
                    <div class="row g-3 g-md-4">
                        <div class="col-12 col-md-3">
                            <label for="startDate" class="form-label">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startVal %>">
                        </div>
                        <div class="col-12 col-md-3">
                            <label for="endDate" class="form-label">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endVal %>">
                        </div>
                        <div class="col-12 col-md-3">
                            <label for="sortOrder" class="form-label">Sort Order</label>
                            <select class="form-select" id="sortOrder" name="sortOrder">
                                <option value="asc" <%= sortVal === 'asc' ? 'selected' : '' %>>Ascending</option>
                                <option value="desc" <%= sortVal === 'desc' ? 'selected' : '' %>>Descending</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-3 d-flex align-items-md-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search"></i> Apply Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Unpaid Payment -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-clock-history"></i> Unpaid Payment</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th>Payment Type</th>
                            <th>Payment Due</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (unpaidList.length > 0) { %>
                            <% unpaidList.forEach(order => { %>
                                <tr>
                                    <td data-label="SO Number"><span class="cell-strong">#<%= order.sonumber %></span></td>
                                    <td data-label="Customer"><%= order.customerName %></td>
                                    <td data-label="Date"><%= fmtDate(order.createdAt) %></td>
                                    <td data-label="Amount" class="text-end num">Rp <%= (Number(order.total) || 0).toLocaleString('id-ID') %></td>
                                    <td data-label="Payment Type"><%= order.paymentType %></td>
                                    <td data-label="Payment Due"><%= order.paymentDueDate ? fmtDate(order.paymentDueDate) : '-' %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></td>
                                    <td data-label="Actions" class="text-end">
                                        <% if (!order.isPaid && role === 'Finance') { %>
                                            <form action="/finance/markOrderPaid/<%= order.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-circle"></i> Paid
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <span class="text-muted-2">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="8">
                                    <div class="empty-state"><i class="bi bi-inbox"></i><h4>No unpaid orders</h4><p>No orders with payment type TOP found.</p></div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Paid Payment -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-cash"></i> Paid Payment</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th>Payment Type</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (paidList.length > 0) { %>
                            <% paidList.forEach(order => { %>
                                <tr>
                                    <td data-label="SO Number"><span class="cell-strong">#<%= order.sonumber %></span></td>
                                    <td data-label="Customer"><%= order.customerName %></td>
                                    <td data-label="Date"><%= fmtDate(order.createdAt) %></td>
                                    <td data-label="Amount" class="text-end num">Rp <%= (Number(order.total) || 0).toLocaleString('id-ID') %></td>
                                    <td data-label="Payment Type"><%= order.paymentType %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="6">
                                    <div class="empty-state"><i class="bi bi-inbox"></i><h4>No paid orders</h4><p>No orders with payment type other than TOP found.</p></div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Payment Due -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-calendar-check"></i> Payment Due</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                            <th>Payment Type</th>
                            <th>Payment Due</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (dueList.length > 0) { %>
                            <% dueList.forEach(order => { %>
                                <tr>
                                    <td data-label="SO Number"><span class="cell-strong">#<%= order.sonumber %></span></td>
                                    <td data-label="Customer"><%= order.customerName %></td>
                                    <td data-label="Date"><%= fmtDate(order.createdAt) %></td>
                                    <td data-label="Amount" class="text-end num">Rp <%= (Number(order.total) || 0).toLocaleString('id-ID') %></td>
                                    <td data-label="Payment Type"><%= order.paymentType %></td>
                                    <td data-label="Payment Due"><%= fmtDate(order.paymentDueDate) %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="7">
                                    <div class="empty-state"><i class="bi bi-inbox"></i><h4>No upcoming dues</h4><p>No upcoming payment dues found.</p></div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
