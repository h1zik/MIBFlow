<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Order Details' }) %>
    <style>
        /* Vertical timeline (page-specific component) */
        .timeline { position: relative; margin: 1rem auto 0; padding: 10px 0; }
        .timeline::before {
            content: ''; position: absolute; width: 3px; background: var(--mib-border);
            top: 0; bottom: 0; left: 50%; margin-left: -1.5px; border-radius: 3px;
        }
        .timeline-item { position: relative; margin: 1.75rem 0; }
        .timeline-item::before {
            content: ''; position: absolute; width: 18px; height: 18px; left: calc(50% - 9px);
            background: #fff; border: 3px solid var(--mib-border-strong); border-radius: 50%; z-index: 1;
        }
        .timeline-item.active::before { border-color: var(--mib-primary); box-shadow: 0 0 0 5px var(--mib-primary-soft); }
        .timeline-item.completed::before { background: var(--mib-primary); border-color: var(--mib-primary); }
        .timeline-content {
            position: relative; width: 44%; padding: 1rem 1.15rem; background: var(--mib-surface);
            border: 1px solid var(--mib-border); border-radius: var(--mib-radius-sm); box-shadow: var(--mib-shadow);
        }
        .timeline-item:nth-child(odd) .timeline-content { margin-left: auto; }
        .timeline-icon { color: var(--mib-primary); font-size: 1.05rem; margin-bottom: 0.25rem; }
        .timeline-title { font-weight: 650; font-size: 0.92rem; margin: 0 0 0.15rem; color: var(--mib-text); }
        .timeline-description { color: var(--mib-text-muted); font-size: 0.82rem; margin: 0; }
        .timeline-date { color: var(--mib-text-faint); font-size: 0.78rem; margin-top: 0.35rem; }
        .total-line { display: flex; justify-content: space-between; padding: 0.55rem 0; border-bottom: 1px solid var(--mib-border); }
        .total-line:last-child { border-bottom: none; font-weight: 700; font-size: 1.1rem; color: var(--mib-text); }
        .product-row { border-left: 3px solid var(--mib-primary); padding: 1rem 1.15rem; background: var(--mib-surface-2); border-radius: var(--mib-radius-sm); margin-bottom: 0.85rem; }
        @media (max-width: 768px) {
            .timeline::before { left: 19px; }
            .timeline-item::before { left: 10px; }
            .timeline-content { width: calc(100% - 48px); margin-left: 48px !important; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/orders/details' }) %>

    <div class="content content-wide">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <ul class="mib-breadcrumb"><li><a href="javascript:history.back()">Orders</a></li><li>Order #<%= order.id %></li></ul>
                <h1 class="page-title"><i class="bi bi-receipt"></i> Order #<%= order.id %>
                    <span class="status-badge status-<%= order.status.toLowerCase().replace(/\s+/g,'-') %> ms-2"><%= order.status %></span>
                </h1>
            </div>
            <div class="page-actions">
                <a href="javascript:history.back()" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back</a>
                <a href="/orders/print/<%= order.id %>" class="btn btn-primary"><i class="bi bi-printer"></i> Print Invoice</a>
            </div>
        </div>

        <!-- Timeline -->
        <div class="panel">
            <h3 class="form-section-title mb-0"><i class="bi bi-signpost-2 me-1"></i> Order Progress</h3>
            <div class="timeline">
                <% const done = (statuses) => statuses.includes(order.status) ? 'completed' : ''; %>
                <div class="timeline-item <%= ['Pending','On Production','Production Completed','Approved','Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-file-earmark-text"></i></div><h6 class="timeline-title">Order Created</h6><p class="timeline-description">Order has been submitted</p><div class="timeline-date"><%= new Date(order.createdAt).toLocaleDateString() %></div></div>
                </div>
                <div class="timeline-item <%= ['On Production','Production Completed','Approved','Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'Pending' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-clock-history"></i></div><h6 class="timeline-title">Pending Review</h6><p class="timeline-description">Order is being reviewed</p><div class="timeline-date">Awaiting production approval</div></div>
                </div>
                <div class="timeline-item <%= ['On Production','Production Completed','Approved','Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.RawMaterialRequests && order.RawMaterialRequests.length > 0 ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-boxes"></i></div><h6 class="timeline-title">Raw Material Requested</h6><p class="timeline-description">Raw materials have been requested</p><div class="timeline-date">
                        <% if (order.RawMaterialRequests && order.RawMaterialRequests.length > 0) { %>
                            <% const allVendorsCompleted = order.RawMaterialRequests.every(req => req.RawMaterialRequestVendors && req.RawMaterialRequestVendors.every(v => v.status === 'Completed' || v.status === 'Quarantined')); %>
                            <%= allVendorsCompleted ? 'All materials received' : 'Materials in process' %>
                        <% } else { %>Awaiting material requests<% } %>
                    </div></div>
                </div>
                <div class="timeline-item <%= ['Production Completed','Approved','Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'On Production' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-gear-wide-connected"></i></div><h6 class="timeline-title">On Production</h6><p class="timeline-description">Products are being manufactured</p><div class="timeline-date">Manufacturing in progress</div></div>
                </div>
                <div class="timeline-item <%= ['Approved','Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'Production Completed' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-check-circle"></i></div><h6 class="timeline-title">Production Completed</h6><p class="timeline-description">Manufacturing process finished</p><div class="timeline-date">Ready for approval</div></div>
                </div>
                <div class="timeline-item <%= ['Paid','Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'Approved' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-hand-thumbs-up"></i></div><h6 class="timeline-title">Approved</h6><p class="timeline-description">Order has been approved</p><div class="timeline-date">Awaiting payment</div></div>
                </div>
                <div class="timeline-item <%= ['Ready to Deliver','On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'Paid' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-cash-stack"></i></div><h6 class="timeline-title">Paid</h6><p class="timeline-description">Payment received</p><div class="timeline-date">Processing for delivery</div></div>
                </div>
                <div class="timeline-item <%= ['On Delivery','Delivered'].includes(order.status) ? 'completed' : order.status === 'Ready to Deliver' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-box-seam"></i></div><h6 class="timeline-title">Ready to Deliver</h6><p class="timeline-description">Order packed and ready</p><div class="timeline-date">Preparing for shipment</div></div>
                </div>
                <div class="timeline-item <%= ['Delivered'].includes(order.status) ? 'completed' : order.status === 'On Delivery' ? 'active' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-truck"></i></div><h6 class="timeline-title">On Delivery</h6><p class="timeline-description">Order is in transit</p><div class="timeline-date">Out for delivery</div></div>
                </div>
                <div class="timeline-item <%= order.status === 'Delivered' ? 'completed' : '' %>">
                    <div class="timeline-content"><div class="timeline-icon"><i class="bi bi-flag"></i></div><h6 class="timeline-title">Delivered</h6><p class="timeline-description">Order successfully delivered</p><div class="timeline-date">Order completed</div></div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card h-100"><div class="card-header"><h2 class="card-title"><i class="bi bi-person"></i> Customer Information</h2></div>
                    <div class="card-body">
                        <div class="mb-2"><span class="cell-sub">Name</span><div class="cell-strong"><%= order.Customer.name %></div></div>
                        <div class="mb-2"><span class="cell-sub">Company</span><div><%= order.Customer.perusahaan %></div></div>
                        <div class="mb-2"><span class="cell-sub">Contact Person</span><div><%= order.Customer.cp %></div></div>
                        <div class="mb-2"><span class="cell-sub">Phone</span><div><%= order.Customer.phone %></div></div>
                        <div class="mb-2"><span class="cell-sub">Email</span><div><%= order.Customer.email %></div></div>
                        <div><span class="cell-sub">Address</span><div><%= order.Customer.alamat %></div></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100"><div class="card-header"><h2 class="card-title"><i class="bi bi-file-earmark-text"></i> Order Information</h2></div>
                    <div class="card-body">
                        <div class="mb-2"><span class="cell-sub">PO Number</span><div class="cell-strong"><%= order.po %></div></div>
                        <div class="mb-2"><span class="cell-sub">Payment Type</span><div><%= order.paymentType %></div></div>
                        <div class="mb-2"><span class="cell-sub">Tax</span><div><%= order.tax ? 'Yes' : 'No' %></div></div>
                        <% if (order.deadline) { %><div class="mb-2"><span class="cell-sub">Deadline</span><div class="<%= new Date(order.deadline) < new Date() ? 'text-danger fw-medium' : '' %>"><%= new Date(order.deadline).toLocaleDateString() %></div></div><% } %>
                        <% if (order.notes) { %><div><span class="cell-sub">Notes</span><div><%= order.notes %></div></div><% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3"><div class="card-header"><h2 class="card-title"><i class="bi bi-box-seam"></i> Products</h2></div>
            <div class="card-body">
                <% groupedItems.forEach(item => { %>
                    <div class="product-row">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                            <div>
                                <h5 class="mb-1 cell-strong"><%= item.product %></h5>
                                <div class="cell-sub">Unit Price: Rp <%= item.unitPrice.toLocaleString() %> / <%= item.satuan %></div>
                                <div>Total Quantity: <%= item.totalQuantity.toLocaleString() %> <%= item.satuan %></div>
                                <div class="cell-sub">Product Total: Rp <%= (item.totalPrice - item.packagingTotal).toLocaleString() %> &middot; Packaging: Rp <%= item.packagingTotal.toLocaleString() %></div>
                            </div>
                            <div class="text-end"><div class="h5 mb-0">Rp <%= item.totalPrice.toLocaleString() %></div></div>
                        </div>
                        <div class="mt-2 ps-2 border-start cell-sub">
                            <% item.packagingDetails.forEach(pkg => { %><div><%= pkg.packagingName %> (<%= pkg.volume %>L) x <%= pkg.unit %> units</div><% }) %>
                        </div>
                    </div>
                <% }) %>

                <h3 class="form-section-title mt-4"><i class="bi bi-box2 me-1"></i> Consumables Used</h3>
                <div class="row">
                    <% const consumables = [
                        { name: 'Pallet', flag: order.pallet }, { name: 'Sticker', flag: order.sticker },
                        { name: 'Wrap', flag: order.wrap }, { name: 'Handling', flag: order.handling },
                        { name: 'Logistic', flag: order.logistic }, { name: 'Triplek', flag: order.triplek },
                        { name: 'Peti', flag: order.peti }, { name: 'Kabel Ties', flag: order.kabelties }
                    ] %>
                    <% consumables.forEach(consumable => { %>
                        <div class="col-md-3 col-6 mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi <%= consumable.flag ? 'bi-check-circle-fill text-success' : 'bi-x-circle text-muted-2' %>"></i>
                                <span><%= consumable.name %></span>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="form-section mt-4 mb-0">
                    <div class="total-line"><span>Products Subtotal</span><span>Rp <%= Object.values(groupedItems).reduce((sum, item) => sum + item.totalPrice - item.packagingTotal, 0).toLocaleString() %></span></div>
                    <div class="total-line"><span>Packaging Subtotal</span><span>Rp <%= Object.values(groupedItems).reduce((sum, item) => sum + item.packagingTotal, 0).toLocaleString() %></span></div>
                    <% if (order.pallet || order.sticker || order.wrap || order.handling || order.logistic || order.triplek || order.peti || order.kabelties) { %>
                    <div class="total-line"><span>Consumables</span><span>Rp <%= consumablesTotal.toLocaleString() %></span></div>
                    <% } %>
                    <div class="total-line"><span>Subtotal</span><span>Rp <%= order.total.toLocaleString() %></span></div>
                    <% if (order.tax) { %><div class="total-line"><span>Tax (11%)</span><span>Rp <%= (order.total * 0.11).toLocaleString() %></span></div><% } %>
                    <div class="total-line"><span>Total</span><span>Rp <%= (order.tax ? order.total * 1.11 : order.total).toLocaleString() %></span></div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
