<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Add Packaging' }) %>
    <style>
        /* Add Packaging — page-scoped flourishes on the shared design system */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .form-actions { display: flex; flex-wrap: wrap; gap: 0.6rem; }
        @media (max-width: 575.98px) { .form-actions { display: grid; } }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/packaging/add' }) %>

    <%
        /* Defensive locals — only some renders pass these */
        const successMsg = (typeof successMessage !== 'undefined' && successMessage) ? successMessage : null;
        const errorMsg   = (typeof error !== 'undefined' && error) ? error : null;
        const fd         = (typeof formData !== 'undefined' && formData) ? formData : {};
    %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Add Packaging',
              pageIcon: 'bi-plus-circle',
              pageSubtitle: 'Fill in the details below to add a new packaging.',
              actionsHtml: '<a href="/packaging/list" class="btn btn-light"><i class="bi bi-boxes"></i> Packaging List</a>'
            }) %>

        <% if (successMsg) { %>
            <div class="mib-flash mib-flash-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><%= successMsg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <% if (errorMsg) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= errorMsg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <form action="/packaging/add" method="POST" class="fade-in">
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-box-seam"></i> Packaging Details</h2>
                <p class="form-section-desc">Enter the packaging name, its volume in litres and the quantity currently in stock.</p>

                <div class="row g-3">
                    <div class="col-12">
                        <label for="name" class="form-label">Packaging Name</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="e.g. Jerry Can 5L" value="<%= fd.name || '' %>" required>
                    </div>
                    <div class="col-md-6">
                        <label for="volume" class="form-label">Volume (L)</label>
                        <input type="number" class="form-control" id="volume" name="volume" placeholder="e.g. 5" value="<%= fd.volume || '' %>" required min="0" step="0.1">
                    </div>
                    <div class="col-md-6">
                        <label for="stock" class="form-label">Stock</label>
                        <input type="number" class="form-control" id="stock" name="stock" placeholder="e.g. 100" value="<%= fd.stock || '' %>" required min="0">
                    </div>
                    <div class="col-12">
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-lg"></i> Add Packaging
                            </button>
                            <a href="/dashboard/raw-material-warehouse" class="btn btn-light">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
