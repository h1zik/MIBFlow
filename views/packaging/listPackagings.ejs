<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Packaging List' }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .vendor-price-item { font-size: 0.82rem; line-height: 1.4; }
        .vendor-price-item + .vendor-price-item { margin-top: 0.15rem; }
        .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/packaging/list' }) %>

    <%
        const list = (typeof packagings !== 'undefined' && packagings) ? packagings : [];
        const showVendorCol = userRole !== 'Raw Material Warehouse';
        const showActions = (userRole === 'Raw Material Warehouse' || userRole === 'Purchase');

        const inStockCount = list.filter(p => p.stock > 0).length;
        const outOfStockCount = list.filter(p => !(p.stock > 0)).length;

        // base columns: ID, Name, Volume, Stock (4)
        let colCount = 4;
        if (showVendorCol) colCount += 1;
        if (showActions) colCount += 1;
    %>

    <div class="content content-wide">

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= error %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (typeof successMessage !== 'undefined' && successMessage) { %>
            <div class="mib-flash mib-flash-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><%= successMessage %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-box-seam"></i> Packaging List</h1>
                <p class="page-subtitle">All packaging types and their available stock</p>
            </div>
            <% if (userRole === 'Raw Material Warehouse') { %>
                <div class="page-actions">
                    <a href="/packaging/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add Packaging</a>
                </div>
            <% } %>
        </div>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Packagings</div>
                    <div class="stat-value"><%= list.length %></div>
                    <span class="stat-sub">Distinct packaging types</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">In Stock</div>
                    <div class="stat-value"><%= inStockCount %></div>
                    <span class="stat-sub">Available now</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-exclamation-octagon"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Out of Stock</div>
                    <div class="stat-value"><%= outOfStockCount %></div>
                    <span class="stat-sub">Needs restocking</span>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control search-input" placeholder="Search packagings…" autocomplete="off">
            </div>
        </div>

        <!-- Table -->
        <div class="table-card fade-in">
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th class="text-end">Volume (L)</th>
                            <th>Stock</th>
                            <% if (showVendorCol) { %>
                                <th>Vendor Prices</th>
                            <% } %>
                            <% if (showActions) { %>
                                <th class="text-end">Actions</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (list.length > 0) { %>
                            <% list.forEach(packaging => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= packaging.id %></span></td>
                                    <td data-label="Name"><span class="cell-strong"><%= packaging.name %></span></td>
                                    <td data-label="Volume (L)" class="text-end num"><%= packaging.volume %></td>
                                    <td data-label="Stock">
                                        <span class="status-badge <%= packaging.stock > 0 ? 'status-completed' : 'status-declined' %>">
                                            <%= packaging.stock %>
                                        </span>
                                    </td>
                                    <% if (showVendorCol) { %>
                                        <td data-label="Vendor Prices">
                                            <% if (packaging.Vendors && packaging.Vendors.length > 0) { %>
                                                <% packaging.Vendors.forEach(vendor => { %>
                                                    <div class="vendor-price-item">
                                                        <strong><%= vendor.name %>:</strong>
                                                        <% if (vendor.vendorPrice) { %>
                                                            Rp <%= parseFloat(vendor.vendorPrice).toLocaleString('id-ID') %>
                                                        <% } else if (vendor.PackagingVendor && vendor.PackagingVendor.price) { %>
                                                            Rp <%= parseFloat(vendor.PackagingVendor.price).toLocaleString('id-ID') %>
                                                        <% } else { %>
                                                            <span class="text-muted-2">N/A</span>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            <% } else { %>
                                                <span class="text-muted-2">No vendors assigned</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                    <% if (showActions) { %>
                                        <td data-label="Actions" class="text-end">
                                            <div class="action-buttons justify-content-end">
                                                <% if (userRole === 'Purchase') { %>
                                                    <a href="/packaging/assignVendor/<%= packaging.id %>" class="btn btn-sm btn-soft">
                                                        <i class="bi bi-building"></i>
                                                        Assign Vendor
                                                    </a>
                                                <% } %>
                                                <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                                    <a href="/packaging/edit/<%= packaging.id %>" class="btn btn-sm btn-primary">
                                                        <i class="bi bi-pencil"></i>
                                                        Edit
                                                    </a>
                                                <% } %>
                                                <% if (userRole === 'Raw Material Warehouse') { %>
                                                    <form action="/packaging/delete/<%= packaging.id %>" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this packaging?')">
                                                            <i class="bi bi-trash"></i>
                                                            Delete
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="<%= colCount %>">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No packagings found</h4>
                                        <p>Packaging types will appear here once added.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle search
            const searchInput = document.querySelector('.search-input');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const searchTerm = this.value.toLowerCase();
                    const rows = document.querySelectorAll('tbody tr');

                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        row.style.display = text.includes(searchTerm) ? '' : 'none';
                    });
                });
            }
        });
    </script>
</body>
</html>
