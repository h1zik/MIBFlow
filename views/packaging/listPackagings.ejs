<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Packaging List - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-dark: #1b5e20;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: all 0.3s ease;
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            padding: 1rem;
        }

        .card-title {
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .table-wrapper {
            margin: -1rem;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 0.75rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 0.75rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            font-size: 0.875rem;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
        }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }

        .badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
            border-radius: 50px;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Mobile-first styles */
        .mobile-card {
            display: block;
            margin-bottom: 1rem;
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .mobile-card-header {
            background-color: var(--background-light);
            padding: 0.75rem;
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }

        .mobile-card-body {
            padding: 0.75rem;
        }

        .mobile-card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .mobile-card-row:last-child {
            border-bottom: none;
        }

        .mobile-card-label {
            color: #6c757d;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .mobile-card-value {
            font-size: 0.875rem;
            font-weight: 500;
        }

        .mobile-actions {
            display: flex;
            gap: 0.5rem;
            justify-content: flex-end;
            margin-top: 0.75rem;
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .table-wrapper {
                margin: 0;
            }

            .mobile-view {
                display: none;
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .desktop-view {
                display: none;
            }

            .page-header {
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <% if (successMessage) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <%= successMessage %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-box-seam"></i>
                Packaging List
            </h1>
            <% if (userRole === 'Raw Material Warehouse') { %>
                <a href="/packaging/add" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add Packaging
                </a>
            <% } %>
        </div>

        <!-- Desktop View -->
        <div class="card fade-in desktop-view">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-list-check"></i>
                    All Packagings
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Volume (L)</th>
                                <th>Stock</th>
                                <% if (userRole !== 'Raw Material Warehouse') { %>
                                    <th>Vendor Prices</th>
                                <% } %>
                                <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                    <th>Actions</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (packagings && packagings.length > 0) { %>
                                <% packagings.forEach(packaging => { %>
                                    <tr>
                                        <td>#<%= packaging.id %></td>
                                        <td><%= packaging.name %></td>
                                        <td><%= packaging.volume %></td>
                                        <td>
                                            <span class="badge bg-<%= packaging.stock > 0 ? 'success' : 'danger' %>">
                                                <%= packaging.stock %>
                                            </span>
                                        </td>
                                        <% if (userRole !== 'Raw Material Warehouse') { %>
                                            <td>
                                                <% if (packaging.Vendors && packaging.Vendors.length > 0) { %>
                                                    <% packaging.Vendors.forEach(vendor => { %>
                                                        <div class="vendor-price-item">
                                                            <strong><%= vendor.name %>:</strong> 
                                                            <% if (vendor.vendorPrice) { %>
                                                                Rp <%= parseFloat(vendor.vendorPrice).toLocaleString('id-ID') %>
                                                            <% } else if (vendor.PackagingVendor && vendor.PackagingVendor.price) { %>
                                                                Rp <%= parseFloat(vendor.PackagingVendor.price).toLocaleString('id-ID') %>
                                                            <% } else { %>
                                                                <span class="text-muted">N/A</span>
                                                            <% } %>
                                                        </div>
                                                    <% }) %>
                                                <% } else { %>
                                                    <span class="text-muted">No vendors assigned</span>
                                                <% } %>
                                            </td>
                                        <% } %>
                                        <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                            <td>
                                                <div class="d-flex gap-2 justify-content-center">
                                                    <% if (userRole === 'Purchase') { %>
                                                        <a href="/packaging/assignVendor/<%= packaging.id %>" class="btn btn-primary btn-sm">
                                                            <i class="bi bi-building"></i>
                                                            Assign Vendor
                                                        </a>
                                                    <% } %>
                                                    <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                                        <a href="/packaging/edit/<%= packaging.id %>" class="btn btn-primary btn-sm">
                                                            <i class="bi bi-pencil"></i>
                                                            Edit
                                                        </a>
                                                    <% } %>
                                                    <% if (userRole === 'Raw Material Warehouse') { %>
                                                        <form action="/packaging/delete/<%= packaging.id %>" method="POST" class="d-inline">
                                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this packaging?')">
                                                                <i class="bi bi-trash"></i>
                                                                Delete
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="<%= userRole === 'Raw Material Warehouse' ? 5 : 6 %>" class="text-center">
                                        No packagings found.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Mobile View -->
        <div class="mobile-view fade-in">
            <% if (packagings && packagings.length > 0) { %>
                <% packagings.forEach(packaging => { %>
                    <div class="mobile-card">
                        <div class="mobile-card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h3 class="card-title mb-0">#<%= packaging.id %></h3>
                                <span class="badge bg-<%= packaging.stock > 0 ? 'success' : 'danger' %>">
                                    Stock: <%= packaging.stock %>
                                </span>
                            </div>
                        </div>
                        <div class="mobile-card-body">
                            <div class="mobile-card-row">
                                <span class="mobile-card-label">Name</span>
                                <span class="mobile-card-value"><%= packaging.name %></span>
                            </div>
                            <div class="mobile-card-row">
                                <span class="mobile-card-label">Volume</span>
                                <span class="mobile-card-value"><%= packaging.volume %> L</span>
                            </div>
                            <% if (userRole !== 'Raw Material Warehouse') { %>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Vendor Prices</span>
                                    <span class="mobile-card-value">
                                        <% if (packaging.Vendors && packaging.Vendors.length > 0) { %>
                                            <% packaging.Vendors.forEach(vendor => { %>
                                                <div class="vendor-price-item">
                                                    <strong><%= vendor.name %>:</strong> 
                                                    <% if (vendor.vendorPrice) { %>
                                                        Rp <%= parseFloat(vendor.vendorPrice).toLocaleString('id-ID') %>
                                                    <% } else if (vendor.PackagingVendor && vendor.PackagingVendor.price) { %>
                                                        Rp <%= parseFloat(vendor.PackagingVendor.price).toLocaleString('id-ID') %>
                                                    <% } else { %>
                                                        <span class="text-muted">N/A</span>
                                                    <% } %>
                                                </div>
                                            <% }) %>
                                        <% } else { %>
                                            <span class="text-muted">No vendors assigned</span>
                                        <% } %>
                                    </span>
                                </div>
                            <% } %>
                            <% if (userRole === 'Raw Material Warehouse' || userRole === 'Purchase') { %>
                                <div class="mobile-actions">
                                    <a href="/packaging/assignVendor/<%= packaging.id %>" class="btn btn-primary btn-sm">
                                        <i class="bi bi-building"></i>
                                        Assign Vendor
                                    </a>
                                    <% if (userRole === 'Raw Material Warehouse') { %>
                                        <a href="/packaging/edit/<%= packaging.id %>" class="btn btn-primary btn-sm">
                                            <i class="bi bi-pencil"></i>
                                            Edit
                                        </a>
                                        <form action="/packaging/delete/<%= packaging.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this packaging?')">
                                                <i class="bi bi-trash"></i>
                                                Delete
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="card">
                    <div class="card-body text-center">
                        No packagings found.
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
