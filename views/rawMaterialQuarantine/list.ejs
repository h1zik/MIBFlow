<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Quarantine List' }) %>
    <style>
        /* ============================================================
           Quarantined Raw Materials — page-scoped flourishes
           Built on the shared mibflow.css design system.
           ============================================================ */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(185px, 1fr)); }
        .qr-toolbar { margin-bottom: 1.1rem; }
        .table thead th { background: var(--mib-surface-2); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/raw-material-quarantine/list' }) %>

    <%
        /* ---- Defensive normalisation (guard optional locals) ---- */
        const qList = (typeof quarantinedRawMaterials !== 'undefined' && quarantinedRawMaterials) ? quarantinedRawMaterials : [];

        /* status badge helper (spec) + quarantine-specific extras */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => {
            const k = String(s || '').toLowerCase().replace(/\s+/g, '-');
            if (k === 'quarantined') return 'status-declined';
            if (k === 'destroyed')   return 'status-cancelled';
            return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral');
        };
        const qb = (s) => s === 'Pass' ? 'status-completed' : (s === 'Fail' ? 'status-declined' : 'status-pending');

        const quarantinedCount = qList.filter(m => m.status === 'Quarantined').length;
        const failedCount       = qList.filter(m => m.qcStatus === 'Fail').length;
        const fmtDate = (d) => d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—';
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Quarantined Raw Materials',
              pageIcon: 'bi-exclamation-triangle',
              pageSubtitle: 'Review, destroy or reuse raw material that failed quality control'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">In Quarantine</div>
                    <div class="stat-value"><%= quarantinedCount %></div>
                    <span class="stat-sub">Awaiting a decision</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-x-octagon"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Failed QC</div>
                    <div class="stat-value"><%= failedCount %></div>
                    <span class="stat-sub">Rejected by quality control</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-clipboard2-data"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Records</div>
                    <div class="stat-value"><%= qList.length %></div>
                    <span class="stat-sub">All quarantine history</span>
                </div>
            </div>
        </div>

        <!-- Quarantined Raw Materials table -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-box-seam"></i> Quarantine Records</h2>
                <div class="toolbar mb-0 qr-toolbar">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" class="form-control form-control-sm" id="rawMaterialSearch" placeholder="Search raw materials…" autocomplete="off">
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="rawMaterialsTable">
                    <thead>
                        <tr>
                            <th>Raw Material</th>
                            <th>Vendor</th>
                            <th>Quantity</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (qList.length > 0) { %>
                            <% qList.forEach(material => { %>
                                <tr>
                                    <td data-label="Raw Material">
                                        <span class="cell-strong"><%= material.RawMaterialRequest && material.RawMaterialRequest.RawMaterial ? material.RawMaterialRequest.RawMaterial.name : 'N/A' %></span>
                                        <div class="cell-sub">#<%= material.id %></div>
                                    </td>
                                    <td data-label="Vendor"><%= material.Vendor ? material.Vendor.name : 'N/A' %></td>
                                    <td data-label="Quantity">
                                        <span class="cell-strong"><%= material.rejectQuantity > 0 ? material.rejectQuantity : material.splitQuantity %> Kg</span>
                                        <% if (material.rejectQuantity > 0) { %>
                                            <div class="cell-sub text-danger">Rejected</div>
                                        <% } %>
                                    </td>
                                    <td data-label="QC Status">
                                        <span class="status-badge <%= qb(material.qcStatus) %>"><%= material.qcStatus || 'Pending' %></span>
                                    </td>
                                    <td data-label="QC Comment"><%= material.qcComment || '—' %></td>
                                    <td data-label="Date"><%= fmtDate(material.createdAt) %></td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= sb(material.status) %>"><%= material.status %></span>
                                    </td>
                                    <td data-label="Actions" class="text-end">
                                        <% if (material.status === 'Quarantined') { %>
                                            <div class="action-buttons justify-content-end">
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="handleDestroy('<%= material.id %>')">
                                                    <i class="bi bi-trash"></i> Destroy
                                                </button>
                                                <button type="button" class="btn btn-sm btn-success" onclick="handleReuse('<%= material.id %>')">
                                                    <i class="bi bi-recycle"></i> Reuse
                                                </button>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted-2">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="8">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No quarantined raw materials</h4>
                                        <p>Raw materials that fail QC will appear here for review.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Function to handle destroy action
        async function handleDestroy(id) {
            if (confirm('Are you sure you want to destroy this raw material?')) {
                try {
                    const response = await fetch(`/raw-material-quarantine/${id}/destroy`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const data = await response.json();
                        alert(data.message || 'Error occurred while destroying material');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while processing your request');
                }
            }
        }

        // Function to handle reuse action
        async function handleReuse(id) {
            if (confirm('Are you sure you want to reuse this raw material?')) {
                try {
                    const response = await fetch(`/raw-material-quarantine/${id}/reuse`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const data = await response.json();
                        alert(data.message || 'Error occurred while reusing material');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while processing your request');
                }
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Search functionality (live-filter table rows)
            const searchInput = document.getElementById('rawMaterialSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function(e) {
                    const searchText = e.target.value.toLowerCase();
                    const table = document.getElementById('rawMaterialsTable');
                    const rows = table.querySelectorAll('tbody tr');

                    rows.forEach(function(row) {
                        if (row.classList.contains('is-empty-row')) return;
                        const cells = row.getElementsByTagName('td');
                        let found = false;
                        for (let cell of cells) {
                            if (cell.textContent.toLowerCase().includes(searchText)) {
                                found = true;
                                break;
                            }
                        }
                        row.style.display = found ? '' : 'none';
                    });
                });
            }
        });
    </script>
</body>
</html>
