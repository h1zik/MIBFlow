<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Manage Tank' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/tank/add' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Manage Tank',
              pageIcon: 'bi-water',
              pageSubtitle: 'Register a new blending tank and its capacity.',
              breadcrumb: [{ label: 'Tanks', href: '/tank/tankList' }, { label: 'Add' }],
              actionsHtml: '<a href="/tank/tankList" class="btn btn-light"><i class="bi bi-list-ul"></i> Tank List</a>'
        }) %>

        <form id="addTankForm" action="/tank/add" method="POST" class="needs-validation" novalidate>
            <div class="form-section fade-in">
                <h3 class="form-section-title"><i class="bi bi-water me-1"></i> Tank Details</h3>
                <p class="form-section-desc">Give the tank a clear name and its volume in litres.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="name" class="form-label">Tank Name</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="e.g. Tank A-01" required>
                        <div class="invalid-feedback" id="nameValidation">Please enter a tank name.</div>
                    </div>
                    <div class="col-md-6">
                        <label for="volume" class="form-label">Volume (L)</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="volume" name="volume" step="0.01" min="0" placeholder="0.00" required>
                            <span class="input-group-text">L</span>
                        </div>
                        <div class="invalid-feedback" id="volumeValidation">Please enter a valid volume.</div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/tank/tankList" class="btn btn-light"><i class="bi bi-x-lg"></i> Cancel</a>
                <button type="submit" class="btn btn-primary" id="submitBtn"><i class="bi bi-check-lg"></i> Save Tank</button>
            </div>
        </form>
    </div>

    <script>
        (function () {
            'use strict';
            const form = document.getElementById('addTankForm');
            const volumeInput = document.getElementById('volume');
            form.addEventListener('submit', function (event) {
                // Extra guard: volume must not be negative (mirrors legacy validation)
                let valid = form.checkValidity();
                if (volumeInput.value !== '' && Number(volumeInput.value) < 0) {
                    volumeInput.setCustomValidity('invalid');
                    valid = false;
                } else {
                    volumeInput.setCustomValidity('');
                }
                if (!valid) {
                    event.preventDefault();
                    event.stopPropagation();
                } else {
                    const b = document.getElementById('submitBtn');
                    if (b) b.disabled = true;
                }
                form.classList.add('was-validated');
            }, false);

            volumeInput.addEventListener('input', () => volumeInput.setCustomValidity(''));
        })();
    </script>
</body>
</html>
