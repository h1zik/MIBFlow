<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Tank List' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/tank/tankList' }) %>

    <%
        /* Defensive normalisation — page is shared across roles/routes */
        const tankList   = (typeof tanks !== 'undefined' && tanks) ? tanks : [];
        const isFinance  = (typeof userRole !== 'undefined' && userRole === 'Finance');
        const totalVol   = tankList.reduce((s, t) => s + (Number(t.volume) || 0), 0);
        const fmtNum     = (n) => Number(n || 0).toLocaleString();
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Tank List',
              pageIcon: 'bi-water',
              pageSubtitle: tankList.length + ' tank' + (tankList.length === 1 ? '' : 's') + ' registered.',
              actionsHtml: '<a href="/tank/add" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add New Tank</a>'
        }) %>

        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-water"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Tanks</div>
                    <div class="stat-value"><%= tankList.length %></div>
                    <span class="stat-sub">Registered in the system</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-droplet-half"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Capacity</div>
                    <div class="stat-value"><%= fmtNum(totalVol) %> L</div>
                    <span class="stat-sub">Combined tank volume</span>
                </div>
            </div>
        </div>

        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control" id="searchTank" placeholder="Search tanks by name..." autocomplete="off">
            </div>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <% if (tankList.length > 0) { %>
                <table class="table table-cards align-middle" id="tanksTable">
                    <thead>
                        <tr>
                            <th>Tank Name</th>
                            <th class="text-end">Volume</th>
                            <% if (isFinance) { %><th class="text-end">Price</th><% } %>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tankList.forEach(tank => { %>
                            <tr class="tank-row" data-tank-name="<%= (tank.name || '').toLowerCase() %>">
                                <td data-label="Tank Name">
                                    <span class="cell-strong"><i class="bi bi-water me-1 text-muted-2"></i><%= tank.name %></span>
                                    <div class="cell-sub">#<%= tank.id %></div>
                                </td>
                                <td data-label="Volume" class="text-end num"><%= tank.volume %> L</td>
                                <% if (isFinance) { %>
                                <td data-label="Price" class="text-end num">Rp <%= tank.price ? tank.price.toLocaleString() : '0' %></td>
                                <% } %>
                                <td data-label="Actions" class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="/tank/edit/<%= tank.id %>" class="btn btn-sm btn-soft" title="Edit Tank"><i class="bi bi-pencil"></i> Edit</a>
                                        <% if (typeof userRole !== 'undefined' && userRole === 'Production') { %>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteTank('<%= tank.id %>')" title="Delete Tank"><i class="bi bi-trash"></i></button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                        <tr class="is-empty-row" id="noResultsRow" style="display:none;">
                            <td colspan="<%= isFinance ? 4 : 3 %>">
                                <div class="empty-state"><i class="bi bi-search"></i><h4>No matching tanks</h4><p>Try a different search term.</p></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <% } else { %>
                    <div class="empty-state">
                        <i class="bi bi-water"></i>
                        <h4>No tanks yet</h4>
                        <p>Add your first tank to get started.</p>
                        <a href="/tank/add" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Add New Tank</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Search functionality — filter table rows by tank name
            const searchInput = document.getElementById('searchTank');
            const rows = Array.prototype.slice.call(document.querySelectorAll('.tank-row'));
            const noResults = document.getElementById('noResultsRow');

            if (searchInput) {
                searchInput.addEventListener('input', function (e) {
                    const term = e.target.value.toLowerCase();
                    let visible = 0;
                    rows.forEach(row => {
                        const name = row.getAttribute('data-tank-name') || '';
                        const match = name.includes(term);
                        row.style.display = match ? '' : 'none';
                        if (match) visible++;
                    });
                    if (noResults) noResults.style.display = (visible === 0 && rows.length) ? '' : 'none';
                });
            }
        });

        // Delete tank functionality (AJAX) — endpoint + JSON contract preserved
        function deleteTank(tankId) {
            if (confirm('Are you sure you want to delete this tank?')) {
                fetch(`/tank/delete/${tankId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.reload();
                    } else {
                        alert(data.message || 'Failed to delete tank');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while deleting the tank. Please try again.');
                });
            }
        }
    </script>
</body>
</html>
