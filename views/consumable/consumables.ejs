<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Manage Consumables' }) %>
    <style>
        /* Manage Consumables — page-scoped flourishes on the shared mibflow.css system */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }

        .price-form { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
        .price-input { max-width: 160px; }
        .price-cell { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--mib-text); }

        /* button loading spinner (used by handleUpdatePrice) */
        .btn.loading { pointer-events: none; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* toast notifications */
        .toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 1080; }
        .toast {
            background: var(--mib-surface); border: 1px solid var(--mib-border); border-radius: var(--mib-radius-sm);
            box-shadow: var(--mib-shadow-md); margin-bottom: 0.5rem; min-width: 250px; animation: toastIn 0.3s ease-out;
        }
        @keyframes toastIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .toast.success { border-left: 4px solid var(--mib-success); }
        .toast.error   { border-left: 4px solid var(--mib-danger); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/finance/consumables' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const consumableList = (typeof consumables !== 'undefined' && consumables) ? consumables : [];
        const typeList       = (typeof availableTypes !== 'undefined' && availableTypes) ? availableTypes : [];
        const flash          = (typeof messages !== 'undefined' && messages) ? messages : {};
        const flashSuccess   = [].concat(flash.success || []).filter(Boolean);
        const flashError     = [].concat(flash.error || []).filter(Boolean);
        const fmtRp = (v) => {
            const n = Number(v);
            return isNaN(n) ? '0.00' : n.toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        };
    %>

    <!-- Toast container for dynamic notifications (used by handleUpdatePrice) -->
    <div class="toast-container"></div>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Manage Consumables',
              pageIcon: 'bi-box-seam',
              pageSubtitle: 'Update and manage prices for consumable items used across order costing.'
        }) %>

        <!-- Flash messages -->
        <% flashError.forEach(function(msg) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span><%= msg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% }); %>
        <% flashSuccess.forEach(function(msg) { %>
            <div class="mib-flash mib-flash-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><%= msg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% }); %>

        <!-- ===================== Add Consumable ===================== -->
        <div class="form-section fade-in">
            <h2 class="form-section-title"><i class="bi bi-plus-circle"></i> Add Consumable</h2>
            <p class="form-section-desc">Consumable types mirror Order History (Pallet, Sticker, Wrap, Handling, Logistic, Triplek, Peti, Kabel Ties).</p>
            <% if (typeList.length > 0) { %>
                <form action="/consumables/add" method="POST" class="price-form" style="align-items: flex-end;">
                    <div>
                        <label class="form-label" for="consumableName">Type</label>
                        <select name="name" id="consumableName" class="form-select" required style="min-width: 220px;">
                            <option value="">Select consumable…</option>
                            <% typeList.forEach(type => { %>
                                <option value="<%= type %>"><%= type %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="consumableFee">Fee (Rp)</label>
                        <div class="input-group price-input">
                            <span class="input-group-text">Rp</span>
                            <input type="number" name="fee" id="consumableFee" class="form-control" step="0.01" min="0" value="0" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> <span>Add</span>
                    </button>
                </form>
            <% } else { %>
                <p class="text-muted-2 mb-0">
                    <i class="bi bi-check-circle-fill text-success me-1"></i>
                    Semua jenis consumable sudah ditambahkan.
                </p>
            <% } %>
        </div>

        <!-- ===================== Consumable Prices ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-currency-dollar"></i> Consumable Prices</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>Consumable</th>
                            <th>Current Price (Rp)</th>
                            <th>New Price (Rp)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (consumableList.length > 0) { %>
                            <% consumableList.forEach(consumable => { %>
                                <tr>
                                    <td data-label="Consumable"><span class="cell-strong"><%= consumable.name %></span></td>
                                    <td data-label="Current Price (Rp)" class="price-cell">Rp<%= fmtRp(consumable.fee) %></td>
                                    <td data-label="New Price (Rp)">
                                        <form onsubmit="handleUpdatePrice(event, '<%= consumable.id %>')" class="price-form">
                                            <div class="input-group price-input">
                                                <span class="input-group-text">Rp</span>
                                                <input
                                                    type="number"
                                                    name="newFee"
                                                    value="<%= consumable.fee %>"
                                                    step="0.01"
                                                    min="0"
                                                    class="form-control"
                                                    required
                                                >
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <i class="bi bi-check-lg"></i>
                                                <span>Update</span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="3"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No consumables yet</h4><p>Add a consumable above to start managing its price.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Toast notification function
        function showToast(message, type = 'success') {
            const toastContainer = document.querySelector('.toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type} show`;
            toast.innerHTML = `
                <div class="toast-body d-flex align-items-center gap-2 p-3">
                    <i class="bi ${type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-x-circle-fill text-danger'}"></i>
                    <span>${message}</span>
                </div>
            `;
            toastContainer.appendChild(toast);

            // Remove toast after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Handle price update form submission
        async function handleUpdatePrice(event, id) {
            event.preventDefault();
            const form = event.target;
            const submitBtn = form.querySelector('button[type="submit"]');
            const input = form.querySelector('input[name="newFee"]');
            const currentPriceCell = form.closest('tr').querySelector('td:nth-child(2)');

            try {
                // Add loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Updating...';
                input.disabled = true;

                // Make AJAX request
                const response = await fetch(`/consumables/update/${id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ newFee: input.value })
                });

                if (!response.ok) {
                    throw new Error('Failed to update price');
                }

                // Update UI on success
                currentPriceCell.textContent = `Rp${parseFloat(input.value).toFixed(2)}`;
                currentPriceCell.classList.add('price-cell');
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Updated';
                submitBtn.classList.remove('btn-primary');
                submitBtn.classList.add('btn-success');

                // Show success message
                showToast('Price updated successfully', 'success');

                // Reset button after delay
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Update';
                    submitBtn.classList.remove('btn-success');
                    submitBtn.classList.add('btn-primary');
                    input.disabled = false;
                }, 2000);

            } catch (error) {
                console.error('Error updating price:', error);
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = '<i class="bi bi-x-lg"></i> Failed';
                submitBtn.classList.remove('btn-primary');
                submitBtn.classList.add('btn-danger');

                // Show error message
                showToast('Failed to update price. Please try again.', 'error');

                // Reset button after delay
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Update';
                    submitBtn.classList.remove('btn-danger');
                    submitBtn.classList.add('btn-primary');
                    input.disabled = false;
                }, 2000);
            }
        }
    </script>
</body>
</html>
