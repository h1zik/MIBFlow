<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Consumable Prices</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-light: #4caf50;
            --primary-dark: #1b5e20;
            --text-color: #2c3e50;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            transition: var(--transition);
            width: calc(100% - 280px);
        }

        body.sidebar-collapsed .main-content {
            margin-left: 70px;
            width: calc(100% - 70px);
        }

        .page-header {
            background: white;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            animation: slideDown 0.5s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            overflow: hidden;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .loading {
            pointer-events: none;
            position: relative;
        }

        .loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin: -10px 0 0 -10px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .price-form {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .price-input {
            max-width: 150px;
            border-radius: 8px;
            border: 1px solid rgba(0,0,0,0.1);
            padding: 0.5rem;
            transition: var(--transition);
        }

        .price-input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
        }

        .btn-update {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
            transition: var(--transition);
        }

        .btn-update:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .btn-update i {
            font-size: 1rem;
        }

        .alert {
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            animation: slideDown 0.3s ease-out;
        }

        .table {
            margin: 0;
            background-color: white;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.875rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
            transition: var(--transition);
        }

        .table tbody tr:hover td {
            background-color: var(--background-light);
        }

        .price-cell {
            font-family: 'Inter', monospace;
            font-weight: 500;
            color: var(--primary-dark);
        }

        .toast-container {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 1050;
        }

        .toast {
            background: white;
            border-radius: 12px;
            box-shadow: var(--shadow);
            margin-bottom: 0.5rem;
            min-width: 250px;
            animation: slideIn 0.3s ease-out;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .toast.success {
            border-left: 4px solid var(--primary-color);
        }

        .toast.error {
            border-left: 4px solid #dc3545;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: var(--transition);
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .form-control {
            border-radius: 8px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            padding: 0.5rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
            outline: none;
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding: 1rem;
                width: 100%;
            }

            .page-header {
                padding: 1rem;
            }

            .table-responsive {
                margin: 0 -1rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-currency-dollar"></i>
                Edit Consumable Prices
            </h1>
            <p class="text-muted mb-0">Update and manage prices for consumable items</p>
        </div>
        <!-- Flash Messages -->
        <% if (messages && messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <%= messages.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        
        <% if (messages && messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="card">
            <!-- Toast Container for Dynamic Notifications -->
            <div class="toast-container"></div>

            <div class="table-responsive">
                <table class="table">
                <thead>
                    <tr>
                        <th>Consumable</th>
                        <th>Current Price (Rp)</th>
                        <th>New Price (Rp)</th>
                    </tr>
                </thead>
                <tbody>
                    <% consumables.forEach(consumable => { %>
                        <tr>
                            <td><%= consumable.name %></td>
                            <td>Rp<%= consumable.fee.toFixed(2) %></td>
                            <td>
                                <form onsubmit="handleUpdatePrice(event, '<%= consumable.id %>')" class="price-form">
                                    <input 
                                        type="number" 
                                        name="newFee" 
                                        value="<%= consumable.fee %>" 
                                        step="0.01" 
                                        min="0" 
                                        class="form-control price-input" 
                                        required
                                    >
                                    <button type="submit" class="btn btn-primary btn-update">
                                        <i class="bi bi-check-lg"></i>
                                        <span>Update</span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });
            observer.observe(sidebar, { attributes: true });
        });

        // Toast notification function
        function showToast(message, type = 'success') {
            const toastContainer = document.querySelector('.toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type} show`;
            toast.innerHTML = `
                <div class="toast-body d-flex align-items-center gap-2 p-3">
                    <i class="bi ${type === 'success' ? 'bi-check-circle-fill text-success' : 'bi-x-circle-fill text-danger'}"></i>
                    <span>${message}</span>
                </div>
            `;
            toastContainer.appendChild(toast);
            
            // Remove toast after 3 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Handle price update form submission
        async function handleUpdatePrice(event, id) {
            event.preventDefault();
            const form = event.target;
            const submitBtn = form.querySelector('button[type="submit"]');
            const input = form.querySelector('input[name="newFee"]');
            const currentPriceCell = form.closest('tr').querySelector('td:nth-child(2)');
            
            try {
                // Add loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Updating...';
                input.disabled = true;

                // Make AJAX request
                const response = await fetch(`/consumables/update/${id}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ newFee: input.value })
                });

                if (!response.ok) {
                    throw new Error('Failed to update price');
                }

                // Update UI on success
                currentPriceCell.textContent = `Rp${parseFloat(input.value).toFixed(2)}`;
                currentPriceCell.classList.add('price-cell');
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Updated';
                submitBtn.classList.remove('btn-primary');
                submitBtn.classList.add('btn-success');

                // Show success message
                showToast('Price updated successfully', 'success');

                // Reset button after delay
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Update';
                    submitBtn.classList.remove('btn-success');
                    submitBtn.classList.add('btn-primary');
                    input.disabled = false;
                }, 2000);

            } catch (error) {
                console.error('Error updating price:', error);
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = '<i class="bi bi-x-lg"></i> Failed';
                submitBtn.classList.remove('btn-primary');
                submitBtn.classList.add('btn-danger');

                // Show error message
                showToast('Failed to update price. Please try again.', 'error');

                // Reset button after delay
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '<i class="bi bi-check-lg"></i> Update';
                    submitBtn.classList.remove('btn-danger');
                    submitBtn.classList.add('btn-primary');
                    input.disabled = false;
                }, 2000);
            }
        }
    </script>
</body>
</html>
