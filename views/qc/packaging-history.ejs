<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Packaging QC History' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/qc/packaging-history' }) %>

    <%
        /* ---- Defensive normalisation (guard optional / null locals) ---- */
        const pkgList = (typeof packagingRequests !== 'undefined' && packagingRequests) ? packagingRequests : [];

        /* status badge helpers (mirror PPIC) */
        const qb = (s) => s === 'Pass' ? 'status-completed'
                        : (s === 'Fail' ? 'status-declined' : 'status-pending');
        const qcLabel = (s) => s || 'Pending';
        const fmtDate = (d) => {
            if (!d) return '—';
            const dt = new Date(d);
            return isNaN(dt) ? '—' : dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        };

        /* counts for quick-stats */
        const passCount = pkgList.filter(r => r.qcStatus === 'Pass').length;
        const failCount = pkgList.filter(r => r.qcStatus === 'Fail').length;
        const pendingCount = pkgList.filter(r => r.qcStatus !== 'Pass' && r.qcStatus !== 'Fail').length;
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Packaging QC History',
              pageIcon: 'bi-box',
              pageSubtitle: 'Quality control outcomes for inbound packaging materials',
              actionsHtml: '<a href="/dashboard/qc" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-clipboard-data"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Records</div>
                    <div class="stat-value"><%= pkgList.length %></div>
                    <span class="stat-sub">QC entries on file</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Passed</div>
                    <div class="stat-value"><%= passCount %></div>
                    <span class="stat-sub">Approved packaging</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-x-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Failed</div>
                    <div class="stat-value"><%= failCount %></div>
                    <span class="stat-sub">Rejected packaging</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-clock"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-sub">Awaiting QC</span>
                </div>
            </div>
        </div>

        <!-- ===================== Toolbar ===================== -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" id="qcSearch" class="form-control" placeholder="Search packaging, vendor…" autocomplete="off">
            </div>
        </div>

        <!-- ===================== QC History ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-list-check"></i> QC History List</h2>
                <span class="pill"><i class="bi bi-hash"></i> <%= pkgList.length %> records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="qcTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Packaging Name</th>
                            <th>Vendor</th>
                            <th>Quantity</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pkgList.length > 0) { %>
                            <% pkgList.forEach(function(request) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Packaging Name">
                                        <span class="cell-strong"><%= (request.PackagingRequest && request.PackagingRequest.Packaging) ? request.PackagingRequest.Packaging.name : '—' %></span>
                                    </td>
                                    <td data-label="Vendor"><%= request.Vendor ? request.Vendor.name : '—' %></td>
                                    <td data-label="Quantity" class="num"><%= request.PackagingRequest ? request.PackagingRequest.quantity : '—' %> pcs</td>
                                    <td data-label="QC Status">
                                        <span class="status-badge <%= qb(request.qcStatus) %>"><%= qcLabel(request.qcStatus) %></span>
                                    </td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= request.qcComment || '—' %></span></td>
                                    <td data-label="Date"><span class="cell-sub"><%= fmtDate(request.updatedAt) %></span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="7">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No QC history found</h4>
                                        <p>Packaging quality control results will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // Live search across the QC history table
        document.addEventListener('DOMContentLoaded', function () {
            const search = document.getElementById('qcSearch');
            if (!search) return;
            search.addEventListener('input', function () {
                const q = this.value.trim().toLowerCase();
                document.querySelectorAll('#qcTable tbody tr').forEach(function (row) {
                    if (row.classList.contains('is-empty-row')) return;
                    row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
            });
        });
    </script>
</body>
</html>
