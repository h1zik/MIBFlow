<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Raw Material QC History' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/qc/raw-material-history' }) %>

    <%
        /* ---- Defensive normalisation (guard optional / null locals) ---- */
        const rawList     = (typeof rawMaterialRequests !== 'undefined' && rawMaterialRequests) ? rawMaterialRequests : [];
        const expiredList = (typeof expiredRawMaterials !== 'undefined' && expiredRawMaterials) ? expiredRawMaterials : [];

        /* status badge helpers (mirror PPIC) */
        const qb = (s) => s === 'Pass' ? 'status-completed'
                        : (s === 'Fail' ? 'status-declined'
                        : (s === 'Reject Sebagian' ? 'status-rejected' : 'status-pending'));
        const qcLabel = (s) => s === 'Reject Sebagian' ? 'Partially Rejected' : (s || 'Pending');
        const fmtDate = (d) => {
            if (!d) return '—';
            const dt = new Date(d);
            return isNaN(dt) ? '—' : dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        };

        /* counts for quick-stats */
        const passCount   = rawList.filter(r => r.qcStatus === 'Pass').length;
        const failCount   = rawList.filter(r => r.qcStatus === 'Fail').length;
        const partialCount = rawList.filter(r => r.qcStatus === 'Reject Sebagian').length;
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Raw Material QC History',
              pageIcon: 'bi-boxes',
              pageSubtitle: 'Quality control outcomes for inbound raw materials',
              actionsHtml: '<a href="/dashboard/qc" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-clipboard-data"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Records</div>
                    <div class="stat-value"><%= rawList.length %></div>
                    <span class="stat-sub">QC entries on file</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Passed</div>
                    <div class="stat-value"><%= passCount %></div>
                    <span class="stat-sub">Approved materials</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Partially Rejected</div>
                    <div class="stat-value"><%= partialCount %></div>
                    <span class="stat-sub">Reject Sebagian</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-x-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Failed</div>
                    <div class="stat-value"><%= failCount %></div>
                    <span class="stat-sub">Rejected materials</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-calendar-x"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Expired</div>
                    <div class="stat-value"><%= expiredList.length %></div>
                    <span class="stat-sub">Past expiry date</span>
                </div>
            </div>
        </div>

        <!-- ===================== Toolbar ===================== -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" id="qcSearch" class="form-control" placeholder="Search materials, PO, batch, vendor…" autocomplete="off">
            </div>
        </div>

        <!-- ===================== QC History ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-list-check"></i> QC History List</h2>
                <span class="pill"><i class="bi bi-hash"></i> <%= rawList.length %> records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="qcTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>PO Number</th>
                            <th>Batch Number</th>
                            <th>Vendor</th>
                            <th>Quantity</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Reject Comment</th>
                            <th>Reject Quantity</th>
                            <th>Expired Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (rawList.length > 0) { %>
                            <% rawList.forEach(function(request) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><span class="cell-strong"><%= request.RawMaterialRequest ? request.RawMaterialRequest.materialName : '—' %></span></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Batch Number"><%= request.batchNumber || 'N/A' %></td>
                                    <td data-label="Vendor"><%= request.Vendor ? request.Vendor.name : '—' %></td>
                                    <td data-label="Quantity" class="num"><%= request.RawMaterialRequest ? request.RawMaterialRequest.realQuantity : '—' %> Kg</td>
                                    <td data-label="QC Status">
                                        <span class="status-badge <%= qb(request.qcStatus) %>"><%= qcLabel(request.qcStatus) %></span>
                                    </td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= request.qcComment || '—' %></span></td>
                                    <td data-label="Reject Comment"><span class="cell-sub"><%= request.rejectComment || '—' %></span></td>
                                    <td data-label="Reject Quantity"><%= request.rejectQuantity ? request.rejectQuantity + ' Kg' : '—' %></td>
                                    <td data-label="Expired Date">
                                        <%
                                        if (request.expiredDate) {
                                            const expiryDate = new Date(request.expiredDate);
                                            const today = new Date();
                                            const monthsUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24 * 30);
                                            const expiryLabel = expiryDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

                                            if (monthsUntilExpiry <= 1) {
                                                const daysUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24); %>
                                                <span class="status-badge status-pending">
                                                    <i class="bi bi-exclamation-triangle"></i>
                                                    <%= expiryLabel %> · in <%= Math.ceil(daysUntilExpiry) %>d
                                                </span>
                                            <% } else if (monthsUntilExpiry <= 6) { %>
                                                <span class="status-badge status-pending">
                                                    <i class="bi bi-exclamation-triangle"></i>
                                                    <%= expiryLabel %> · in <%= Math.ceil(monthsUntilExpiry) %>mo
                                                </span>
                                            <% } else { %>
                                                <span class="cell-sub"><%= expiryLabel %></span>
                                            <% }
                                        } else { %>
                                            —
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No QC history found</h4>
                                        <p>Raw material quality control results will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===================== Expired Raw Materials ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-calendar-x"></i> Expired Raw Materials</h2>
                <span class="pill"><i class="bi bi-hash"></i> <%= expiredList.length %> records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="expiredTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Material Name</th>
                            <th>PO Number</th>
                            <th>Batch Number</th>
                            <th>Vendor</th>
                            <th>Quantity</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Reject Comment</th>
                            <th>Reject Quantity</th>
                            <th>Expired Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (expiredList.length > 0) { %>
                            <% expiredList.forEach(function(request) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                    <td data-label="Material Name"><span class="cell-strong"><%= request.RawMaterialRequest ? request.RawMaterialRequest.materialName : '—' %></span></td>
                                    <td data-label="PO Number"><%= request.ponumber || 'N/A' %></td>
                                    <td data-label="Batch Number"><%= request.batchNumber || 'N/A' %></td>
                                    <td data-label="Vendor"><%= request.Vendor ? request.Vendor.name : '—' %></td>
                                    <td data-label="Quantity" class="num"><%= request.splitQuantity %> Kg</td>
                                    <td data-label="QC Status">
                                        <span class="status-badge <%= qb(request.qcStatus) %>"><%= qcLabel(request.qcStatus) %></span>
                                    </td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= request.qcComment || '—' %></span></td>
                                    <td data-label="Reject Comment"><span class="cell-sub"><%= request.rejectComment || '—' %></span></td>
                                    <td data-label="Reject Quantity"><%= request.rejectQuantity ? request.rejectQuantity + ' Kg' : '—' %></td>
                                    <td data-label="Expired Date">
                                        <span class="status-badge status-declined">
                                            <i class="bi bi-exclamation-circle"></i>
                                            <%= fmtDate(request.expiredDate) %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No expired raw materials</h4>
                                        <p>Materials past their expiry date will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // Live search across both QC history tables
        document.addEventListener('DOMContentLoaded', function () {
            const search = document.getElementById('qcSearch');
            if (!search) return;
            search.addEventListener('input', function () {
                const q = this.value.trim().toLowerCase();
                document.querySelectorAll('#qcTable tbody tr, #expiredTable tbody tr').forEach(function (row) {
                    if (row.classList.contains('is-empty-row')) return;
                    row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
            });
        });
    </script>
</body>
</html>
