<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Production QC History</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .badge {
            padding: 0.35rem 0.65rem;
            font-size: 0.75rem;
            font-weight: 500;
            border-radius: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            margin: 0.125rem;
        }

        .badge-pass {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-fail {
            background-color: #f8d7da;
            color: #721c24;
        }

        .badge-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-clipboard-check"></i>
                Production QC History
            </h1>
            <p class="page-subtitle">View quality control history for productions</p>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-list-check"></i>
                    QC History List
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Production Date</th>
                                <th>Batch Number</th>
                                <th>SO Number</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>QC Status</th>
                                <th>QC Comment</th>
                                <th>Sample Retained</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (productions && productions.length > 0) { %>
                                <% productions.forEach(function(production) { %>
                                    <tr>
                                        <td>#<%= production.id %></td>
                                        <td><%= production.startDate.toISOString().split('T')[0] %></td>
                                        <td><%= production.batchNumber %></td>
                                        <td>
                                            <% if (production.ProductionRequest?.orderId && production.ProductionRequest.Order) { %>
                                                <%= production.ProductionRequest.Order.sonumber %>
                                            <% } else if (production.ProductionRequest?.prodreqnumber) { %>
                                                <%= production.ProductionRequest.prodreqnumber %>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= production.Product.name %></td>
                                        <td><%= production.quantity %> Kg</td>
                                        <td>
                                            <% if (production.qcStatus === 'Pass') { %>
                                                <span class="badge badge-pass">
                                                    <i class="bi bi-check-circle"></i>
                                                    Pass
                                                </span>
                                            <% } else if (production.qcStatus === 'Fail') { %>
                                                <span class="badge badge-fail">
                                                    <i class="bi bi-x-circle"></i>
                                                    Fail
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-clock"></i>
                                                    Pending
                                                </span>
                                            <% } %>
                                        </td>
                                        <td><%= production.qcComment || '-' %></td>
                                        <td>
                                            <% if (production.sampleRetained) { %>
                                                <span class="badge badge-pass">
                                                    <i class="bi bi-check-circle"></i>
                                                    Yes
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-dash-circle"></i>
                                                    No
                                                </span>
                                            <% } %>
                                        </td>
                                        <td><%= production.updatedAt.toLocaleDateString() %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="text-center text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No QC history found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
