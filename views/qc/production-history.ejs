<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Production QC History' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/qc/production-history' }) %>

    <%
        /* ---- Defensive normalisation (guard optional / null locals) ---- */
        const prodList = (typeof productions !== 'undefined' && productions) ? productions : [];

        /* status badge helpers (mirror PPIC) */
        const qb = (s) => s === 'Pass' ? 'status-completed'
                        : (s === 'Fail' ? 'status-declined' : 'status-pending');
        const qcLabel = (s) => s || 'Pending';
        const fmtDate = (d) => {
            if (!d) return '—';
            const dt = new Date(d);
            return isNaN(dt) ? '—' : dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        };
        const fmtISODate = (d) => {
            if (!d) return '—';
            const dt = new Date(d);
            return isNaN(dt) ? '—' : dt.toISOString().split('T')[0];
        };
        const soNumber = (p) => {
            if (p.ProductionRequest && p.ProductionRequest.orderId && p.ProductionRequest.Order) return p.ProductionRequest.Order.sonumber;
            if (p.ProductionRequest && p.ProductionRequest.prodreqnumber) return p.ProductionRequest.prodreqnumber;
            return '—';
        };

        /* counts for quick-stats */
        const passCount = prodList.filter(p => p.qcStatus === 'Pass').length;
        const failCount = prodList.filter(p => p.qcStatus === 'Fail').length;
        const pendingCount = prodList.filter(p => p.qcStatus !== 'Pass' && p.qcStatus !== 'Fail').length;
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Production QC History',
              pageIcon: 'bi-clipboard-check',
              pageSubtitle: 'Quality control outcomes across production batches',
              actionsHtml: '<a href="/dashboard/qc" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-clipboard-data"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Batches</div>
                    <div class="stat-value"><%= prodList.length %></div>
                    <span class="stat-sub">QC entries on file</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Passed</div>
                    <div class="stat-value"><%= passCount %></div>
                    <span class="stat-sub">Approved batches</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-x-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Failed</div>
                    <div class="stat-value"><%= failCount %></div>
                    <span class="stat-sub">Rejected batches</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-clock"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-sub">Awaiting QC</span>
                </div>
            </div>
        </div>

        <!-- ===================== Toolbar ===================== -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" id="qcSearch" class="form-control" placeholder="Search batch, SO, product…" autocomplete="off">
            </div>
        </div>

        <!-- ===================== QC History ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-list-check"></i> QC History List</h2>
                <span class="pill"><i class="bi bi-hash"></i> <%= prodList.length %> records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="qcTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Production Date</th>
                            <th>Batch Number</th>
                            <th>SO Number</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Sample Retained</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (prodList.length > 0) { %>
                            <% prodList.forEach(function(production) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= production.id %></span></td>
                                    <td data-label="Production Date"><span class="cell-sub"><%= fmtISODate(production.startDate) %></span></td>
                                    <td data-label="Batch Number"><%= production.batchNumber || 'N/A' %></td>
                                    <td data-label="SO Number"><span class="cell-strong"><%= soNumber(production) %></span></td>
                                    <td data-label="Product"><%= production.Product ? production.Product.name : '—' %></td>
                                    <td data-label="Quantity" class="num"><%= production.quantity %> Kg</td>
                                    <td data-label="QC Status">
                                        <span class="status-badge <%= qb(production.qcStatus) %>"><%= qcLabel(production.qcStatus) %></span>
                                    </td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= production.qcComment || '—' %></span></td>
                                    <td data-label="Sample Retained">
                                        <% if (production.sampleRetained) { %>
                                            <span class="status-badge status-completed"><i class="bi bi-check-circle"></i> Yes</span>
                                        <% } else { %>
                                            <span class="status-badge status-neutral"><i class="bi bi-dash-circle"></i> No</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Date"><span class="cell-sub"><%= fmtDate(production.updatedAt) %></span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="10">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No QC history found</h4>
                                        <p>Production quality control results will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // Live search across the QC history table
        document.addEventListener('DOMContentLoaded', function () {
            const search = document.getElementById('qcSearch');
            if (!search) return;
            search.addEventListener('input', function () {
                const q = this.value.trim().toLowerCase();
                document.querySelectorAll('#qcTable tbody tr').forEach(function (row) {
                    if (row.classList.contains('is-empty-row')) return;
                    row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
            });
        });
    </script>
</body>
</html>
