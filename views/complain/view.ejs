<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'View Complain' }) %>
    <style>
        .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
        .info-item { background: var(--mib-surface-2); border: 1px solid var(--mib-border); padding: 0.9rem 1rem; border-radius: var(--mib-radius-sm); }
        .info-label { color: var(--mib-text-muted); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; margin-bottom: 0.3rem; }
        .info-value { color: var(--mib-text); font-weight: 650; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/complain' }) %>

    <div class="content content-wide">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <ul class="mib-breadcrumb"><li><a href="/complain">Complains</a></li><li>#<%= complain.id %></li></ul>
                <h1 class="page-title"><i class="bi bi-eye"></i> Complain #<%= complain.id %></h1>
                <p class="page-subtitle">Detailed information about the complaint.</p>
            </div>
            <div class="page-actions">
                <a href="/complain" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back</a>
                <% if (complain.status === 'Pending' && userRole === 'QC') { %>
                    <form action="/complain/approve/<%= complain.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Approve</button></form>
                    <form action="/complain/reject/<%= complain.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-outline-danger"><i class="bi bi-x-lg"></i> Reject</button></form>
                <% } %>
            </div>
        </div>

        <div class="panel">
            <h3 class="form-section-title"><i class="bi bi-info-circle me-1"></i> General Information</h3>
            <div class="info-grid">
                <div class="info-item"><div class="info-label">Complain ID</div><div class="info-value">#<%= complain.id %></div></div>
                <div class="info-item"><div class="info-label">SO Number</div><div class="info-value"><%= complain.sonumber %></div></div>
                <div class="info-item"><div class="info-label">Customer Name</div><div class="info-value"><%= complain.customerName %></div></div>
                <div class="info-item"><div class="info-label">Status</div><div class="info-value"><span class="status-badge status-<%= complain.status === 'Pending' ? 'pending' : (complain.status === 'Approved' ? 'approved' : 'rejected') %>"><%= complain.status %></span></div></div>
                <div class="info-item"><div class="info-label">Created At</div><div class="info-value"><%= new Date(complain.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div></div>
            </div>
        </div>

        <div class="table-card">
            <div class="card-header"><h2 class="card-title"><i class="bi bi-box-seam"></i> Complained Products</h2></div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead><tr><th>Product</th><th>Quantity Rejected</th><th>Notes</th><th>Status</th></tr></thead>
                    <tbody>
                        <% complain.ComplainItems.forEach(item => { %>
                            <tr>
                                <td data-label="Product" class="cell-strong" data-product-id="<%= item.productId %>"><%= item.product %></td>
                                <td data-label="Quantity Rejected"><%= item.quantityRejected %> KG</td>
                                <td data-label="Notes" class="cell-sub"><%= item.notes || '—' %></td>
                                <td data-label="Status"><span class="status-badge status-<%= item.status === 'Pending' ? 'pending' : (item.status === 'Approved' ? 'approved' : 'rejected') %>"><%= item.status %></span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
