<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Complain List' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/complain' }) %>

    <div class="content content-wide">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-exclamation-circle"></i> Complain List</h1>
                <p class="page-subtitle">View and manage product complaints.</p>
            </div>
            <% if (userRole === 'Marketing') { %>
            <div class="page-actions">
                <a href="/complain/create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Complain</a>
            </div>
            <% } %>
        </div>

        <div class="table-card fade-in">
            <div class="table-responsive">
                <% if (complains && complains.length > 0) { %>
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>SO Number</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% complains.forEach(complain => { %>
                            <tr>
                                <td data-label="ID" class="cell-sub">#<%= complain.id %></td>
                                <td data-label="SO Number" class="cell-strong"><%= complain.sonumber %></td>
                                <td data-label="Customer"><%= complain.customerName %></td>
                                <td data-label="Status">
                                    <span class="status-badge status-<%= complain.status === 'Pending' ? 'pending' : (complain.status === 'Approved' ? 'approved' : 'rejected') %>"><%= complain.status %></span>
                                </td>
                                <td data-label="Date"><%= new Date(complain.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                                <td data-label="Actions" class="text-end">
                                    <div class="d-flex gap-1 justify-content-end flex-wrap">
                                        <a href="/complain/view/<%= complain.id %>" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                        <% if (complain.status === 'Pending' && userRole === 'QC') { %>
                                            <form action="/complain/approve/<%= complain.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i></button></form>
                                            <form action="/complain/reject/<%= complain.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i></button></form>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% } else { %>
                <div class="empty-state"><i class="bi bi-inbox"></i><h4>No complaints found</h4><p>Complaints created from delivered orders will appear here.</p></div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
