<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Create Complain' }) %>
    <style>
        .complain-item { background: var(--mib-surface-2); border: 1px solid var(--mib-border); padding: 1.25rem; border-radius: var(--mib-radius-sm); margin-bottom: 1.25rem; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/complain/create' }) %>

    <div class="content content-narrow">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <ul class="mib-breadcrumb"><li><a href="/complain">Complains</a></li><li>Create</li></ul>
                <h1 class="page-title"><i class="bi bi-pencil-square"></i> Create Complain</h1>
                <p class="page-subtitle">Report a new product complaint from a delivered order.</p>
            </div>
        </div>

        <form id="complainForm" class="needs-validation" novalidate>
            <div class="form-section">
                <h3 class="form-section-title"><i class="bi bi-receipt me-1"></i> Order</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="orderId" class="form-label">SO Number</label>
                        <select class="form-select" id="orderId" name="orderId" required>
                            <option value="">Select SO Number</option>
                            <% orders.forEach(order => { %>
                                <option value="<%= order.id %>" data-customer="<%= order.customerName %>" data-sonumber="<%= order.sonumber %>"><%= order.sonumber %> - <%= order.customerName %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label for="customerName" class="form-label">Customer Name</label>
                        <input type="text" class="form-control" id="customerName" name="customerName" readonly>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3 class="form-section-title"><i class="bi bi-box-seam me-1"></i> Complain Items</h3>
                <div id="complainItems">
                    <div class="complain-item">
                        <div class="mb-3">
                            <label class="form-label">Product</label>
                            <select class="form-select product-select" required><option value="">Select Product</option></select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quantity Rejected</label>
                            <input type="number" class="form-control quantity-rejected" min="1" required>
                        </div>
                        <div class="mb-0">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control notes" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-light btn-sm" id="addItem"><i class="bi bi-plus-circle"></i> Add Another Item</button>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/complain" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Submit Complain</button>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const orderSelect = document.getElementById('orderId');
            const customerNameInput = document.getElementById('customerName');
            const complainForm = document.getElementById('complainForm');
            const addItemBtn = document.getElementById('addItem');
            const complainItems = document.getElementById('complainItems');
            const orders = JSON.parse('<%- JSON.stringify(orders) %>');
            let selectedOrder = null;

            orderSelect.addEventListener('change', function () {
                customerNameInput.value = this.options[this.selectedIndex].dataset.customer || '';
                selectedOrder = orders.find(order => order.id === parseInt(this.value));
                updateAllProductDropdowns();
            });

            addItemBtn.addEventListener('click', function () {
                const newItem = document.querySelector('.complain-item').cloneNode(true);
                newItem.querySelector('.product-select').value = '';
                newItem.querySelector('.quantity-rejected').value = '';
                newItem.querySelector('.notes').value = '';
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'btn btn-sm btn-outline-danger mt-2';
                removeBtn.innerHTML = '<i class="bi bi-trash"></i> Remove Item';
                removeBtn.onclick = () => newItem.remove();
                newItem.appendChild(removeBtn);
                complainItems.appendChild(newItem);
                if (selectedOrder) updateProductDropdown(newItem.querySelector('.product-select'));
            });

            function updateAllProductDropdowns() {
                document.querySelectorAll('.product-select').forEach(updateProductDropdown);
            }
            function updateProductDropdown(select) {
                select.innerHTML = '<option value="">Select Product</option>';
                if (selectedOrder && selectedOrder.OrderItems) {
                    selectedOrder.OrderItems.forEach(item => {
                        const option = document.createElement('option');
                        option.value = JSON.stringify({ id: item.Product.id, name: item.Product.name });
                        option.textContent = item.Product.name;
                        select.appendChild(option);
                    });
                }
            }

            complainForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                const items = [];
                document.querySelectorAll('.complain-item').forEach(item => {
                    const raw = item.querySelector('.product-select').value;
                    if (!raw) return;
                    const productData = JSON.parse(raw);
                    items.push({
                        productId: productData.id,
                        product: productData.name,
                        quantityRejected: parseInt(item.querySelector('.quantity-rejected').value),
                        notes: item.querySelector('.notes').value
                    });
                });
                const formData = {
                    orderId: orderSelect.value,
                    sonumber: orderSelect.options[orderSelect.selectedIndex].dataset.sonumber,
                    customerName: customerNameInput.value,
                    items: items
                };
                try {
                    const response = await fetch('/complain/create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });
                    const result = await response.json();
                    if (result.success) window.location.href = '/complain';
                    else alert('Error creating complain: ' + result.message);
                } catch (error) {
                    console.error('Error:', error);
                    alert('Error creating complain');
                }
            });
        });
    </script>
</body>
</html>
