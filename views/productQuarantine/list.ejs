<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quarantined Products - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-light: #4caf50;
            --primary-dark: #1b5e20;
            --text-color: #2c3e50;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            transition: var(--transition);
            width: calc(100% - 280px);
        }

        body.sidebar-collapsed .main-content {
            margin-left: 70px;
            width: calc(100% - 70px);
        }

        .page-header {
            background: white;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            animation: slideDown 0.5s ease-out;
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .table-container {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            padding: 1.5rem;
            animation: fadeIn 0.5s ease-out;
            margin-bottom: 2rem;
        }

        .search-box {
            margin-bottom: 1rem;
            position: relative;
        }

        .search-box i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
        }

        .search-input {
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            border-radius: 8px;
            border: 1px solid #ced4da;
            width: 100%;
            transition: var(--transition);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
        }

        .table tbody tr {
            transition: var(--transition);
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding: 1rem;
                width: 100%;
            }

            .page-header {
                padding: 1rem;
            }

            .table-container {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-exclamation-triangle"></i>
                Quarantined Products
            </h1>
            <p class="text-muted mb-0">View quarantined productions and complain items</p>
        </div>

        <!-- Quarantined Productions -->
        <div class="table-container">
            <h4 class="mb-4">Quarantined Productions</h4>
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" id="productionSearch" placeholder="Search productions...">
            </div>
            <div class="table-responsive">
                <table class="table" id="productionsTable">
                    <thead>
                        <tr>
                                            <th>PRODREQ Number</th>
                                            <th>Batch Number</th>
                                            <th>Product Name</th>
                                            <th>Quantity</th>
                                            <th>Production Date</th>
                                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (quarantinedProductions && quarantinedProductions.length > 0) { %>
                            <% quarantinedProductions.forEach(production => { %>
                                <tr>
                                                    <td><%= production.ProductionRequest ? production.ProductionRequest.prodreqnumber : 'N/A' %></td>
                                                    <td><%= production.batchNumber || 'N/A' %></td>
                                                    <td><%= production.Product ? production.Product.name : 'N/A' %></td>
                                                    <td><%= production.quantity || 0 %> Kg</td>
                                                    <td><%= new Date(production.createdAt).toLocaleDateString('en-US', { 
                                                        year: 'numeric', 
                                                        month: 'short', 
                                                        day: 'numeric' 
                                                    }) %></td>
                                                    <td><%= production.status %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    No quarantined productions found
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Quarantined Complain Items -->
        <div class="table-container">
            <h4 class="mb-4">Quarantined Complain Items</h4>
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" id="complainSearch" placeholder="Search complain items...">
            </div>
            <div class="table-responsive">
                <table class="table" id="complainsTable">
                    <thead>
                        <tr>
                            <th>PO Number</th>
                            <th>Customer Name</th>
                            <th>Product Name</th>
                            <th>Rejected Quantity</th>
                            <th>Date</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (quarantinedComplainItems && quarantinedComplainItems.length > 0) { %>
                            <% quarantinedComplainItems.forEach(item => { %>
                                <tr>
                                    <td><%= item.Complain && item.Complain.Order ? item.Complain.Order.sonumber : 'N/A' %></td>
                                    <td><%= item.Complain && item.Complain.Order ? item.Complain.Order.customerName : 'N/A' %></td>
                                    <td><%= item.product || 'N/A' %></td>
                                    <td><%= item.quantityRejected || 0 %> KG</td>
                                    <td><%= new Date(item.createdAt).toLocaleDateString('en-US', { 
                                        year: 'numeric', 
                                        month: 'short', 
                                        day: 'numeric' 
                                    }) %></td>
                                    <td><%= item.notes || '-' %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                    No quarantined complain items found
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });
            observer.observe(sidebar, { attributes: true });

            // Search functionality for productions
            document.getElementById('productionSearch').addEventListener('input', function(e) {
                const searchText = e.target.value.toLowerCase();
                const table = document.getElementById('productionsTable');
                const rows = table.getElementsByTagName('tr');

                for (let i = 1; i < rows.length; i++) {
                    const row = rows[i];
                    if (!row.classList.contains('no-results')) {
                        const cells = row.getElementsByTagName('td');
                        let found = false;
                        for (let cell of cells) {
                            if (cell.textContent.toLowerCase().includes(searchText)) {
                                found = true;
                                break;
                            }
                        }
                        row.style.display = found ? '' : 'none';
                    }
                }
            });

            // Search functionality for complain items
            document.getElementById('complainSearch').addEventListener('input', function(e) {
                const searchText = e.target.value.toLowerCase();
                const table = document.getElementById('complainsTable');
                const rows = table.getElementsByTagName('tr');

                for (let i = 1; i < rows.length; i++) {
                    const row = rows[i];
                    if (!row.classList.contains('no-results')) {
                        const cells = row.getElementsByTagName('td');
                        let found = false;
                        for (let cell of cells) {
                            if (cell.textContent.toLowerCase().includes(searchText)) {
                                found = true;
                                break;
                            }
                        }
                        row.style.display = found ? '' : 'none';
                    }
                }
            });
        });
    </script>
</body>
</html>
