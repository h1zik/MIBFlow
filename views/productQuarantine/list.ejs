<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Quarantine List' }) %>
    <style>
        /* ----- Page-scoped flourishes (built on the shared --mib-* system) ----- */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }

        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/product-quarantine/list' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const productionList = (typeof quarantinedProductions !== 'undefined' && quarantinedProductions) ? quarantinedProductions : [];
        const complainList   = (typeof quarantinedComplainItems !== 'undefined' && quarantinedComplainItems) ? quarantinedComplainItems : [];

        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
        const fmtD = (d) => { if (!d) return '—'; const dt = new Date(d); return isNaN(dt) ? '—' : dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }); };
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Quarantine List',
              pageIcon: 'bi-exclamation-triangle',
              pageSubtitle: 'Quarantined productions and complain items held for review.'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-clipboard-x"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Quarantined Productions</div>
                    <div class="stat-value" data-count="<%= productionList.length %>">0</div>
                    <span class="stat-sub">Batches held for review</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-tools"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Quarantined Complain Items</div>
                    <div class="stat-value" data-count="<%= complainList.length %>">0</div>
                    <span class="stat-sub">Rejected items under hold</span>
                </div>
            </div>
        </div>

        <!-- Quarantined Productions -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-clipboard-x"></i> Quarantined Productions</h2>
                <div class="toolbar mb-0">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" class="form-control form-control-sm" id="productionSearch" placeholder="Search productions…" autocomplete="off">
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="productionsTable">
                    <thead>
                        <tr>
                            <th>PRODREQ Number</th>
                            <th>Batch Number</th>
                            <th>Product Name</th>
                            <th>Quantity</th>
                            <th>Production Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (productionList.length > 0) { %>
                            <% productionList.forEach(production => { %>
                                <tr>
                                    <td data-label="PRODREQ Number"><span class="cell-strong"><%= production.ProductionRequest ? production.ProductionRequest.prodreqnumber : 'N/A' %></span></td>
                                    <td data-label="Batch Number"><%= production.batchNumber || 'N/A' %></td>
                                    <td data-label="Product Name"><%= production.Product ? production.Product.name : 'N/A' %></td>
                                    <td data-label="Quantity"><%= production.quantity || 0 %> Kg</td>
                                    <td data-label="Production Date"><%= fmtD(production.createdAt) %></td>
                                    <td data-label="Status"><span class="status-badge <%= sb(production.status) %>"><%= production.status %></span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No quarantined productions</h4><p>Productions placed in quarantine will appear here.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Quarantined Complain Items -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-tools"></i> Quarantined Complain Items</h2>
                <div class="toolbar mb-0">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" class="form-control form-control-sm" id="complainSearch" placeholder="Search complain items…" autocomplete="off">
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle" id="complainsTable">
                    <thead>
                        <tr>
                            <th>PO Number</th>
                            <th>Customer Name</th>
                            <th>Product Name</th>
                            <th>Rejected Quantity</th>
                            <th>Date</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (complainList.length > 0) { %>
                            <% complainList.forEach(item => { %>
                                <tr>
                                    <td data-label="PO Number"><span class="cell-strong"><%= item.Complain && item.Complain.Order ? item.Complain.Order.sonumber : 'N/A' %></span></td>
                                    <td data-label="Customer Name"><%= item.Complain && item.Complain.Order ? item.Complain.Order.customerName : 'N/A' %></td>
                                    <td data-label="Product Name"><%= item.product || 'N/A' %></td>
                                    <td data-label="Rejected Quantity"><%= item.quantityRejected || 0 %> KG</td>
                                    <td data-label="Date"><%= fmtD(item.createdAt) %></td>
                                    <td data-label="Notes"><span class="cell-sub"><%= item.notes || '—' %></span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row"><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No quarantined complain items</h4><p>Complain items placed in quarantine will appear here.</p></div></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Live search that skips the empty-state row
            function wireSearch(inputId, tableId) {
                const input = document.getElementById(inputId);
                const table = document.getElementById(tableId);
                if (!input || !table) return;
                input.addEventListener('input', function (e) {
                    const q = e.target.value.toLowerCase();
                    table.querySelectorAll('tbody tr').forEach(function (row) {
                        if (row.classList.contains('is-empty-row')) return;
                        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                    });
                });
            }
            wireSearch('productionSearch', 'productionsTable');
            wireSearch('complainSearch', 'complainsTable');

            // Count-up stat values
            document.querySelectorAll('.stat-value[data-count]').forEach(el => {
                const target = parseInt(el.getAttribute('data-count'), 10) || 0;
                if (!target) { el.textContent = '0'; return; }
                const dur = 800, start = performance.now();
                (function tick(now) {
                    const p = Math.min((now - start) / dur, 1);
                    el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString('id-ID');
                    if (p < 1) requestAnimationFrame(tick);
                })(start);
            });
        });
    </script>
</body>
</html>
