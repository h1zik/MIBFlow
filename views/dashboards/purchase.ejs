    </div>

    <!-- jQuery + Chart.js loaded non-deferred so the inline handlers below have them available -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ---- SSE notifications ----
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/purchase.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);

            if (data.type === 'newRawMaterialRequest') {
                const notification = `New raw material request: ${data.materialName} (${data.quantity} Kg)`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'newPackagingRequest') {
                const notification = `New packaging request: ${data.packagingName} (${data.quantity} pcs)`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'newIndividualPackagingRequest') {
                const notification = `New packaging request: ${data.packagingName} (${data.quantity} pcs)`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'newIndividualRawMaterialRequest') {
                const notification = `New raw material request request: ${data.materialName} (${data.quantity} pcs)`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcFailRawMaterial') {
                const notification = `QC Failed: ${data.materialName} (${data.status})`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcFailPackaging') {
                const notification = `QC Failed: ${data.packagingName} (${data.status})`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcRejectSebagianRawMaterial') {
                const notification = `QC Failed: ${data.materialName} (${data.status})`;
                showNotification(notification);
                if (data.audio) { audio.play(); }
            }
        };

        function showNotification(message) {
            const notificationDiv = document.createElement('div');
            notificationDiv.className = 'alert alert-info alert-dismissible fade show';
            notificationDiv.style.position = 'fixed';
            notificationDiv.style.top = '20px';
            notificationDiv.style.right = '20px';
            notificationDiv.style.zIndex = '9999';
            notificationDiv.style.maxWidth = '360px';
            notificationDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(notificationDiv);
            setTimeout(() => { notificationDiv.remove(); }, 5000);
        }

        // Add global error handler
        window.onerror = function(msg, url, line) {
            console.error('JavaScript error:', msg);
            console.error('URL:', url);
            console.error('Line:', line);
        };

        document.addEventListener('DOMContentLoaded', function() {
            const rawMaterialLabels = JSON.parse('<%- JSON.stringify(rawMaterialLabels) %>');
            const rawMaterialData = JSON.parse('<%- JSON.stringify(rawMaterialData) %>');
            const colors = [
                '#4CAF50', '#2196F3', '#FFC107', '#9C27B0',
                '#FF5722', '#795548', '#607D8B'
            ];
            let currentChart = null;

            function createChart(type) {
                const container = document.querySelector('.chart-container');
                if (!container.offsetParent) {
                    container.style.display = 'block';
                }

                const canvas = document.getElementById('rawMaterialChart');
                const ctx = canvas.getContext('2d');

                if (currentChart) {
                    currentChart.destroy();
                    currentChart = null;
                }

                void canvas.offsetWidth;

                const formattedData = rawMaterialData.map(value => parseFloat(value).toFixed(2));

                currentChart = new Chart(ctx, {
                    type: type,
                    data: {
                        labels: rawMaterialLabels,
                        datasets: [{
                            data: formattedData,
                            backgroundColor: type === 'pie' ? colors : colors.map(color => `${color}CC`),
                            borderColor: type === 'pie' ? '#ffffff' : colors,
                            borderWidth: type === 'pie' ? 2 : 1,
                            maxBarThickness: 50,
                            label: 'Quantity (Kg)',
                            hoverBackgroundColor: colors,
                            hoverBorderColor: type === 'pie' ? '#ffffff' : colors,
                            hoverBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 750,
                            easing: 'easeInOutQuart'
                        },
                        plugins: {
                            legend: {
                                display: type === 'pie',
                                position: window.innerWidth > 768 ? 'right' : 'bottom',
                                labels: {
                                    boxWidth: 12,
                                    padding: 15,
                                    font: {
                                        size: 11,
                                        weight: 500
                                    },
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            return data.labels.map((label, i) => {
                                                const value = data.datasets[0].data[i];
                                                return {
                                                    text: `${label}: ${value} Kg`,
                                                    fillStyle: colors[i],
                                                    strokeStyle: '#ffffff',
                                                    lineWidth: 2,
                                                    hidden: false,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const label = context.label || '';
                                        const value = context.raw || 0;
                                        return `${label}: ${value} Kg`;
                                    }
                                }
                            }
                        },
                        ...(type === 'pie' ? {
                            cutout: '60%',
                            radius: '90%'
                        } : {
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: {
                                        display: true,
                                        drawBorder: false,
                                        color: 'rgba(0,0,0,0.1)'
                                    },
                                    ticks: {
                                        font: {
                                            size: 11,
                                            weight: 500
                                        },
                                        callback: function(value) {
                                            return value + ' Kg';
                                        }
                                    },
                                    title: {
                                        display: true,
                                        text: 'Quantity (Kg)',
                                        font: {
                                            size: 12,
                                            weight: 600
                                        }
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    },
                                    ticks: {
                                        font: {
                                            size: 11,
                                            weight: 500
                                        },
                                        maxRotation: 45,
                                        minRotation: 45
                                    }
                                }
                            }
                        })
                    }
                });
            }

            // Initialize chart after ensuring container is visible
            setTimeout(() => {
                createChart('pie');
            }, 0);

            // Handle chart type toggle
            document.querySelectorAll('[data-chart-type]').forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    if (this.classList.contains('active')) return;

                    document.querySelectorAll('[data-chart-type]').forEach(btn => {
                        btn.classList.remove('active');
                    });
                    this.classList.add('active');

                    requestAnimationFrame(() => {
                        createChart(this.dataset.chartType);
                    });
                });
            });

            // Handle responsive legend position
            window.addEventListener('resize', () => {
                if (currentChart) {
                    currentChart.options.plugins.legend.position = window.innerWidth > 768 ? 'right' : 'bottom';
                    currentChart.update();
                }
            });

            // Remove any existing event handlers
            $(document).off('click', '.btn-add-split, .remove-split');

            // Add new vendor split row - single handler for both raw material and packaging
            $(document).on('click', '.btn-add-split', function(e) {
                e.preventDefault();
                e.stopPropagation();

                const form = $(this).closest('form');
                const requestId = form.attr('action').split('/').pop();
                const container = form.find(`#split-rows-${requestId}`);

                // Clone the first row
                const newRow = container.find('.split-row').first().clone();

                // Clear input values and reset selects
                newRow.find('input').val('');
                newRow.find('select').prop('selectedIndex', 0);

                // Add a remove button
                const removeBtn = $('<button type="button" class="btn btn-outline-danger btn-sm mt-2 remove-split"><i class="bi bi-x-lg"></i> Remove</button>');
                newRow.append(removeBtn);

                // Append the new row
                container.append(newRow);
            });

            // Remove vendor split row
            $(document).on('click', '.remove-split', function(e) {
                e.preventDefault();
                e.stopPropagation();

                const splitRow = $(this).closest('.split-row');
                const container = splitRow.parent();

                // Only remove if there's more than one row
                if (container.find('.split-row').length > 1) {
                    splitRow.remove();
                }
            });

            // Form submission handler to validate the total quantity
            $(document).on('submit', 'form[action^="/rawMaterial/splitQuantity"], form[action^="/packaging-request/purchase/submitSplitQuantities"]', function(e) {
                const splitQuantities = $(this).find('input[name="splitQuantities[]"]').map(function() {
                    const value = parseFloat($(this).val());
                    return isNaN(value) ? 0 : value;
                }).get();

                const totalQuantity = splitQuantities.reduce((sum, qty) => sum + qty, 0);
                const realQuantity = parseFloat($(this).closest('tr').find('input[name="realQuantityHidden"]').val());

                if (totalQuantity !== realQuantity) {
                    alert('The total split quantity must equal the real quantity.');
                    e.preventDefault();
                }
            });

            // Adjust real quantity based on unit and density
            $(document).on('submit', '.real-quantity-form', function(e) {
                const form = $(this);
                const unit = form.find('select[name="unit"]').val();
                const realQuantityInput = form.find('input[name="realQuantity"]');
                const density = parseFloat(form.data('density'));

                if (unit === 'L' && density) {
                    const quantityInLiters = parseFloat(realQuantityInput.val());
                    const quantityInKg = quantityInLiters * density;
                    realQuantityInput.val(quantityInKg.toFixed(2)); // Convert to Kg and update the input
                }
            });

            // Adjust displayed quantity based on unit selection
            $(document).on('change', '.unit-selection', function() {
                const density = parseFloat($(this).data('density'));
                const originalQuantity = parseFloat($(this).data('quantity'));
                const quantityCell = $(this).closest('td');

                if ($(this).val() === 'L') {
                    const newQuantity = originalQuantity / density;
                    quantityCell.html(`${newQuantity.toFixed(2)} L`);
                } else {
                    quantityCell.html(`${originalQuantity} Kg`);
                }

                // Re-append the unit selection dropdown
                quantityCell.append($(this));
            });

            $(document).on('change', '.unit-selection-realQuantity', function() {
                const density = parseFloat($(this).data('density'));
                const originalQuantity = parseFloat($(this).data('quantity'));
                const quantityCell = $(this).closest('td');
                let newQuantity;

                if ($(this).val() === 'L') {
                    newQuantity = originalQuantity / density;
                    quantityCell.html(`${newQuantity.toFixed(2)} L`);
                } else {
                    newQuantity = originalQuantity;
                    quantityCell.html(`${newQuantity} Kg`);
                }

                // Update the hidden input value for real quantity
                const hiddenInput = quantityCell.find('input[name="realQuantityHidden"]');
                if (hiddenInput.length > 0) {
                    hiddenInput.val(originalQuantity.toFixed(2)); // Always store in Kg
                } else {
                    quantityCell.append(`<input type="hidden" name="realQuantityHidden" value="${originalQuantity.toFixed(2)}">`);
                }

                // Re-append the unit selection dropdown
                quantityCell.append($(this));
            });

            // Initialize collapsible sections (chevron rotation synced to bootstrap collapse)
            const sections = document.querySelectorAll('.dashboard-section');
            sections.forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');
                if (!content || !icon) return;

                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }

                content.addEventListener('show.bs.collapse', () => {
                    icon.style.transform = 'rotate(180deg)';
                });

                content.addEventListener('hide.bs.collapse', () => {
                    icon.style.transform = 'rotate(0)';
                });
            });

            // Form submissions loading state
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.classList.add('loading');
                        submitBtn.disabled = true;
                    }
                });
            });
        });

        // PO Number edit functions
        window.editPoNumber = function(id) {
            document.getElementById(`ponumber-${id}`).style.display = 'none';
            document.getElementById(`edit-ponumber-form-${id}`).style.display = 'block';
        }

        window.cancelEdit = function(id) {
            document.getElementById(`ponumber-${id}`).style.display = 'inline';
            document.getElementById(`edit-ponumber-form-${id}`).style.display = 'none';
        }
    </script>
    <script>

        // Submit real quantity AJAX handler for raw materials
        $(document).ready(function() {
            // Remove any existing event handlers to prevent duplicates
            $(document).off('submit', '.ajax-real-quantity');
            $(document).off('submit', '.ajax-vendor-split');
            $(document).off('submit', '.ajax-real-quantity-packaging');
            $(document).off('submit', '.ajax-vendor-split-packaging');

            // Prevent duplicate submissions for vendor split forms
            let isSubmittingVendorSplit = false;

            // Submit real quantity AJAX handler for raw materials
            $(document).on('submit', '.ajax-real-quantity', function(e) {
                e.preventDefault();
                const form = $(this);
                const url = form.attr('action');
                const requestId = form.data('request-id');
                const density = form.data('density');

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        // Update the real quantity cell
                        const realQuantityCell = form.closest('td');
                        const realQuantity = form.find('input[name="realQuantity"]').val();
                        const unit = form.find('select[name="unit"]').val();

                        realQuantityCell.html(`
                            ${realQuantity} ${unit}
                            <select class="unit-selection-realQuantity form-select form-select-sm d-inline-block w-auto" data-density="${density}" data-quantity="${realQuantity}">
                                <option value="Kg">Kg</option>
                                <option value="L">L</option>
                            </select>
                            <input type="hidden" name="realQuantityHidden" value="${realQuantity}">
                        `);

                        // Show vendor split container and hide the message
                        $(`#vendor-split-container-${requestId}`).show();
                        $(`#vendor-split-msg-${requestId}`).hide();
                    },
                    error: function(xhr, status, error) {
                        alert('Error setting real quantity: ' + error);
                    }
                });
            });

            // Submit vendor split AJAX handler for raw materials
            $(document).on('submit', '.ajax-vendor-split', function(e) {
                e.preventDefault();

                if (isSubmittingVendorSplit) {
                    return false;
                }

                isSubmittingVendorSplit = true;
                const form = $(this);
                const url = form.attr('action');

                // Validate total quantity before submitting
                const splitQuantities = form.find('input[name="splitQuantities[]"]').map(function() {
                    return parseFloat($(this).val()) || 0;
                }).get();

                const totalSplit = splitQuantities.reduce((a, b) => a + b, 0);
                const realQuantity = parseFloat(form.closest('tr').find('input[name="realQuantityHidden"]').val());

                if (Math.abs(totalSplit - realQuantity) > 0.01) {
                    alert('Total split quantity must equal the real quantity');
                    isSubmittingVendorSplit = false;
                    return false;
                }

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        // Hide the vendor split form and show success message
                        form.hide();
                        form.after('<span class="text-success">Vendor Split Submitted</span>');
                    },
                    error: function(xhr, status, error) {
                        alert('Error submitting vendor split: ' + error);
                    },
                    complete: function() {
                        isSubmittingVendorSplit = false;
                    }
                });
            });

            // Submit real quantity AJAX handler for packaging
            $(document).on('submit', '.ajax-real-quantity-packaging', function(e) {
                e.preventDefault();
                const form = $(this);
                const url = form.attr('action');
                const requestId = form.data('request-id');

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        // Update the real quantity cell
                        const realQuantityCell = form.closest('td');
                        const realQuantity = form.find('input[name="realQuantity"]').val();

                        realQuantityCell.html(`${realQuantity} pcs`);

                        // Show vendor split container and hide the message
                        $(`#vendor-split-container-${requestId}`).show();
                        $(`#vendor-split-msg-${requestId}`).hide();
                    },
                    error: function(xhr, status, error) {
                        alert('Error setting real quantity: ' + error);
                    }
                });
            });

            // Submit vendor split AJAX handler for packaging
            $(document).on('submit', '.ajax-vendor-split-packaging', function(e) {
                e.preventDefault();

                if (isSubmittingVendorSplit) {
                    return false;
                }

                isSubmittingVendorSplit = true;
                const form = $(this);
                const url = form.attr('action');

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: form.serialize(),
                    success: function(response) {
                        // Hide the vendor split form and show success message
                        form.hide();
                        form.after('<span class="text-success">Vendor Split Submitted</span>');
                    },
                    error: function(xhr, status, error) {
                        alert('Error submitting vendor split: ' + error);
                    },
                    complete: function() {
                        isSubmittingVendorSplit = false;
                    }
                });
            });

            // Add split row button handler
            $(document).on('click', '.btn-add-split', function() {
                const container = $(this).closest('form').find('.split-rows');
                const newRow = container.find('.split-row').first().clone();
                newRow.find('input').val('');
                container.append(newRow);
            });

            // Remove split row button handler
            $(document).on('click', '.btn-remove-split', function() {
                const container = $(this).closest('form').find('.split-rows');
                if (container.find('.split-row').length > 1) {
                    $(this).closest('.split-row').remove();
                }
            });
        });

        // Add handlers for Return and No Return buttons in failed requests
        $(document).off('submit', '.failed-request-return-form, .failed-request-no-return-form');

        // Handle Return button click for failed requests
        $(document).on('submit', '.failed-request-return-form', function(e) {
            e.preventDefault();
            const form = $(this);
            const url = form.attr('action');

            $.ajax({
                url: url,
                type: 'POST',
                data: form.serialize(),
                success: function(response) {
                    if (response.success) {
                        // Remove the entire row from the failed requests table
                        form.closest('tr').fadeOut(400, function() {
                            $(this).remove();
                        });
                    } else {
                        alert('Failed to process return. Please try again.');
                    }
                },
                error: function(xhr, status, error) {
                    alert('An error occurred. Please try again.');
                }
            });
        });

        // Handle No Return button click for failed requests
        $(document).on('submit', '.failed-request-no-return-form', function(e) {
            e.preventDefault();
            const form = $(this);
            const url = form.attr('action');

            $.ajax({
                url: url,
                type: 'POST',
                data: form.serialize(),
                success: function(response) {
                    if (response.success) {
                        // Remove the entire row from the failed requests table
                        form.closest('tr').fadeOut(400, function() {
                            $(this).remove();
                        });
                    } else {
                        alert('Failed to process no-return. Please try again.');
                    }
                },
                error: function(xhr, status, error) {
                    alert('An error occurred. Please try again.');
                }
            });
        });
    </script>
</body>
</html>
