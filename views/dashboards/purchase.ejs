                                                                    </select>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <select name="paymentTypes[]" class="form-select form-select-sm" required>
                                                                        <option value="CBD">CBD</option>
                                                                        <option value="DP">DP</option>
