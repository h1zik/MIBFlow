        <!-- ===================== Analytics ===================== -->
        <div class="row g-3 mb-4 mt-1 analytics-row">
            <!-- Raw Material Purchases Chart -->
            <div class="col-lg-6">
                <div class="dashboard-section">
                    <div class="section-header" style="cursor:default">
                        <h2 class="section-title">
