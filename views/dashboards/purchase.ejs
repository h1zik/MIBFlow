<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Purchase Dashboard' }) %>
    <style>
        /* Legacy-var bridge so shared partials (chat) stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }

        /* ---------- Hero ---------- */
        .dash-hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--mib-radius-lg);
            padding: 1.85rem 2rem;
            margin-bottom: 1.6rem;
            color: #eaf6ef;
            background: var(--mib-sidebar-bg);
            box-shadow: var(--mib-shadow-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
            flex-wrap: wrap;
        }
        .dash-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(460px 220px at 86% -30%, rgba(110, 231, 183, 0.30), transparent 60%),
                radial-gradient(360px 200px at 8% 130%, rgba(110, 231, 183, 0.15), transparent 60%);
        }
        .dash-hero__text { position: relative; z-index: 1; min-width: 0; }
        .dash-hello { margin: 0 0 0.35rem; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(255, 255, 255, 0.66); }
        .dash-hero h1 { margin: 0; font-size: 1.85rem; font-weight: 750; letter-spacing: -0.025em; color: #fff; display: flex; align-items: center; gap: 0.6rem; }
        .dash-hero p.sub { margin: 0.5rem 0 0; color: rgba(255, 255, 255, 0.78); font-size: 0.92rem; max-width: 52ch; }
        .dash-hero__actions { position: relative; z-index: 1; display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .dash-hero .btn-light { background: rgba(255, 255, 255, 0.14); border-color: rgba(255, 255, 255, 0.22); color: #fff; backdrop-filter: blur(4px); }
        .dash-hero .btn-light:hover { background: rgba(255, 255, 255, 0.24); color: #fff; }
        .dash-hero .btn-white { background: #fff; color: var(--mib-primary-dark); border: none; box-shadow: 0 8px 18px -6px rgba(0,0,0,0.3); }
        .dash-hero .btn-white:hover { background: #f3faf6; color: var(--mib-primary-dark); transform: translateY(-1px); }

        /* staggered entrance */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }
        .stagger > *:nth-child(3) { animation-delay: 0.19s; }
        .stagger > *:nth-child(4) { animation-delay: 0.26s; }
        .stagger > *:nth-child(5) { animation-delay: 0.33s; }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(185px, 1fr)); }
        .stat-icon.is-violet { background: linear-gradient(135deg, #a78bfa, #7c3aed); box-shadow: 0 8px 18px -4px rgba(124, 58, 237, 0.35); }

        /* ---------- Work-queue panels (built on the shared design system) ---------- */
        .dashboard-section {
            --accent: var(--mib-primary);
            --accent-soft: var(--mib-primary-soft);
            background: var(--mib-grad-surface);
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow);
            margin-bottom: 1rem;
            overflow: hidden;
            transition: box-shadow var(--mib-transition);
        }
        .dashboard-section:hover { box-shadow: var(--mib-shadow-md); }
        .section-header {
            position: relative; display: flex; align-items: center; gap: 0.85rem;
            padding: 1rem 1.25rem 1rem 1.4rem; cursor: pointer; transition: background var(--mib-transition);
        }
        .section-header:hover { background: var(--mib-surface-2); }
        .section-header::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
        .section-title {
            margin: 0; flex: 1; min-width: 0; font-weight: 650; font-size: 1rem; color: var(--mib-text);
            display: flex; align-items: center; gap: 0.6rem;
        }
        .section-title > i {
            flex-shrink: 0; width: 38px; height: 38px; border-radius: 11px; display: grid; place-items: center;
            font-size: 1.05rem; color: var(--accent); background: var(--accent-soft);
        }
        .section-title .badge { font-weight: 700; }
        .section-header > .bi-chevron-down { margin-left: auto; color: var(--mib-text-faint); font-size: 1.1rem; transition: transform 0.28s ease; }
        .section-content { border-top: 1px solid var(--mib-border); }
        .section-content .table-responsive { box-shadow: none; border: none; border-radius: 0; margin: 0; }

        /* accent tints per section */
        .dashboard-section.acc-raw    { --accent: #d97706; --accent-soft: #fef3c7; }
        .dashboard-section.acc-vendor { --accent: #2563eb; --accent-soft: #dbeafe; }
        .dashboard-section.acc-pkg    { --accent: #0d9488; --accent-soft: #ccfbf1; }
        .dashboard-section.acc-fail   { --accent: #e11d48; --accent-soft: #ffe4e6; }

        /* ---------- Badges used in tables ---------- */
        .badge-pending { background: var(--mib-warning-soft); color: #92400e; }
        .badge-success { background: var(--mib-success-soft); color: #166534; }
        .badge-danger  { background: var(--mib-danger-soft);  color: #991b1b; }
        .badge-pending, .badge-success, .badge-danger {
            display: inline-flex; align-items: center; gap: 0.35em;
            padding: 0.32em 0.7em; border-radius: var(--mib-radius-pill);
            font-size: 0.73rem; font-weight: 600; line-height: 1.2;
        }

        /* vendor split form spacing inside cells */
        .vendor-split-container { padding-top: 0.4rem; }
        .split-row.row { row-gap: 0.5rem; }

        /* charts */
        .analytics-row .dashboard-section { height: 100%; }
        .analytics-row .section-content { border-top: none; padding: 0 1.25rem 1.25rem; }
        .chart-container { position: relative; }

        .table thead th { background: var(--mib-surface-2); }

        /* button loading spinner */
        .btn.loading { pointer-events: none; color: transparent !important; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .dash-hero { padding: 1.4rem 1.25rem; }
            .dash-hero__actions { width: 100%; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/purchase' }) %>
    <%- include('../partials/chat', { users: (typeof users !== 'undefined' ? users : []), userRole: userRole, userId: userId }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const rawReqList   = (typeof rawMaterialRequests !== 'undefined' && rawMaterialRequests) ? rawMaterialRequests : [];
        const rawVendList  = (typeof rawMaterialRequestVendors !== 'undefined' && rawMaterialRequestVendors) ? rawMaterialRequestVendors : [];
        const pkgReqList   = (typeof packagingRequests !== 'undefined' && packagingRequests) ? packagingRequests : [];
        const pkgVendList  = (typeof packagingRequestVendors !== 'undefined' && packagingRequestVendors) ? packagingRequestVendors : [];
        const failPkgList  = (typeof failedPackagingRequests !== 'undefined' && failedPackagingRequests) ? failedPackagingRequests : [];
        const failRawList  = (typeof failedRawMaterialRequestsVendors !== 'undefined' && failedRawMaterialRequestsVendors) ? failedRawMaterialRequestsVendors : [];
        const topVendorList = (typeof topVendors !== 'undefined' && topVendors) ? topVendors : [];

        const procurementCount = rawReqList.length + pkgReqList.length;
        const failedCount = failRawList.length + failPkgList.length;

        /* status badge helper (shared design-system fallback) */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
    %>

    <div class="content content-wide">

        <!-- ===================== Hero ===================== -->
        <div class="dash-hero fade-in">
            <div class="dash-hero__text">
                <p class="dash-hello">Purchase Workspace</p>
                <h1><i class="bi bi-cart-fill"></i> Purchase Dashboard</h1>
                <p class="sub">Manage raw material requests, vendor assignments and packaging procurement in one place.</p>
            </div>
            <div class="dash-hero__actions">
                <a href="/vendorList" class="btn btn-light"><i class="bi bi-people"></i> Vendor List</a>
                <a href="/ppic/addVendor" class="btn btn-white"><i class="bi bi-plus-lg"></i> Add Vendor</a>
            </div>
        </div>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-box-seam"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Raw Material Requests</div>
                    <div class="stat-value"><%= rawReqList.length %></div>
                    <span class="stat-sub">Awaiting real quantity &amp; split</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Vendor Assignments</div>
                    <div class="stat-value"><%= rawVendList.length + pkgVendList.length %></div>
                    <span class="stat-sub">Active vendor splits</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-violet"><i class="bi bi-box2"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Packaging Requests</div>
                    <div class="stat-value"><%= pkgReqList.length %></div>
                    <span class="stat-sub">Pending procurement</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon <%= failedCount > 0 ? 'is-danger' : 'is-success' %>"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Failed / Rejected</div>
                    <div class="stat-value"><%= failedCount %></div>
                    <span class="stat-sub">Needs return decision</span>
                </div>
            </div>
        </div>

        <%- include('../partials/kanban-toggle') %>

        <!-- ===================== Raw Material Requests ===================== -->
        <div class="dashboard-section acc-raw">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#rawMaterialRequests" aria-expanded="true" aria-controls="rawMaterialRequests">
                <h2 class="section-title">
                    <i class="bi bi-box-seam"></i>
                    Raw Material Requests
                    <% if (rawReqList.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= rawReqList.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="rawMaterialRequests" class="collapse section-content">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Material Name</th>
                                <th>Quantity</th>
                                <th>Real Quantity</th>
                                <th>Vendor Split</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (rawReqList.length > 0) { %>
                                <% rawReqList.forEach(request => { %>
                                    <tr>
                                        <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                        <td data-label="PO Number"><%= request.ponumber %></td>
                                        <td data-label="Material Name"><span class="cell-strong"><%= request.RawMaterial.name %></span></td>
                                        <td data-label="Quantity">
                                            <%= request.quantity %>
                                            <select class="unit-selection form-select form-select-sm d-inline-block w-auto" data-density="<%= request.RawMaterial.density %>" data-quantity="<%= request.quantity %>">
                                                <option value="Kg">Kg</option>
                                                <option value="L">L</option>
                                            </select>
                                        </td>
                                        <td data-label="Real Quantity">
                                            <% if (request.realQuantity) { %>
                                                <%= request.realQuantity %> Kg
                                                <select class="unit-selection-realQuantity form-select form-select-sm d-inline-block w-auto" data-density="<%= request.RawMaterial.density %>" data-quantity="<%= request.realQuantity %>">
                                                    <option value="Kg">Kg</option>
                                                    <option value="L">L</option>
                                                </select>
                                                <input type="hidden" name="realQuantityHidden" value="<%= request.realQuantity %>">
                                            <% } else { %>
                                                <form action="/purchase/setRealQuantity/<%= request.id %>" method="POST" class="d-flex gap-2 ajax-real-quantity" data-density="<%= request.RawMaterial.density %>" data-request-id="<%= request.id %>">
                                                    <input type="number" name="realQuantity" class="form-control form-control-sm" placeholder="Real Quantity" required>
                                                    <select name="unit" class="form-select form-select-sm w-auto" required>
                                                        <option value="Kg">Kg</option>
                                                        <option value="L">L</option>
                                                    </select>
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Submit</button>
                                                </form>
                                            <% } %>
                                        </td>
                                        <td data-label="Vendor Split">
                                            <!-- Pre-render vendor-split container; hide if no real quantity or if already assigned -->
<div id="vendor-split-container-<%= request.id %>" class="vendor-split-container" style="display: <%= request.realQuantity && request.status !== 'Vendor Assigned' ? 'block' : 'none' %>">
                                                <% if (request.RawMaterial && request.RawMaterial.Vendors && request.RawMaterial.Vendors.length > 0) { %>
                                                    <form action="/rawMaterial/splitQuantity/<%= request.id %>" method="POST" class="ajax-vendor-split">
                                                        <div id="split-rows-<%= request.id %>">
                                                            <div class="split-row row g-2">
                                                                <div class="col-md-4">
                                                                    <select name="vendorIds[]" class="form-select form-select-sm" required>
                                                                        <% request.RawMaterial.Vendors.forEach(vendor => { %>
                                                                            <option value="<%= vendor.id %>"><%= vendor.name %></option>
                                                                        <% }) %>
                                                                    </select>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <input type="number" name="splitQuantities[]" class="form-control form-control-sm" placeholder="Quantity (Kg)" required>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <select name="taxes[]" class="form-select form-select-sm" required>
                                                                        <option value="PPN 11%">PPN 11%</option>
                                                                        <option value="PPh 23">PPh 23</option>
                                                                        <option value="Non Pajak">Non Pajak</option>
                                                                    </select>
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <select name="paymentTypes[]" class="form-select form-select-sm" required>
                                                                        <option value="CBD">CBD</option>
                                                                        <option value="DP">DP</option>
                                                                        <option value="TOP15">TOP 15 Days</option>
                                                                        <option value="TOP30">TOP 30 Days</option>
                                                                        <option value="TOP45">TOP 45 Days</option>
                                                                        <option value="TOP60">TOP 60 Days</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex flex-wrap gap-2 mt-3">
                                                            <button type="button" class="btn btn-sm btn-soft btn-add-split"><i class="bi bi-plus-lg"></i> Add Vendor</button>
                                                            <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Submit Vendor Splits</button>
                                                        </div>
                                                    </form>
                                                <% } else { %>
                                                    <p class="text-muted-2 mb-0">No vendors available for this raw material. Please assign vendors in the <a href="/rawMaterials/rawMaterialStock">raw material list</a>.</p>
                                                <% } %>
                                            </div>
                                            <% if (!request.realQuantity) { %>
                                                <p class="text-muted-2 mb-0" id="vendor-split-msg-<%= request.id %>">Submit the real quantity to enable vendor splitting.</p>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No raw material requests</h4><p>New raw material requests will appear here.</p></div></td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== Raw Material Request Vendor ===================== -->
        <div class="dashboard-section acc-vendor">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#rawMaterialRequestVendors" aria-expanded="true" aria-controls="rawMaterialRequestVendors">
                <h2 class="section-title">
                    <i class="bi bi-truck"></i>
                    Raw Material Request Vendor
                    <% if (rawVendList.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= rawVendList.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="rawMaterialRequestVendors" class="collapse section-content">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Material Name</th>
                                <th>Vendor</th>
                                <th>Split Quantity</th>
                                <th>Tax</th>
                                <th>Payment Type</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (rawVendList.length > 0) { %>
                                <% rawVendList.forEach(vendor => { %>
                                    <tr>
                                        <td data-label="ID"><span class="cell-strong">#<%= vendor.id %></span></td>
                                        <td data-label="PO Number">
                                            <div class="d-flex align-items-center justify-content-end justify-content-md-start">
                                                <span id="ponumber-<%= vendor.id %>"><%= vendor.ponumber || 'N/A' %></span>
                                                <button class="btn btn-icon btn-sm btn-ghost ms-2" onclick="editPoNumber('<%= vendor.id %>')" aria-label="Edit PO number">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            </div>
                                            <form id="edit-ponumber-form-<%= vendor.id %>" style="display: none;"
                                                  action="/rawMaterial/updatePoNumber/<%= vendor.id %>" method="POST"
                                                  class="mt-2">
                                                <div class="input-group input-group-sm">
                                                    <input type="text" name="ponumber" class="form-control"
                                                           value="<%= vendor.ponumber || '' %>" required>
                                                    <button type="submit" class="btn btn-success">Save</button>
                                                    <button type="button" class="btn btn-light"
                                                            onclick="cancelEdit('<%= vendor.id %>')">Cancel</button>
                                                </div>
                                            </form>
                                        </td>
                                        <td data-label="Material Name"><span class="cell-strong"><%= vendor.RawMaterialRequest.materialName %></span></td>
                                        <td data-label="Vendor"><%= vendor.Vendor ? vendor.Vendor.name : 'N/A' %></td>
                                        <td data-label="Split Quantity"><%= vendor.splitQuantity %> Kg</td>
                                        <td data-label="Tax"><%= vendor.tax %></td>
                                        <td data-label="Payment Type"><%= vendor.paymentType %></td>
                                        <td data-label="Status"><span class="status-badge <%= sb(vendor.status) %>"><%= vendor.status %></span></td>
                                        <td data-label="Actions"></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No raw material request vendors</h4><p>Vendor splits will appear here once assigned.</p></div></td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== Packaging Requests ===================== -->
        <div class="dashboard-section acc-pkg">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#packagingRequests" aria-expanded="true" aria-controls="packagingRequests">
                <h2 class="section-title">
                    <i class="bi bi-box2"></i>
                    Packaging Requests
                    <% if (pkgReqList.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= pkgReqList.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="packagingRequests" class="collapse section-content">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Packaging Name</th>
                                <th>Quantity</th>
                                <th>Real Quantity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pkgReqList.length > 0) { %>
                                <% pkgReqList.forEach(request => { %>
                                    <tr id="packaging-row-<%= request.id %>">
                                        <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                        <td data-label="PO Number"><%= request.ponumber %></td>
                                        <td data-label="Packaging Name"><span class="cell-strong"><%= request.packagingName %></span></td>
                                        <td data-label="Quantity"><%= request.quantity %> pcs</td>
                                        <td data-label="Real Quantity" id="real-quantity-cell-<%= request.id %>">
                                            <% if (request.realQuantity) { %>
                                                <%= request.realQuantity %> pcs
                                                <input type="hidden" name="realQuantityHidden" value="<%= request.realQuantity %>">
                                            <% } else { %>
                                                <form action="/packaging-request/purchase/setRealQuantity/<%= request.id %>" method="POST" class="d-flex gap-2 ajax-real-quantity-packaging" data-request-id="<%= request.id %>">
                                                    <input type="number" name="realQuantity" class="form-control form-control-sm" placeholder="Real Quantity" required>
                                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Submit</button>
                                                </form>
                                            <% } %>
                                        </td>
                                        <td data-label="Status">
                                            <span class="badge badge-<%= request.status === 'Pending' ? 'pending' : 'success' %>">
                                                <i class="bi bi-<%= request.status === 'Pending' ? 'clock' : 'check-circle' %>"></i>
                                                <%= request.status %>
                                            </span>
                                        </td>
                                        <td data-label="Actions">
                                            <!-- Pre-render vendor-split container; hide if no real quantity or if already assigned -->
<div id="vendor-split-container-<%= request.id %>" class="vendor-split-container" style="display: <%= request.realQuantity && request.status !== 'Vendor Assigned' ? 'block' : 'none' %>">
                                                <% if (request.Packaging && request.Packaging.Vendors && request.Packaging.Vendors.length > 0) { %>
                                                    <form action="/packaging-request/purchase/submitSplitQuantities/<%= request.id %>" method="POST" class="ajax-vendor-split-packaging">
                                                        <div id="split-rows-<%= request.id %>">
                                                            <div class="split-row row g-2">
                                                                <div class="col-md-4">
                                                                    <select name="vendorIds[]" class="form-select form-select-sm" required>
                                                                        <% request.Packaging.Vendors.forEach(vendor => { %>
                                                                            <option value="<%= vendor.id %>"><%= vendor.name %></option>
                                                                        <% }) %>
                                                                    </select>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <input type="number" name="splitQuantities[]" class="form-control form-control-sm" placeholder="Quantity (pcs)" required>
                                                                </div>
                                                                <div class="col-md-3">
