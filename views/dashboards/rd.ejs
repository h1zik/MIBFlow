<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>R&D Dashboard - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-light: #4caf50;
            --primary-dark: #1b5e20;
            --text-color: #2c3e50;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 2rem;
            transition: var(--transition);
            width: 100%;
        }

        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                width: calc(100% - 280px);
            }

            body.sidebar-collapsed .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }
        }

        .page-header {
            background: white;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            animation: slideDown 0.5s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .dashboard-section {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            overflow: hidden;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-header {
            padding: 1.5rem;
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-header:hover {
            background-color: #d7ecd8;
        }

        .section-header .bi-chevron-down {
            transition: transform 0.3s ease;
        }

        .section-header.collapsed .bi-chevron-down {
            transform: rotate(-90deg);
        }

        .section-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-content {
            padding: 1.5rem;
            display: none;
        }

        .section-content.show {
            display: block;
            animation: slideDown 0.3s ease-out;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
        }

        .table tbody tr {
            transition: var(--transition);
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .badge {
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .badge i {
            font-size: 0.75rem;
        }

        .badge-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .badge-approved {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-rejected {
            background-color: #f8d7da;
            color: #842029;
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
        }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);
        }

        .btn-success {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-success:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .action-buttons .btn {
            padding: 0.4rem 0.8rem;
            font-size: 0.875rem;
        }

        .input-group-sm .form-control {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }

        .input-group-sm .btn {
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
        }

        /* Loading Animation */
        .loading {
            pointer-events: none;
            position: relative;
        }

        .loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin: -10px 0 0 -10px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Enhanced Mobile Styles */
        @media (max-width: 768px) {
            /* Layout Improvements */
            .main-content {
                margin-left: 0;
                padding: 0.75rem;
                width: 100%;
            }

            .dashboard-section {
                margin-bottom: 1rem;
                border-radius: 10px;
            }

            .section-header {
                padding: 0.875rem;
            }

            .section-content {
                padding: 0.75rem;
            }

            /* Mobile Table Improvements */
            .table-responsive {
                border-radius: 8px;
                background: white;
                box-shadow: var(--shadow);
                margin-bottom: 1rem;
            }

            .table {
                display: block;
            }

            .table thead {
                display: none; /* Hide headers on mobile */
            }

            .table tbody {
                display: block;
            }

            .table tr {
                display: block;
                margin-bottom: 1rem;
                border: 1px solid var(--background-light);
                border-radius: 8px;
                background: white;
            }

            .table td {
                display: flex;
                padding: 0.75rem;
                align-items: center;
                border: none;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .table td:last-child {
                border-bottom: none;
            }

            .table td::before {
                content: attr(data-label);
                font-weight: 600;
                width: 120px;
                min-width: 120px;
                color: var(--primary-dark);
                font-size: 0.85rem;
            }

            .table td > * {
                flex: 1;
                margin-left: 1rem;
            }

            /* Form Controls */
            .form-control {
                height: 40px;
                font-size: 16px; /* Prevents iOS zoom */
                padding: 0.5rem;
            }

            .input-group {
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            .input-group > * {
                flex: 1 1 auto;
                width: 100% !important;
                margin: 0 !important;
            }

            .input-group .btn {
                border-radius: 8px !important;
            }

            /* Button Improvements */
            .btn {
                height: 40px;
                padding: 0 1rem;
                margin: 0.25rem;
                font-size: 0.9rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 100px;
                touch-action: manipulation;
            }

            .action-buttons {
                flex-direction: column;
                gap: 0.5rem;
            }

            .action-buttons .btn {
                width: 100%;
                justify-content: center;
                margin: 0;
            }

            /* Status Badge Adjustments */
            .status-badge {
                font-size: 0.8rem;
                padding: 0.4rem 0.8rem;
            }

            /* Touch-friendly Improvements */
            .btn, 
            .form-control,
            select,
            .section-header {
                cursor: pointer;
                -webkit-tap-highlight-color: transparent;
            }

            .btn:active,
            .section-header:active {
                transform: scale(0.98);
            }

            /* Scrollbar Improvements */
            .table-responsive::-webkit-scrollbar {
                height: 6px;
            }

            .table-responsive::-webkit-scrollbar-track {
                background: transparent;
            }

            .table-responsive::-webkit-scrollbar-thumb {
                background-color: var(--primary-light);
                border-radius: 3px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-flask"></i>
                R&D Dashboard
            </h1>
            <p class="text-muted mb-0">Manage formulas, rework items, and TDS/MSDS requests</p>
        </div>

        <!-- Flash Messages -->
        <% if (messages && messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <% if (messages.error.includes('\n')) { %>
                    <pre class="mb-0" style="white-space: pre-wrap;"><%= messages.error %></pre>
                <% } else { %>
                    <%= messages.error %>
                <% } %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        
        <% if (messages && messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <%- include('../partials/kanban-toggle') %>
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#formulaRequests">
                <h2 class="section-title">
                    <i class="bi bi-list-check"></i>
                    Formula Requests
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="formulaRequests" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (formulaRequests && formulaRequests.length > 0) { %>
                                <% formulaRequests.forEach(function(request) { %>
                                    <tr>
                                        <td data-label="ID">#<%= request.id %></td>
                                        <td data-label="Product"><%= request.Product.name %></td>
                                        <td data-label="Date"><%= new Date(request.createdAt).toLocaleDateString() %></td>
                                        <td data-label="Status">
                                            <% if (request.status === 'Pending') { %>
                                                <span class="status-badge status-pending">Pending</span>
                                            <% } else if (request.status === 'Approved') { %>
                                                <span class="status-badge status-approved">Approved</span>
                                            <% } else { %>
                                                <span class="status-badge status-rejected">Rejected</span>
                                            <% } %>
                                        </td>
                                        <td data-label="Actions">
                                            <% if (request.status === 'Pending') { %>
                                                <form action="/rd/uploadFormula/<%= request.id %>" method="POST" enctype="multipart/form-data" class="d-inline">
                                                    <div class="input-group input-group-sm">
                                                        <input type="file" name="formula" accept="application/pdf" required class="form-control">
                                                        <button type="submit" class="btn btn-success">
                                                            <i class="bi bi-check-lg"></i>
                                                            Approve
                                                        </button>
                                                    </div>
                                                </form>
                                                <form action="/rd/declineFormula/<%= request.id %>" method="POST" class="d-inline ms-2">
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-x-lg"></i>
                                                        Decline
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <a href="/formulaRequests/<%= request.id %>" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-eye"></i>
                                                    View
                                                </a>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No formula requests found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#reworkItems">
                <h2 class="section-title">
                    <i class="bi bi-tools"></i>
                    Rework Items
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="reworkItems" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>PO Number</th>
                                <th>Customer Name</th>
                                <th>Product</th>
                                <th>Quantity Rejected</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (reworkItems && reworkItems.length > 0) { %>
                                <% reworkItems.forEach(function(item) { %>
                                    <tr>
                                        <td data-label="PO Number"><%= item.Complain.Order.sonumber %></td>
                                        <td data-label="Customer Name"><%= item.Complain.Order.customerName %></td>
                                        <td data-label="Product"><%= item.product %></td>
                                        <td data-label="Quantity Rejected"><%= item.quantityRejected %> KG</td>
                                        <td data-label="Notes"><%= item.notes || '-' %></td>
                                        <td data-label="Actions">
                                            <div class="action-buttons">
                                                <a href="/rd/insert-raw-materials/<%= item.id %>" class="btn btn-primary">
                                                    <i class="bi bi-plus-circle"></i>
                                                    Insert Raw Materials
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No rework items found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#tdsmsdsRequests">
                <h2 class="section-title">
                    <i class="bi bi-file-text"></i>
                    TDSMSDS Requests
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="tdsmsdsRequests" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Request Type</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (tdsmsdsRequests && tdsmsdsRequests.length > 0) { %>
                                <% const pendingRequests = tdsmsdsRequests.filter(request => request.status !== 'Approved'); %>
                                <% if (pendingRequests.length > 0) { %>
                                    <% pendingRequests.forEach(function(request) { %>
                                        <tr>
                                            <td data-label="ID">#<%= request.id %></td>
                                            <td data-label="Product"><%= request.Product.name %></td>
                                            <td data-label="Request Type"><%= request.requestType %></td>
                                            <td data-label="Date"><%= new Date(request.createdAt).toLocaleDateString() %></td>
                                            <td data-label="Status">
                                                <% if (request.status === 'Pending') { %>
                                                    <span class="status-badge status-pending">Pending</span>
                                                <% } else if (request.status === 'Approved') { %>
                                                    <span class="status-badge status-approved">Approved</span>
                                                <% } else { %>
                                                    <span class="status-badge status-rejected">Rejected</span>
                                                <% } %>
                                            </td>
                                            <td data-label="Actions">
                                                <% if (request.status === 'Pending') { %>
                                                    <form action="/tdsmsdsRequest/upload/<%= request.id %>" method="POST" enctype="multipart/form-data" class="d-inline">
                                                        <div class="input-group input-group-sm">
                                                            <input type="file" name="<%= request.requestType.toLowerCase() %>" accept="application/pdf" required class="form-control">
                                                            <button type="submit" class="btn btn-success">
                                                                <i class="bi bi-check-lg"></i>
                                                                Upload & Approve
                                                            </button>
                                                        </div>
                                                    </form>
                                                    <form action="/tdsmsdsRequest/decline/<%= request.id %>" method="POST" class="d-inline ms-2">
                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                            <i class="bi bi-x-lg"></i>
                                                            Decline
                                                        </button>
                                                    </form>
                                                <% } else if (request.status === 'Declined') { %>
                                                    <span class="text-danger">Declined</span>
                                                <% } else { %>
                                                    <a href="/tdsmsdsRequests/<%= request.id %>" class="btn btn-sm btn-primary">
                                                        <i class="bi bi-eye"></i>
                                                        View
                                                    </a>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No pending TDSMSDS requests found
                                    </td>
                                    </tr>
                                <% } %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No TDSMSDS requests found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set up SSE for notifications
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/rd.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);
            
            if (data.type === 'newTdsMsdsRequest') {
                // Show notification for new TDS/MSDS request
                const notification = `New ${data.requestType} request for ${data.productName}`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }

                // Refresh the page to show the new request
                setTimeout(() => {
                    location.reload();
                }, 3000);
            } else if (data.type === 'rdFormula') {
                // Show notification for formula request
                const notification = `New formula request for ${data.product} (${data.sonumber} - ${data.customerName})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }

                // Refresh the page to show the new request
                setTimeout(() => {
                    location.reload();
                }, 3000);
            }
        };

        function showNotification(message) {
            const notificationDiv = document.createElement('div');
            notificationDiv.className = 'alert alert-info alert-dismissible fade show';
            notificationDiv.style.position = 'fixed';
            notificationDiv.style.top = '20px';
            notificationDiv.style.right = '20px';
            notificationDiv.style.zIndex = '9999';
            notificationDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(notificationDiv);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                notificationDiv.remove();
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            // Handle sidebar collapse state
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Initial state check
            if (sidebar.classList.contains('collapsed')) {
                document.body.classList.add('sidebar-collapsed');
            }

            // Handle section collapse/expand
            document.querySelectorAll('.section-header').forEach(header => {
                header.addEventListener('click', () => {
                    const chevron = header.querySelector('.bi-chevron-down');
                    if (header.classList.contains('collapsed')) {
                        chevron.style.transform = 'rotate(-90deg)';
                    } else {
                        chevron.style.transform = 'rotate(0deg)';
                    }
                });
            });

            // Initialize chevron states
            document.querySelectorAll('.section-header').forEach(header => {
                const chevron = header.querySelector('.bi-chevron-down');
                if (header.classList.contains('collapsed')) {
                    chevron.style.transform = 'rotate(-90deg)';
                }
            });
        });
    </script>
    <%- include('../partials/chat', { users: users, userRole: userRole, userId: userId }) %>
</body>
</html>
