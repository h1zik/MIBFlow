<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'R&D Dashboard' }) %>
    <style>
        /* ============================================================
           R&D Dashboard — page-specific flourishes
           Built on the shared mibflow.css design system.
           ============================================================ */

        /* Legacy-var bridge so shared partials (chat, kanban) stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }

        /* ---------- Hero ---------- */
        .rd-hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--mib-radius-lg);
            padding: 1.85rem 2rem;
            margin-bottom: 1.6rem;
            color: #eaf6ef;
            background: var(--mib-sidebar-bg);
            box-shadow: var(--mib-shadow-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
            flex-wrap: wrap;
        }
        .rd-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(460px 220px at 86% -30%, rgba(110, 231, 183, 0.30), transparent 60%),
                radial-gradient(360px 200px at 8% 130%, rgba(110, 231, 183, 0.15), transparent 60%);
        }
        .rd-hero__text { position: relative; z-index: 1; min-width: 0; }
        .rd-eyebrow {
            margin: 0 0 0.4rem; font-size: 0.78rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255, 255, 255, 0.66);
            display: inline-flex; align-items: center; gap: 0.5rem;
        }
        .live-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #6ee7b7; box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.7);
            animation: livePulse 1.8s ease-out infinite;
        }
        @keyframes livePulse {
            0%   { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55); }
            70%  { box-shadow: 0 0 0 9px rgba(110, 231, 183, 0); }
            100% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0); }
        }
        .rd-hero h1 {
            margin: 0; font-size: 1.85rem; font-weight: 750; letter-spacing: -0.025em; color: #fff;
            display: flex; align-items: center; gap: 0.6rem;
        }
        .rd-hero .sub { margin: 0.5rem 0 0; color: rgba(255, 255, 255, 0.78); font-size: 0.92rem; max-width: 56ch; }
        .rd-hero__actions { position: relative; z-index: 1; display: flex; gap: 0.6rem; flex-wrap: wrap; justify-content: flex-end; }
        .rd-hero .btn-white { background: #fff; color: var(--mib-primary-dark); border: none; box-shadow: 0 8px 18px -6px rgba(0,0,0,0.3); }
        .rd-hero .btn-white:hover { background: #f3faf6; color: var(--mib-primary-dark); transform: translateY(-1px); }
        .rd-hero .btn-glass { background: rgba(255,255,255,0.13); border: 1px solid rgba(255,255,255,0.22); color: #fff; backdrop-filter: blur(4px); }
        .rd-hero .btn-glass:hover { background: rgba(255,255,255,0.22); color: #fff; }

        /* ---------- Staggered entrance ---------- */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }
        .stagger > *:nth-child(3) { animation-delay: 0.19s; }
        .stagger > *:nth-child(4) { animation-delay: 0.26s; }

        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .stat-icon.is-violet { background: linear-gradient(135deg, #a78bfa, #7c3aed); box-shadow: 0 8px 18px -4px rgba(124, 58, 237, 0.35); }

        /* ---------- Queue panels (shared kanban-toggle compatible) ---------- */
        .dashboard-section {
            --accent: var(--mib-primary);
            --accent-soft: var(--mib-primary-soft);
            background: var(--mib-grad-surface);
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow);
            margin-bottom: 1rem;
            overflow: hidden;
            transition: box-shadow var(--mib-transition), border-color var(--mib-transition);
        }
        .dashboard-section:hover { box-shadow: var(--mib-shadow-md); }
        .section-header {
            position: relative; display: flex; align-items: center; gap: 0.85rem;
            padding: 1rem 1.25rem 1rem 1.4rem; cursor: pointer; transition: background var(--mib-transition);
        }
        .section-header:hover { background: var(--mib-surface-2); }
        .section-header::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
        .sec-ico {
            flex-shrink: 0; width: 40px; height: 40px; border-radius: 12px; display: grid; place-items: center;
            font-size: 1.1rem; color: var(--accent); background: var(--accent-soft);
        }
        .section-title {
            margin: 0; font-weight: 650; font-size: 1rem; color: var(--mib-text);
            display: flex; align-items: center; gap: 0.55rem;
        }
        .section-title .badge {
            display: inline-flex; align-items: center; justify-content: center; min-width: 1.5rem; height: 1.5rem; padding: 0 0.5rem;
            border-radius: var(--mib-radius-pill); background: var(--accent-soft); color: var(--accent);
            font-size: 0.78rem; font-weight: 700;
        }
        .section-title .badge.is-zero { background: var(--mib-surface-2); color: var(--mib-text-faint); }
        .sec-sub { margin: 0.1rem 0 0; font-size: 0.78rem; color: var(--mib-text-muted); }
        .section-header .bi-chevron-down { margin-left: auto; color: var(--mib-text-faint); font-size: 1.1rem; transition: transform 0.28s ease; }
        .section-header.collapsed .bi-chevron-down { transform: rotate(-90deg); }
        .section-content { border-top: 1px solid var(--mib-border); }
        .section-content .table-responsive { box-shadow: none; border: none; border-radius: 0; margin: 0; }
        .table thead th { background: var(--mib-surface-2); }
        .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }

        /* approve-with-upload inline group */
        .upload-approve { display: flex; align-items: stretch; gap: 0.4rem; flex-wrap: wrap; }
        .upload-approve .form-control { max-width: 230px; }

        /* button loading spinner */
        .btn.loading { pointer-events: none; color: transparent !important; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .rd-hero { padding: 1.4rem 1.25rem; }
            .rd-hero__actions { justify-content: flex-start; }
            .upload-approve .form-control { max-width: 100%; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/rd' }) %>
    <%- include('../partials/chat', { users: (typeof users !== 'undefined' ? users : []), userRole: userRole, userId: userId }) %>

    <%
        /* ---- Defensive normalisation (guard optional locals) ---- */
        const formulaReqList = (typeof formulaRequests !== 'undefined' && formulaRequests) ? formulaRequests : [];
        const reworkList     = (typeof reworkItems !== 'undefined' && reworkItems) ? reworkItems : [];
        const tdsmsdsList    = (typeof tdsmsdsRequests !== 'undefined' && tdsmsdsRequests) ? tdsmsdsRequests : [];
        const pendingTdsmsds = tdsmsdsList.filter(r => r.status !== 'Approved');

        const flash        = (typeof messages !== 'undefined' && messages) ? messages : {};
        const flashSuccess = flash.success;
        const flashError   = flash.error;

        /* status badge helper */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
    %>

    <div class="content content-wide">

        <!-- ===================== Hero ===================== -->
        <div class="rd-hero fade-in">
            <div class="rd-hero__text">
                <p class="rd-eyebrow"><span class="live-dot"></span> R&amp;D Workspace</p>
                <h1><i class="bi bi-flask"></i> R&amp;D Dashboard</h1>
                <p class="sub">Manage formulas, rework items and TDS/MSDS requests — one place to keep the lab moving.</p>
            </div>
            <div class="rd-hero__actions">
                <a href="/products/listProduct" class="btn btn-glass"><i class="bi bi-box-seam"></i> Products</a>
                <a href="/products/addProduct" class="btn btn-white"><i class="bi bi-plus-lg"></i> Add Product</a>
            </div>
        </div>

        <!-- ===================== Flash messages ===================== -->
        <% if (flashError) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <% if (String(flashError).includes('\n')) { %><pre class="mb-0" style="white-space:pre-wrap"><%= flashError %></pre><% } else { %><span><%= flashError %></span><% } %>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (flashSuccess) { %>
            <div class="mib-flash mib-flash-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><%= flashSuccess %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-list-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Formula Requests</div>
                    <div class="stat-value"><%= formulaReqList.length %></div>
                    <span class="stat-sub">Awaiting formula upload</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon <%= reworkList.length > 0 ? 'is-danger' : 'is-success' %>"><i class="bi bi-tools"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Rework Items</div>
                    <div class="stat-value"><%= reworkList.length %></div>
                    <span class="stat-sub">Need raw materials</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-violet"><i class="bi bi-file-text"></i></div>
                <div class="stat-body">
                    <div class="stat-label">TDS/MSDS Requests</div>
                    <div class="stat-value"><%= pendingTdsmsds.length %></div>
                    <span class="stat-sub">Pending documents</span>
                </div>
            </div>
        </div>

        <!-- ===================== List / Board toggle ===================== -->
        <%- include('../partials/kanban-toggle') %>

        <!-- ===================== Formula Requests ===================== -->
        <div class="dashboard-section" style="--accent:#4f46e5;--accent-soft:#e0e7ff">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#formulaRequests" aria-expanded="true" aria-controls="formulaRequests">
                <span class="sec-ico"><i class="bi bi-list-check"></i></span>
                <div class="sec-titles">
                    <h2 class="section-title">Formula Requests <span class="badge <%= formulaReqList.length ? '' : 'is-zero' %>"><%= formulaReqList.length %></span></h2>
                    <p class="sec-sub">Upload &amp; approve formulas requested from R&amp;D</p>
                </div>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="formulaRequests" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (formulaReqList.length > 0) { %>
                                <% formulaReqList.forEach(function(request) { %>
                                    <tr>
                                        <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                        <td data-label="Product"><span class="cell-strong"><%= request.Product ? request.Product.name : '—' %></span></td>
                                        <td data-label="Date"><%= new Date(request.createdAt).toLocaleDateString() %></td>
                                        <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                        <td data-label="Actions" class="text-end">
                                            <% if (request.status === 'Pending') { %>
                                                <div class="action-buttons justify-content-end">
                                                    <form action="/rd/uploadFormula/<%= request.id %>" method="POST" enctype="multipart/form-data" class="d-inline">
                                                        <div class="upload-approve">
                                                            <input type="file" name="formula" accept="application/pdf" required class="form-control form-control-sm">
                                                            <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Approve</button>
                                                        </div>
                                                    </form>
                                                    <form action="/rd/declineFormula/<%= request.id %>" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Decline</button>
                                                    </form>
                                                </div>
                                            <% } else { %>
                                                <div class="action-buttons justify-content-end">
                                                    <a href="/formulaRequests/<%= request.id %>" class="btn btn-sm btn-primary"><i class="bi bi-eye"></i> View</a>
                                                </div>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="5"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No formula requests</h4><p>Requested formulas will appear here for upload.</p></div></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== Rework Items ===================== -->
        <div class="dashboard-section" style="--accent:#e11d48;--accent-soft:#ffe4e6">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#reworkItems" aria-expanded="true" aria-controls="reworkItems">
                <span class="sec-ico"><i class="bi bi-tools"></i></span>
                <div class="sec-titles">
                    <h2 class="section-title">Rework Items <span class="badge <%= reworkList.length ? '' : 'is-zero' %>"><%= reworkList.length %></span></h2>
                    <p class="sec-sub">Insert raw materials for rejected production</p>
                </div>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="reworkItems" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>PO Number</th>
                                <th>Customer Name</th>
                                <th>Product</th>
                                <th>Quantity Rejected</th>
                                <th>Notes</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (reworkList.length > 0) { %>
                                <% reworkList.forEach(function(item) { %>
                                    <tr>
                                        <td data-label="PO Number"><span class="cell-strong"><%= (item.Complain && item.Complain.Order) ? item.Complain.Order.sonumber : '—' %></span></td>
                                        <td data-label="Customer Name"><%= (item.Complain && item.Complain.Order) ? item.Complain.Order.customerName : '—' %></td>
                                        <td data-label="Product"><%= item.product %></td>
                                        <td data-label="Quantity Rejected"><%= item.quantityRejected %> KG</td>
                                        <td data-label="Notes"><%= item.notes || '-' %></td>
                                        <td data-label="Actions" class="text-end">
                                            <div class="action-buttons justify-content-end">
                                                <a href="/rd/insert-raw-materials/<%= item.id %>" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> Insert Raw Materials</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No rework items</h4><p>Rejected items needing rework will appear here.</p></div></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== TDS/MSDS Requests ===================== -->
        <div class="dashboard-section" style="--accent:#7c3aed;--accent-soft:#f3e8ff">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#tdsmsdsRequests" aria-expanded="true" aria-controls="tdsmsdsRequests">
                <span class="sec-ico"><i class="bi bi-file-text"></i></span>
                <div class="sec-titles">
                    <h2 class="section-title">TDS/MSDS Requests <span class="badge <%= pendingTdsmsds.length ? '' : 'is-zero' %>"><%= pendingTdsmsds.length %></span></h2>
                    <p class="sec-sub">Upload technical &amp; safety data sheets</p>
                </div>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="tdsmsdsRequests" class="section-content collapse show">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Request Type</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pendingTdsmsds.length > 0) { %>
                                <% pendingTdsmsds.forEach(function(request) { %>
                                    <tr>
                                        <td data-label="ID"><span class="cell-strong">#<%= request.id %></span></td>
                                        <td data-label="Product"><span class="cell-strong"><%= request.Product ? request.Product.name : '—' %></span></td>
                                        <td data-label="Request Type"><%= request.requestType %></td>
                                        <td data-label="Date"><%= new Date(request.createdAt).toLocaleDateString() %></td>
                                        <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                        <td data-label="Actions" class="text-end">
                                            <% if (request.status === 'Pending') { %>
                                                <div class="action-buttons justify-content-end">
                                                    <form action="/tdsmsdsRequest/upload/<%= request.id %>" method="POST" enctype="multipart/form-data" class="d-inline">
                                                        <div class="upload-approve">
                                                            <input type="file" name="<%= request.requestType.toLowerCase() %>" accept="application/pdf" required class="form-control form-control-sm">
                                                            <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Upload &amp; Approve</button>
                                                        </div>
                                                    </form>
                                                    <form action="/tdsmsdsRequest/decline/<%= request.id %>" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Decline</button>
                                                    </form>
                                                </div>
                                            <% } else if (request.status === 'Declined') { %>
                                                <span class="status-badge status-declined">Declined</span>
                                            <% } else { %>
                                                <div class="action-buttons justify-content-end">
                                                    <a href="/tdsmsdsRequests/<%= request.id %>" class="btn btn-sm btn-primary"><i class="bi bi-eye"></i> View</a>
                                                </div>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No TDS/MSDS requests</h4><p>Pending TDS &amp; MSDS document requests will appear here.</p></div></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <script>
        // ---- SSE notifications ----
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/rd.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);

            if (data.type === 'newTdsMsdsRequest') {
                const notification = `New ${data.requestType} request for ${data.productName}`;
                showNotification(notification);
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }
                setTimeout(() => { location.reload(); }, 3000);
            } else if (data.type === 'rdFormula') {
                const notification = `New formula request for ${data.product} (${data.sonumber} - ${data.customerName})`;
                showNotification(notification);
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }
                setTimeout(() => { location.reload(); }, 3000);
            }
        };

        function showNotification(message) {
            const n = document.createElement('div');
            n.className = 'alert alert-info alert-dismissible fade show';
            n.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;max-width:360px';
            n.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>`;
            document.body.appendChild(n);
            setTimeout(() => { n.remove(); }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Section collapse chevron sync (kanban-auto.js handles board mode)
            document.querySelectorAll('.section-header[data-bs-toggle="collapse"]').forEach(header => {
                const target = document.querySelector(header.getAttribute('data-bs-target'));
                if (!target) return;
                target.addEventListener('show.bs.collapse', () => header.classList.remove('collapsed'));
                target.addEventListener('hide.bs.collapse', () => header.classList.add('collapsed'));
            });

            // Button loading state on submit
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function() {
                    const btn = this.querySelector('button[type="submit"]');
                    if (btn) { btn.classList.add('loading'); btn.disabled = true; }
                });
            });
        });
    </script>
</body>
</html>
