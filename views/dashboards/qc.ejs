        <!-- Rework Production Quality Control Section -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#reworkProductionList">
                <h2 class="section-title">
                    <i class="bi bi-arrow-repeat"></i>
                    Rework Production Quality Control
                    <% if (reworkProductions && reworkProductions.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= reworkProductions.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="reworkProductionList" class="section-content collapse">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Batch</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Tanks</th>
                                <th>Dates</th>
                                <th>QC Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (reworkProductions && reworkProductions.length > 0) { %>
                                <% reworkProductions.forEach(function(rework) { %>
                                    <tr>
                                        <td data-label="Batch">
                                            <div class="fw-semibold">#<%= rework.batchNumber %></div>
                                            <small class="text-muted">ID: <%= rework.id %></small>
                                        </td>
                                        <td data-label="Product"><%= rework.ComplainItem.product %></td>
                                        <td data-label="Quantity"><%= rework.quantity %> KG</td>
                                        <td data-label="Tanks">
                                            <div class="d-flex flex-wrap gap-1">
                                                <% rework.Tanks.forEach(tank => { %>
                                                    <div class="d-flex flex-column align-items-center">
                                                        <span class="badge badge-tank mb-1">
                                                            <%= tank.name %> (<%= tank.volume %> L)
                                                        </span>
                                                        <small class="badge bg-light text-secondary border d-flex align-items-center gap-1" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">
                                                            <i class="bi bi-arrow-repeat"></i>
                                                            Stir <%= rework.stirSequence %>
                                                        </small>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        </td>
                                        <td data-label="Dates">
                                            <div>Start: <%= rework.startDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
                                            <div>Due: <%= rework.deadlineDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></div>
                                        </td>
                                        <td data-label="QC Status">
                                            <% if (rework.qcStatus === 'Pass') { %>
                                                <span class="badge badge-pass">
                                                    <i class="bi bi-check-circle"></i> Pass
                                                </span>
                                            <% } else if (rework.qcStatus === 'Fail') { %>
                                                <span class="badge badge-fail">
                                                    <i class="bi bi-x-circle"></i> Fail
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-clock"></i> Pending
                                                </span>
                                            <% } %>
                                            <% if (rework.qcComment) { %>
                                                <div class="small text-muted mt-1">
                                                    <%= rework.qcComment %>
                                                </div>
                                            <% } %>
                                        </td>
                                        <td data-label="Actions">
                                            <div id="actions-<%= rework.id %>">
                                                <% if (rework.qcStatus !== 'Pass' && rework.qcStatus !== 'Fail') { %>
                                                    <form class="qc-form" onsubmit="handleReworkQCSubmit(event, '<%= rework.id %>')">
                                                        <select class="form-select" name="qcStatus" required>
                                                            <option value="">Select Status</option>
                                                            <option value="Pass">Pass QC</option>
                                                            <option value="Fail">Fail QC</option>
                                                        </select>
                                                        <textarea class="form-control" name="qcComment" placeholder="Add QC comments..." required></textarea>
                                                        <button type="submit" class="btn btn-primary w-100">
                                                            <i class="bi bi-check-lg"></i>
                                                            Submit QC Result
                                                        </button>
                                                    </form>
                                                <% } %>
                                                <% if (rework.qcStatus === 'Pass' && !rework.sampleRetained) { %>
                                                    <form class="retain-sample-form" onsubmit="handleRetainReworkSample(event, '<%= rework.id %>')">
                                                        <div class="form-group">
                                                            <label for="retainedSampleVolume">Sample Volume (ml)</label>
                                                            <input type="number" id="retainedSampleVolume" name="retainedSampleVolume" placeholder="Enter volume" required>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="expiredDate">Expired Date</label>
                                                            <input type="date" id="expiredDate" name="expiredDate" required>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="rackNumber">No Rack</label>
                                                            <input type="text" id="rackNumber" name="rackNumber" placeholder="Enter rack number" required>
                                                        </div>
                                                        <button type="submit" class="btn btn-primary">
                                                            <i class="bi bi-flask"></i>
                                                            Retain Sample & Print Label
                                                        </button>
                                                    </form>
                                                <% } else if (rework.sampleRetained) { %>
                                                    <div class="retain-sample-form">
                                                        <div class="form-group">
                                                            <label>Sample Volume</label>
                                                            <div class="form-control-plaintext"><%= rework.retainedSampleVolume %> ml</div>
                                                        </div>
                                                        <div class="form-group">
                                                            <label>Expired Date</label>
                                                            <div class="form-control-plaintext"><%= new Date(rework.expiryDate).toLocaleDateString() %></div>
                                                        </div>
                                                        <div class="form-group">
                                                            <label>No Rack</label>
                                                            <div class="form-control-plaintext"><%= rework.rackNumber %></div>
                                                        </div>
                                                        <a href="/qc/generateReworkPDF/<%= rework.id %>" class="btn print-label-btn" target="_blank">
                                                            <i class="bi bi-printer"></i>
                                                            Print Label
                                                        </a>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No rework productions pending QC
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle QC form submissions
            async function makeRequest(url, method = 'POST', data = null) {
                try {
                    const options = {
                        method
                    };

                    if (data instanceof FormData) {
                        // For FormData, don't set Content-Type header - browser will set it with boundary
                        options.body = data;
                    } else if (data) {
                        options.headers = { 'Content-Type': 'application/json' };
                        options.body = JSON.stringify(data);
                    }

                    const response = await fetch(url, options);
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return await response.json();
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred. Please try again.');
                    throw error;
                }
            }

            // Update UI after QC status change
            function updateQCStatus(elementId, status, comment, newActions = '') {
                const statusCell = document.querySelector(`#status-${elementId}`);
                const actionsCell = document.querySelector(`#actions-${elementId}`);

                if (statusCell) {
                    let badgeClass = 'badge-pending';
                    let icon = 'clock';
                    
                    if (status === 'Pass') {
                        badgeClass = 'badge-pass';
                        icon = 'check-circle';
                    } else if (status === 'Fail') {
                        badgeClass = 'badge-fail';
                        icon = 'x-circle';
                    }

                    statusCell.innerHTML = `
                        <span class="badge ${badgeClass}">
                            <i class="bi bi-${icon}"></i>
                            ${status}
                        </span>
                        ${comment ? `<div class="small text-muted mt-1">${comment}</div>` : ''}
                    `;
                }

                if (actionsCell && newActions) {
                    actionsCell.innerHTML = newActions;
                    // Reattach event listeners to new form if needed
                    if (newActions.includes('retain-sample-form')) {
                        const newForm = actionsCell.querySelector('.retain-sample-form');
                        if (newForm) {
                            newForm.addEventListener('submit', (e) => handleRetainSample(e, elementId));
                        }
                    }
                }
            }

            // Toggle BG scan field visibility
            window.toggleBGScanField = function(select) {
                const form = select.closest('form');
                const bgscanSection = form.querySelector('.bgscan-section');
                const bgscanInput = form.querySelector('[name="bgscan"]');
                
                if (select.value === 'Pass') {
                    bgscanSection.style.display = 'block';
                    bgscanInput.required = true;
                } else {
                    bgscanSection.style.display = 'none';
                    bgscanInput.required = false;
                }
            };

            // Production QC form submission
            window.handleQCSubmit = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    qcStatus: form.qcStatus.value,
                    qcComment: form.qcComment.value
                };

                const result = await makeRequest(`/qc/updateStatus/${id}`, 'POST', data);
                if (result.success) {
                    updateQCStatus(id, result.status, result.comment, result.newActions);
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    const alertClass = result.status === 'Fail' ? 'alert-danger' : 'alert-success';
                    const message = result.status === 'Fail' ? 
                        'QC result: Failed! This item has been marked as failed.' :
                        'QC status has been updated successfully.';
                    actionsCell.innerHTML = `
                        <div class="alert ${alertClass}">
                            <strong>${result.status === 'Fail' ? 'Failed!' : 'Success!'}</strong> ${message}
                        </div>
                    ` + (result.newActions || '');
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Toggle QC fields visibility
            window.toggleQCFields = function(select) {
                const form = select.closest('form');
                const rejectSection = form.querySelector('.reject-comment-section');
                const rejectComment = form.querySelector('[name="rejectComment"]');
                const passSection = form.querySelector('.pass-qc-section');
                const batchNumber = form.querySelector('[name="batchNumber"]');
                const expiredDate = form.querySelector('[name="expiredDate"]');
                
                // Hide all sections first
                rejectSection.style.display = 'none';
                passSection.style.display = 'none';
                rejectComment.required = false;
                batchNumber.required = false;
                expiredDate.required = false;

                // Show relevant section based on selection
                if (select.value === 'Reject Sebagian') {
                    rejectSection.style.display = 'block';
                    rejectComment.required = true;
                } else if (select.value === 'Pass') {
                    passSection.style.display = 'block';
                    batchNumber.required = true;
                    expiredDate.required = true;
                }
            };

            // Raw Material QC form submission
            window.handleRawMaterialQCSubmit = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    qcStatus: form.qcStatus.value,
                    qcComment: form.qcComment.value,
                    rejectComment: form.qcStatus.value === 'Reject Sebagian' ? form.rejectComment.value : null,
                    batchNumber: form.qcStatus.value === 'Pass' ? form.batchNumber.value : null,
                    expiredDate: form.qcStatus.value === 'Pass' ? form.expiredDate.value : null
                };

                const result = await makeRequest(`/qc/updateStatusRawMaterial/${id}`, 'POST', data);
                if (result.success) {
                    updateQCStatus(id, result.status, result.comment, result.newActions);
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    if (result.status === 'Reject Sebagian') {
                        actionsCell.innerHTML = `
                            <div class="alert alert-warning">
                                <strong>Partially Rejected!</strong> This item has been sent to Raw Material Warehouse for quantity assessment.
                            </div>
                        `;
                    } else if (result.status === 'Fail') {
                        actionsCell.innerHTML = `
                            <div class="alert alert-danger">
                                <strong>Failed!</strong> Raw material QC result: Failed. This item has been marked as failed.
                            </div>
                        `;
                    } else {
                        actionsCell.innerHTML = `
                            <div class="alert alert-success">
                                <strong>Success!</strong> Raw material QC status has been updated successfully.
                            </div>
                        `;
                    }
                    if (result.rejectComment) {
                        // Show reject comment in status cell
                        const statusCell = document.querySelector(`#status-${id}`);
                        if (statusCell) {
                            const commentDiv = document.createElement('div');
                            commentDiv.className = 'small text-danger mt-1';
                            commentDiv.textContent = `Reject Reason: ${result.rejectComment}`;
                            statusCell.appendChild(commentDiv);
                        }
                    }
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Packaging QC form submission
            window.handlePackagingQCSubmit = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    qcStatus: form.qcStatus.value,
                    qcComment: form.qcComment.value
                };

                const result = await makeRequest(`/qc/updateStatusPackaging/${id}`, 'POST', data);
                if (result.success) {
                    updateQCStatus(id, result.status, result.comment, result.newActions);
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    if (result.status === 'Reject Sebagian') {
                        actionsCell.innerHTML = `
                            <div class="alert alert-warning">
                                <strong>Partially Rejected!</strong> This item has been sent to Warehouse for quantity assessment.
                            </div>
                        `;
                    } else if (result.status === 'Fail') {
                        actionsCell.innerHTML = `
                            <div class="alert alert-danger">
                                <strong>Failed!</strong> Packaging QC result: Failed. This item has been marked as failed.
                            </div>
                        `;
                    } else {
                        actionsCell.innerHTML = `
                            <div class="alert alert-success">
                                <strong>Success!</strong> Packaging QC status has been updated successfully.
                            </div>
                        `;
                    }
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Product Check QC form submission
            window.handleProductCheckQCSubmit = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    qcStatus: form.qcStatus.value,
                    qcComment: form.qcComment.value
                };

                const result = await makeRequest(`/products/productCheck/${id}/updateQC`, 'POST', data);
                if (result.success) {
                    updateQCStatus(id, result.status, result.comment);
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    
                    let alertClass, message, statusText;
                    
                    if (result.status === 'Fail') {
                        alertClass = 'alert-danger';
                        message = 'Product check QC result: Failed. This item has been marked as failed.';
                        statusText = 'Failed!';
                    } else if (result.status === 'Reject Sebagian') {
                        alertClass = 'alert-warning';
                        message = 'Product check QC result: Partially Rejected. This item has been marked for partial rejection.';
                        statusText = 'Partially Rejected!';
                    } else {
                        alertClass = 'alert-success';
                        message = 'Product check QC status has been updated successfully.';
                        statusText = 'Success!';
                    }
                    
                    actionsCell.innerHTML = `
                        <div class="alert ${alertClass}">
                            <strong>${statusText}</strong> ${message}
                        </div>
                    `;
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Rework QC form submission
            window.handleReworkQCSubmit = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    qcStatus: form.qcStatus.value,
                    qcComment: form.qcComment.value
                };

                const result = await makeRequest(`/qc/updateReworkStatus/${id}`, 'POST', data);
                if (result.success) {
                    updateQCStatus(id, result.status, result.comment, result.newActions);
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    const alertClass = result.status === 'Fail' ? 'alert-danger' : 'alert-success';
                    const message = result.status === 'Fail' ? 
                        'Rework QC result: Failed. This item has been marked as failed.' :
                        'Rework QC status has been updated successfully.';
                    actionsCell.innerHTML = `
                        <div class="alert ${alertClass}">
                            <strong>${result.status === 'Fail' ? 'Failed!' : 'Success!'}</strong> ${message}
                        </div>
                    ` + (result.newActions || '');
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Retain rework sample form submission
            window.handleRetainReworkSample = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                // Show loading state
                submitBtn.disabled = true;
                submitBtn.classList.add('loading');
                submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                submitBtn.innerHTML = '';

                const data = {
                    retainedSampleVolume: form.retainedSampleVolume.value,
                    expiredDate: form.expiredDate.value,
                    rackNumber: form.rackNumber.value
                };

                const result = await makeRequest(`/qc/retainReworkSample/${id}`, 'POST', data);
                if (result.success) {
                    // Open PDF in new tab
                    window.open(result.pdfUrl, '_blank');
                    // Update the UI with retained sample info
                    const actionsCell = document.querySelector(`#actions-${id}`);
                    if (actionsCell) {
                        actionsCell.innerHTML = `
                            <div class="alert alert-success">
                                <strong>Success!</strong> Rework sample has been retained successfully.
                            </div>
                        ` + (result.newActions || '');
                    }
                }

                // Restore button state
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
                submitBtn.innerHTML = submitBtn.getAttribute('original-text');
            };

            // Retain sample form submission
            window.handleRetainSample = async function(event, id) {
                event.preventDefault();
                const form = event.target;
                const submitBtn = form.querySelector('button[type="submit"]');
                
                try {
                    // Show loading state
                    submitBtn.disabled = true;
                    submitBtn.classList.add('loading');
                    submitBtn.setAttribute('original-text', submitBtn.innerHTML);
                    submitBtn.innerHTML = '';

                    // Get form values
                    const retainedSampleVolume = form.querySelector('[name="retainedSampleVolume"]').value;
                    const expiredDate = form.querySelector('[name="expiredDate"]').value;
                    const noRack = form.querySelector('[name="noRack"]').value;
                    const bgscanFile = form.querySelector('[name="bgscan"]').files[0];

                    // Validate required fields
                    if (!retainedSampleVolume || !expiredDate || !noRack || !bgscanFile) {
                        throw new Error('Please fill in all required fields');
                    }

                    // Create FormData object
                    const formData = new FormData();
                    formData.append('retainedSampleVolume', retainedSampleVolume);
                    formData.append('expiredDate', expiredDate);
                    formData.append('noRack', noRack);
                    formData.append('bgscan', bgscanFile);

                    // Log values for debugging
                    console.log('Form values:', {
                        retainedSampleVolume,
                        expiredDate,
                        noRack,
                        hasBgscan: !!bgscanFile
                    });

                    const result = await makeRequest(`/qc/retainSample/${id}`, 'POST', formData);
                    if (result.success) {
                        // Open PDF in new tab
                        window.open(result.pdfUrl, '_blank');
                        // Update the UI with retained sample info
                        const actionsCell = document.querySelector(`#actions-${id}`);
                        if (actionsCell) {
                            actionsCell.innerHTML = `
                                <div class="alert alert-success">
                                    <strong>Success!</strong> Sample has been retained successfully.
                                </div>
                            ` + (result.newActions || '');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert(error.message || 'An error occurred. Please try again.');
                } finally {
                    // Restore button state
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('loading');
                    submitBtn.innerHTML = submitBtn.getAttribute('original-text');
                }
            };

            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });
            observer.observe(sidebar, { attributes: true });

            // Initialize collapsible sections
            const sections = document.querySelectorAll('.dashboard-section');
            sections.forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');

                // Set initial state
                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }

                // Use Bootstrap's collapse events
                content.addEventListener('show.bs.collapse', () => {
                    icon.style.transform = 'rotate(180deg)';
                });

                content.addEventListener('hide.bs.collapse', () => {
                    icon.style.transform = 'rotate(0)';
                });
            });

            // Form submissions
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.classList.add('loading');
                        submitBtn.disabled = true;
                    }
                });
            });

            // Set up SSE for notifications
            const evtSource = new EventSource('/notifications');
            const audio = new Audio('/audio/qc.mp3');

            evtSource.onmessage = function(event) {
                const data = JSON.parse(event.data);
                
                if (data.type === 'newProductCheck') {
                    const notification = `New product check request: ${data.productName} (${data.quantity} KG)`;
                    showNotification(notification);
                    
                    // Play audio if specified
                    if (data.audio) {
                        audio.play().catch(e => console.error('Error playing audio:', e));
                    }

                    // Refresh the page to show the new request
                    setTimeout(() => {
                        location.reload();
                    }, 3000);
                } else if (data.type === 'newQCRequest') {
                    // Show notification based on source
                    let notification = '';
                    if (data.source === 'Raw Material') {
                        notification = `New QC request for raw material: ${data.materialName}`;
                    } else if (data.source === 'Packaging') {
                        notification = `New QC request for packaging: ${data.packagingName}`;
                    } else if (data.source === 'Production') {
                        notification = `New QC request for production batch: ${data.batchNumber} (${data.productName})`;
                    } else if (data.source === 'Complain') {
                        notification = `New QC request for rework batch: ${data.batchNumber}`;
                    }
                    
                    showNotification(notification);
                    
                    // Play audio if specified
                    if (data.audio) {
                        audio.play().catch(e => console.error('Error playing audio:', e));
                    }

                    // Refresh the page to show the new request
                    setTimeout(() => {
                        location.reload();
                    }, 3000);
                } else if (data.type === 'newComplainQC') {
                    // Show notification for new complain QC request
                    const notification = `New complain QC request: ${data.sonumber} (${data.customerName})`;
                    showNotification(notification);
                    
                    // Play audio if specified
                    if (data.audio) {
                        audio.play().catch(e => console.error('Error playing audio:', e));
                    }

                    // Refresh the page to show the new request
                    setTimeout(() => {
                        location.reload();
                    }, 3000);
                }
            };

            function showNotification(message) {
                const notificationDiv = document.createElement('div');
                notificationDiv.className = 'alert alert-info alert-dismissible fade show';
                notificationDiv.style.position = 'fixed';
                notificationDiv.style.top = '20px';
                notificationDiv.style.right = '20px';
                notificationDiv.style.zIndex = '9999';
                notificationDiv.innerHTML = `
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.body.appendChild(notificationDiv);

                // Auto-remove after 5 seconds
                setTimeout(() => {
                    notificationDiv.remove();
                }, 5000);
            }
        });
    </script>
    <%- include('../partials/chat', { users: users, userRole: userRole, userId: userId }) %>
</body>
</html>
