            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#packagingRequests">
                <h2 class="section-title">
                    <i class="bi bi-box2"></i>
                    Packaging Quality Control
                    <% if (packagingRequestVendors && packagingRequestVendors.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= packagingRequestVendors.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="packagingRequests" class="section-content collapse">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Packaging</th>
                                <th>Vendor</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>QC Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (packagingRequestVendors && packagingRequestVendors.length > 0) { %>
                                <% packagingRequestVendors.forEach(function(requestVendor) { %>
                                    <tr>
                                        <td data-label="ID">#<%= requestVendor.id %></td>
                                        <td data-label="PO Number"><%= requestVendor.ponumber %></td>
                                        <td data-label="Packaging">
                                            <div class="fw-semibold"><%= requestVendor.PackagingRequest.packagingName %></div>
                                        </td>
                                        <td data-label="Vendor"><%= requestVendor.Vendor.name %></td>
                                        <td data-label="Quantity">
                                            <% if (requestVendor.rejectQuantity && requestVendor.status === 'QC Testing') { %>
                                                <%= requestVendor.rejectQuantity %> pcs (Rejected Quantity)
                                            <% } else { %>
                                                <%= requestVendor.splitQuantity %> pcs
                                            <% } %>
                                        </td>
                                        <td data-label="Status"><%= requestVendor.status %></td>
                                        <td data-label="QC Status" id="status-<%= requestVendor.id %>">
                                            <% if (requestVendor.qcStatus === 'Pass') { %>
                                                <span class="badge badge-pass">
                                                    <i class="bi bi-check-circle"></i> Pass
                                                </span>
                                            <% } else if (requestVendor.qcStatus === 'Fail') { %>
                                                <span class="badge badge-fail">
                                                    <i class="bi bi-x-circle"></i> Fail
                                                </span>
                                            <% } else { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-clock"></i> Pending
                                                </span>
