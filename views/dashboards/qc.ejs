                                        </td>
                                        <td data-label="Actions">
                                            <div id="actions-<%= requestVendor.id %>">
                                                <form class="qc-form" onsubmit="handlePackagingQCSubmit(event, '<%= requestVendor.id %>')">
                                                    <select class="form-select" name="qcStatus" onchange="toggleQCFields(this)" required>
                                                        <option value="">Select Status</option>
                                                        <option value="Pass">Pass QC</option>
                                                        <option value="Fail">Fail QC</option>
                                                        <option value="Reject Sebagian">Reject Sebagian</option>
                                                    </select>
                                                    <textarea class="form-control" name="qcComment" placeholder="Add QC comments..." required></textarea>
                                                    <div class="reject-comment-section" style="display: none;">
                                                        <textarea class="form-control" name="rejectComment" placeholder="Enter rejection reason..."></textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-primary w-100">
                                                        <i class="bi bi-check-lg"></i>
                                                        Submit QC Result
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No packaging requests pending QC
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
