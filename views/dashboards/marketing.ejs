<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Marketing Dashboard', extraScripts: ['https://cdn.jsdelivr.net/npm/chart.js'] }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/marketing' }) %>
    <%- include('../partials/chat', { userId: userId, users: users }) %>

    <div class="content content-wide">
        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-speedometer2"></i> Marketing Dashboard</h1>
                <p class="page-subtitle">Overview of your orders, customers and sales activity.</p>
            </div>
            <div class="page-actions">
                <a href="/orders/create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Order</a>
            </div>
        </div>

        <!-- Quick stats -->
        <div class="quick-stats fade-in">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-receipt"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Orders</div>
                    <div class="stat-value"><%= orders.length %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= orders.filter(o => o.status === 'Pending').length %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-arrow-repeat"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Processing</div>
                    <div class="stat-value"><%= orders.filter(o => o.status === 'Processing').length %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Delivered</div>
                    <div class="stat-value"><%= orders.filter(o => o.status === 'Delivered').length %></div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="chart-grid">
            <div class="chart-card">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h3 class="mb-0"><i class="bi bi-pie-chart me-1"></i> Top Products Distribution</h3>
                    <div class="btn-group">
                        <button type="button" class="btn btn-sm btn-outline-primary active" data-chart-type="pie" aria-label="Pie chart"><i class="bi bi-pie-chart"></i></button>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-chart-type="bar" aria-label="Bar chart"><i class="bi bi-bar-chart"></i></button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <h3><i class="bi bi-people me-1"></i> Top 5 Customers</h3>
                <% if (topCustomers && topCustomers.length) { %>
                <div class="list-group list-group-flush">
                    <% topCustomers.forEach((customer, index) => { %>
                    <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <div class="d-flex align-items-center gap-2">
                            <span class="pill"><%= index + 1 %></span>
                            <span class="cell-strong"><%= customer.name %></span>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold">Rp <%= customer.totalAmount.toLocaleString() %></div>
                            <small class="cell-sub"><%= customer.totalOrders %> orders</small>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <div class="empty-state"><i class="bi bi-people"></i><p>No customer data yet.</p></div>
                <% } %>
            </div>
        </div>

        <!-- Recent orders -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-clock-history"></i> Recent Orders</h2>
                <div class="toolbar mb-0">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" id="orderSearch" class="form-control form-control-sm" placeholder="Search orders…">
                    </div>
                    <select id="dateRange" class="form-select form-select-sm" style="width:auto">
                        <option value="lastWeek">Last Week</option>
                        <option value="lastMonth">Last Month</option>
                        <option value="lastYear">Last Year</option>
                    </select>
                    <select id="statusFilter" class="form-select form-select-sm" style="width:auto">
                        <option value="all">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="processing">Processing</option>
                        <option value="delivered">Delivered</option>
                        <option value="on-production">On Production</option>
                        <option value="production-completed">Production Completed</option>
                        <option value="on-delivery">On Delivery</option>
                        <option value="paid">Paid</option>
                        <option value="completed">Completed</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Products</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!orders.length) { %>
                        <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No orders yet</h4><p>Create your first order to get started.</p><a href="/orders/create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> New Order</a></div></td></tr>
                        <% } %>
                        <% orders.forEach(order => { %>
                        <tr>
                            <td data-label="SO Number">
                                <div class="d-flex align-items-center gap-2 justify-content-end justify-content-md-start">
                                    <span class="cell-strong"><%= order.sonumber %></span>
                                    <button class="btn btn-icon btn-sm btn-ghost" onclick="openEditSOModal('<%= order.id %>', '<%= order.sonumber %>')" aria-label="Edit SO"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td data-label="Date">
                                <div class="d-flex align-items-center gap-2 justify-content-end justify-content-md-start">
                                    <span><%= new Date(order.createdAt).toLocaleDateString() %></span>
                                    <button class="btn btn-icon btn-sm btn-ghost" onclick="openEditDateModal('<%= order.id %>', '<%= order.createdAt %>')" aria-label="Edit date"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td data-label="Customer"><%= order.customerName %></td>
                            <td data-label="Products">
                                <span class="cell-sub">
                                <% order.products.forEach((product, index) => { %><%= product.name %> (<%= product.quantity %> <%= product.satuan %>)<%= index < order.products.length - 1 ? ', ' : '' %><% }) %>
                                </span>
                            </td>
                            <td data-label="Status">
                                <span class="status-badge status-<%= order.status.toLowerCase().replace(/\s+/g, '-') %>"><%= order.status %></span>
                            </td>
                            <td data-label="Actions" class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/orders/<%= order.id %>" class="btn btn-icon btn-sm btn-soft" aria-label="View"><i class="bi bi-eye"></i></a>
                                    <% if (order.status === 'On Delivery') { %>
                                    <form action="/orders/deliver/<%= order.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-icon btn-sm btn-success" aria-label="Mark delivered"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                    <% } %>
                                    <% if (order.po) { %>
                                    <a href="/uploads/<%= order.po %>" target="_blank" class="btn btn-icon btn-sm btn-ghost" aria-label="View PO"><i class="bi bi-file-earmark-pdf"></i></a>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Date Modal -->
    <div class="modal fade" id="editDateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Date</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editDateForm" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="orderDate" class="form-label">Date</label>
                            <input type="date" class="form-control" id="orderDate" name="createdAt" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit SO Number Modal -->
    <div class="modal fade" id="editSOModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit SO Number</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editSOForm" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="soNumber" class="form-label">SO Number</label>
                            <input type="text" class="form-control" id="soNumber" name="sonumber" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // ---- SSE notifications ----
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/marketing.mp3');
        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);
            if (data.type === 'tdsMsdsRequestApproved' || data.type === 'tdsMsdsRequestDeclined') {
                const verb = data.type === 'tdsMsdsRequestApproved' ? 'approved' : 'declined';
                showNotification(`TDS/MSDS request for ${data.productName} (${data.requestType}) has been ${verb}`);
                if (data.audio) audio.play().catch(() => {});
                setTimeout(() => location.reload(), 3000);
            }
        };
        function showNotification(message) {
            const n = document.createElement('div');
            n.className = 'alert alert-info alert-dismissible fade show';
            n.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;max-width:360px';
            n.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.body.appendChild(n);
            setTimeout(() => n.remove(), 5000);
        }

        document.addEventListener('DOMContentLoaded', function () {
            // ---- Product chart ----
            const aggregatedProducts = JSON.parse('<%- JSON.stringify(aggregatedProducts) %>');
            const productLabels = aggregatedProducts.map(p => p.name);
            const productData = aggregatedProducts.map(p => parseFloat(p.quantity).toFixed(2));
            const colors = ['#2f6f4e','#3f8c63','#16a34a','#43a047','#66bb6a','#81c784','#a5d6a7','#c8e6c9','#225239','#1b5e20'];
            let productChart = null;

            function createProductChart(type) {
                const ctx = document.getElementById('pieChart').getContext('2d');
                if (productChart) { productChart.destroy(); productChart = null; }
                productChart = new Chart(ctx, {
                    type: type,
                    data: {
                        labels: productLabels,
                        datasets: [{
                            data: productData,
                            backgroundColor: type === 'pie' ? colors : colors.map(c => `${c}CC`),
                            borderColor: type === 'pie' ? '#ffffff' : colors,
                            borderWidth: type === 'pie' ? 2 : 1,
                            maxBarThickness: 50,
                            label: 'Quantity'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: type === 'pie',
                                position: window.innerWidth > 768 ? 'right' : 'bottom',
                                labels: { boxWidth: 12, padding: 14, font: { size: 11, weight: 500 } }
                            },
                            tooltip: { callbacks: { label: (c) => `${c.label || ''}: ${c.raw || 0}` } }
                        },
                        ...(type === 'pie'
                            ? { cutout: '60%', radius: '90%' }
                            : { scales: {
                                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.06)' } },
                                    x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 45 } }
                                } })
                    }
                });
            }
            createProductChart('pie');

            document.querySelectorAll('[data-chart-type]').forEach(button => {
                button.addEventListener('click', function () {
                    if (this.classList.contains('active')) return;
                    this.closest('.btn-group').querySelectorAll('[data-chart-type]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    createProductChart(this.dataset.chartType);
                });
            });
            window.addEventListener('resize', () => {
                if (productChart) {
                    productChart.options.plugins.legend.position = window.innerWidth > 768 ? 'right' : 'bottom';
                    productChart.update();
                }
            });

            // ---- Filters ----
            document.getElementById('dateRange').addEventListener('change', function () {
                window.location.href = `/dashboard/marketing?dateRange=${this.value}`;
            });

            function applyTableFilter() {
                const status = document.getElementById('statusFilter').value;
                const q = document.getElementById('orderSearch').value.trim().toLowerCase();
                document.querySelectorAll('tbody tr').forEach(row => {
                    if (!row.querySelector('td[data-label]')) return; // skip empty-state row
                    const statusCell = row.querySelector('td:nth-child(5)');
                    const matchStatus = status === 'all' || (statusCell && statusCell.textContent.trim().toLowerCase().includes(status));
                    const matchText = !q || row.textContent.toLowerCase().includes(q);
                    row.style.display = (matchStatus && matchText) ? '' : 'none';
                });
            }
            document.getElementById('statusFilter').addEventListener('change', applyTableFilter);
            document.getElementById('orderSearch').addEventListener('input', applyTableFilter);

            // ---- Modals ----
            let editSOModal, editDateModal;
            window.openEditSOModal = function (orderId, currentSO) {
                editSOModal = editSOModal || new bootstrap.Modal(document.getElementById('editSOModal'));
                document.getElementById('editSOForm').action = `/orders/${orderId}/updateSO`;
                document.getElementById('soNumber').value = currentSO;
                editSOModal.show();
            };
            window.openEditDateModal = function (orderId, currentDate) {
                editDateModal = editDateModal || new bootstrap.Modal(document.getElementById('editDateModal'));
                document.getElementById('editDateForm').action = `/orders/${orderId}/updateDate`;
                document.getElementById('orderDate').value = new Date(currentDate).toISOString().split('T')[0];
                editDateModal.show();
            };
        });
    </script>
</body>
</html>
