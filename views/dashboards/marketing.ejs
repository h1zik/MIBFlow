<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Marketing Dashboard', extraScripts: ['https://cdn.jsdelivr.net/npm/chart.js'] }) %>
    <style>
        /* ----- Dashboard-only flourishes (built on the shared system) ----- */
        .dash-hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--mib-radius-lg);
            padding: 1.9rem 2rem;
            margin-bottom: 1.75rem;
            color: #eaf6ef;
            background: var(--mib-sidebar-bg);
            box-shadow: var(--mib-shadow-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
            flex-wrap: wrap;
        }
        .dash-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(460px 220px at 88% -30%, rgba(110, 231, 183, 0.30), transparent 60%),
                radial-gradient(360px 200px at 10% 130%, rgba(110, 231, 183, 0.16), transparent 60%);
            pointer-events: none;
        }
        .dash-hero__text { position: relative; z-index: 1; min-width: 0; }
        .dash-hello { margin: 0 0 0.35rem; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(255, 255, 255, 0.66); }
        .dash-hero h1 { margin: 0; font-size: 1.85rem; font-weight: 750; letter-spacing: -0.025em; color: #fff; display: flex; align-items: center; gap: 0.6rem; }
        .dash-hero p.sub { margin: 0.5rem 0 0; color: rgba(255, 255, 255, 0.78); font-size: 0.92rem; max-width: 52ch; }
        .dash-hero__actions { position: relative; z-index: 1; display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .dash-hero .btn-light { background: rgba(255, 255, 255, 0.14); border-color: rgba(255, 255, 255, 0.22); color: #fff; backdrop-filter: blur(4px); }
        .dash-hero .btn-light:hover { background: rgba(255, 255, 255, 0.24); color: #fff; }
        .dash-hero .btn-white { background: #fff; color: var(--mib-primary-dark); border: none; box-shadow: 0 8px 18px -6px rgba(0,0,0,0.3); }
        .dash-hero .btn-white:hover { background: #f3faf6; color: var(--mib-primary-dark); transform: translateY(-1px); }

        /* staggered entrance */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }
        .stagger > *:nth-child(3) { animation-delay: 0.19s; }
        .stagger > *:nth-child(4) { animation-delay: 0.26s; }

        /* top-customers list */
        .rank-list { display: flex; flex-direction: column; }
        .rank-row {
            display: flex; align-items: center; gap: 0.85rem;
            padding: 0.7rem 0; border-top: 1px solid var(--mib-border);
        }
        .rank-row:first-child { border-top: none; }
        .rank-badge {
            flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px;
            display: grid; place-items: center; font-weight: 700; font-size: 0.82rem;
            background: var(--mib-surface-2); color: var(--mib-text-muted); border: 1px solid var(--mib-border);
        }
        .rank-row:nth-child(1) .rank-badge { background: linear-gradient(135deg, #fde68a, #f59e0b); color: #fff; border: none; }
        .rank-row:nth-child(2) .rank-badge { background: linear-gradient(135deg, #e5e7eb, #9ca3af); color: #fff; border: none; }
        .rank-row:nth-child(3) .rank-badge { background: linear-gradient(135deg, #fcd9b6, #d97706); color: #fff; border: none; }
        .rank-name { font-weight: 600; color: var(--mib-text); min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .rank-meta { margin-left: auto; text-align: right; flex-shrink: 0; }
        .rank-amount { font-weight: 700; color: var(--mib-text); font-variant-numeric: tabular-nums; }
        .rank-sub { font-size: 0.74rem; color: var(--mib-text-muted); }

        .seg { display: inline-flex; background: var(--mib-surface-2); border: 1px solid var(--mib-border); border-radius: var(--mib-radius-pill); padding: 0.2rem; }
        .seg .btn { border: none; border-radius: var(--mib-radius-pill); padding: 0.3rem 0.6rem; color: var(--mib-text-muted); background: transparent; box-shadow: none; }
        .seg .btn.active { background: var(--mib-surface); color: var(--mib-primary-dark); box-shadow: var(--mib-shadow-xs); }

        .stat-sub { display: block; font-size: 0.76rem; color: var(--mib-text-muted); margin-top: 0.45rem; }
        .stat-trend { white-space: nowrap; }

        /* keep the Recent Orders header on one row on wide screens */
        @media (min-width: 992px) {
            .table-card > .card-header { flex-wrap: nowrap; }
            .table-card > .card-header .toolbar { margin-left: auto; flex-wrap: nowrap; }
            .table-card > .card-header .toolbar .search { flex-basis: 220px; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/marketing' }) %>
    <%- include('../partials/chat', { userId: userId, users: users }) %>

    <%
    const all = Array.isArray(allOrders) ? allOrders : [];
    const totalOrders = all.length;
    const pendingCount = all.filter(o => o.status === 'Pending').length;
    const deliveredCount = all.filter(o => o.status === 'Delivered').length;
    const revenue = all.reduce((s, o) => s + (Number(o.total) || 0), 0);
    const fmtShort = (n) => {
        if (n >= 1e9) return (n / 1e9).toFixed(1).replace(/\.0$/, '') + 'B';
        if (n >= 1e6) return (n / 1e6).toFixed(1).replace(/\.0$/, '') + 'M';
        if (n >= 1e3) return (n / 1e3).toFixed(1).replace(/\.0$/, '') + 'K';
        return n.toLocaleString('id-ID');
    };
    %>

    <div class="content content-wide">
        <!-- Hero header -->
        <div class="dash-hero fade-in">
            <div class="dash-hero__text">
                <p class="dash-hello">Marketing Workspace</p>
                <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
                <p class="sub">Track orders, customers and sales performance — all in one place.</p>
            </div>
            <div class="dash-hero__actions">
                <a href="/orders/addCustomer" class="btn btn-light"><i class="bi bi-person-plus"></i> Add Customer</a>
                <a href="/orders/create" class="btn btn-white"><i class="bi bi-plus-lg"></i> New Order</a>
            </div>
        </div>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Sales Value</div>
                    <div class="stat-value" title="Rp <%= revenue.toLocaleString('id-ID') %>">Rp <%= fmtShort(revenue) %></div>
                    <span class="stat-sub">Across all active orders</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-receipt-cutoff"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Total Orders</div>
                    <div class="stat-value"><%= totalOrders %></div>
                    <span class="stat-sub">All time</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-trend <%= pendingCount > 0 ? 'is-down' : 'is-up' %>"><%= pendingCount > 0 ? 'Awaiting approval' : 'All clear' %></span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Delivered</div>
                    <div class="stat-value"><%= deliveredCount %></div>
                    <span class="stat-trend is-up">Completed</span>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="chart-grid">
            <div class="chart-card card-hover">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h3 class="mb-0"><i class="bi bi-pie-chart me-1"></i> Top Products</h3>
                    <div class="seg" role="group" aria-label="Chart type">
                        <button type="button" class="btn btn-sm active" data-chart-type="pie" aria-label="Pie chart"><i class="bi bi-pie-chart"></i></button>
                        <button type="button" class="btn btn-sm" data-chart-type="bar" aria-label="Bar chart"><i class="bi bi-bar-chart"></i></button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>

            <div class="chart-card card-hover">
                <h3><i class="bi bi-trophy me-1"></i> Top 5 Customers</h3>
                <% if (topCustomers && topCustomers.length) { %>
                <div class="rank-list">
                    <% topCustomers.forEach((customer, index) => { %>
                    <div class="rank-row">
                        <span class="rank-badge"><%= index + 1 %></span>
                        <span class="rank-name"><%= customer.name %></span>
                        <div class="rank-meta">
                            <div class="rank-amount">Rp <%= customer.totalAmount.toLocaleString('id-ID') %></div>
                            <div class="rank-sub"><%= customer.totalOrders %> order<%= customer.totalOrders === 1 ? '' : 's' %></div>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <div class="empty-state"><i class="bi bi-people"></i><p>No customer data yet.</p></div>
                <% } %>
            </div>
        </div>

        <!-- Recent orders -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-clock-history"></i> Recent Orders</h2>
                <div class="toolbar mb-0">
                    <div class="search">
                        <i class="bi bi-search"></i>
                        <input type="text" id="orderSearch" class="form-control form-control-sm" placeholder="Search orders…">
                    </div>
                    <select id="dateRange" class="form-select form-select-sm" style="width:auto">
                        <option value="lastWeek">Last Week</option>
                        <option value="lastMonth">Last Month</option>
                        <option value="lastYear">Last Year</option>
                    </select>
                    <select id="statusFilter" class="form-select form-select-sm" style="width:auto">
                        <option value="all">All Status</option>
                        <option value="pending">Pending</option>
                        <option value="processing">Processing</option>
                        <option value="delivered">Delivered</option>
                        <option value="on-production">On Production</option>
                        <option value="production-completed">Production Completed</option>
                        <option value="on-delivery">On Delivery</option>
                        <option value="paid">Paid</option>
                        <option value="completed">Completed</option>
                        <option value="cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>SO Number</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Products</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!orders.length) { %>
                        <tr><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No orders yet</h4><p>Create your first order to get started.</p><a href="/orders/create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> New Order</a></div></td></tr>
                        <% } %>
                        <% orders.forEach(order => { %>
                        <tr>
                            <td data-label="SO Number">
                                <div class="d-flex align-items-center gap-2 justify-content-end justify-content-md-start">
                                    <span class="cell-strong"><%= order.sonumber %></span>
                                    <button class="btn btn-icon btn-sm btn-ghost" onclick="openEditSOModal('<%= order.id %>', '<%= order.sonumber %>')" aria-label="Edit SO"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td data-label="Date">
                                <div class="d-flex align-items-center gap-2 justify-content-end justify-content-md-start">
                                    <span><%= new Date(order.createdAt).toLocaleDateString() %></span>
                                    <button class="btn btn-icon btn-sm btn-ghost" onclick="openEditDateModal('<%= order.id %>', '<%= order.createdAt %>')" aria-label="Edit date"><i class="bi bi-pencil"></i></button>
                                </div>
                            </td>
                            <td data-label="Customer"><span class="cell-strong"><%= order.customerName %></span></td>
                            <td data-label="Products">
                                <span class="cell-sub">
                                <% order.products.forEach((product, index) => { %><%= product.name %> (<%= product.quantity %> <%= product.satuan %>)<%= index < order.products.length - 1 ? ', ' : '' %><% }) %>
                                </span>
                            </td>
                            <td data-label="Status">
                                <span class="status-badge status-<%= order.status.toLowerCase().replace(/\s+/g, '-') %>"><%= order.status %></span>
                            </td>
                            <td data-label="Actions" class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/orders/<%= order.id %>" class="btn btn-icon btn-sm btn-soft" aria-label="View"><i class="bi bi-eye"></i></a>
                                    <% if (order.status === 'On Delivery') { %>
                                    <form action="/orders/deliver/<%= order.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-icon btn-sm btn-success" aria-label="Mark delivered"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                    <% } %>
                                    <% if (order.po) { %>
                                    <a href="/uploads/<%= order.po %>" target="_blank" class="btn btn-icon btn-sm btn-ghost" aria-label="View PO"><i class="bi bi-file-earmark-pdf"></i></a>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Edit Date Modal -->
    <div class="modal fade" id="editDateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Date</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editDateForm" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="orderDate" class="form-label">Date</label>
                            <input type="date" class="form-control" id="orderDate" name="createdAt" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit SO Number Modal -->
    <div class="modal fade" id="editSOModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit SO Number</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editSOForm" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="soNumber" class="form-label">SO Number</label>
                            <input type="text" class="form-control" id="soNumber" name="sonumber" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // ---- SSE notifications ----
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/marketing.mp3');
        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);
            if (data.type === 'tdsMsdsRequestApproved' || data.type === 'tdsMsdsRequestDeclined') {
                const verb = data.type === 'tdsMsdsRequestApproved' ? 'approved' : 'declined';
                showNotification(`TDS/MSDS request for ${data.productName} (${data.requestType}) has been ${verb}`);
                if (data.audio) audio.play().catch(() => {});
                setTimeout(() => location.reload(), 3000);
            }
        };
        function showNotification(message) {
            const n = document.createElement('div');
            n.className = 'alert alert-info alert-dismissible fade show';
            n.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;max-width:360px';
            n.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
            document.body.appendChild(n);
            setTimeout(() => n.remove(), 5000);
        }

        document.addEventListener('DOMContentLoaded', function () {
            // ---- Product chart ----
            const aggregatedProducts = JSON.parse('<%- JSON.stringify(aggregatedProducts) %>');
            const productLabels = aggregatedProducts.map(p => p.name);
            const productData = aggregatedProducts.map(p => parseFloat(p.quantity).toFixed(2));
            const colors = ['#2f6f4e','#3f8c63','#16a34a','#43a047','#66bb6a','#81c784','#a5d6a7','#c8e6c9','#225239','#1b5e20'];
            let productChart = null;

            function createProductChart(type) {
                const ctx = document.getElementById('pieChart').getContext('2d');
                if (productChart) { productChart.destroy(); productChart = null; }
                productChart = new Chart(ctx, {
                    type: type,
                    data: {
                        labels: productLabels,
                        datasets: [{
                            data: productData,
                            backgroundColor: type === 'pie' ? colors : colors.map(c => `${c}CC`),
                            borderColor: type === 'pie' ? '#ffffff' : colors,
                            borderWidth: type === 'pie' ? 2 : 1,
                            maxBarThickness: 50,
                            borderRadius: type === 'bar' ? 6 : 0,
                            label: 'Quantity'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: type === 'pie',
                                position: window.innerWidth > 768 ? 'right' : 'bottom',
                                labels: { boxWidth: 12, padding: 14, font: { size: 11, weight: 500 } }
                            },
                            tooltip: { callbacks: { label: (c) => `${c.label || ''}: ${c.raw || 0}` } }
                        },
                        ...(type === 'pie'
                            ? { cutout: '62%', radius: '90%' }
                            : { scales: {
                                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.06)' } },
                                    x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 45 } }
                                } })
                    }
                });
            }
            createProductChart('pie');

            document.querySelectorAll('[data-chart-type]').forEach(button => {
                button.addEventListener('click', function () {
                    if (this.classList.contains('active')) return;
                    this.closest('.seg').querySelectorAll('[data-chart-type]').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    createProductChart(this.dataset.chartType);
                });
            });
            window.addEventListener('resize', () => {
                if (productChart) {
                    productChart.options.plugins.legend.position = window.innerWidth > 768 ? 'right' : 'bottom';
                    productChart.update();
                }
            });

            // ---- Filters ----
            document.getElementById('dateRange').addEventListener('change', function () {
                window.location.href = `/dashboard/marketing?dateRange=${this.value}`;
            });

            function applyTableFilter() {
                const status = document.getElementById('statusFilter').value;
                const q = document.getElementById('orderSearch').value.trim().toLowerCase();
                document.querySelectorAll('tbody tr').forEach(row => {
                    if (!row.querySelector('td[data-label]')) return; // skip empty-state row
                    const statusCell = row.querySelector('td:nth-child(5)');
                    const matchStatus = status === 'all' || (statusCell && statusCell.textContent.trim().toLowerCase().includes(status));
                    const matchText = !q || row.textContent.toLowerCase().includes(q);
                    row.style.display = (matchStatus && matchText) ? '' : 'none';
                });
            }
            document.getElementById('statusFilter').addEventListener('change', applyTableFilter);
            document.getElementById('orderSearch').addEventListener('input', applyTableFilter);

            // ---- Modals ----
            let editSOModal, editDateModal;
            window.openEditSOModal = function (orderId, currentSO) {
                editSOModal = editSOModal || new bootstrap.Modal(document.getElementById('editSOModal'));
                document.getElementById('editSOForm').action = `/orders/${orderId}/updateSO`;
                document.getElementById('soNumber').value = currentSO;
                editSOModal.show();
            };
            window.openEditDateModal = function (orderId, currentDate) {
                editDateModal = editDateModal || new bootstrap.Modal(document.getElementById('editDateModal'));
                document.getElementById('editDateForm').action = `/orders/${orderId}/updateDate`;
                document.getElementById('orderDate').value = new Date(currentDate).toISOString().split('T')[0];
                editDateModal.show();
            };
        });
    </script>
</body>
</html>
