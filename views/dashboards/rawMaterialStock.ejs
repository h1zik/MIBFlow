<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raw Material Stock</title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8f9fa;
        }
        .sidebar {
            height: 100vh;
            position: fixed;
            left: 0;
            width: 250px;
            background-color: #2c3e50;
            padding-top: 20px;
        }
        .sidebar a {
            padding: 15px 25px;
            text-align: left;
            display: block;
            color: white;
            text-decoration: none;
        }
        .sidebar a:hover {
            background-color: #4CAF50;
        }
        .sidebar .active {
            background-color: #4CAF50;
        }
        .content {
            margin-left: 260px;
            padding: 20px;
        }
        .container {
            background: white;
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            max-width: 800px;
            margin: auto;
        }
        .header h2 {
            color: #4CAF50;
        }
        .table thead th {
            background-color: #4CAF50;
            color: white;
        }
        a {
            color: #4CAF50;
        }
        a:hover {
            color: #388E3C;
            text-decoration: none;
        }
        @media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }
            .sidebar a {
                float: left;
            }
            .sidebar a {
                text-align: center;
                float: none;
            }
            .content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <a class="navbar-brand text-center" href="#" style="font-size: 24px; margin-bottom: 20px;">PT MIB</a>
    </div>
    <div class="content">
        <div class="container">
            <div class="header">
                <h2>Raw Material Stock</h2>
            </div>
            <ul>
                <li><a href="/dashboard/ppic">Back to Dashboard</a></li>
            </ul>
            <h3>Stock List</h3>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Stock</th>
                    </tr>
                </thead>
                <tbody>
                    <% rawMaterials.forEach(material => { %>
                        <tr>
                            <td><%= material.id %></td>
                            <td><%= material.name %></td>
                            <td><%= material.stock %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
