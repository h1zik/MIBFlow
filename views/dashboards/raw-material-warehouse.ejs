    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // Set up SSE for notifications
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/raw.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);
            
            if (data.type === 'newDeliveryRawMaterial') {
                // Show notification for new raw material delivery
                const notification = `New raw material delivery: ${data.materialName} (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }
            } else if (data.type === 'newDeliveryPackaging') {
                // Show notification for new packaging delivery
                const notification = `New packaging delivery (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }
            } else if (data.type === 'qcPassRawMaterial') {
                // Show notification for QC Passed raw material
                const notification = `QC Passed: ${data.materialName} (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'qcRejectSebagianRawMaterial') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC Rejected Sebagian: ${data.materialName} (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'qcPassPackaging') {
                // Show notification for QC Passed raw material
                const notification = `QC Passed: ${data.packagingName} (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'qcRejectSebagianPackaging') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC Rejected Sebagian: ${data.packagingName} (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'returnRawMaterial') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC Return: ${data.materialName} ${data.quantity}KG (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'noReturnRawMaterial') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC No Return: ${data.materialName} ${data.quantity}KG (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'returnPackaging') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC Return: ${data.packagingName} ${data.quantity}Pcs (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            } else if (data.type === 'noReturnPackaging') {
                // Show notification for QC Rejected Sebagian raw material
                const notification = `QC No Return: ${data.packagingName} ${data.quantity}Pcs (${data.status})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play();
                }
            }
        };

        function showNotification(message) {
            const notificationDiv = document.createElement('div');
            notificationDiv.className = 'alert alert-info alert-dismissible fade show';
            notificationDiv.style.position = 'fixed';
            notificationDiv.style.top = '20px';
            notificationDiv.style.right = '20px';
            notificationDiv.style.zIndex = '9999';
            notificationDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(notificationDiv);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                notificationDiv.remove();
            }, 5000);
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);

            // Initialize date pickers with default values
            const defaultConfig = {
                mode: "range",
                dateFormat: "Y-m-d",
                defaultDate: [
                    "<%= defaultStartDate %>",
                    "<%= defaultEndDate %>"
                ],
                onChange: function(selectedDates, dateStr, instance) {
                    // When dates are selected, automatically submit the form
                    if (selectedDates.length === 2) {
                        instance.element.closest('form').submit();
                    }
                }
            };

            // Initialize all date range pickers
            document.querySelectorAll('.date-range-picker').forEach(picker => {
                const currentValue = picker.value;
                flatpickr(picker, {
                    ...defaultConfig,
                    defaultDate: currentValue ? currentValue.split(' to ') : defaultConfig.defaultDate
                });
            });

            // Initialize collapsible sections
            const sections = document.querySelectorAll('.dashboard-section');
            sections.forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');

                // Set initial state
                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }

                // Use Bootstrap's collapse events
                content.addEventListener('show.bs.collapse', () => {
                    icon.style.transform = 'rotate(180deg)';
                });

                content.addEventListener('hide.bs.collapse', () => {
                    icon.style.transform = 'rotate(0)';
                });
            });

            // Form submissions
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.classList.add('loading');
                        submitBtn.disabled = true;
                    }
                });
            });

            // Add AJAX functionality for filters
            document.querySelectorAll('.filter-section').forEach(form => {
                const nameFilter = form.querySelector('input[name="nameFilter"]');
                const dateRangePicker = form.querySelector('.date-range-picker');
                const submitButton = form.querySelector('button[type="submit"]');

                // Handle name filter input
                if (nameFilter) {
                    // Set initial value from URL if exists
                    const urlParams = new URLSearchParams(window.location.search);
                    const nameFilterValue = urlParams.get('nameFilter');
                    if (nameFilterValue) {
                        nameFilter.value = nameFilterValue;
                    }

                    // Add input event listener to submit form on input
                    nameFilter.addEventListener('input', function(e) {
                        // Small delay to avoid too many requests while typing
                        clearTimeout(this.timer);
                        this.timer = setTimeout(() => {
                            form.dispatchEvent(new Event('submit'));
                        }, 500);
                    });
                }

                // Handle form submission
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    
                    // Show loading state
                    submitButton.classList.add('loading');
                    submitButton.disabled = true;

                    const formData = new FormData(this);
                    const section = this.closest('.dashboard-section');
                    const tableBody = section.querySelector('tbody');
                    
                    // Get the current URL and its search params
                    const url = new URL(window.location.href);
                    const searchParams = new URLSearchParams(url.search);
                    
                    // Update search params with form data
                    for (const [key, value] of formData.entries()) {
                        if (value) { // Only add non-empty values
                            searchParams.set(key, value);
                        } else {
                            searchParams.delete(key);
                        }
                    }
                    
                    try {
                        const response = await fetch(`${window.location.pathname}?${searchParams.toString()}`, {
                            headers: {
                                'Accept': 'application/json'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }

                        const data = await response.json();
                        
                        // Update the appropriate section based on the form
                        if (this.querySelector('[name="inboundDateRange"]')) {
                            updateInboundRawMaterialTable(data.inboundRawMaterialRequests, tableBody);
                        } else if (this.querySelector('[name="inboundPackagingDateRange"]')) {
                            updateInboundPackagingTable(data.inboundPackagingRequests, tableBody);
                        } else if (this.querySelector('[name="outboundDateRange"]')) {
                            updateOutboundMaterialTable(data.productions, tableBody);
                        } else if (this.querySelector('[name="outboundPackagingDateRange"]')) {
                            updateOutboundPackagingTable(data.outboundPackaging, tableBody);
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        // Show error message in table
                        tableBody.innerHTML = `
                            <tr>
                                <td colspan="6" class="text-center py-4 text-danger">
                                    <i class="bi bi-exclamation-circle fs-4 d-block mb-2"></i>
                                    Error loading data. Please try again.
                                </td>
                            </tr>
                        `;
                    } finally {
                        // Remove loading state
                        submitButton.classList.remove('loading');
                        submitButton.disabled = false;
                    }
                });
            });

            // Helper functions to update tables
            function updateInboundRawMaterialTable(requests, tableBody) {
                if (!requests || requests.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No inbound raw materials found
                            </td>
                        </tr>
                    `;
                    return;
                }

                tableBody.innerHTML = requests.map(req => `
                    <tr>
                        <td>${new Date(req.date).toLocaleString()}</td>
                        <td>${req.poSoNumber || '-'}</td>
                        <td>${req.batchNumber || '-'}</td>
                        <td><div class="fw-semibold">${req.item}</div></td>
                        <td>${req.vendor}</td>
                        <td class="quantity-positive">${req.quantity}</td>
                        <td>${req.notes || '-'}</td>
                    </tr>
                `).join('');
            }

            function updateInboundPackagingTable(requests, tableBody) {
                if (!requests || requests.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No inbound packaging found
                            </td>
                        </tr>
                    `;
                    return;
                }

                tableBody.innerHTML = requests.map(req => `
                    <tr>
                        <td>${new Date(req.date).toLocaleString()}</td>
                        <td>${req.poSoNumber || '-'}</td>
                        <td>${req.batchNumber || '-'}</td>
                        <td><div class="fw-semibold">${req.item}</div></td>
                        <td>${req.vendor}</td>
                        <td class="quantity-positive">${req.quantity}</td>
                        <td>${req.notes || '-'}</td>
                    </tr>
                `).join('');
            }

            function updateOutboundMaterialTable(productions, tableBody) {
                if (!productions || productions.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No outbound raw materials found
                            </td>
                        </tr>
                    `;
                    return;
                }

                tableBody.innerHTML = productions.map(prod => `
                    <tr>
                        <td>${new Date(prod.date).toLocaleString()}</td>
                        <td>${prod.soPrn || '-'}</td>
                        <td>${prod.batchNumber || '-'}</td>
                        <td>${prod.customer || '-'}</td>
                        <td>${prod.product || '-'}</td>
                        <td><div class="fw-semibold">${prod.item}</div></td>
                        <td class="quantity-negative">${prod.quantity}</td>
                        <td>${prod.notes || '-'}</td>
                    </tr>
                `).join('');
            }

            function updateOutboundPackagingTable(items, tableBody) {
                if (!items || items.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No outbound packaging found
                            </td>
                        </tr>
                    `;
                    return;
                }

                tableBody.innerHTML = items.map(item => `
                    <tr>
                        <td>${new Date(item.date).toLocaleString()}</td>
                        <td>${item.soPrn || '-'}</td>
                        <td>${item.batchNumber || '-'}</td>
                        <td>${item.customer || '-'}</td>
                        <td>${item.product || '-'}</td>
                        <td><div class="fw-semibold">${item.type === 'Product' && item.Packaging ? item.Packaging.name : item.item}</div></td>
                        <td class="quantity-negative">${item.quantity} PCS</td>
                        <td>${item.notes || '-'}</td>
                    </tr>
                `).join('');
            }
        });

        // Handle receive button clicks
        document.querySelectorAll('.receive-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const url = type === 'raw' ? `/rawMaterial/received/${id}` : `/packaging-request/received/${id}`;
                
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        // Update the UI
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            // Replace receive button with test to QC button
                            const actionCell = row.querySelector('.d-flex.gap-2');
                            actionCell.innerHTML = `
                                <button type="button" class="btn btn-warning test-qc-btn" data-id="${id}" data-type="${type}">
                                    <i class="bi bi-clipboard-check"></i>
                                    Test to QC
                                </button>
                            `;
                            
                            // Add click event listener to the new button
                            const newButton = actionCell.querySelector('.test-qc-btn');
                            addTestQCListener(newButton);
                        }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });

        // Function to add Test QC button listener
        function addTestQCListener(button) {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const url = type === 'raw' ? `/rawMaterial/testToQC/${id}` : `/packaging-request/testToQC/${id}`;
                
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        // Remove the Test to QC button after successful QC test
                        this.remove();
                        
                        // Update status badges if they exist
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            const statusBadge = row.querySelector('.badge');
                            if (statusBadge) {
                                statusBadge.className = 'badge badge-pending';
                                statusBadge.textContent = 'QC Testing';
                            }
                        }
                    } else {
                        throw new Error('Failed to process QC test');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process QC test. Please try again.');
                }
            });
        }

        // Add listeners to existing Test QC buttons
        document.querySelectorAll('.test-qc-btn').forEach(button => {
            addTestQCListener(button);
        });

        // Handle receive failed material/packaging button clicks
        document.querySelectorAll('.receive-failed-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const url = type === 'raw' 
                    ? `/rawMaterial/receivedFailedMaterial/${id}` 
                    : `/packaging-request/receivedFailedPackaging/${id}`;
                
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        // Remove the button after successful action
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            row.remove();
                        }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });

        // Handle update stock button clicks
        document.querySelectorAll('.update-stock-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const container = this.closest('.update-stock-container');
                const rejectQuantityInput = container?.querySelector('.reject-quantity');
                const url = type === 'raw' 
                    ? `/rawMaterial/updateStock/${id}` 
                    : `/packaging-request/updateStock/${id}`;
                
                try {
                    const data = {};
                    if (rejectQuantityInput) {
                        const rejectQuantity = parseFloat(rejectQuantityInput.value);
                        if (isNaN(rejectQuantity) || rejectQuantity < 0) {
                            alert('Please enter a valid reject quantity');
                            return;
                        }
                        data.rejectQuantity = rejectQuantity;
                    }

                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        // Remove the row after successful stock update
                        const row = document.querySelector(`#request-row-${this.dataset.id}`);
                        if (row) {
                            row.remove();
                        }
                    } else {
                        throw new Error('Failed to update stock');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to update stock. Please try again.');
                }
            });
        });

        // Handle receive failed form submissions
        document.querySelectorAll('.receive-failed-form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const id = this.dataset.id;
                const type = this.dataset.type;
                
                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (response.ok) {
                        // Remove the row after successful action
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            row.remove();
                        }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });

        // Handle update stock form submissions
        document.querySelectorAll('.update-stock-form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const data = {};
                formData.forEach((value, key) => {
                    data[key] = value;
                });
                
                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        // Remove the row after successful stock update
                        const row = document.querySelector(`#request-row-${this.dataset.id}`);
                        if (row) {
                            row.remove();
                        }
                    } else {
                        throw new Error('Failed to update stock');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to update stock. Please try again.');
                }
            });
        });

        // Add AJAX functionality for mobile view forms
        document.querySelectorAll('.mobile-view form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const data = {};
                formData.forEach((value, key) => {
                    data[key] = value;
                });
                
                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        // Remove the row after successful action
                        const row = document.querySelector(`#request-row-${this.dataset.id}`);
                        if (row) {
                            row.remove();
                        }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });
    </script>

