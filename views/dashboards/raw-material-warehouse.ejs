                                                    <div class="alert alert-warning mb-2">
                                                        <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                    </div>
                                                <% } %>
                                            <% } %>
                                            <button type="submit" class="btn btn-warning">
                                                <i class="bi bi-arrow-clockwise"></i>
                                                Update Stock
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
