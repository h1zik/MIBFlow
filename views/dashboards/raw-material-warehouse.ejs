<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Raw Material Warehouse - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="/css/stylepurchase.css">
    <style>
        .page-subtitle {
            color: #6c757d;
            margin: 0.5rem 0 0 0;
            font-size: 0.875rem;
        }

        /* Mobile Card View */
        .mobile-card {
            background: white;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow);
        }

        .mobile-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }

        .mobile-card-title {
            font-weight: 600;
            color: var(--primary-dark);
            margin: 0;
            font-size: 0.875rem;
        }

        .mobile-card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .mobile-card-label {
            color: #6c757d;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .mobile-card-value {
            font-size: 0.875rem;
            font-weight: 500;
        }

        .mobile-card-actions {
            display: grid;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        /* Badges */
        .badge-pass {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-fail {
            background-color: #f8d7da;
            color: #842029;
        }

        /* Buttons */
        .btn-warning {
            background-color: #ffc107;
            border: none;
            color: #000;
        }

        .btn-warning:hover {
            background-color: #ffca2c;
            color: #000;
            transform: translateY(-1px);
        }

        /* Filter Section */
        .filter-section {
            background: white;
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            display: grid;
            gap: 1rem;
        }

        .filter-group {
            width: 100%;
        }

        .filter-group input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            font-size: 0.875rem;
        }

        .filter-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: var(--text-color);
        }

        .date-range-picker {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            font-size: 0.875rem;
        }

        @media (min-width: 769px) {
            .filter-section {
                display: flex;
                align-items: flex-end;
                gap: 1rem;
            }

            .filter-group {
                flex: 1;
            }

            .filter-section button {
                margin-bottom: 0.5rem;
            }
        }

        /* Quantities */
        .quantity-positive {
            color: var(--primary-color);
            font-weight: 500;
        }

        .quantity-negative {
            color: #dc3545;
            font-weight: 500;
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .filter-section {
                display: flex;
                padding: 1.5rem;
            }

            /* Hide the whole mobile rendering on desktop (not just the cards) —
               otherwise the mobile-view empty state duplicates the table's. */
            .mobile-view {
                display: none;
            }

            .desktop-table {
                display: block;
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }
        }

        /* Enhanced Mobile Styles */
        @media (max-width: 768px) {
            .desktop-table {
                display: none;
            }

            .mobile-view {
                display: block;
            }

            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            /* Filter Section Improvements */
            .filter-section {
                padding: 0.75rem;
                margin-bottom: 0.75rem;
            }

            .filter-group {
                margin-bottom: 0.75rem;
            }

            .filter-group:last-child {
                margin-bottom: 0;
            }

            .filter-group input,
            .filter-group select {
                font-size: 16px;
                height: 40px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/raw-material-warehouse' }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-box-seam"></i>
                Raw Material Warehouse
            </h1>
            <p class="page-subtitle">Manage inbound and outbound raw materials</p>
        </div>

        <!-- Pending Raw Material Requests -->
        <%- include('../partials/kanban-toggle') %>
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#pendingRawMaterialRequests" aria-expanded="true" aria-controls="pendingRawMaterialRequests">
                <h2 class="section-title">
                    <i class="bi bi-hourglass-split"></i>
                    Pending Raw Material Requests
                    <% if (pendingRawMaterialRequests && pendingRawMaterialRequests.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= pendingRawMaterialRequests.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="pendingRawMaterialRequests" class="collapse section-content">
                <!-- Desktop View -->
                <div class="table-responsive desktop-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Batch Number</th>
                                <th>Material</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Vendor</th>
                                <th>QC Status</th>
                                <th>Expired Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pendingRawMaterialRequests && pendingRawMaterialRequests.length > 0) { %>
                                <% pendingRawMaterialRequests.forEach(function(requestVendor) { %>
                                    <tr id="request-row-<%= requestVendor.id %>">
                                        <td>#<%= requestVendor.id %></td>
                                        <td><%= requestVendor.ponumber || '-' %></td>
                                        <td><%= requestVendor.batchNumber || '-' %></td>
                                        <td>
                                            <div class="fw-semibold"><%= requestVendor.RawMaterialRequest.materialName %></div>
                                        </td>
                                        <td>
                                            <% if (requestVendor.rejectQuantity > 0) { %>
                                                <%= requestVendor.rejectQuantity %> Kg (Rejected Quantity)
                                            <% } else { %>
                                                <%= requestVendor.splitQuantity %> Kg
                                            <% } %>
                                        </td>
                                        <td>
                                            <%= requestVendor.status %>
                                            <% if (requestVendor.status === 'Quarantined') { %>
                                                <span class="text-danger">(Failed Raw Material)</span>
                                            <% } %>
                                        </td>
                                        <td><%= requestVendor.Vendor.name %></td>
                                        <td>
                                            <% if (requestVendor.qcStatus === 'Pending') { %>
                                                <span class="badge badge-pending">Pending</span>
                                            <% } else if (requestVendor.qcStatus === 'Pass') { %>
                                                <span class="badge badge-pass">Pass</span>
                                            <% } else if (requestVendor.qcStatus === 'Fail') { %>
                                                <span class="badge badge-fail">Fail</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (requestVendor.expiredDate) { %>
                                                <%= new Date(requestVendor.expiredDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-check-lg"></i>
                                                        Receive
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received' && (requestVendor.qcStatus === 'Pending' || requestVendor.qcStatus === 'Fail')) { %>
                                                    <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i>
                                                        Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received') { %>
                                                    <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i>
                                                        Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i>
                                                        Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'No Return') { %>
                                                    <form class="receive-failed-form" action="/rawMaterial/receivedFailedMaterial/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <button type="submit" class="btn btn-warning">
                                                            <i class="bi bi-box-arrow-in-down"></i>
                                                            Received Failed Raw Material
                                                        </button>
                                                    </form>
                                                <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                    <form class="update-stock-form" action="/rawMaterial/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                            <div class="mb-2">
                                                                <label class="form-label">Reject Quantity (Kg)</label>
                                                                <% if (requestVendor.status === 'QC Testing') { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> Kg</small>
                                                                <% } else { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                                <% } %>
                                                            </div>
                                                            <% if (requestVendor.rejectComment) { %>
                                                                <div class="alert alert-warning mb-2">
                                                                    <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <% if (requestVendor.qcStatus === 'Pass') { %>
                                                            <% if (requestVendor.rejectQuantity === 0) { %>
                                                                <div class="mb-2">
                                                                    <label class="form-label">Real Quantity (Kg)</label>
                                                                    <input type="number" name="realQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <button type="submit" class="btn btn-warning">
                                                            <i class="bi bi-arrow-clockwise"></i>
                                                            Update Stock
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No pending raw material requests found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View -->
                <div class="mobile-view">
                    <% if (pendingRawMaterialRequests && pendingRawMaterialRequests.length > 0) { %>
                        <% pendingRawMaterialRequests.forEach(function(requestVendor) { %>
                            <div class="mobile-card">
                                <div class="mobile-card-header">
                                    <h3 class="mobile-card-title">#<%= requestVendor.id %></h3>
                                    <% if (requestVendor.qcStatus === 'Pending') { %>
                                        <span class="badge badge-pending">QC Pending</span>
                                    <% } else if (requestVendor.qcStatus === 'Pass') { %>
                                        <span class="badge badge-pass">QC Pass</span>
                                    <% } else if (requestVendor.qcStatus === 'Fail') { %>
                                        <span class="badge badge-fail">QC Fail</span>
                                    <% } %>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Material</span>
                                    <span class="mobile-card-value"><%= requestVendor.RawMaterialRequest.materialName %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Quantity</span>
                                    <span class="mobile-card-value">
                                        <% if (requestVendor.rejectQuantity > 0) { %>
                                            <%= requestVendor.rejectQuantity %> Kg (Rejected Quantity)
                                        <% } else { %>
                                            <%= requestVendor.splitQuantity %> Kg
                                        <% } %>
                                    </span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Status</span>
                                    <span class="mobile-card-value">
                                        <%= requestVendor.status %>
                                        <% if (requestVendor.status === 'Quarantined') { %>
                                            <span class="text-danger">(Failed Raw Material)</span>
                                        <% } %>
                                    </span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Vendor</span>
                                    <span class="mobile-card-value"><%= requestVendor.Vendor.name %></span>
                                </div>
                                <div class="mobile-card-actions">
                                    <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                        <button type="button" class="btn btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <i class="bi bi-check-lg"></i>
                                            Receive
                                        </button>
                                    <% } else if (requestVendor.status === 'Received' && (requestVendor.qcStatus === 'Pending' || requestVendor.qcStatus === 'Fail')) { %>
                                        <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <i class="bi bi-clipboard-check"></i>
                                            Test to QC
                                        </button>
                                    <% } else if (requestVendor.status === 'Received') { %>
                                        <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <i class="bi bi-clipboard-check"></i>
                                            Test to QC
                                        </button>
                                    <% } else if (requestVendor.status === 'Returned') { %>
                                        <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <i class="bi bi-clipboard-check"></i>
                                            Test to QC
                                        </button>
                                    <% } else if (requestVendor.status === 'No Return') { %>
                                        <form class="receive-failed-form" action="/rawMaterial/receivedFailedMaterial/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <button type="submit" class="btn btn-warning">
                                                <i class="bi bi-box-arrow-in-down"></i>
                                                Received Failed Raw Material
                                            </button>
                                        </form>
                                    <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                        <form class="update-stock-form" action="/rawMaterial/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                            <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                <div class="mb-2">
                                                    <label class="form-label">Reject Quantity (Kg)</label>
                                                    <% if (requestVendor.status === 'QC Testing') { %>
                                                        <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                        <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> Kg</small>
                                                    <% } else { %>
                                                        <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                        <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                    <% } %>
                                                </div>
                                                <% if (requestVendor.rejectComment) { %>
                                                    <div class="alert alert-warning mb-2">
                                                        <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                    </div>
                                                <% } %>
                                            <% } %>
                                            <% if (requestVendor.qcStatus === 'Pass') { %>
                                                <% if (requestVendor.rejectQuantity === 0) { %>
                                                    <div class="mb-2">
                                                        <label class="form-label">Real Quantity (Kg)</label>
                                                        <input type="number" name="realQuantity" class="form-control" step="0.01" required>
                                                        <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                    </div>
                                                <% } %>
                                            <% } %>
                                            <button type="submit" class="btn btn-warning">
                                                <i class="bi bi-arrow-clockwise"></i>
                                                Update Stock
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            No pending raw material requests found
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Pending Packaging Requests -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#pendingPackagingRequests" aria-expanded="true" aria-controls="pendingPackagingRequests">
                <h2 class="section-title">
                    <i class="bi bi-box2"></i>
                    Pending Packaging Requests
                    <% if (pendingPackagingRequests && pendingPackagingRequests.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= pendingPackagingRequests.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="pendingPackagingRequests" class="collapse section-content">
                <!-- Desktop View -->
                <div class="table-responsive desktop-table">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Packaging</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Vendor</th>
                                <th>QC Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pendingPackagingRequests && pendingPackagingRequests.length > 0) { %>
                                <% pendingPackagingRequests.forEach(function(requestVendor) { %>
                                    <tr id="request-row-<%= requestVendor.id %>">
                                        <td>#<%= requestVendor.id %></td>
                                        <td><%= requestVendor.ponumber %></td>
                                        <td>
                                            <div class="fw-semibold"><%= requestVendor.PackagingRequest.packagingName %></div>
                                        </td>
                                        <td>
                                            <% if (requestVendor.rejectQuantity > 0) { %>
                                                <%= requestVendor.rejectQuantity %> pcs (Rejected Quantity)
                                            <% } else { %>
                                                <%= requestVendor.splitQuantity %> pcs
                                            <% } %>
                                        </td>
                                        <td>
                                            <%= requestVendor.status %>
                                            <% if (requestVendor.status === 'Quarantined') { %>
                                                <span class="text-danger">(Failed Packaging)</span>
                                            <% } %>
                                        </td>
                                        <td><%= requestVendor.Vendor.name %></td>
                                        <td>
                                            <% if (requestVendor.qcStatus === 'Pending') { %>
                                                <span class="badge badge-pending">Pending</span>
                                            <% } else if (requestVendor.qcStatus === 'Pass') { %>
                                                <span class="badge badge-pass">Pass</span>
                                            <% } else if (requestVendor.qcStatus === 'Fail') { %>
                                                <span class="badge badge-fail">Fail</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <i class="bi bi-check-lg"></i>
                                                        Receive
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <i class="bi bi-clipboard-check"></i>
                                                        Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'No Return') { %>
                                                    <form class="receive-failed-form" action="/packaging-request/receivedFailedPackaging/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <button type="submit" class="btn btn-warning">
                                                            <i class="bi bi-box-arrow-in-down"></i>
                                                            Received Failed Packaging
                                                        </button>
                                                    </form>
                                                <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                    <form class="update-stock-form" action="/packaging-request/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                            <div class="mb-2">
                                                                <label class="form-label">Reject Quantity (pcs)</label>
                                                                <% if (requestVendor.status === 'QC Testing') { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" required>
                                                                    <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> pcs</small>
                                                                <% } else { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> pcs</small>
                                                                <% } %>
                                                            </div>
                                                            <% if (requestVendor.rejectComment) { %>
                                                                <div class="alert alert-warning mb-2">
                                                                    <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <button type="submit" class="btn btn-warning">
                                                            <i class="bi bi-arrow-clockwise"></i>
                                                            Update Stock
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No pending packaging requests found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View -->
                <div class="mobile-view">
                    <% if (pendingPackagingRequests && pendingPackagingRequests.length > 0) { %>
                        <% pendingPackagingRequests.forEach(function(requestVendor) { %>
                            <div class="mobile-card">
                                <div class="mobile-card-header">
                                    <h3 class="mobile-card-title">#<%= requestVendor.id %></h3>
                                    <% if (requestVendor.qcStatus === 'Pending') { %>
                                        <span class="badge badge-pending">QC Pending</span>
                                    <% } else if (requestVendor.qcStatus === 'Pass') { %>
                                        <span class="badge badge-pass">QC Pass</span>
                                    <% } else if (requestVendor.qcStatus === 'Fail') { %>
                                        <span class="badge badge-fail">QC Fail</span>
                                    <% } %>
