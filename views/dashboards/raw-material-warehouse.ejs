        <!-- ===================== Outbound Packaging ===================== -->
        <div class="dashboard-section" style="--accent:#4f46e5;--accent-soft:#e0e7ff">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#outboundPackaging" aria-expanded="false" aria-controls="outboundPackaging">
                <h2 class="section-title">
                    <i class="bi bi-box-arrow-right"></i>
                    Outbound Packaging
                    <% if (outboundPkg.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= outboundPkg.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="outboundPackaging" class="collapse section-content">
                <form class="filter-section" method="GET">
                    <div class="filter-group">
                        <label class="form-label">Date Range</label>
                        <input type="text" class="date-range-picker form-control" name="outboundPackagingDateRange"
                            value="<%= fOutStart ? fOutStart + ' to ' + fOutEnd : '' %>"
                            placeholder="Select date range">
                    </div>
                    <div class="filter-group">
                        <label class="form-label">Filter by Name</label>
                        <input type="text" class="form-control" name="nameFilter" placeholder="Enter packaging name">
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Apply Filter
                    </button>
                </form>
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>SO/PRN</th>
                                <th>Batch Number</th>
                                <th>Customer</th>
                                <th>Product</th>
                                <th>Packaging</th>
                                <th>Quantity</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (outboundPkg.length > 0) { %>
                                <% outboundPkg.forEach(function(outbound) { %>
                                    <tr>
                                        <td data-label="Date"><%= fmtDate(outbound.date) %></td>
                                        <td data-label="SO/PRN"><%= outbound.soPrn || '-' %></td>
                                        <td data-label="Batch Number"><%= outbound.batchNumber || '-' %></td>
                                        <td data-label="Customer"><%= outbound.customer || '-' %></td>
                                        <td data-label="Product"><%= outbound.product || '-' %></td>
                                        <td data-label="Packaging">
                                            <span class="cell-strong">
                                                <% if (outbound.type === 'Product' && outbound.Packaging) { %>
                                                    <%= outbound.Packaging.name %>
                                                <% } else { %>
                                                    <%= outbound.item %>
                                                <% } %>
                                            </span>
                                        </td>
                                        <td data-label="Quantity" class="quantity-negative"><%= outbound.quantity %> PCS</td>
                                        <td data-label="Notes"><%= outbound.notes || '-' %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr class="is-empty-row">
                                    <td colspan="8">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <h4>No outbound packaging</h4>
                                            <p>Packaging issued to production will appear here.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ===================== SSE for notifications =====================
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/raw.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);

            if (data.type === 'newDeliveryRawMaterial') {
                showNotification(`New raw material delivery: ${data.materialName} (${data.status})`);
                if (data.audio) { audio.play().catch(e => console.error('Error playing audio:', e)); }
            } else if (data.type === 'newDeliveryPackaging') {
                showNotification(`New packaging delivery (${data.status})`);
                if (data.audio) { audio.play().catch(e => console.error('Error playing audio:', e)); }
            } else if (data.type === 'qcPassRawMaterial') {
                showNotification(`QC Passed: ${data.materialName} (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcRejectSebagianRawMaterial') {
                showNotification(`QC Rejected Sebagian: ${data.materialName} (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcPassPackaging') {
                showNotification(`QC Passed: ${data.packagingName} (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'qcRejectSebagianPackaging') {
                showNotification(`QC Rejected Sebagian: ${data.packagingName} (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'returnRawMaterial') {
                showNotification(`QC Return: ${data.materialName} ${data.quantity}KG (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'noReturnRawMaterial') {
                showNotification(`QC No Return: ${data.materialName} ${data.quantity}KG (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'returnPackaging') {
                showNotification(`QC Return: ${data.packagingName} ${data.quantity}Pcs (${data.status})`);
                if (data.audio) { audio.play(); }
            } else if (data.type === 'noReturnPackaging') {
                showNotification(`QC No Return: ${data.packagingName} ${data.quantity}Pcs (${data.status})`);
                if (data.audio) { audio.play(); }
            }
        };

        function showNotification(message) {
            const notificationDiv = document.createElement('div');
            notificationDiv.className = 'mib-flash mib-flash-success alert-dismissible fade show';
            notificationDiv.style.position = 'fixed';
            notificationDiv.style.top = '20px';
            notificationDiv.style.right = '20px';
            notificationDiv.style.zIndex = '9999';
            notificationDiv.style.maxWidth = '360px';
            notificationDiv.innerHTML = `
                <i class="bi bi-bell-fill"></i>
                <span>${message}</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(notificationDiv);
            setTimeout(() => { notificationDiv.remove(); }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Rotate chevrons on collapse (Bootstrap events)
            document.querySelectorAll('.dashboard-section').forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');
                if (!content || !icon) return;
                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }
                content.addEventListener('show.bs.collapse', () => { icon.style.transform = 'rotate(180deg)'; });
                content.addEventListener('hide.bs.collapse', () => { icon.style.transform = 'rotate(0)'; });
            });

            // Initialise date range pickers
            const defaultConfig = {
                mode: "range",
                dateFormat: "Y-m-d",
                defaultDate: [
                    "<%= defStart %>",
                    "<%= defEnd %>"
                ],
                onChange: function(selectedDates, dateStr, instance) {
                    if (selectedDates.length === 2) {
                        instance.element.closest('form').dispatchEvent(new Event('submit'));
                    }
                }
            };

            document.querySelectorAll('.date-range-picker').forEach(picker => {
                const currentValue = picker.value;
                flatpickr(picker, {
                    ...defaultConfig,
                    defaultDate: currentValue ? currentValue.split(' to ') : defaultConfig.defaultDate
                });
            });

            // ===================== AJAX filter forms =====================
            document.querySelectorAll('.filter-section').forEach(form => {
                const nameFilter = form.querySelector('input[name="nameFilter"]');
                const submitButton = form.querySelector('button[type="submit"]');

                if (nameFilter) {
                    const urlParams = new URLSearchParams(window.location.search);
                    const nameFilterValue = urlParams.get('nameFilter');
                    if (nameFilterValue) {
                        nameFilter.value = nameFilterValue;
                    }
                    nameFilter.addEventListener('input', function() {
                        clearTimeout(this.timer);
                        this.timer = setTimeout(() => {
                            form.dispatchEvent(new Event('submit'));
                        }, 500);
                    });
                }

                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    submitButton.classList.add('loading');
                    submitButton.disabled = true;

                    const formData = new FormData(this);
                    const section = this.closest('.dashboard-section');
                    const tableBody = section.querySelector('tbody');

                    const url = new URL(window.location.href);
                    const searchParams = new URLSearchParams(url.search);
                    for (const [key, value] of formData.entries()) {
                        if (value) { searchParams.set(key, value); }
                        else { searchParams.delete(key); }
                    }

                    try {
                        const response = await fetch(`${window.location.pathname}?${searchParams.toString()}`, {
                            headers: { 'Accept': 'application/json' }
                        });
                        if (!response.ok) { throw new Error('Network response was not ok'); }
                        const data = await response.json();

                        if (this.querySelector('[name="inboundDateRange"]')) {
                            updateInboundRawMaterialTable(data.inboundRawMaterialRequests, tableBody);
                        } else if (this.querySelector('[name="inboundPackagingDateRange"]')) {
                            updateInboundPackagingTable(data.inboundPackagingRequests, tableBody);
                        } else if (this.querySelector('[name="outboundDateRange"]')) {
                            updateOutboundMaterialTable(data.productions, tableBody);
                        } else if (this.querySelector('[name="outboundPackagingDateRange"]')) {
                            updateOutboundPackagingTable(data.outboundPackaging, tableBody);
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        tableBody.innerHTML = `
                            <tr><td colspan="8" class="text-center py-4 text-danger">
                                <i class="bi bi-exclamation-circle fs-4 d-block mb-2"></i>
                                Error loading data. Please try again.
                            </td></tr>`;
                    } finally {
                        submitButton.classList.remove('loading');
                        submitButton.disabled = false;
                    }
                });
            });

            // Helper functions to update tables (data-label kept for mobile cards)
            function updateInboundRawMaterialTable(requests, tableBody) {
                if (!requests || requests.length === 0) {
                    tableBody.innerHTML = `
                        <tr class="is-empty-row"><td colspan="7">
                            <div class="empty-state"><i class="bi bi-inbox"></i><h4>No inbound raw materials</h4><p>Received raw materials in this range will appear here.</p></div>
                        </td></tr>`;
                    return;
                }
                tableBody.innerHTML = requests.map(req => `
                    <tr>
                        <td data-label="Date">${new Date(req.date).toLocaleString()}</td>
                        <td data-label="PO/SO Number">${req.poSoNumber || '-'}</td>
                        <td data-label="Batch Number">${req.batchNumber || '-'}</td>
                        <td data-label="Item"><span class="cell-strong">${req.item}</span></td>
                        <td data-label="Vendor">${req.vendor}</td>
                        <td data-label="Quantity" class="quantity-positive">${req.quantity} KG</td>
                        <td data-label="Notes">${req.notes || '-'}</td>
                    </tr>`).join('');
            }

            function updateInboundPackagingTable(requests, tableBody) {
                if (!requests || requests.length === 0) {
                    tableBody.innerHTML = `
                        <tr class="is-empty-row"><td colspan="7">
                            <div class="empty-state"><i class="bi bi-inbox"></i><h4>No inbound packaging</h4><p>Received packaging in this range will appear here.</p></div>
                        </td></tr>`;
                    return;
                }
                tableBody.innerHTML = requests.map(req => `
                    <tr>
                        <td data-label="Date">${new Date(req.date).toLocaleString()}</td>
                        <td data-label="PO/SO Number">${req.poSoNumber || '-'}</td>
                        <td data-label="Batch Number">${req.batchNumber || '-'}</td>
                        <td data-label="Item"><span class="cell-strong">${req.item}</span></td>
                        <td data-label="Vendor">${req.vendor}</td>
                        <td data-label="Quantity" class="quantity-positive">${req.quantity} PCS</td>
                        <td data-label="Notes">${req.notes || '-'}</td>
                    </tr>`).join('');
            }

            function updateOutboundMaterialTable(productions, tableBody) {
                if (!productions || productions.length === 0) {
                    tableBody.innerHTML = `
                        <tr class="is-empty-row"><td colspan="8">
                            <div class="empty-state"><i class="bi bi-inbox"></i><h4>No outbound raw materials</h4><p>Raw materials issued to production will appear here.</p></div>
                        </td></tr>`;
                    return;
                }
                tableBody.innerHTML = productions.map(prod => `
                    <tr>
                        <td data-label="Date">${new Date(prod.date).toLocaleString()}</td>
                        <td data-label="SO/PRN">${prod.soPrn || '-'}</td>
                        <td data-label="Batch Number">${prod.batchNumber || '-'}</td>
                        <td data-label="Customer">${prod.customer || '-'}</td>
                        <td data-label="Product">${prod.product || '-'}</td>
                        <td data-label="Item"><span class="cell-strong">${prod.item}</span></td>
                        <td data-label="Quantity" class="quantity-negative">${prod.quantity} KG</td>
                        <td data-label="Notes">${prod.notes || '-'}</td>
                    </tr>`).join('');
            }

            function updateOutboundPackagingTable(items, tableBody) {
                if (!items || items.length === 0) {
                    tableBody.innerHTML = `
                        <tr class="is-empty-row"><td colspan="8">
                            <div class="empty-state"><i class="bi bi-inbox"></i><h4>No outbound packaging</h4><p>Packaging issued to production will appear here.</p></div>
                        </td></tr>`;
                    return;
                }
                tableBody.innerHTML = items.map(item => `
                    <tr>
                        <td data-label="Date">${new Date(item.date).toLocaleString()}</td>
                        <td data-label="SO/PRN">${item.soPrn || '-'}</td>
                        <td data-label="Batch Number">${item.batchNumber || '-'}</td>
                        <td data-label="Customer">${item.customer || '-'}</td>
                        <td data-label="Product">${item.product || '-'}</td>
                        <td data-label="Packaging"><span class="cell-strong">${item.type === 'Product' && item.Packaging ? item.Packaging.name : item.item}</span></td>
                        <td data-label="Quantity" class="quantity-negative">${item.quantity} PCS</td>
                        <td data-label="Notes">${item.notes || '-'}</td>
                    </tr>`).join('');
            }
        });

        // ===================== Receive button clicks (AJAX) =====================
        document.querySelectorAll('.receive-btn').forEach(button => {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const url = type === 'raw' ? `/rawMaterial/received/${id}` : `/packaging-request/received/${id}`;

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    if (response.ok) {
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            const actionCell = row.querySelector('.d-flex.gap-2');
                            actionCell.innerHTML = `
                                <button type="button" class="btn btn-sm btn-soft test-qc-btn" data-id="${id}" data-type="${type}">
                                    <i class="bi bi-clipboard-check"></i> Test to QC
                                </button>`;
                            const newButton = actionCell.querySelector('.test-qc-btn');
                            addTestQCListener(newButton);
                        }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });

        // Function to add Test QC button listener
        function addTestQCListener(button) {
            button.addEventListener('click', async function() {
                const id = this.dataset.id;
                const type = this.dataset.type;
                const url = type === 'raw' ? `/rawMaterial/testToQC/${id}` : `/packaging-request/testToQC/${id}`;

                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    if (response.ok) {
                        this.remove();
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) {
                            const statusBadge = row.querySelector('.status-badge');
                            if (statusBadge) {
                                statusBadge.className = 'status-badge status-pending';
                                statusBadge.textContent = 'QC Testing';
                            }
                        }
                    } else {
                        throw new Error('Failed to process QC test');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process QC test. Please try again.');
                }
            });
        }

        // Add listeners to existing Test QC buttons
        document.querySelectorAll('.test-qc-btn').forEach(button => {
            addTestQCListener(button);
        });

        // Handle receive failed form submissions
        document.querySelectorAll('.receive-failed-form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const id = this.dataset.id;

                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    if (response.ok) {
                        const row = document.querySelector(`#request-row-${id}`);
                        if (row) { row.remove(); }
                    } else {
                        throw new Error('Failed to process request');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to process the request. Please try again.');
                }
            });
        });

        // Handle update stock form submissions
        document.querySelectorAll('.update-stock-form').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                const data = {};
                formData.forEach((value, key) => { data[key] = value; });

                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    if (response.ok) {
                        const row = document.querySelector(`#request-row-${this.dataset.id}`);
                        if (row) { row.remove(); }
                    } else {
                        throw new Error('Failed to update stock');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Failed to update stock. Please try again.');
                }
            });
        });
    </script>
</body>
</html>
