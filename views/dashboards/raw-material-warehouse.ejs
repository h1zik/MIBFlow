                                    <span class="mobile-card-label">Packaging</span>
                                    <span class="mobile-card-value"><%= requestVendor.PackagingRequest.packagingName %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Quantity</span>
                                    <span class="mobile-card-value">
                                        <% if (requestVendor.rejectQuantity > 0) { %>
                                            <%= requestVendor.rejectQuantity %> pcs (Rejected Quantity)
                                        <% } else { %>
                                            <%= requestVendor.splitQuantity %> pcs
                                        <% } %>
                                    </span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Status</span>
                                    <span class="mobile-card-value"><%= requestVendor.status %></span>
                                </div>
                                <div class="mobile-card-row">
                                    <span class="mobile-card-label">Vendor</span>
                                    <span class="mobile-card-value"><%= requestVendor.Vendor.name %></span>
                                </div>
                                <div class="mobile-card-actions">
                                    <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                        <button type="button" class="btn btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                            <i class="bi bi-check-lg"></i>
                                            Receive
                                        </button>
                                    <% } else if (requestVendor.status === 'Received' || requestVendor.status === 'Returned') { %>
                                        <button type="button" class="btn btn-warning test-qc-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                            <i class="bi bi-clipboard-check"></i>
                                            Test to QC
                                        </button>
                                    <% } else if (requestVendor.status === 'No Return') { %>
                                        <form class="receive-failed-form" action="/packaging-request/receivedFailedPackaging/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                            <button type="submit" class="btn btn-warning">
                                                <i class="bi bi-box-arrow-in-down"></i>
                                                Received Failed Packaging
                                            </button>
                                        </form>
                                    <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                        <form class="update-stock-form" action="/packaging-request/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                            <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                <div class="mb-2">
                                                    <label class="form-label">Reject Quantity (pcs)</label>
                                                    <% if (requestVendor.status === 'QC Testing') { %>
                                                        <input type="number" name="rejectQuantity" class="form-control" required>
                                                        <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> pcs</small>
                                                    <% } else { %>
                                                        <input type="number" name="rejectQuantity" class="form-control" required>
                                                        <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> pcs</small>
                                                    <% } %>
                                                </div>
