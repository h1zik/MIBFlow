<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
          pageTitle: 'Raw Material Warehouse',
          extraStylesheets: ['https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css'],
          extraScripts: ['https://cdn.jsdelivr.net/npm/flatpickr']
    }) %>
    <style>
        /* ============================================================
           Raw Material Warehouse — dashboard flourishes
           Built on the shared mibflow.css design system.
           ============================================================ */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }

        /* ---------- Hero ---------- */
        .rmw-hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--mib-radius-lg);
            padding: 1.9rem 2rem;
            margin-bottom: 1.75rem;
            color: #eaf6ef;
            background: var(--mib-sidebar-bg);
            box-shadow: var(--mib-shadow-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
            flex-wrap: wrap;
        }
        .rmw-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(460px 220px at 88% -30%, rgba(110, 231, 183, 0.30), transparent 60%),
                radial-gradient(360px 200px at 10% 130%, rgba(110, 231, 183, 0.16), transparent 60%);
        }
        .rmw-hero__text { position: relative; z-index: 1; min-width: 0; }
        .rmw-hello { margin: 0 0 0.35rem; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: rgba(255, 255, 255, 0.66); }
        .rmw-hero h1 { margin: 0; font-size: 1.85rem; font-weight: 750; letter-spacing: -0.025em; color: #fff; display: flex; align-items: center; gap: 0.6rem; }
        .rmw-hero p.sub { margin: 0.5rem 0 0; color: rgba(255, 255, 255, 0.78); font-size: 0.92rem; max-width: 56ch; }
        .rmw-hero__actions { position: relative; z-index: 1; display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .rmw-hero .btn-light { background: rgba(255, 255, 255, 0.14); border-color: rgba(255, 255, 255, 0.22); color: #fff; backdrop-filter: blur(4px); }
        .rmw-hero .btn-light:hover { background: rgba(255, 255, 255, 0.24); color: #fff; }
        .rmw-hero .btn-white { background: #fff; color: var(--mib-primary-dark); border: none; box-shadow: 0 8px 18px -6px rgba(0,0,0,0.3); }
        .rmw-hero .btn-white:hover { background: #f3faf6; color: var(--mib-primary-dark); transform: translateY(-1px); }

        /* ---------- Staggered entrance ---------- */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .stagger > *:nth-child(2) { animation-delay: 0.12s; }
        .stagger > *:nth-child(3) { animation-delay: 0.19s; }
        .stagger > *:nth-child(4) { animation-delay: 0.26s; }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(195px, 1fr)); }

        /* ---------- Queue panels (.dashboard-section) — base styles
             (PPIC-equivalent, since stylepurchase.css is no longer loaded) ---------- */
        .dashboard-section {
            --accent: var(--mib-primary);
            --accent-soft: var(--mib-primary-soft);
            background: var(--mib-grad-surface);
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow);
            margin-bottom: 1rem;
            overflow: hidden;
            transition: box-shadow var(--mib-transition), border-color var(--mib-transition);
        }
        .dashboard-section:hover { box-shadow: var(--mib-shadow-md); }
        .section-header {
            position: relative; display: flex; align-items: center; gap: 0.85rem;
            padding: 1rem 1.25rem 1rem 1.4rem; cursor: pointer; transition: background var(--mib-transition);
        }
        .section-header:hover { background: var(--mib-surface-2); }
        .section-header::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
        .section-title {
            margin: 0; font-weight: 650; font-size: 1rem; color: var(--mib-text);
            display: flex; align-items: center; gap: 0.6rem;
        }
        .section-title > i { color: var(--accent); }
        .section-title .badge { font-size: 0.74rem; font-weight: 700; }
        .section-header > .bi-chevron-down { margin-left: auto; color: var(--mib-text-faint); font-size: 1.1rem; transition: transform 0.28s ease; }
        .section-content { border-top: 1px solid var(--mib-border); }
        .section-content .table-responsive { box-shadow: none; border: none; border-radius: 0; margin: 0; }
        .table thead th { background: var(--mib-surface-2); }

        /* ---------- Filter toolbar (inside a section) ---------- */
        .filter-section {
            display: flex; align-items: flex-end; gap: 1rem; flex-wrap: wrap;
            padding: 1.1rem 1.25rem; border-bottom: 1px solid var(--mib-border);
            background: var(--mib-surface-2);
        }
        .filter-group { flex: 1 1 220px; min-width: 0; }
        .filter-group label { display: block; margin-bottom: 0.35rem; font-weight: 600; font-size: 0.82rem; color: var(--mib-text-muted); }

        /* ---------- Quantities ---------- */
        .quantity-positive { color: var(--mib-primary-dark); font-weight: 600; }
        .quantity-negative { color: var(--mib-danger); font-weight: 600; }

        /* ---------- Button loading spinner ---------- */
        .btn.loading { pointer-events: none; color: transparent !important; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .rmw-hero { padding: 1.4rem 1.25rem; }
            .filter-section { padding: 0.9rem 1rem; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/raw-material-warehouse' }) %>
    <%- include('../partials/chat', {
          users: (typeof users !== 'undefined' ? users : []),
          userRole: userRole,
          userId: (typeof userId !== 'undefined' ? userId : '')
    }) %>

    <%
        /* ---- Defensive normalisation (template renders from several routes) ---- */
        const pendingRaw   = (typeof pendingRawMaterialRequests !== 'undefined' && pendingRawMaterialRequests) ? pendingRawMaterialRequests : [];
        const pendingPkg   = (typeof pendingPackagingRequests !== 'undefined' && pendingPackagingRequests) ? pendingPackagingRequests : [];
        const inboundRaw   = (typeof inboundRawMaterialRequests !== 'undefined' && inboundRawMaterialRequests) ? inboundRawMaterialRequests : [];
        const inboundPkg   = (typeof inboundPackagingRequests !== 'undefined' && inboundPackagingRequests) ? inboundPackagingRequests : [];
        const outboundRaw  = (typeof productions !== 'undefined' && productions) ? productions : [];
        const outboundPkg  = (typeof outboundPackaging !== 'undefined' && outboundPackaging) ? outboundPackaging : [];

        /* optional filter locals */
        const fInStart   = (typeof inboundStartDate !== 'undefined' && inboundStartDate) ? inboundStartDate : '';
        const fInEnd     = (typeof inboundEndDate !== 'undefined' && inboundEndDate) ? inboundEndDate : '';
        const fOutStart  = (typeof outboundStartDate !== 'undefined' && outboundStartDate) ? outboundStartDate : '';
        const fOutEnd    = (typeof outboundEndDate !== 'undefined' && outboundEndDate) ? outboundEndDate : '';
        const defStart   = (typeof defaultStartDate !== 'undefined' && defaultStartDate) ? defaultStartDate : '';
        const defEnd     = (typeof defaultEndDate !== 'undefined' && defaultEndDate) ? defaultEndDate : '';

        /* QC badge helper */
        const qcb = (s) => {
            if (s === 'Pass') return 'status-completed';
            if (s === 'Fail') return 'status-declined';
            return 'status-pending';
        };
        const fmtDate = (d) => d ? new Date(d).toLocaleString() : '—';
        const fmtExp  = (d) => d ? new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—';

        const pendingCount = pendingRaw.length + pendingPkg.length;
    %>

    <div class="content content-wide">

        <!-- ===================== Hero ===================== -->
        <div class="rmw-hero fade-in">
            <div class="rmw-hero__text">
                <p class="rmw-hello">Warehouse Workspace</p>
                <h1><i class="bi bi-box-seam"></i> Raw Material Warehouse</h1>
                <p class="sub">Receive deliveries, test materials through QC and track inbound &amp; outbound stock — all from one place.</p>
            </div>
            <div class="rmw-hero__actions">
                <a href="/products/addRawMaterial" class="btn btn-light"><i class="bi bi-plus-lg"></i> Add Raw Material</a>
                <a href="/rawMaterials/rawMaterialStock" class="btn btn-white"><i class="bi bi-boxes"></i> Check Stock</a>
            </div>
        </div>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon <%= pendingCount > 0 ? 'is-warning' : 'is-success' %>"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending Requests</div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <span class="stat-sub">Materials &amp; packaging to process</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-box-arrow-in-down"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Inbound</div>
                    <div class="stat-value"><%= inboundRaw.length + inboundPkg.length %></div>
                    <span class="stat-sub">Recent receipts in range</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-box-arrow-right"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Outbound</div>
                    <div class="stat-value"><%= outboundRaw.length + outboundPkg.length %></div>
                    <span class="stat-sub">Issued to production</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Raw Material Pending</div>
                    <div class="stat-value"><%= pendingRaw.length %></div>
                    <span class="stat-sub">Awaiting receive / QC</span>
                </div>
            </div>
        </div>

        <!-- ===================== List / Board toggle ===================== -->
        <%- include('../partials/kanban-toggle') %>

        <!-- ===================== Pending Raw Material Requests ===================== -->
        <div class="dashboard-section" style="--accent:#d97706;--accent-soft:#fef3c7">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#pendingRawMaterialRequests" aria-expanded="true" aria-controls="pendingRawMaterialRequests">
                <h2 class="section-title">
                    <i class="bi bi-hourglass-split"></i>
                    Pending Raw Material Requests
                    <% if (pendingRaw.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= pendingRaw.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="pendingRawMaterialRequests" class="collapse show section-content">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Batch Number</th>
                                <th>Material</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Vendor</th>
                                <th>QC Status</th>
                                <th>Expired Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pendingRaw.length > 0) { %>
                                <% pendingRaw.forEach(function(requestVendor) { %>
                                    <tr id="request-row-<%= requestVendor.id %>">
                                        <td data-label="ID"><span class="cell-strong">#<%= requestVendor.id %></span></td>
                                        <td data-label="PO Number"><%= requestVendor.ponumber || '-' %></td>
                                        <td data-label="Batch Number"><%= requestVendor.batchNumber || '-' %></td>
                                        <td data-label="Material">
                                            <span class="cell-strong"><%= requestVendor.RawMaterialRequest ? requestVendor.RawMaterialRequest.materialName : '-' %></span>
                                        </td>
                                        <td data-label="Quantity">
                                            <% if (requestVendor.rejectQuantity > 0) { %>
                                                <%= requestVendor.rejectQuantity %> Kg <span class="cell-sub">(Rejected Quantity)</span>
                                            <% } else { %>
                                                <%= requestVendor.splitQuantity %> Kg
                                            <% } %>
                                        </td>
                                        <td data-label="Status">
                                            <%= requestVendor.status %>
                                            <% if (requestVendor.status === 'Quarantined') { %>
                                                <span class="text-danger">(Failed Raw Material)</span>
                                            <% } %>
                                        </td>
                                        <td data-label="Vendor"><%= requestVendor.Vendor ? requestVendor.Vendor.name : '-' %></td>
                                        <td data-label="QC Status">
                                            <span class="status-badge <%= qcb(requestVendor.qcStatus) %>"><%= requestVendor.qcStatus || 'Pending' %></span>
                                        </td>
                                        <td data-label="Expired Date">
                                            <%= requestVendor.expiredDate ? fmtExp(requestVendor.expiredDate) : '-' %>
                                        </td>
                                        <td data-label="Actions" class="text-end">
                                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-sm btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-check-lg"></i> Receive
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received' && (requestVendor.qcStatus === 'Pending' || requestVendor.qcStatus === 'Fail')) { %>
                                                    <button type="button" class="btn btn-sm btn-soft test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i> Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received') { %>
                                                    <button type="button" class="btn btn-sm btn-soft test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i> Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-sm btn-soft test-qc-btn" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <i class="bi bi-clipboard-check"></i> Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'No Return') { %>
                                                    <form class="receive-failed-form" action="/rawMaterial/receivedFailedMaterial/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <button type="submit" class="btn btn-sm btn-soft">
                                                            <i class="bi bi-box-arrow-in-down"></i> Received Failed Raw Material
                                                        </button>
                                                    </form>
                                                <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                    <form class="update-stock-form" action="/rawMaterial/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="raw">
                                                        <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                            <div class="mb-2">
                                                                <label class="form-label">Reject Quantity (Kg)</label>
                                                                <% if (requestVendor.status === 'QC Testing') { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> Kg</small>
                                                                <% } else { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                                <% } %>
                                                            </div>
                                                            <% if (requestVendor.rejectComment) { %>
                                                                <div class="alert alert-warning mb-2">
                                                                    <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <% if (requestVendor.qcStatus === 'Pass') { %>
                                                            <% if (requestVendor.rejectQuantity === 0) { %>
                                                                <div class="mb-2">
                                                                    <label class="form-label">Real Quantity (Kg)</label>
                                                                    <input type="number" name="realQuantity" class="form-control" step="0.01" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> Kg</small>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <button type="submit" class="btn btn-sm btn-primary">
                                                            <i class="bi bi-arrow-clockwise"></i> Update Stock
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr class="is-empty-row">
                                    <td colspan="10">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <h4>No pending raw material requests</h4>
                                            <p>Incoming raw material deliveries will appear here.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== Pending Packaging Requests ===================== -->
        <div class="dashboard-section" style="--accent:#0d9488;--accent-soft:#ccfbf1">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#pendingPackagingRequests" aria-expanded="true" aria-controls="pendingPackagingRequests">
                <h2 class="section-title">
                    <i class="bi bi-box2"></i>
                    Pending Packaging Requests
                    <% if (pendingPkg.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= pendingPkg.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="pendingPackagingRequests" class="collapse show section-content">
                <div class="table-responsive">
                    <table class="table table-cards align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>PO Number</th>
                                <th>Packaging</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Vendor</th>
                                <th>QC Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (pendingPkg.length > 0) { %>
                                <% pendingPkg.forEach(function(requestVendor) { %>
                                    <tr id="request-row-<%= requestVendor.id %>">
                                        <td data-label="ID"><span class="cell-strong">#<%= requestVendor.id %></span></td>
                                        <td data-label="PO Number"><%= requestVendor.ponumber || '-' %></td>
                                        <td data-label="Packaging">
                                            <span class="cell-strong"><%= requestVendor.PackagingRequest ? requestVendor.PackagingRequest.packagingName : '-' %></span>
                                        </td>
                                        <td data-label="Quantity">
                                            <% if (requestVendor.rejectQuantity > 0) { %>
                                                <%= requestVendor.rejectQuantity %> pcs <span class="cell-sub">(Rejected Quantity)</span>
                                            <% } else { %>
                                                <%= requestVendor.splitQuantity %> pcs
                                            <% } %>
                                        </td>
                                        <td data-label="Status">
                                            <%= requestVendor.status %>
                                            <% if (requestVendor.status === 'Quarantined') { %>
                                                <span class="text-danger">(Failed Packaging)</span>
                                            <% } %>
                                        </td>
                                        <td data-label="Vendor"><%= requestVendor.Vendor ? requestVendor.Vendor.name : '-' %></td>
                                        <td data-label="QC Status">
                                            <span class="status-badge <%= qcb(requestVendor.qcStatus) %>"><%= requestVendor.qcStatus || 'Pending' %></span>
                                        </td>
                                        <td data-label="Actions" class="text-end">
                                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                <% if (requestVendor.status === 'On Delivery' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-sm btn-success receive-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <i class="bi bi-check-lg"></i> Receive
                                                    </button>
                                                <% } else if (requestVendor.status === 'Received' || requestVendor.status === 'Returned') { %>
                                                    <button type="button" class="btn btn-sm btn-soft test-qc-btn" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <i class="bi bi-clipboard-check"></i> Test to QC
                                                    </button>
                                                <% } else if (requestVendor.status === 'No Return') { %>
                                                    <form class="receive-failed-form" action="/packaging-request/receivedFailedPackaging/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <button type="submit" class="btn btn-sm btn-soft">
                                                            <i class="bi bi-box-arrow-in-down"></i> Received Failed Packaging
                                                        </button>
                                                    </form>
                                                <% } else if (requestVendor.qcStatus === 'Pass' || requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                    <form class="update-stock-form" action="/packaging-request/updateStock/<%= requestVendor.id %>" method="POST" data-id="<%= requestVendor.id %>" data-type="packaging">
                                                        <% if (requestVendor.qcStatus === 'Reject Sebagian') { %>
                                                            <div class="mb-2">
                                                                <label class="form-label">Reject Quantity (pcs)</label>
                                                                <% if (requestVendor.status === 'QC Testing') { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" required>
                                                                    <small class="text-muted">Current Reject: <%= requestVendor.rejectQuantity %> pcs</small>
                                                                <% } else { %>
                                                                    <input type="number" name="rejectQuantity" class="form-control" required>
                                                                    <small class="text-muted">Current Split: <%= requestVendor.splitQuantity %> pcs</small>
                                                                <% } %>
                                                            </div>
                                                            <% if (requestVendor.rejectComment) { %>
                                                                <div class="alert alert-warning mb-2">
                                                                    <strong>Reject Reason:</strong> <%= requestVendor.rejectComment %>
                                                                </div>
                                                            <% } %>
                                                        <% } %>
                                                        <button type="submit" class="btn btn-sm btn-primary">
                                                            <i class="bi bi-arrow-clockwise"></i> Update Stock
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr class="is-empty-row">
                                    <td colspan="8">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <h4>No pending packaging requests</h4>
                                            <p>Incoming packaging deliveries will appear here.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ===================== Inbound Raw Material ===================== -->
        <div class="dashboard-section" style="--accent:#2563eb;--accent-soft:#dbeafe">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#inboundRawMaterial" aria-expanded="false" aria-controls="inboundRawMaterial">
                <h2 class="section-title">
                    <i class="bi bi-box-arrow-in-down"></i>
                    Inbound Raw Material
                    <% if (inboundRaw.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= inboundRaw.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="inboundRawMaterial" class="collapse section-content">
                <form class="filter-section" method="GET">
                    <div class="filter-group">
                        <label class="form-label">Date Range</label>
                        <input type="text" class="date-range-picker form-control" name="inboundDateRange"
