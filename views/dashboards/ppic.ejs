<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'PPIC Dashboard' }) %>
    <style>
        /* ============================================================
           PPIC Control Tower — page-specific flourishes
           Built on the shared mibflow.css design system.
           ============================================================ */

        /* Legacy-var bridge so shared partials (chat) stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }

        /* ---------- Hero ---------- */
        .ppic-hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--mib-radius-lg);
            padding: 1.85rem 2rem;
            margin-bottom: 1.6rem;
            color: #eaf6ef;
            background: var(--mib-sidebar-bg);
            box-shadow: var(--mib-shadow-md);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.25rem;
            flex-wrap: wrap;
        }
        .ppic-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                radial-gradient(460px 220px at 86% -30%, rgba(110, 231, 183, 0.30), transparent 60%),
                radial-gradient(360px 200px at 8% 130%, rgba(110, 231, 183, 0.15), transparent 60%);
        }
        .ppic-hero__text { position: relative; z-index: 1; min-width: 0; }
        .ppic-eyebrow {
            margin: 0 0 0.4rem; font-size: 0.78rem; font-weight: 600;
            letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255, 255, 255, 0.66);
            display: inline-flex; align-items: center; gap: 0.5rem;
        }
        .live-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #6ee7b7; box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.7);
            animation: livePulse 1.8s ease-out infinite;
        }
        @keyframes livePulse {
            0%   { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55); }
            70%  { box-shadow: 0 0 0 9px rgba(110, 231, 183, 0); }
            100% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0); }
        }
        .ppic-hero h1 {
            margin: 0; font-size: 1.85rem; font-weight: 750; letter-spacing: -0.025em; color: #fff;
            display: flex; align-items: center; gap: 0.6rem;
        }
        .ppic-hero .sub { margin: 0.5rem 0 0; color: rgba(255, 255, 255, 0.78); font-size: 0.92rem; max-width: 56ch; }
        .ppic-hero__aside { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: flex-end; gap: 0.85rem; }
        .ppic-clock {
            font-variant-numeric: tabular-nums; font-weight: 750; font-size: 1.7rem; line-height: 1;
            color: #fff; letter-spacing: -0.01em;
        }
        .ppic-clock small { display: block; font-size: 0.74rem; font-weight: 500; color: rgba(255,255,255,0.66); letter-spacing: 0.02em; margin-top: 0.3rem; text-align: right; }
        .ppic-hero__actions { display: flex; gap: 0.55rem; flex-wrap: wrap; justify-content: flex-end; }
        .ppic-hero .btn-white { background: #fff; color: var(--mib-primary-dark); border: none; box-shadow: 0 8px 18px -6px rgba(0,0,0,0.3); }
        .ppic-hero .btn-white:hover { background: #f3faf6; color: var(--mib-primary-dark); transform: translateY(-1px); }
        .ppic-hero .btn-glass { background: rgba(255,255,255,0.13); border: 1px solid rgba(255,255,255,0.22); color: #fff; backdrop-filter: blur(4px); }
        .ppic-hero .btn-glass:hover { background: rgba(255,255,255,0.22); color: #fff; }

        /* ---------- Staggered entrance ---------- */
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }
        .stagger > *:nth-child(5) { animation-delay: 0.28s; }
        .stagger > *:nth-child(6) { animation-delay: 0.34s; }
        .stagger > *:nth-child(7) { animation-delay: 0.40s; }
        .stagger > *:nth-child(8) { animation-delay: 0.46s; }

        /* ---------- Clickable stat cards ---------- */
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(185px, 1fr)); }
        .stat-card.is-clickable { cursor: pointer; user-select: none; }
        .stat-card.is-clickable:focus-visible { outline: none; box-shadow: var(--mib-shadow-md), var(--mib-ring); }
        .stat-card .stat-go {
            position: absolute; top: 0.95rem; right: 1.05rem; color: var(--mib-text-faint);
            opacity: 0; transform: translateX(-4px); transition: opacity .18s, transform .18s; z-index: 1;
        }
        .stat-card.is-clickable:hover .stat-go { opacity: 1; transform: translateX(0); }
        .stat-icon.is-violet { background: linear-gradient(135deg, #a78bfa, #7c3aed); box-shadow: 0 8px 18px -4px rgba(124, 58, 237, 0.35); }

        /* ---------- Toolbar ---------- */
        .ppic-toolbar { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.2rem; }
        .ppic-toolbar .vb-label { color: var(--mib-text-muted); font-size: 0.8rem; font-weight: 650; text-transform: uppercase; letter-spacing: 0.05em; }
        .seg { display: inline-flex; background: var(--mib-surface-2); border: 1px solid var(--mib-border); border-radius: var(--mib-radius-pill); padding: 0.22rem; gap: 0.15rem; }
        .seg .btn {
            border: none; border-radius: var(--mib-radius-pill); padding: 0.4rem 0.95rem; font-size: 0.84rem;
            color: var(--mib-text-muted); background: transparent; box-shadow: none; font-weight: 600;
        }
        .seg .btn:hover { color: var(--mib-primary-dark); transform: none; }
        .seg .btn.active { background: var(--mib-surface); color: var(--mib-primary-dark); box-shadow: var(--mib-shadow-xs); }
        .seg .btn.active i { color: var(--mib-primary); }
        .ppic-search { position: relative; flex: 1 1 240px; max-width: 360px; }
        .ppic-search i { position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); color: var(--mib-text-faint); font-size: 1rem; pointer-events: none; }
        .ppic-search input { padding-left: 2.4rem; }
        .ppic-toolbar .spacer { flex: 1 1 auto; }
        .list-only { display: inline-flex; }
        body.board-mode .list-only { display: none; }

        /* ---------- Queue panels (list view) ---------- */
        .dashboard-section {
            --accent: var(--mib-primary);
            --accent-soft: var(--mib-primary-soft);
            background: var(--mib-grad-surface);
            border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow);
            margin-bottom: 1rem;
            overflow: hidden;
            transition: box-shadow var(--mib-transition), border-color var(--mib-transition);
        }
        .dashboard-section:hover { box-shadow: var(--mib-shadow-md); }
        .section-header {
            position: relative; display: flex; align-items: center; gap: 0.85rem;
            padding: 1rem 1.25rem 1rem 1.4rem; cursor: pointer; transition: background var(--mib-transition);
        }
        .section-header:hover { background: var(--mib-surface-2); }
        .section-header::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--accent); }
        .sec-ico {
            flex-shrink: 0; width: 40px; height: 40px; border-radius: 12px; display: grid; place-items: center;
            font-size: 1.1rem; color: var(--accent); background: var(--accent-soft);
        }
        .sec-titles { min-width: 0; }
        .sec-title { margin: 0; font-weight: 650; font-size: 1rem; color: var(--mib-text); display: flex; align-items: center; gap: 0.55rem; }
        .sec-sub { margin: 0.1rem 0 0; font-size: 0.78rem; color: var(--mib-text-muted); }
        .sec-count {
            display: inline-flex; align-items: center; justify-content: center; min-width: 1.5rem; height: 1.5rem; padding: 0 0.5rem;
            border-radius: var(--mib-radius-pill); background: var(--accent-soft); color: var(--accent);
            font-size: 0.78rem; font-weight: 700;
        }
        .sec-count.is-zero { background: var(--mib-surface-2); color: var(--mib-text-faint); }
        .sec-chevron { margin-left: auto; color: var(--mib-text-faint); font-size: 1.1rem; transition: transform 0.28s ease; }
        .section-header[aria-expanded="true"] .sec-chevron { transform: rotate(180deg); }
        .section-content { border-top: 1px solid var(--mib-border); }
        .section-content .table-responsive { box-shadow: none; border: none; border-radius: 0; margin: 0; }

        .table thead th { background: var(--mib-surface-2); }
        .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
        .chip-list { display: flex; flex-wrap: wrap; gap: 0.3rem; }
        .chip {
            display: inline-flex; align-items: center; gap: 0.3rem; background: var(--mib-surface-2);
            border: 1px solid var(--mib-border); color: var(--mib-text-muted); border-radius: var(--mib-radius-pill);
            padding: 0.18rem 0.6rem; font-size: 0.76rem; font-weight: 550;
        }

        /* extra status mappings used on PPIC */
        .status-scheduled { background: var(--mib-info-soft); color: #1e40af; }

        /* ---------- Board (Kanban) ---------- */
        #ppicKanbanView { animation: fadeIn 0.35s ease-out; }
        /* Board scroll bar (hint + prev/next) */
        .board-bar { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.7rem; }
        .board-hint { display: inline-flex; align-items: center; gap: 0.45rem; color: var(--mib-text-muted); font-size: 0.8rem; font-weight: 550; }
        .board-hint i { color: var(--mib-primary); font-size: 0.95rem; }
        .board-nav { display: flex; gap: 0.35rem; }
        .board-nav .btn-icon { width: 34px; height: 34px; }
        .board-nav .btn:disabled { opacity: 0.4; pointer-events: none; }
        /* Trello-style horizontal board: fixed columns extend right, scroll left/right */
        .kanban-board {
            display: flex; gap: 1rem; align-items: flex-start;
            overflow-x: auto; overflow-y: hidden;
            padding-bottom: 0.85rem;
            scroll-snap-type: x proximity; scroll-behavior: smooth;
            overscroll-behavior-x: contain;
        }
        .kanban-board::-webkit-scrollbar { height: 10px; }
        .kanban-board::-webkit-scrollbar-track { background: var(--mib-surface-2); border-radius: 999px; }
        .kanban-board::-webkit-scrollbar-thumb { background: var(--mib-border-strong); border-radius: 999px; border: 2px solid var(--mib-surface-2); }
        .kanban-board::-webkit-scrollbar-thumb:hover { background: var(--mib-primary-light); }
        .kanban-col {
            --accent: var(--mib-primary);
            --accent-soft: var(--mib-primary-soft);
            position: relative; flex: 0 0 320px; scroll-snap-align: start; background: var(--mib-surface);
            border: 1px solid var(--mib-border); border-top: 3px solid var(--accent);
            border-radius: var(--mib-radius); padding: 0.7rem 0.7rem 0.8rem;
            max-height: calc(100vh - 250px); overflow-y: auto;
        }
        .kanban-col::-webkit-scrollbar { width: 6px; }
        .kanban-col::-webkit-scrollbar-thumb { background: var(--mib-border-strong); border-radius: 3px; }
        .kanban-col-head {
            position: sticky; top: -0.7rem; z-index: 2; margin: -0.7rem -0.7rem 0.7rem; padding: 0.75rem 0.85rem;
            background: var(--mib-surface); border-bottom: 1px solid var(--mib-border);
            display: flex; align-items: center; gap: 0.6rem;
        }
        .kanban-col-ico { width: 30px; height: 30px; border-radius: 9px; display: grid; place-items: center; font-size: 0.95rem; color: var(--accent); background: var(--accent-soft); flex-shrink: 0; }
        .kanban-col-title { font-weight: 650; color: var(--mib-text); font-size: 0.9rem; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .kanban-count { margin-left: auto; flex-shrink: 0; background: var(--accent-soft); color: var(--accent); border-radius: var(--mib-radius-pill); padding: 0.08rem 0.6rem; font-size: 0.74rem; font-weight: 700; }
        .kanban-card {
            position: relative; background: var(--mib-surface); border: 1px solid var(--mib-border);
            border-radius: var(--mib-radius-sm); padding: 0.85rem; margin-bottom: 0.65rem;
            box-shadow: var(--mib-shadow-xs); transition: transform var(--mib-transition), box-shadow var(--mib-transition), border-color var(--mib-transition);
        }
        .kanban-card:hover { transform: translateY(-2px); box-shadow: var(--mib-shadow-md); border-color: var(--mib-border-strong); }
        .kanban-card:last-child { margin-bottom: 0; }
        .kanban-del {
            position: absolute; top: 6px; right: 6px; width: 24px; height: 24px; line-height: 1; border: none; border-radius: 7px;
            background: transparent; color: var(--mib-text-faint); font-size: 1.05rem; cursor: pointer; display: grid; place-items: center;
            opacity: 0; transition: opacity .15s, background .15s, color .15s;
        }
        .kanban-card:hover .kanban-del { opacity: 1; }
        .kanban-del:hover { background: var(--mib-danger-soft); color: var(--mib-danger); }
        @media (hover: none) { .kanban-del { opacity: 1; } }
        .kanban-card .so { padding-right: 1.4rem; font-weight: 700; color: var(--mib-text); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
        .kanban-card .cust { color: var(--mib-text-muted); font-size: 0.8rem; margin: 0.2rem 0 0.6rem; display: flex; align-items: center; gap: 0.35rem; }
        .kanban-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.65rem; }
        .kanban-actions { display: flex; flex-wrap: wrap; gap: 0.35rem; }
        .kanban-actions .btn { width: auto; }
        .kanban-empty { color: var(--mib-text-faint); font-size: 0.84rem; text-align: center; padding: 1.75rem 0; }
        .kanban-empty i { display: block; font-size: 1.5rem; margin-bottom: 0.35rem; opacity: 0.7; }
        .queue-flash { animation: queueFlash 1.1s ease-out; }
        @keyframes queueFlash {
            0% { box-shadow: 0 0 0 0 var(--accent-soft); }
            30% { box-shadow: 0 0 0 4px var(--accent-soft); }
            100% { box-shadow: var(--mib-shadow); }
        }

        /* ---------- Button loading spinner ---------- */
        .btn.loading { pointer-events: none; color: transparent !important; position: relative; }
        .btn.loading::after {
            content: ""; position: absolute; width: 16px; height: 16px; top: 50%; left: 50%; margin: -8px 0 0 -8px;
            border: 2px solid rgba(255, 255, 255, 0.55); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 768px) {
            .ppic-hero { padding: 1.4rem 1.25rem; }
            .ppic-hero__aside { align-items: flex-start; width: 100%; }
            .ppic-hero__actions { justify-content: flex-start; }
            .kanban-col { flex-basis: 86vw; max-height: calc(100vh - 200px); }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/dashboard/ppic' }) %>
    <%- include('../partials/chat', { users: (typeof users !== 'undefined' ? users : []), userRole: userRole, userId: userId }) %>

    <%
        /* ---- Defensive normalisation (template is rendered from several routes) ---- */
        const orderList      = (typeof orders !== 'undefined' && orders) ? orders : [];
        const prodList       = (typeof completedProductions !== 'undefined' && completedProductions) ? completedProductions : [];
        const reqList        = (typeof requests !== 'undefined' && requests) ? requests : [];
        const rawReqList     = (typeof rawMaterialRequests !== 'undefined' && rawMaterialRequests) ? rawMaterialRequests : [];
        const pkgReqList     = (typeof packagingRequests !== 'undefined' && packagingRequests) ? packagingRequests : [];
        const formulaReqList = (typeof formulaRequests !== 'undefined' && formulaRequests) ? formulaRequests : [];
        const checkList      = (typeof productChecks !== 'undefined' && productChecks) ? productChecks : [];
        const reworkAll      = (typeof complainItems !== 'undefined' && complainItems) ? complainItems : [];
        const flash          = (typeof messages !== 'undefined' && messages) ? messages : {};
        const flashSuccess   = [].concat(flash.success || []).filter(Boolean);
        const flashError     = [].concat(flash.error || []).filter(Boolean);

        const unprintedProductions = orderList ? prodList.filter(p => !p.isPrinted) : [];
        const reworkActive = reworkAll.filter(i => i.status !== 'Completed');

        /* status badge helpers */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
        const qb = (s) => s === 'Pass' ? 'status-completed' : (s === 'Fail' ? 'status-declined' : 'status-pending');
        const fmtD = (d) => d ? new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '—';

        const procurementCount = rawReqList.length + pkgReqList.length;
        const qcCount = checkList.length + reworkActive.length;
    %>

    <div class="content content-wide">

        <!-- ===================== Hero ===================== -->
        <div class="ppic-hero fade-in">
            <div class="ppic-hero__text">
                <p class="ppic-eyebrow"><span class="live-dot"></span> PPIC Control Tower</p>
                <h1><i class="bi bi-clipboard-data"></i> Production Planning</h1>
                <p class="sub">Orders, production, materials and quality — one live command center for the whole production pipeline.</p>
            </div>
            <div class="ppic-hero__aside">
                <div class="ppic-clock">
                    <span id="ppicClock">--:--</span>
                    <small id="ppicDate"></small>
                </div>
                <div class="ppic-hero__actions">
                    <a href="/ppic/requestProduction" class="btn btn-glass"><i class="bi bi-clock-history"></i> Schedule</a>
                    <a href="/ppic/requestProduction" class="btn btn-white"><i class="bi bi-plus-lg"></i> Request Production</a>
                </div>
            </div>
        </div>

        <!-- Flash messages -->
        <% flashError.forEach(function(msg) { %>
            <div class="mib-flash mib-flash-error alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <% if (String(msg).includes('\n')) { %><pre class="mb-0" style="white-space:pre-wrap"><%= msg %></pre><% } else { %><span><%= msg %></span><% } %>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% }); %>
        <% flashSuccess.forEach(function(msg) { %>
            <div class="mib-flash mib-flash-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><%= msg %></span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% }); %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card is-clickable" role="button" tabindex="0" data-focus="orders">
                <i class="bi bi-arrow-right-short stat-go fs-5"></i>
                <div class="stat-icon"><i class="bi bi-cart3"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Active Orders</div>
                    <div class="stat-value" data-count="<%= orderList.length %>">0</div>
                    <span class="stat-sub">Awaiting planning &amp; production</span>
                </div>
            </div>
            <div class="stat-card is-clickable" role="button" tabindex="0" data-focus="productionList">
                <i class="bi bi-arrow-right-short stat-go fs-5"></i>
                <div class="stat-icon is-info"><i class="bi bi-printer"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Ready to Print</div>
                    <div class="stat-value" data-count="<%= unprintedProductions.length %>">0</div>
                    <span class="stat-sub">Batches pending labels</span>
                </div>
            </div>
            <div class="stat-card is-clickable" role="button" tabindex="0" data-focus="productionRequests">
                <i class="bi bi-arrow-right-short stat-go fs-5"></i>
                <div class="stat-icon is-violet"><i class="bi bi-gear-wide-connected"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Production Requests</div>
                    <div class="stat-value" data-count="<%= reqList.length %>">0</div>
                    <span class="stat-sub">In the production queue</span>
                </div>
            </div>
            <div class="stat-card is-clickable" role="button" tabindex="0" data-focus="rawMaterial">
                <i class="bi bi-arrow-right-short stat-go fs-5"></i>
                <div class="stat-icon is-warning"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Procurement</div>
                    <div class="stat-value" data-count="<%= procurementCount %>">0</div>
                    <span class="stat-sub">Raw material &amp; packaging</span>
                </div>
            </div>
            <div class="stat-card is-clickable" role="button" tabindex="0" data-focus="productChecks">
                <i class="bi bi-arrow-right-short stat-go fs-5"></i>
                <div class="stat-icon <%= qcCount > 0 ? 'is-danger' : 'is-success' %>"><i class="bi bi-clipboard2-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">QC &amp; Rework</div>
                    <div class="stat-value" data-count="<%= qcCount %>">0</div>
                    <span class="stat-sub">Checks &amp; rework items</span>
                </div>
            </div>
        </div>

        <!-- ===================== Toolbar ===================== -->
        <div class="ppic-toolbar">
            <span class="vb-label d-none d-sm-inline">View</span>
            <div class="seg" role="group" aria-label="View switch">
                <button type="button" class="btn active" id="btnListView"><i class="bi bi-list-ul"></i> List</button>
                <button type="button" class="btn" id="btnKanbanView"><i class="bi bi-kanban"></i> Board</button>
            </div>
            <div class="ppic-search">
                <i class="bi bi-search"></i>
                <input type="text" id="ppicSearch" class="form-control form-control-sm" placeholder="Search across queues…" autocomplete="off">
            </div>
            <div class="spacer"></div>
            <button type="button" class="btn btn-ghost btn-sm list-only" id="btnExpandAll"><i class="bi bi-arrows-expand"></i> Expand all</button>
            <button type="button" class="btn btn-ghost btn-sm list-only" id="btnCollapseAll"><i class="bi bi-arrows-collapse"></i> Collapse all</button>
        </div>

        <!-- ===================== Board (Kanban) view ===================== -->
        <div id="ppicKanbanView" style="display:none;">
            <div class="board-bar">
                <span class="board-hint"><i class="bi bi-arrow-left-right"></i> Scroll sideways to see every queue</span>
                <div class="board-nav">
                    <button type="button" class="btn btn-ghost btn-icon btn-sm" id="boardLeft" aria-label="Scroll left"><i class="bi bi-chevron-left"></i></button>
                    <button type="button" class="btn btn-ghost btn-icon btn-sm" id="boardRight" aria-label="Scroll right"><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
            <div class="kanban-board">

                <!-- Orders -->
                <div class="kanban-col" data-queue="orders" style="--accent:#2f6f4e;--accent-soft:#e7f1ec">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-cart3"></i></span>
                        <span class="kanban-col-title">Orders</span>
                        <span class="kanban-count"><%= orderList.length %></span>
                    </div>
                    <% if (!orderList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No orders</div><% } %>
                    <% orderList.forEach(order => { %>
                        <div class="kanban-card" data-card-key="orders-<%= order.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= order.sonumber %> <span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></div>
                            <div class="cust"><i class="bi bi-person"></i> <%= order.Customer ? order.Customer.name : '—' %></div>
                            <div class="kanban-chips">
                                <% (order.products || []).forEach(p => { %><span class="chip"><%= p.name %> (<%= p.quantity %> <%= p.satuan %>)</span><% }) %>
                            </div>
                            <div class="kanban-actions">
                                <% if (order.status == "Pending" || order.status == "Production Completed") { %>
                                    <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#deliveryModal<%= order.id %>"><i class="bi bi-check-lg"></i> Approve</button>
                                <% } %>
                                <button type="button" class="btn btn-sm btn-outline-primary check-stock-btn" data-order-id="<%= order.id %>"><i class="bi bi-box"></i> Stock</button>
                                <a href="/orders/<%= order.id %>" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                <% if (order.needsProduction && order.status !== 'On Production' && order.status !== 'Production Completed') { %>
                                    <a href="/production/request/<%= order.id %>" class="btn btn-sm btn-primary"><i class="bi bi-gear"></i> Request</a>
                                <% } %>
                                <% if (!(order.OrderItems || []).every(item => item.Product.formula)) { %>
                                    <form action="/orders/requestFormula/<%= order.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-file-text"></i> Formula</button></form>
                                <% } %>
                                <form action="/orders/decline/<%= order.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Decline</button></form>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Production List -->
                <div class="kanban-col" data-queue="productionList" style="--accent:#7c3aed;--accent-soft:#f3e8ff">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-list-check"></i></span>
                        <span class="kanban-col-title">Production List</span>
                        <span class="kanban-count"><%= unprintedProductions.length %></span>
                    </div>
                    <% if (!unprintedProductions.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>Nothing to print</div><% } %>
                    <% unprintedProductions.forEach(p => { %>
                        <div class="kanban-card" data-card-key="prod-<%= p.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= p.Product ? p.Product.name : 'Product' %></div>
                            <div class="cust">Batch: <%= p.batchNumber || 'Not Generated' %> · <%= p.quantity %> Kg</div>
                            <div class="kanban-chips">
                                <span class="status-badge <%= sb(p.status) %>"><%= p.status %></span>
                                <span class="status-badge <%= qb(p.qcStatus) %>">QC: <%= p.qcStatus %></span>
                            </div>
                            <% if (p.batchNumber) { %>
                            <div class="kanban-actions">
                                <a href="/production/blending-guide/<%= p.id %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-earmark-text"></i> Guide</a>
                                <% if (!p.isPrinted && p.qcStatus !== 'Pass') { %>
                                <form action="/production/print/<%= p.id %>" method="POST" style="display:inline-block;"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-printer"></i> Print</button></form>
                                <% } %>
                            </div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

                <!-- Production Requests -->
                <div class="kanban-col" data-queue="productionRequests" style="--accent:#2563eb;--accent-soft:#dbeafe">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-gear"></i></span>
                        <span class="kanban-col-title">Production Requests</span>
                        <span class="kanban-count"><%= reqList.length %></span>
                    </div>
                    <% if (!reqList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No requests</div><% } %>
                    <% reqList.forEach(r => { %>
                        <div class="kanban-card" data-card-key="prodreq-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= r.product %></div>
                            <div class="cust"><%= r.orderId ? (r.Order ? r.Order.sonumber : 'N/A') : r.prodreqnumber %> · <%= r.quantity %> Kg</div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <div class="kanban-actions">
                                <a href="/production/<%= r.id %>/view" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                <% if (r.allCompleted) { %><form action="/production/<%= r.id %>/clear" method="POST"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Clear</button></form><% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Raw Material Requests -->
                <div class="kanban-col" data-queue="rawMaterial" style="--accent:#d97706;--accent-soft:#fef3c7">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-box-seam"></i></span>
                        <span class="kanban-col-title">Raw Material Requests</span>
                        <span class="kanban-count"><%= rawReqList.length %></span>
                    </div>
                    <% if (!rawReqList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No requests</div><% } %>
                    <% rawReqList.forEach(r => { %>
                        <div class="kanban-card" data-card-key="rawmat-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= r.materialName %></div>
                            <div class="cust"><%= r.quantity %> Kg</div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <% if (r.allVendorsCompleted) { %>
                            <div class="kanban-actions"><button type="button" class="btn btn-sm btn-success complete-raw-material" data-id="<%= r.id %>"><i class="bi bi-check-lg"></i> Complete</button></div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

                <!-- Packaging Requests -->
                <div class="kanban-col" data-queue="packaging" style="--accent:#0d9488;--accent-soft:#ccfbf1">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-box2"></i></span>
                        <span class="kanban-col-title">Packaging Requests</span>
                        <span class="kanban-count"><%= pkgReqList.length %></span>
                    </div>
                    <% if (!pkgReqList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No requests</div><% } %>
                    <% pkgReqList.forEach(r => { %>
                        <div class="kanban-card" data-card-key="pkg-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= r.Packaging ? r.Packaging.name : 'Packaging' %></div>
                            <div class="cust"><%= r.quantity %> pcs</div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <div class="kanban-actions">
                                <a href="/packaging-request/<%= r.id %>/view" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                <% if (r.allVendorsCompleted) { %><button type="button" class="btn btn-sm btn-success complete-packaging" data-id="<%= r.id %>"><i class="bi bi-check-lg"></i> Complete</button><% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Formula Requests -->
                <div class="kanban-col" data-queue="formula" style="--accent:#4f46e5;--accent-soft:#e0e7ff">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-file-text"></i></span>
                        <span class="kanban-col-title">Formula Requests</span>
                        <span class="kanban-count"><%= formulaReqList.length %></span>
                    </div>
                    <% if (!formulaReqList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No requests</div><% } %>
                    <% formulaReqList.forEach(r => { %>
                        <div class="kanban-card" data-card-key="formula-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= r.Product ? r.Product.name : 'Product' %></div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <% if (r.Product && r.Product.formula) { %>
                            <div class="kanban-actions"><a href="/uploads/<%= r.Product.formula %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-pdf"></i> Formula</a></div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

                <!-- Product Checks -->
                <div class="kanban-col" data-queue="productChecks" style="--accent:#16a34a;--accent-soft:#dcfce7">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-check2-square"></i></span>
                        <span class="kanban-col-title">Product Checks</span>
                        <span class="kanban-count"><%= checkList.length %></span>
                    </div>
                    <% if (!checkList.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No checks</div><% } %>
                    <% checkList.forEach(c => { %>
                        <div class="kanban-card" data-card-key="check-<%= c.id %>">
                            <button type="button" class="kanban-del" title="Delete from board" aria-label="Delete card">&times;</button>
                            <div class="so"><%= c.productName %></div>
                            <div class="cust"><%= c.quantity %> KG<%= c.qcComment ? ' · ' + c.qcComment : '' %></div>
                            <div class="kanban-chips"><span class="status-badge <%= qb(c.qcStatus) %>"><%= c.qcStatus %></span></div>
                        </div>
                    <% }) %>
                </div>

                <!-- Rework Items -->
                <div class="kanban-col" data-queue="rework" style="--accent:#e11d48;--accent-soft:#ffe4e6">
                    <div class="kanban-col-head">
                        <span class="kanban-col-ico"><i class="bi bi-tools"></i></span>
                        <span class="kanban-col-title">Rework Items</span>
                        <span class="kanban-count"><%= reworkActive.length %></span>
                    </div>
                    <% if (!reworkActive.length) { %><div class="kanban-empty"><i class="bi bi-inbox"></i>No rework items</div><% } %>
                    <% reworkActive.forEach(item => { %>
                        <div class="kanban-card">
                            <div class="so"><%= item.product %></div>
                            <div class="cust"><%= item.Complain.Order.sonumber %> · <%= item.Complain.Order.customerName %></div>
                            <div class="kanban-chips">
                                <span class="chip"><%= item.quantityRejected %> KG rejected</span>
                                <span class="status-badge <%= sb(item.status) %>"><%= item.status %></span>
                            </div>
                            <div class="kanban-actions">
                                <% if (item.status === 'Delivered') { %>
                                    <button type="button" class="btn btn-sm btn-success complete-complain" data-id="<%= item.Complain.id %>"><i class="bi bi-check-lg"></i> Complete</button>
                                <% } else if (item.status === 'Raw Materials Added') { %>
                                    <form action="/complain/request-rework/<%= item.id %>" method="POST"><input type="hidden" name="complainItemId" value="<%= item.id %>"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-gear"></i> Request Rework</button></form>
                                <% } else if (item.status === 'Sent to PPIC') { %>
                                    <form action="/rd/request-formula/<%= item.id %>" method="POST"><input type="hidden" name="complainItemId" value="<%= item.id %>"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-file-text"></i> Request Formula</button></form>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

            </div>
        </div>

        <!-- ===================== List view ===================== -->
        <div id="ppicListView" class="stagger">

            <!-- Orders -->
            <section class="dashboard-section" id="sec-orders" style="--accent:#2f6f4e;--accent-soft:#e7f1ec">
                <div class="section-header" data-bs-toggle="collapse" data-bs-target="#q-orders" aria-expanded="true" aria-controls="q-orders">
                    <span class="sec-ico"><i class="bi bi-cart3"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Orders <span class="sec-count <%= orderList.length ? '' : 'is-zero' %>"><%= orderList.length %></span></h2>
                        <p class="sec-sub">Approve, check stock and kick off production</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-orders" class="section-content collapse show">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>SO Number</th><th>Customer</th><th>Products</th><th>Status</th><th>PO File</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (orderList.length > 0) { %>
                                    <% orderList.forEach(order => { %>
                                        <tr>
                                            <td data-label="SO Number"><span class="cell-strong"><%= order.sonumber %></span><div class="cell-sub">#<%= order.id %></div></td>
                                            <td data-label="Customer"><span class="cell-strong"><%= order.Customer ? order.Customer.name : '—' %></span></td>
                                            <td data-label="Products">
                                                <div class="chip-list">
                                                    <%
                                                        const groupedProducts = {};
                                                        for (const item of order.OrderItems) {
                                                            const name = item.Product.name;
                                                            if (!groupedProducts[name]) groupedProducts[name] = { quantity: 0, satuan: item.satuan };
                                                            groupedProducts[name].quantity += item.quantity;
                                                        }
                                                        for (const [name, details] of Object.entries(groupedProducts)) {
                                                    %>
                                                        <span class="chip"><%= name %> (<%= details.quantity %> <%= details.satuan %>)</span>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td data-label="Status"><span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></td>
                                            <td data-label="PO File">
                                                <% if (order.po) { %>
                                                    <a href="/uploads/<%= order.po %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-earmark-pdf"></i> View PO</a>
                                                <% } else { %>
                                                    <span class="text-muted-2"><i class="bi bi-x-circle"></i> No PO</span>
                                                <% } %>
                                            </td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <% if (order.status == "Pending" || order.status == "Production Completed") { %>
                                                        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#deliveryModal<%= order.id %>"><i class="bi bi-check-lg"></i> Approve</button>
                                                    <% } %>
                                                    <button type="button" class="btn btn-sm btn-outline-primary check-stock-btn" data-order-id="<%= order.id %>"><i class="bi bi-box"></i> Stock</button>
                                                    <a href="/orders/<%= order.id %>" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                                    <% if (order.needsProduction && order.status !== 'On Production' && order.status !== 'Production Completed') { %>
                                                        <a href="/production/request/<%= order.id %>" class="btn btn-sm btn-primary"><i class="bi bi-gear"></i> Request Production</a>
                                                    <% } %>
                                                    <% if (!order.OrderItems.every(item => item.Product.formula)) { %>
                                                        <form action="/orders/requestFormula/<%= order.id %>" method="POST" class="d-inline">
                                                            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-file-text"></i> Request Formula</button>
                                                        </form>
                                                    <% } %>
                                                    <form action="/orders/decline/<%= order.id %>" method="POST" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Decline</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No orders</h4><p>New orders will appear here for planning.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Production List -->
            <section class="dashboard-section" id="sec-productionList" style="--accent:#7c3aed;--accent-soft:#f3e8ff">
                <div class="section-header" data-bs-toggle="collapse" data-bs-target="#q-productionList" aria-expanded="true" aria-controls="q-productionList">
                    <span class="sec-ico"><i class="bi bi-list-check"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Production List <span class="sec-count <%= unprintedProductions.length ? '' : 'is-zero' %>"><%= unprintedProductions.length %></span></h2>
                        <p class="sec-sub">Completed batches awaiting blending guide &amp; print</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-productionList" class="section-content collapse show">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Product</th><th>Batch</th><th>Qty</th><th>Dates</th><th>Status</th><th>QC</th><th>Tanks</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (unprintedProductions.length > 0) { %>
                                    <% unprintedProductions.forEach(production => { %>
                                        <tr>
                                            <td data-label="Product"><span class="cell-strong"><%= production.Product ? production.Product.name : 'Product' %></span><div class="cell-sub">#<%= production.id %> · PREQ #<%= production.productionRequestId %></div></td>
                                            <td data-label="Batch"><%= production.batchNumber || 'Not Generated' %></td>
                                            <td data-label="Qty"><%= production.quantity %> Kg</td>
                                            <td data-label="Dates"><div class="cell-sub">Start: <%= fmtD(production.startDate) %></div><div class="cell-sub">Due: <%= fmtD(production.deadlineDate) %></div></td>
                                            <td data-label="Status"><span class="status-badge <%= sb(production.status) %>"><%= production.status %></span></td>
                                            <td data-label="QC"><span class="status-badge <%= qb(production.qcStatus) %>"><%= production.qcStatus %></span></td>
                                            <td data-label="Tanks">
                                                <div class="chip-list">
                                                    <% (production.Tanks || []).forEach(tank => { %><span class="chip"><%= tank.name %> (<%= tank.volume %> L)</span><% }) %>
                                                </div>
                                            </td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <% if (production.batchNumber) { %>
                                                        <a href="/production/blending-guide/<%= production.id %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-earmark-text"></i> Blending Guide</a>
                                                    <% } %>
                                                    <% if (production.batchNumber && !production.isPrinted && production.qcStatus !== 'Pass') { %>
                                                        <form action="/production/print/<%= production.id %>" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-printer"></i> Print</button></form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="8"><div class="empty-state"><i class="bi bi-inbox"></i><h4>Nothing to print</h4><p>Completed production batches will show up here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Production Requests -->
            <section class="dashboard-section" id="sec-productionRequests" style="--accent:#2563eb;--accent-soft:#dbeafe">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-productionRequests" aria-expanded="false" aria-controls="q-productionRequests">
                    <span class="sec-ico"><i class="bi bi-gear"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Production Requests <span class="sec-count <%= reqList.length ? '' : 'is-zero' %>"><%= reqList.length %></span></h2>
                        <p class="sec-sub">Requests currently in the production queue</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-productionRequests" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Number</th><th>Product</th><th>Qty</th><th>Formula</th><th>Status</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (reqList.length > 0) { %>
                                    <% reqList.forEach(request => { %>
                                        <tr>
                                            <td data-label="Number"><span class="cell-strong"><%= request.orderId ? (request.Order ? request.Order.sonumber : 'N/A') : request.prodreqnumber %></span><div class="cell-sub">#<%= request.id %></div></td>
                                            <td data-label="Product"><%= request.product %></td>
                                            <td data-label="Qty"><%= request.quantity %> Kg</td>
                                            <td data-label="Formula"><a href="/uploads/<%= request.formula %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-pdf"></i> View</a></td>
                                            <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <a href="/production/<%= request.id %>/view" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                                    <% if (request.allCompleted) { %>
                                                        <form action="/production/<%= request.id %>/clear" method="POST" class="d-inline"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Clear</button></form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="6"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No production requests</h4><p>Requested productions appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Raw Material Requests -->
            <section class="dashboard-section" id="sec-rawMaterial" style="--accent:#d97706;--accent-soft:#fef3c7">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-rawMaterial" aria-expanded="false" aria-controls="q-rawMaterial">
                    <span class="sec-ico"><i class="bi bi-box-seam"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Raw Material Requests <span class="sec-count <%= rawReqList.length ? '' : 'is-zero' %>"><%= rawReqList.length %></span></h2>
                        <p class="sec-sub">Procurement from vendors</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-rawMaterial" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Material</th><th>Qty</th><th>Status</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (rawReqList.length > 0) { %>
                                    <% rawReqList.forEach(request => { %>
                                        <tr>
                                            <td data-label="Material"><span class="cell-strong"><%= request.materialName %></span><div class="cell-sub">#<%= request.id %></div></td>
                                            <td data-label="Qty"><%= request.quantity %> Kg</td>
                                            <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <% if (request.allVendorsCompleted) { %>
                                                        <button type="button" class="btn btn-sm btn-success complete-raw-material" data-id="<%= request.id %>"><i class="bi bi-check-lg"></i> Complete</button>
                                                    <% } else { %>
                                                        <span class="text-muted-2 small">Awaiting vendors</span>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="4"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No raw material requests</h4><p>Material procurement requests appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Packaging Requests -->
            <section class="dashboard-section" id="sec-packaging" style="--accent:#0d9488;--accent-soft:#ccfbf1">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-packaging" aria-expanded="false" aria-controls="q-packaging">
                    <span class="sec-ico"><i class="bi bi-box2"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Packaging Requests <span class="sec-count <%= pkgReqList.length ? '' : 'is-zero' %>"><%= pkgReqList.length %></span></h2>
                        <p class="sec-sub">Packaging procurement from vendors</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-packaging" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Packaging</th><th>Qty</th><th>Status</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (pkgReqList.length > 0) { %>
                                    <% pkgReqList.forEach(request => { %>
                                        <tr>
                                            <td data-label="Packaging"><span class="cell-strong"><%= request.Packaging ? request.Packaging.name : 'Packaging' %></span><div class="cell-sub">#<%= request.id %></div></td>
                                            <td data-label="Qty"><%= request.quantity %> pcs</td>
                                            <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <a href="/packaging-request/<%= request.id %>/view" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i> View</a>
                                                    <% if (request.allVendorsCompleted) { %>
                                                        <button type="button" class="btn btn-sm btn-success complete-packaging" data-id="<%= request.id %>"><i class="bi bi-check-lg"></i> Complete</button>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="4"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No packaging requests</h4><p>Packaging procurement requests appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Formula Requests -->
            <section class="dashboard-section" id="sec-formula" style="--accent:#4f46e5;--accent-soft:#e0e7ff">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-formula" aria-expanded="false" aria-controls="q-formula">
                    <span class="sec-ico"><i class="bi bi-file-text"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Formula Requests <span class="sec-count <%= formulaReqList.length ? '' : 'is-zero' %>"><%= formulaReqList.length %></span></h2>
                        <p class="sec-sub">Formulas requested from R&amp;D</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-formula" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Product</th><th>Status</th><th class="text-end">Formula</th></tr>
                            </thead>
                            <tbody>
                                <% if (formulaReqList.length > 0) { %>
                                    <% formulaReqList.forEach(request => { %>
                                        <tr>
                                            <td data-label="Product"><span class="cell-strong"><%= request.Product ? request.Product.name : 'Product' %></span><div class="cell-sub">#<%= request.id %></div></td>
                                            <td data-label="Status"><span class="status-badge <%= sb(request.status) %>"><%= request.status %></span></td>
                                            <td data-label="Formula" class="text-end">
                                                <% if (request.Product && request.Product.formula) { %>
                                                    <a href="/uploads/<%= request.Product.formula %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-pdf"></i> View Formula</a>
                                                <% } else { %>
                                                    <span class="text-muted-2"><i class="bi bi-x-circle"></i> No formula</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="3"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No formula requests</h4><p>Formula requests appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Product Checks -->
            <section class="dashboard-section" id="sec-productChecks" style="--accent:#16a34a;--accent-soft:#dcfce7">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-productChecks" aria-expanded="false" aria-controls="q-productChecks">
                    <span class="sec-ico"><i class="bi bi-check2-square"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Product Checks <span class="sec-count <%= checkList.length ? '' : 'is-zero' %>"><%= checkList.length %></span></h2>
                        <p class="sec-sub">QC outcomes awaiting stock action</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-productChecks" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Product</th><th>Qty</th><th>QC Status</th><th>Comment</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (checkList.length > 0) { %>
                                    <% checkList.forEach(check => { %>
                                        <tr>
                                            <td data-label="Product"><span class="cell-strong"><%= check.productName %></span><div class="cell-sub">#<%= check.id %></div></td>
                                            <td data-label="Qty"><%= check.quantity %> KG</td>
                                            <td data-label="QC Status"><span class="status-badge <%= qb(check.qcStatus) %>"><%= check.qcStatus %></span></td>
                                            <td data-label="Comment"><span class="cell-sub"><%= check.qcComment || '—' %></span></td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <% if (check.qcStatus === 'Pass' || check.qcStatus === 'Fail') { %>
                                                        <button type="button" class="btn btn-sm btn-success complete-product-check" data-id="<%= check.id %>" data-qc-status="<%= check.qcStatus %>" data-quantity="<%= check.quantity %>" data-product-id="<%= check.productId %>"><i class="bi bi-check-lg"></i> Complete</button>
                                                    <% } else if (check.qcStatus === 'Reject Sebagian') { %>
                                                        <form class="reject-sebagian-form d-flex gap-2 align-items-center" id="reject-form-<%= check.id %>">
                                                            <input type="number" class="form-control form-control-sm" id="reject-quantity-<%= check.id %>" name="rejectQuantity" step="0.01" min="0" max="<%= check.quantity %>" placeholder="Reject KG" style="width:120px" required>
                                                            <button type="button" class="btn btn-sm btn-warning update-stock-btn" data-id="<%= check.id %>" data-product-id="<%= check.productId %>"><i class="bi bi-arrow-repeat"></i> Update Stock</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="5"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No product checks</h4><p>QC results appear here for action.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Rework Items -->
            <section class="dashboard-section" id="sec-rework" style="--accent:#e11d48;--accent-soft:#ffe4e6">
                <div class="section-header collapsed" data-bs-toggle="collapse" data-bs-target="#q-rework" aria-expanded="false" aria-controls="q-rework">
                    <span class="sec-ico"><i class="bi bi-tools"></i></span>
                    <div class="sec-titles">
                        <h2 class="sec-title">Rework Items <span class="sec-count <%= reworkActive.length ? '' : 'is-zero' %>"><%= reworkActive.length %></span></h2>
                        <p class="sec-sub">Complaint-driven rework in progress</p>
                    </div>
                    <i class="bi bi-chevron-down sec-chevron"></i>
                </div>
                <div id="q-rework" class="section-content collapse">
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>PO Number</th><th>Customer</th><th>Product</th><th>Qty Rejected</th><th>Notes</th><th>Status</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                <% if (reworkActive.length > 0) { %>
                                    <% reworkActive.forEach(function(item) { %>
                                        <tr>
                                            <td data-label="PO Number"><span class="cell-strong"><%= item.Complain.Order.sonumber %></span></td>
                                            <td data-label="Customer"><%= item.Complain.Order.customerName %></td>
                                            <td data-label="Product"><%= item.product %></td>
                                            <td data-label="Qty Rejected"><%= item.quantityRejected %> KG</td>
                                            <td data-label="Notes"><span class="cell-sub"><%= item.notes || '—' %></span></td>
                                            <td data-label="Status"><span class="status-badge <%= sb(item.status) %>"><%= item.status %></span></td>
                                            <td data-label="Actions" class="text-end">
                                                <div class="action-buttons justify-content-end">
                                                    <% if (item.status === 'Delivered') { %>
                                                        <button type="button" class="btn btn-sm btn-success complete-complain" data-id="<%= item.Complain.id %>"><i class="bi bi-check-lg"></i> Complete</button>
                                                    <% } else if (item.status === 'Raw Materials Added') { %>
                                                        <form action="/complain/request-rework/<%= item.id %>" method="POST" class="d-inline"><input type="hidden" name="complainItemId" value="<%= item.id %>"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-gear"></i> Request Rework</button></form>
                                                    <% } else if (item.status === 'Sent to PPIC') { %>
                                                        <form action="/rd/request-formula/<%= item.id %>" method="POST" class="d-inline"><input type="hidden" name="complainItemId" value="<%= item.id %>"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-file-text"></i> Request Formula</button></form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="7"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No rework items</h4><p>Rework requests from complaints appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

        </div>
    </div>

    <!-- ===================== Delivery (Approve) modals — page-level so they open from List & Board ===================== -->
