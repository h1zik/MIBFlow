<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PPIC Dashboard - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-light: #4caf50;
            --primary-dark: #1b5e20;
            --text-color: #2c3e50;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            transition: var(--transition);
            width: calc(100% - 280px);
        }

        /* When sidebar is collapsed */
        body.sidebar-collapsed .main-content {
            margin-left: 70px;
            width: calc(100% - 70px);
        }

        .page-header {
            background: white;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            animation: slideDown 0.5s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .dashboard-section {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            overflow: hidden;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-header {
            padding: 1.5rem;
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-header:hover {
            background-color: #d7ecd8;
        }

        .section-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-content {
            padding: 1.5rem;
            display: none;
        }

        .section-content.show {
            display: block;
            animation: slideDown 0.3s ease-out;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
        }

        .table tbody tr {
            transition: var(--transition);
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .badge {
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .badge i {
            font-size: 0.75rem;
        }

        .badge-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .badge-scheduled {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-approved {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-declined {
            background-color: #f8d7da;
            color: #842029;
        }

        .badge-pass {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .badge-fail {
            background-color: #f8d7da;
            color: #842029;
        }

        .badge-tank {
            background-color: #e2e3e5;
            color: #383d41;
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .btn-danger {
            background-color: #dc3545;
            border: none;
        }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);
        }

        .btn-success {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-success:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .action-buttons .btn {
            padding: 0.4rem 0.8rem;
            font-size: 0.875rem;
        }

        /* Modal Styling */
        .modal-content {
            border-radius: 15px;
            border: none;
            box-shadow: var(--shadow);
        }

        .modal-header {
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            padding: 1.5rem;
        }

        .modal-title {
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            border-top: 1px solid rgba(0,0,0,0.1);
            padding: 1rem 1.5rem;
        }

        .alert {
            border-radius: 10px;
            border: none;
            padding: 1rem;
        }

        .alert ul {
            margin-bottom: 0;
            padding-left: 1.5rem;
        }

        .alert li {
            margin-bottom: 0.5rem;
        }

        .alert li:last-child {
            margin-bottom: 0;
        }

        /* Loading Animation */
        .loading {
            pointer-events: none;
            position: relative;
        }

        .loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin: -10px 0 0 -10px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Enhanced Mobile Styles */
        @media (max-width: 768px) {
            /* Layout Improvements */
            .main-content {
                margin-left: 0;
                padding: 0.75rem;
                width: 100%;
            }

            .dashboard-section {
                margin-bottom: 1rem;
                border-radius: 10px;
            }

            .section-header {
                padding: 0.875rem;
            }

            .section-content {
                padding: 0.75rem;
            }

            /* Mobile Table Improvements */
            .table-responsive {
                border-radius: 8px;
                background: white;
                box-shadow: var(--shadow);
                margin-bottom: 1rem;
            }

            .table {
                display: block;
            }

            .table thead {
                display: none; /* Hide headers on mobile */
            }

            .table tbody {
                display: block;
            }

            .table tr {
                display: block;
                margin-bottom: 1rem;
                border: 1px solid var(--background-light);
                border-radius: 8px;
                background: white;
            }

            .table td {
                display: flex;
                padding: 0.75rem;
                align-items: center;
                border: none;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .table td:last-child {
                border-bottom: none;
            }

            .table td::before {
                content: attr(data-label);
                font-weight: 600;
                width: 120px;
                min-width: 120px;
                color: var(--primary-dark);
                font-size: 0.85rem;
            }

            .table td > * {
                flex: 1;
                margin-left: 1rem;
            }

            .table .form-control,
            .table .btn,
            .table select {
                width: auto;
                min-width: 120px;
            }

            .table-responsive::-webkit-scrollbar {
                height: 6px;
            }

            .table-responsive::-webkit-scrollbar-track {
                background: transparent;
            }

            .table-responsive::-webkit-scrollbar-thumb {
                background-color: var(--primary-light);
                border-radius: 3px;
            }

            .table-responsive::after {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                bottom: 0;
                width: 5px;
                background: linear-gradient(to left, rgba(0,0,0,0.05), transparent);
                pointer-events: none;
            }

            .table td, .table th {
                padding: 0.75rem 0.5rem;
                white-space: normal;
                min-width: 120px;
            }

            .table th {
                position: sticky;
                top: 0;
                background: var(--background-light);
                z-index: 1;
            }

            /* Form Controls */
            .form-control {
                height: 40px;
                font-size: 16px; /* Prevents iOS zoom */
                padding: 0.5rem;
            }

            select.form-control {
                padding-right: 24px;
            }

            /* Button Improvements */
            .btn {
                height: 40px;
                padding: 0 1rem;
                margin: 0.25rem;
                font-size: 0.9rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 100px;
                touch-action: manipulation;
            }

            /* Action Buttons */
            .action-buttons {
                flex-direction: column;
                gap: 0.5rem;
            }

            .action-buttons .btn {
                width: 100%;
                justify-content: center;
                margin: 0;
            }

            /* Badge Adjustments */
            .badge {
                font-size: 0.8rem;
                padding: 0.4rem 0.8rem;
            }

            /* Modal Improvements */
            .modal-content {
                margin: 0.5rem;
            }

            .modal-header {
                padding: 1rem;
            }

            .modal-body {
                padding: 1rem;
            }

            .modal-footer {
                padding: 0.75rem 1rem;
            }

            /* Touch-friendly Improvements */
            .btn:active,
            .section-header:active {
                transform: scale(0.98);
            }

            .table tbody tr:active {
                background-color: var(--background-light);
            }

            .form-control:focus,
            select:focus {
                outline: none;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 2px rgba(46, 125, 50, 0.2);
            }

            /* Loading State */
            .loading {
                min-height: 40px;
            }

            .loading::after {
                width: 24px;
                height: 24px;
                margin: -12px 0 0 -12px;
                border-width: 2px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-clipboard-data"></i>
                PPIC Dashboard
            </h1>
            <p class="text-muted mb-0">Manage orders, production requests, and material planning</p>
        </div>

        <!-- Flash Messages -->
        <% if (messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <% if (messages.error.includes('\n')) { %>
                    <pre class="mb-0" style="white-space: pre-wrap;"><%= messages.error %></pre>
                <% } else { %>
                    <%= messages.error %>
                <% } %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        
        <% if (messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <!-- View toggle: List / Kanban -->
        <style>
            .ppic-viewbar { display:flex; align-items:center; gap:0.75rem; margin-bottom:1.25rem; }
            .ppic-viewbar .vb-label { color: var(--mib-text-muted,#6b7280); font-size:0.85rem; font-weight:600; }
            .ppic-viewbar .btn-group .btn { display:inline-flex; align-items:center; gap:0.4rem; }
            .kanban-board { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:1rem; align-items:start; padding-bottom:0.6rem; }
            .kanban-col { min-width:0; max-height:calc(100vh - 220px); overflow-y:auto; background: var(--mib-surface-2,#f9fafb); border:1px solid var(--mib-border,#e8ebe9); border-radius:14px; padding:0.85rem; }
            .kanban-col-title { font-weight:650; color:var(--mib-text,#1f2937); display:flex; align-items:center; gap:0.4rem; font-size:0.92rem; }
            .kanban-col-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:0.85rem; }
            .kanban-count { background:#fff; border:1px solid var(--mib-border,#e8ebe9); border-radius:999px; padding:0.05rem 0.55rem; font-size:0.74rem; color:var(--mib-text-muted,#6b7280); font-weight:600; }
            .kanban-card { position:relative; background:#fff; border:1px solid var(--mib-border,#e8ebe9); border-radius:11px; padding:0.85rem; margin-bottom:0.7rem; box-shadow:0 1px 2px rgba(16,24,40,0.05); }
            .kanban-del { position:absolute; top:6px; right:6px; width:24px; height:24px; line-height:1; border:none; border-radius:6px; background:transparent; color:var(--mib-text-faint,#9ca3af); font-size:1.05rem; cursor:pointer; display:grid; place-items:center; opacity:0; transition:opacity .15s ease, background .15s ease, color .15s ease; }
            .kanban-card:hover .kanban-del { opacity:1; }
            .kanban-del:hover { background:var(--mib-danger-soft,#fee2e2); color:var(--mib-danger,#dc2626); }
            @media (hover: none){ .kanban-del { opacity:1; } }
            .kanban-card .so { padding-right:1.4rem; }
            .kanban-card .so { font-weight:700; color:var(--mib-text,#1f2937); }
            .kanban-card .cust { color:var(--mib-text-muted,#6b7280); font-size:0.82rem; margin:0.1rem 0 0.6rem; }
            .kanban-chips { display:flex; flex-wrap:wrap; gap:0.3rem; margin-bottom:0.7rem; }
            .kanban-chip { background:var(--mib-primary-soft,#e7f1ec); color:var(--mib-primary-dark,#225239); border-radius:999px; padding:0.12rem 0.6rem; font-size:0.73rem; font-weight:500; }
            .kanban-actions { display:flex; flex-wrap:wrap; gap:0.35rem; }
            .kanban-actions .btn { width:auto; }
            .kanban-empty { color:var(--mib-text-faint,#9ca3af); font-size:0.85rem; text-align:center; padding:1.5rem 0; }
        </style>
        <div class="ppic-viewbar">
            <span class="vb-label">View</span>
            <div class="btn-group" role="group" aria-label="View switch">
                <button type="button" class="btn btn-outline-primary active" id="btnListView"><i class="bi bi-list-ul"></i> List</button>
                <button type="button" class="btn btn-outline-primary" id="btnKanbanView"><i class="bi bi-kanban"></i> Kanban</button>
            </div>
        </div>

        <!-- Kanban view: one column per List-view section -->
        <% const sb = (s) => 'status-' + String(s || '').toLowerCase().replace(/\s+/g, '-'); %>
        <% const qb = (s) => s === 'Pass' ? 'status-completed' : (s === 'Fail' ? 'status-declined' : (s === 'Reject Sebagian' ? 'status-pending' : 'status-pending')); %>
        <% const unprintedProductions = (completedProductions || []).filter(p => !p.isPrinted); %>
        <div id="ppicKanbanView" style="display:none;">
            <div class="kanban-board">

                <!-- 1. Orders -->
                <div class="kanban-col">
                    <div class="kanban-col-head">
                        <span class="kanban-col-title"><i class="bi bi-cart"></i> Orders</span>
                        <span class="kanban-count"><%= (orders || []).length %></span>
                    </div>
                    <% if (!orders || !orders.length) { %><div class="kanban-empty"><i class="bi bi-inbox d-block mb-1"></i>No orders</div><% } %>
                    <% (orders || []).forEach(order => { %>
                        <div class="kanban-card" data-card-key="orders-<%= order.id %>">
                            <button type="button" class="kanban-del" title="Hide from board" aria-label="Hide card">&times;</button>
                            <div class="so"><%= order.sonumber %> <span class="status-badge <%= sb(order.status) %>"><%= order.status %></span></div>
                            <div class="cust"><i class="bi bi-person"></i> <%= order.Customer ? order.Customer.name : '' %></div>
                            <div class="kanban-chips">
                                <% (order.products || []).forEach(p => { %><span class="kanban-chip"><%= p.name %> (<%= p.quantity %> <%= p.satuan %>)</span><% }) %>
                            </div>
                            <div class="kanban-actions">
                                <a href="/orders/<%= order.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i> View</a>
                                <button type="button" class="btn btn-sm btn-outline-primary check-stock-btn" data-order-id="<%= order.id %>"><i class="bi bi-box"></i> Stock</button>
                                <% if (order.status !== 'On Production' && order.status !== 'Production Completed') { %>
                                    <a href="/production/request/<%= order.id %>" class="btn btn-sm btn-primary"><i class="bi bi-gear"></i> Request</a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- 2. Production List -->
                <div class="kanban-col">
                    <div class="kanban-col-head">
                        <span class="kanban-col-title"><i class="bi bi-list-check"></i> Production List</span>
                        <span class="kanban-count"><%= unprintedProductions.length %></span>
                    </div>
                    <% if (!unprintedProductions.length) { %><div class="kanban-empty"><i class="bi bi-inbox d-block mb-1"></i>Nothing to print</div><% } %>
                    <% unprintedProductions.forEach(p => { %>
                        <div class="kanban-card" data-card-key="prod-<%= p.id %>">
                            <button type="button" class="kanban-del" title="Hide from board" aria-label="Hide card">&times;</button>
                            <div class="so"><%= p.Product ? p.Product.name : 'Product' %></div>
                            <div class="cust">Batch: <%= p.batchNumber || 'Not Generated' %> · <%= p.quantity %> Kg</div>
                            <div class="kanban-chips">
                                <span class="status-badge <%= sb(p.status) %>"><%= p.status %></span>
                                <span class="status-badge <%= qb(p.qcStatus) %>">QC: <%= p.qcStatus %></span>
                            </div>
                            <% if (p.batchNumber && !p.isPrinted && p.qcStatus !== 'Pass') { %>
                            <div class="kanban-actions">
                                <form action="/production/print/<%= p.id %>" method="POST"><button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-printer"></i> Print</button></form>
                            </div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

                <!-- 3. Production Requests -->
                <div class="kanban-col">
                    <div class="kanban-col-head">
                        <span class="kanban-col-title"><i class="bi bi-gear"></i> Production Requests</span>
                        <span class="kanban-count"><%= (requests || []).length %></span>
                    </div>
                    <% if (!requests || !requests.length) { %><div class="kanban-empty"><i class="bi bi-inbox d-block mb-1"></i>No requests</div><% } %>
                    <% (requests || []).forEach(r => { %>
                        <div class="kanban-card" data-card-key="prodreq-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Hide from board" aria-label="Hide card">&times;</button>
                            <div class="so"><%= r.product %></div>
                            <div class="cust"><%= r.orderId ? (r.Order ? r.Order.sonumber : 'N/A') : r.prodreqnumber %> · <%= r.quantity %> Kg</div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <div class="kanban-actions">
                                <a href="/production/<%= r.id %>/view" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i> View</a>
                                <% if (r.allCompleted) { %><form action="/production/<%= r.id %>/clear" method="POST"><button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Clear</button></form><% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- 4. Raw Material Requests -->
                <div class="kanban-col">
                    <div class="kanban-col-head">
                        <span class="kanban-col-title"><i class="bi bi-box-seam"></i> Raw Material Requests</span>
                        <span class="kanban-count"><%= (rawMaterialRequests || []).length %></span>
                    </div>
                    <% if (!rawMaterialRequests || !rawMaterialRequests.length) { %><div class="kanban-empty"><i class="bi bi-inbox d-block mb-1"></i>No requests</div><% } %>
                    <% (rawMaterialRequests || []).forEach(r => { %>
                        <div class="kanban-card" data-card-key="rawmat-<%= r.id %>">
                            <button type="button" class="kanban-del" title="Hide from board" aria-label="Hide card">&times;</button>
                            <div class="so"><%= r.materialName %></div>
                            <div class="cust"><%= r.quantity %> Kg</div>
                            <div class="kanban-chips"><span class="status-badge <%= sb(r.status) %>"><%= r.status %></span></div>
                            <% if (r.allVendorsCompleted) { %>
                            <div class="kanban-actions"><button type="button" class="btn btn-sm btn-success complete-raw-material" data-id="<%= r.id %>"><i class="bi bi-check-lg"></i> Complete</button></div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

                <!-- 5. Packaging Requests -->
                <div class="kanban-col">
                    <div class="kanban-col-head">
                        <span class="kanban-col-title"><i class="bi bi-box2"></i> Packaging Requests</span>
                        <span class="kanban-count"><%= (packagingRequests || []).length %></span>
                    </div>
                    <% if (!packagingRequests || !packagingRequests.length) { %><div class="kanban-empty"><i class="bi bi-inbox d-block mb-1"></i>No requests</div><% } %>
                    <% (packagingRequests || []).forEach(r => { %>
                        <div class="kanban-card" data-card-key="pkg-<%= r.id %>">
