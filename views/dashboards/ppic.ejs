                                                        <div class="modal-dialog">
                                                            <div class="modal-content">
                                                                <div class="modal-header">
                                                                    <h5 class="modal-title" id="deliveryModalLabel<%= order.id %>">Delivery Details - SO#<%= order.sonumber %></h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <form action="/orders/approve/<%= order.id %>" method="POST">
                                                                    <div class="modal-body">
                                                                        <% order.OrderItems.forEach(function(item, index) { %>
                                                                            <div class="mb-4">
                                                                                <h6 class="mb-3"><%= item.Product.name %></h6>
                                                                <div class="mb-3">
                                                                    <label class="form-label">
                                                                        <%= item.Product.name %> in <%= item.Packaging.name %> 
                                                                        (<%= item.Packaging.volume %> <%= item.satuan %>)
                                                                    </label>
                                                                    <div class="input-group">
                                                                        <input type="number" 
                                                                            class="form-control" 
                                                                            name="sentQuantities[<%= index %>]" 
                                                                            placeholder="Enter number of packaging units"
                                                                            max="<%= item.unit %>"
                                                                            required>
                                                                        <span class="input-group-text">units</span>
                                                                    </div>
                                                                    <small class="text-muted">
                                                                        Total packaging units needed: <%= item.unit %>
                                                                    </small>
                                                                </div>
                                                                            </div>
                                                                        <% }); %>
                                                                    </div>
                                                                    <div class="modal-footer">
                                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
