    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Request notification permission on page load
        document.addEventListener('DOMContentLoaded', () => {
            if (Notification.permission !== 'granted') {
                Notification.requestPermission();
            }

            // Connect to SSE endpoint
            const eventSource = new EventSource('/notifications');

            // Handle connection open
            eventSource.onopen = () => {
                console.log('Connected to notification stream');
            };

            // Handle connection error
            eventSource.onerror = (error) => {
                console.error('Notification stream error:', error);
                // Attempt to reconnect after 5 seconds
                setTimeout(() => {
                    eventSource.close();
                    new EventSource('/notifications');
                }, 5000);
            };

            // Handle ping events to keep connection alive
            eventSource.addEventListener('ping', (e) => {
                console.log('Ping received');
            });

            // Handle notification events
            eventSource.onmessage = (event) => {
                const data = JSON.parse(event.data);
            if (data.type === 'newOrder') {
                    // Play notification sound
                    const audio = new Audio('/audio/notification.mp3');
                    audio.play();

                    // Create notification
                    const notification = new Notification('New Order Received', {
                        body: `New order ${data.sonumber} from ${data.customerName}`,
                        icon: '/images/logomib.png',
                        silent: true // Disable default notification sound since we're using custom sound
                    });

                    // Reload page when notification is clicked
                    notification.onclick = () => {
                        window.focus();
                        location.reload();
                    };
                } else if (data.type === 'ppicRework') {
                    // Play notification sound
                    const audio = new Audio('/audio/notification.mp3');
                    audio.play();

                    // Create notification
                    const notification = new Notification('New Rework Request', {
                        body: `New rework request for ${data.product} (${data.sonumber} - ${data.customerName})`,
                        icon: '/images/logomib.png',
                        silent: true // Disable default notification sound since we're using custom sound
                    });

                    // Reload page when notification is clicked
                    notification.onclick = () => {
                        window.focus();
                        location.reload();
                    };
                } else if (data.type === 'productCheckQCStatus') {
                    // Play notification sound
                    const audio = new Audio('/audio/notification.mp3');
                    audio.play();

                    // Create notification
                    const notification = new Notification('Product Check QC Update', {
                        body: `${data.productName} (${data.quantity} KG) - QC Status: ${data.status}`,
                        icon: '/images/logomib.png',
                        silent: true
                    });

                    // Reload page when notification is clicked
                    notification.onclick = () => {
                        window.focus();
                        location.reload();
                    };
                } else if (data.type === 'ppicRawMaterials') {
                    // Play notification sound
                    const audio = new Audio('/audio/notification.mp3');
                    audio.play();

                    // Create notification
                    const notification = new Notification('New Rework Request', {
                        body: `New rework request for ${data.product} (${data.sonumber} - ${data.customerName})`,
                        icon: '/images/logomib.png',
                        silent: true // Disable default notification sound since we're using custom sound
                    });

                    // Reload page when notification is clicked
                    notification.onclick = () => {
                        window.focus();
                        location.reload();
                    };
                }
            };

            // Clean up on page unload
            window.addEventListener('beforeunload', () => {
                eventSource.close();
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });
            observer.observe(sidebar, { attributes: true });

            // Initialize collapsible sections
            const sections = document.querySelectorAll('.dashboard-section');
            sections.forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');

                // Set initial state
                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }

                // Use Bootstrap's collapse events
                content.addEventListener('show.bs.collapse', () => {
                    icon.style.transform = 'rotate(180deg)';
                });

                content.addEventListener('hide.bs.collapse', () => {
                    icon.style.transform = 'rotate(0)';
                });
            });
            // Form submissions
            document.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.classList.add('loading');
                        submitBtn.disabled = true;
                    }
                });
            });

            // Stock check functionality
            // Add event listeners for stock check buttons
            document.querySelectorAll('.check-stock-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const orderId = this.dataset.orderId;
                    this.classList.add('loading');
                    this.disabled = true;

                    $.ajax({
                        url: '/orders/checkStock/' + orderId,
                        type: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        success: (response) => {
                            console.log('Stock check response:', response);
                            if (response.outOfStockProducts) {
                                console.log('Out of Stock Products:', response.outOfStockProducts);
                                response.outOfStockProducts.forEach(product => {
                                    console.log('Product:', product);
                                    console.log('Product ID:', product.id);
                                    console.log('Product ID (alternate):', product.productId);
                                });
                            }
                            if (response.inStockProducts) {
                                console.log('In Stock Products:', response.inStockProducts);
                                response.inStockProducts.forEach(product => {
                                    console.log('Product:', product);
                                    console.log('Product ID:', product.id);
                                    console.log('Product ID (alternate):', product.productId);
                                });
                            }
                            this.classList.remove('loading');
                            this.disabled = false;

                            let modalBody = '';
                            if (response.error || response.message === 'error') {
                            modalBody = `
                                <div class="alert alert-danger">
                                    <h6 class="alert-heading mb-2">
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        Stock Check Failed
                                    </h6>
                                    <p class="mb-2">${response.error}</p>
                            ${response.outOfStockProducts ? `
                                        <strong class="d-block mb-2">Out of Stock Products:</strong>
                                        <ul class="mb-3">
                                            ${response.outOfStockProducts.map(product => `
                                                <li>
                                                    <strong>${product.name}</strong><br>
                                                    Needed: ${product.satuan === 'L' ? (product.needed * product.density).toFixed(2) : product.needed} KG<br>
                                                    Available: ${product.available} KG<br>
                                                    <div class="mt-2">
                                                        <button class="btn btn-primary check-product" 
                                                            data-product-name="${product.name}"
                                                            data-product-id="${product.id}">
                                                            Check
                                                        </button>
                                                        <div class="input-group mt-2 quantity-input-group" style="display: none;">
                                                            <input type="number" class="form-control quantity-input" 
                                                                data-product-name="${product.name}"
                                                                data-product-id="${product.id}"
                                                                placeholder="Enter quantity in KG">
                                                            <button class="btn btn-primary submit-check" 
                                                                data-product-name="${product.name}"
                                                                data-product-id="${product.id}">
                                                                Submit
                                                            </button>
                                                        </div>
                                                    </div>
                                                </li>
                                            `
                                            ).join('')}
                                        </ul>
                                    ` : ''}
                                    ${response.inStockProducts ? `
                                        <strong class="d-block mb-2">In Stock Products:</strong>
                                        <ul class="mb-3">
                                            ${response.inStockProducts.map(product => `
                                                <li>
                                                    <strong>${product.name}</strong><br>
                                                    Available: ${product.available} KG<br>
                                                    <div class="mt-2">
                                                        <div class="input-group">
                                                            <input type="number" class="form-control quantity-input" 
                                                                data-product-name="${product.name}"
                                                                data-product-id="${product.id}"
                                                                placeholder="Enter quantity in KG">
                                                            <button class="btn btn-primary submit-check" 
                                                                data-product-name="${product.name}"
                                                                data-product-id="${product.id}">
                                                                Submit
                                                            </button>
                                                        </div>
                                                    </div>
                                                </li>
                                            `).join('')}
                                        </ul>
                                    ` : ''}
                                    ${response.outOfStockPackaging ? `
                                        <strong class="d-block mb-2">Out of Stock Packaging:</strong>
                                        <ul class="mb-3">
                                            ${response.outOfStockPackaging.map(pkg => 
                                                '<li>' +
                                                    '<strong>' + pkg.name + '</strong><br>' +
                                                    'Needed: ' + pkg.needed + ' ' + pkg.satuan + '<br>' +
                                                    'Available: ' + pkg.available + ' ' + pkg.satuan +
                                                '</li>'
                                            ).join('')}
                                        </ul>
                                    ` : ''}
                                    ${response.inStockPackaging ? `
                                        <strong class="d-block mb-2">In Stock Packaging:</strong>
                                        <ul class="mb-0">
                                            ${response.inStockPackaging.map(pkg => `
                                            <li>
                                                <strong>${pkg.name}</strong><br>
                                                Available: ${pkg.available} ${pkg.satuan}
                                            </li>
                                        `).join('')}
                                        </ul>
                                    ` : ''}
                                </div>
                            `;
                        } else if (response.inStockProducts) {
                            modalBody = `
                                <div class="alert alert-success">
                                    <h6 class="alert-heading mb-2">
                                        <i class="bi bi-check-circle me-2"></i>
                                        All Products In Stock
                                    </h6>
                                    <p class="mb-2">${response.message}</p>
                                    <ul class="mb-3">
                                            ${response.inStockProducts.map(product => `
                                            <li>
                                                <strong>${product.name}</strong><br>
                                                Available: ${product.available} KG<br>
                                                <div class="mt-2">
                                                    <div class="input-group">
                                                        <input type="number" class="form-control quantity-input" 
                                                            data-product-id="${product.id}"
                                                            data-product-name="${product.name}"
                                                            placeholder="Enter quantity in KG">
                                                        <button class="btn btn-primary submit-check" 
                                                            data-product-id="${product.id}"
                                                            data-product-name="${product.name}">
                                                            Submit
                                                        </button>
                                                    </div>
                                                </div>
                                            </li>
                                        `).join('')}
                                    </ul>
                                </div>
                            `;
                        } else {
                            modalBody = `
                                <div class="alert alert-warning">
                                    <h6 class="alert-heading mb-2">
                                        <i class="bi bi-exclamation-circle me-2"></i>
                                        No Stock Information
                                    </h6>
                                    <p class="mb-0">No stock information is available for this order.</p>
                                </div>
                            `;
                        }
                        
                        $('#modalBody').html(modalBody);
                        $('#stockModal').modal('show');
                    },
                        error: (error) => {
                            this.classList.remove('loading');
                            this.disabled = false;

                            console.error('Error checking stock:', error);
                            const modalBody = `
                                <div class="alert alert-danger">
                                    <h6 class="alert-heading mb-2">
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        Error
                                    </h6>
                                    <p class="mb-0">An error occurred while checking stock. Please try again later.</p>
                                </div>
                            `;
                            $('#modalBody').html(modalBody);
                            $('#stockModal').modal('show');
                        }
                    });
                });
            });
        });
    </script>
    <script>
        // Add event listener for check button
        $(document).on('click', '.check-product', function() {
            const btn = $(this);
            const productId = btn.data('product-id');
            const productName = btn.data('product-name');
            
            // Show the quantity input group for this product
            btn.siblings('.quantity-input-group').show();
            btn.prop('disabled', true);
        });

        // Add event listener for product check submission
        $(document).on('click', '.submit-check', function() {
            const btn = $(this);
            const productName = btn.data('product-name');
            
            // Get the input element using the button's parent container
            const inputGroup = btn.closest('.input-group');
            const quantityInput = inputGroup.find('.quantity-input');
            const quantity = quantityInput.val();

            if (!quantity || quantity <= 0) {
                alert('Please enter a valid quantity');
                return;
            }

            btn.prop('disabled', true);

            // Use the product ID from the button's data attribute
            const productId = btn.data('product-id');
            if (!productId) {
                alert('Product ID not found');
                btn.prop('disabled', false);
                return;
            }

            // Convert productId to a number since it comes from data attribute as string
            const productIdNum = parseInt(productId, 10);
            if (isNaN(productIdNum)) {
                alert('Invalid product ID');
                btn.prop('disabled', false);
                return;
            }

            const requestData = {
                productId: productIdNum,
                productName: productName,
                quantity: parseFloat(quantity),
                qcStatus: 'Pending',
                qcComment: ''
            };

            console.log('Sending request with data:', requestData);

            $.ajax({
                url: '/products/productCheck/add',
                type: 'POST',
                data: requestData,
                dataType: 'json',
                success: function(response) {
                    if (response.success) {
                        alert('Product check submitted successfully');
                        quantityInput.val('');
                        // Refresh the page to show the new product check
                        location.reload();
                    } else {
                        alert('Failed to submit product check: ' + (response.error || 'Unknown error'));
                    }
                    btn.prop('disabled', false);
                },
                error: function(xhr) {
                    let errorMessage = 'Error submitting product check';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        errorMessage = xhr.responseJSON.error;
                    }
                    alert(errorMessage);
                    btn.prop('disabled', false);
                }
            });
        });
    </script>
    <script>
        // AJAX handlers for Complete buttons
        $(document).ready(function() {
            // Raw Material Request completion
            $('.complete-raw-material').click(function(e) {
                e.preventDefault();
                const btn = $(this);
                const row = btn.closest('tr');
                const id = btn.data('id');
                btn.prop('disabled', true).addClass('loading');
                
                $.post(`/rawMaterial/complete/${id}`)
                    .done(function() {
                        row.fadeOut(300, function() {
                            $(this).remove();
                            // If no more rows, show the empty state
                            if ($('#rawMaterialRequests tbody tr').length === 0) {
                                $('#rawMaterialRequests tbody').html(`
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No raw material requests found
                                        </td>
                                    </tr>
                                `);
                            }
                        });
                    })
                    .fail(function(xhr) {
                        alert('Error completing raw material request: ' + (xhr.responseJSON?.error || 'Unknown error'));
                        btn.prop('disabled', false).removeClass('loading');
                    });
            });

            // Packaging Request completion
            $('.complete-packaging').click(function() {
                const btn = $(this);
                const id = btn.data('id');
                btn.prop('disabled', true);
                
                $.post(`/packaging-request/complete/${id}`)
                    .done(function() {
                        location.reload();
                    })
                    .fail(function(xhr) {
                        alert('Error completing packaging request: ' + (xhr.responseJSON?.error || 'Unknown error'));
                        btn.prop('disabled', false);
                    });
            });

            // Product Check completion
            $('.complete-product-check').click(function(e) {
                e.preventDefault();
                const btn = $(this);
                const row = btn.closest('tr');
                const id = btn.data('id');
                const data = {
                    qcStatus: btn.data('qc-status'),
                    quantity: btn.data('quantity'),
                    productId: btn.data('product-id')
                };
                btn.prop('disabled', true).addClass('loading');
                
                $.post(`/products/productCheck/${id}/complete`, data)
                    .done(function() {
                        row.fadeOut(300, function() {
                            $(this).remove();
                            // If no more rows, show the empty state
                            if ($('#productChecks tbody tr').length === 0) {
                                $('#productChecks tbody').html(`
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                            No product checks found
                                        </td>
                                    </tr>
                                `);
                            }
                        });
                    })
                    .fail(function(xhr) {
                        alert('Error completing product check: ' + (xhr.responseJSON?.error || 'Unknown error'));
                        btn.prop('disabled', false).removeClass('loading');
                    });
            });

            // Complain completion
            $('.complete-complain').click(function() {
                const btn = $(this);
                const id = btn.data('id');
                btn.prop('disabled', true);
                
                $.post(`/complain/complete/${id}`)
                    .done(function() {
                        location.reload();
                    })
                    .fail(function(xhr) {
                        alert('Error completing complain: ' + (xhr.responseJSON?.error || 'Unknown error'));
                        btn.prop('disabled', false);
                    });
            });
            
            // Reject Sebagian - Update Stock button handler
            $('.update-stock-btn').click(function(e) {
                e.preventDefault();
                const btn = $(this);
                const row = btn.closest('tr');
                const id = btn.data('id');
                const productId = btn.data('product-id');
                const form = $(`#reject-form-${id}`);
                const rejectQuantity = form.find('input[name="rejectQuantity"]').val();
                
                if (!rejectQuantity || parseFloat(rejectQuantity) <= 0) {
                    alert('Please enter a valid reject quantity');
                    return;
                }
                
                const data = {
                    productId: productId,
                    rejectQuantity: rejectQuantity
                };
                
                btn.prop('disabled', true).addClass('loading');
                
                $.post(`/products/productCheck/${id}/updateStock`, data)
                    .done(function(response) {
                        if (response.success) {
                            row.fadeOut(300, function() {
                                $(this).remove();
                                // If no more rows, show the empty state
                                if ($('#productChecks tbody tr').length === 0) {
                                    $('#productChecks tbody').html(`
                                        <tr>
                                            <td colspan="6" class="text-center py-4 text-muted">
                                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                                No product checks found
                                            </td>
                                        </tr>
                                    `);
                                }
                            });
                        } else {
                            alert(response.message || 'Error updating stock');
                            btn.prop('disabled', false).removeClass('loading');
                        }
                    })
                    .fail(function(xhr) {
                        alert('Error updating stock: ' + (xhr.responseJSON?.error || 'Unknown error'));
                        btn.prop('disabled', false).removeClass('loading');
                    });
            });
        });
    </script>
    <%- include('../partials/chat', { users: users, userRole: userRole, userId: userId }) %>

</body>
</html>
