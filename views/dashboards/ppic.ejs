    <!-- ===================== Stock Check Modal ===================== -->
    <style>
        #stockModal .modal-content { border-radius: 16px; overflow: hidden; }
        #stockModal .modal-body { display: block; padding: 1.25rem 1.5rem; max-height: 70vh; overflow-y: auto; }
        #stockModal .stock-result { display: block; }
        #stockModal .stock-banner { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.9rem 1rem; border-radius: 12px; margin-bottom: 1.15rem; }
        #stockModal .stock-banner i { font-size: 1.35rem; line-height: 1.5; flex: 0 0 auto; }
        #stockModal .stock-banner-title { font-weight: 700; font-size: 1rem; }
        #stockModal .stock-banner-sub { font-size: 0.875rem; opacity: 0.9; margin-top: 0.1rem; }
        #stockModal .stock-banner--fail { background: #fdecea; color: #b42318; }
        #stockModal .stock-banner--ok   { background: #e7f4ea; color: #1b5e20; }
        #stockModal .stock-banner--warn { background: #fff6e6; color: #92610a; }
        #stockModal .stock-section { display: block; margin-bottom: 1.15rem; }
        #stockModal .stock-section:last-child { margin-bottom: 0; }
        #stockModal .stock-section-head { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.55rem; }
        #stockModal .stock-section-head.out { color: #b42318; }
        #stockModal .stock-section-head.in  { color: #1b7a3b; }
        #stockModal .stock-items { display: grid; grid-template-columns: 1fr; gap: 0.6rem; }
        #stockModal .stock-item { display: block; padding: 0.8rem 0.9rem; border: 1px solid #eceeec; border-left: 3px solid #d0d5dd; border-radius: 10px; background: #fff; }
        #stockModal .stock-item.out { border-left-color: #d92d20; background: #fffafa; }
        #stockModal .stock-item.in  { border-left-color: #2e7d32; background: #fbfdfb; }
        #stockModal .stock-item-name { font-weight: 700; color: #1f2937; margin-bottom: 0.5rem; }
        #stockModal .stock-item-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; }
        #stockModal .stock-pill { display: inline-flex; align-items: baseline; gap: 0.3rem; font-size: 0.78rem; padding: 0.2rem 0.6rem; border-radius: 999px; background: #f2f4f7; color: #475467; white-space: nowrap; }
        #stockModal .stock-pill strong { font-weight: 700; }
        #stockModal .stock-pill.need  { background: #eef4ff; color: #1849a9; }
        #stockModal .stock-pill.short { background: #fee4e2; color: #b42318; }
        #stockModal .stock-pill.have  { background: #e7f4ea; color: #1b7a3b; }
        #stockModal .stock-item-action { margin-top: 0.65rem; }
        #stockModal .stock-item-action .btn { min-width: 0; height: auto; margin: 0; }
        #stockModal .stock-item-action .input-group { max-width: 320px; }
        #stockModal .modal-footer { background: #fafbfa; }
    </style>
    <div class="modal fade" id="stockModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-box"></i> Stock Check Result</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalBody"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===================== Scripts ===================== -->
    <script>
        // ---- View toggle, board delete, search, focus, clock, count-up, SSE (vanilla) ----
        (function () {
            const TYPE_MAP = {
                orders:   { type: 'order',                label: 'order' },
                prod:     { type: 'production',           label: 'production batch' },
                prodreq:  { type: 'production-request',   label: 'production request' },
                rawmat:   { type: 'raw-material-request', label: 'raw material request' },
                pkg:      { type: 'packaging-request',    label: 'packaging request' },
                formula:  { type: 'formula-request',      label: 'formula request' },
                check:    { type: 'product-check',        label: 'product check' },
            };

            function setView(v) {
                const list = document.getElementById('ppicListView');
                const kanban = document.getElementById('ppicKanbanView');
                const bL = document.getElementById('btnListView');
                const bK = document.getElementById('btnKanbanView');
                if (v === 'kanban') {
                    if (list) list.style.display = 'none';
                    if (kanban) kanban.style.display = 'block';
                    bK.classList.add('active'); bL.classList.remove('active');
                    document.body.classList.add('board-mode');
                    requestAnimationFrame(updateBoardNav);
                } else {
                    if (list) list.style.display = '';
                    if (kanban) kanban.style.display = 'none';
                    bL.classList.add('active'); bK.classList.remove('active');
                    document.body.classList.remove('board-mode');
                }
                try { localStorage.setItem('ppicView', v); } catch (e) {}
            }

            function updateColumnCounts() {
                document.querySelectorAll('#ppicKanbanView .kanban-col').forEach(col => {
                    const countEl = col.querySelector('.kanban-count');
                    if (countEl) countEl.textContent = col.querySelectorAll('.kanban-card').length;
                });
            }

            function scrollBoard(dir) {
                const board = document.querySelector('.kanban-board');
                if (!board) return;
                const col = board.querySelector('.kanban-col');
                const step = (col ? col.getBoundingClientRect().width : 320) + 16;
                board.scrollBy({ left: dir * step, behavior: 'smooth' });
            }

            function updateBoardNav() {
                const board = document.querySelector('.kanban-board');
                const left = document.getElementById('boardLeft');
                const right = document.getElementById('boardRight');
                if (!board || !left || !right) return;
                const max = board.scrollWidth - board.clientWidth - 1;
                const scrollable = max > 1;
                left.disabled = !scrollable || board.scrollLeft <= 0;
                right.disabled = !scrollable || board.scrollLeft >= max;
            }

            async function deleteCard(card) {
                const key = card.getAttribute('data-card-key') || '';
                const dash = key.indexOf('-');
                const prefix = key.slice(0, dash);
                const id = key.slice(dash + 1);
                const map = TYPE_MAP[prefix];
                if (!map || !id) return;
                if (!confirm(`Hapus ${map.label} ini secara permanen dari database? Tindakan ini tidak bisa dibatalkan.`)) return;
                const btn = card.querySelector('.kanban-del');
                if (btn) { btn.disabled = true; btn.textContent = '…'; }
                try {
                    const res = await fetch(`/ppic/kanban/delete/${map.type}/${id}`, { method: 'POST', headers: { 'Accept': 'application/json' } });
                    const data = await res.json().catch(() => ({}));
                    if (res.ok && data.success) { card.remove(); updateColumnCounts(); updateBoardNav(); }
                    else { alert('Gagal menghapus: ' + (data.message || res.status)); if (btn) { btn.disabled = false; btn.innerHTML = '&times;'; } }
                } catch (e) {
                    alert('Gagal menghapus: ' + e.message);
                    if (btn) { btn.disabled = false; btn.innerHTML = '&times;'; }
                }
            }

            // Jump to a queue from the stat cards
            function focusQueue(key) {
                const isBoard = document.body.classList.contains('board-mode');
                if (isBoard) {
                    const col = document.querySelector(`.kanban-col[data-queue="${key}"]`);
                    if (col) { col.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' }); col.classList.remove('queue-flash'); void col.offsetWidth; col.classList.add('queue-flash'); }
                } else {
                    const sec = document.getElementById('sec-' + key);
                    const body = document.getElementById('q-' + key);
                    if (body && window.bootstrap) bootstrap.Collapse.getOrCreateInstance(body, { toggle: false }).show();
                    if (sec) { sec.scrollIntoView({ behavior: 'smooth', block: 'start' }); sec.classList.remove('queue-flash'); void sec.offsetWidth; sec.classList.add('queue-flash'); }
                }
            }

            // Live search across list rows + board cards
            function applySearch(q) {
                q = (q || '').trim().toLowerCase();
                // list rows
                document.querySelectorAll('#ppicListView tbody tr').forEach(row => {
                    if (row.classList.contains('is-empty-row')) return;
                    row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
                // board cards
                document.querySelectorAll('#ppicKanbanView .kanban-card').forEach(card => {
                    card.style.display = (!q || card.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
                // expand all sections while searching so matches are visible
                if (q && window.bootstrap) {
                    document.querySelectorAll('#ppicListView .section-content').forEach(c => bootstrap.Collapse.getOrCreateInstance(c, { toggle: false }).show());
                }
            }

            document.addEventListener('DOMContentLoaded', function () {
                document.getElementById('btnListView').addEventListener('click', () => setView('list'));
                document.getElementById('btnKanbanView').addEventListener('click', () => setView('kanban'));

                document.querySelectorAll('#ppicKanbanView .kanban-del').forEach(btn => {
                    btn.addEventListener('click', function (e) { e.preventDefault(); const card = this.closest('.kanban-card'); if (card) deleteCard(card); });
                });

                // board horizontal scroll controls
                const boardEl = document.querySelector('.kanban-board');
                const bLeft = document.getElementById('boardLeft');
                const bRight = document.getElementById('boardRight');
                if (bLeft) bLeft.addEventListener('click', () => scrollBoard(-1));
                if (bRight) bRight.addEventListener('click', () => scrollBoard(1));
                if (boardEl) boardEl.addEventListener('scroll', updateBoardNav, { passive: true });
                window.addEventListener('resize', updateBoardNav);

                // stat cards -> focus queue
                document.querySelectorAll('.stat-card[data-focus]').forEach(card => {
                    const go = () => focusQueue(card.getAttribute('data-focus'));
                    card.addEventListener('click', go);
                    card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); } });
                });

                // expand / collapse all
                const allBodies = () => document.querySelectorAll('#ppicListView .section-content');
                document.getElementById('btnExpandAll').addEventListener('click', () => allBodies().forEach(c => window.bootstrap && bootstrap.Collapse.getOrCreateInstance(c, { toggle: false }).show()));
                document.getElementById('btnCollapseAll').addEventListener('click', () => allBodies().forEach(c => window.bootstrap && bootstrap.Collapse.getOrCreateInstance(c, { toggle: false }).hide()));

                // chevron rotation synced to bootstrap collapse
                document.querySelectorAll('#ppicListView .section-content').forEach(content => {
                    const header = content.parentElement.querySelector('.section-header');
                    content.addEventListener('show.bs.collapse', () => header && header.setAttribute('aria-expanded', 'true'));
                    content.addEventListener('hide.bs.collapse', () => header && header.setAttribute('aria-expanded', 'false'));
                });

                // search
                const search = document.getElementById('ppicSearch');
                if (search) search.addEventListener('input', () => applySearch(search.value));

                // restore saved view
                let saved = null; try { saved = localStorage.getItem('ppicView'); } catch (e) {}
                if (saved === 'kanban') setView('kanban');

                // count-up stat values
                document.querySelectorAll('.stat-value[data-count]').forEach(el => {
                    const target = parseInt(el.getAttribute('data-count'), 10) || 0;
                    if (!target) { el.textContent = '0'; return; }
                    const dur = 850, start = performance.now();
                    (function tick(now) {
                        const p = Math.min((now - start) / dur, 1);
                        el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString('id-ID');
                        if (p < 1) requestAnimationFrame(tick);
                    })(start);
                });

                // hero clock
                function tickClock() {
                    const c = document.getElementById('ppicClock');
                    const d = document.getElementById('ppicDate');
                    const now = new Date();
                    if (c) c.textContent = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                    if (d) d.textContent = now.toLocaleDateString('en-US', { weekday: 'long', day: 'numeric', month: 'long' });
                }
                tickClock(); setInterval(tickClock, 15000);

                // form loading state
                document.querySelectorAll('form').forEach(form => {
                    form.addEventListener('submit', function () {
                        const submitBtn = this.querySelector('button[type="submit"]');
                        if (submitBtn) { submitBtn.classList.add('loading'); submitBtn.disabled = true; }
                    });
                });

                // ---- SSE notifications ----
                try {
                    if ('Notification' in window && Notification.permission !== 'granted') Notification.requestPermission();
                    const eventSource = new EventSource('/notifications');
                    const ping = (title, body) => {
                        try { new Audio('/audio/notification.mp3').play().catch(() => {}); } catch (e) {}
                        try {
                            const n = new Notification(title, { body, icon: '/images/logomib.png', silent: true });
                            n.onclick = () => { window.focus(); location.reload(); };
                        } catch (e) {}
                    };
                    eventSource.onmessage = (event) => {
                        let data; try { data = JSON.parse(event.data); } catch (e) { return; }
                        if (data.type === 'newOrder') ping('New Order Received', `New order ${data.sonumber} from ${data.customerName}`);
                        else if (data.type === 'ppicRework' || data.type === 'ppicRawMaterials') ping('New Rework Request', `New rework request for ${data.product} (${data.sonumber} - ${data.customerName})`);
                        else if (data.type === 'productCheckQCStatus') ping('Product Check QC Update', `${data.productName} (${data.quantity} KG) - QC Status: ${data.status}`);
                    };
                    eventSource.onerror = () => {};
                    window.addEventListener('beforeunload', () => eventSource.close());
                } catch (e) { console.warn('SSE unavailable', e); }
            });

            // expose for inline use if needed
            window.ppicFocusQueue = focusQueue;
            window.ppicUpdateColumnCounts = updateColumnCounts;
        })();
    </script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // ---- Stock check (jQuery AJAX) ----
        $(document).ready(function () {
            $(document).on('click', '.check-stock-btn', function () {
                const btn = this;
                const orderId = btn.dataset.orderId;
                btn.classList.add('loading'); btn.disabled = true;
                $.ajax({
                    url: '/orders/checkStock/' + orderId,
                    type: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    success: (response) => {
                        btn.classList.remove('loading'); btn.disabled = false;
                        let modalBody = '';
                        if (response.error || response.message === 'error') {
                            modalBody = `
                                <div class="stock-result">
                                    <div class="stock-banner stock-banner--fail">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                        <div><div class="stock-banner-title">Stock Check Failed</div>
                                        <div class="stock-banner-sub">${response.error || 'Some items are out of stock.'}</div></div>
                                    </div>
                                    ${response.outOfStockProducts ? `
                                        <div class="stock-section">
                                            <div class="stock-section-head out"><i class="bi bi-x-circle"></i> Out of Stock — Products</div>
                                            <div class="stock-items">
                                                ${response.outOfStockProducts.map(product => `
                                                    <div class="stock-item out">
                                                        <div class="stock-item-name">${product.name}</div>
                                                        <div class="stock-item-meta">
                                                            <span class="stock-pill need">Needed <strong>${product.satuan === 'L' ? (product.needed * product.density).toFixed(2) : product.needed} KG</strong></span>
                                                            <span class="stock-pill short">Available <strong>${product.available} KG</strong></span>
                                                        </div>
                                                        <div class="stock-item-action">
                                                            <button class="btn btn-primary btn-sm check-product" data-product-name="${product.name}" data-product-id="${product.id}"><i class="bi bi-clipboard-check"></i> Check</button>
                                                            <div class="input-group input-group-sm mt-2 quantity-input-group" style="display:none;">
                                                                <input type="number" class="form-control quantity-input" data-product-name="${product.name}" data-product-id="${product.id}" placeholder="Quantity (KG)">
                                                                <button class="btn btn-primary submit-check" data-product-name="${product.name}" data-product-id="${product.id}">Submit</button>
                                                            </div>
                                                        </div>
                                                    </div>`).join('')}
                                            </div>
                                        </div>` : ''}
                                    ${response.inStockProducts ? `
                                        <div class="stock-section">
                                            <div class="stock-section-head in"><i class="bi bi-check-circle"></i> In Stock — Products</div>
                                            <div class="stock-items">
                                                ${response.inStockProducts.map(product => `
                                                    <div class="stock-item in">
                                                        <div class="stock-item-name">${product.name}</div>
                                                        <div class="stock-item-meta"><span class="stock-pill have">Available <strong>${product.available} KG</strong></span></div>
                                                        <div class="stock-item-action">
                                                            <div class="input-group input-group-sm">
                                                                <input type="number" class="form-control quantity-input" data-product-name="${product.name}" data-product-id="${product.id}" placeholder="Quantity (KG)">
                                                                <button class="btn btn-primary submit-check" data-product-name="${product.name}" data-product-id="${product.id}">Submit</button>
                                                            </div>
                                                        </div>
                                                    </div>`).join('')}
                                            </div>
                                        </div>` : ''}
                                    ${response.outOfStockPackaging ? `
                                        <div class="stock-section">
                                            <div class="stock-section-head out"><i class="bi bi-x-circle"></i> Out of Stock — Packaging</div>
                                            <div class="stock-items">
                                                ${response.outOfStockPackaging.map(pkg => `
                                                    <div class="stock-item out">
                                                        <div class="stock-item-name">${pkg.name}</div>
                                                        <div class="stock-item-meta">
                                                            <span class="stock-pill need">Needed <strong>${pkg.needed} ${pkg.satuan}</strong></span>
                                                            <span class="stock-pill short">Available <strong>${pkg.available} ${pkg.satuan}</strong></span>
                                                        </div>
                                                    </div>`).join('')}
                                            </div>
                                        </div>` : ''}
                                    ${response.inStockPackaging ? `
                                        <div class="stock-section">
                                            <div class="stock-section-head in"><i class="bi bi-check-circle"></i> In Stock — Packaging</div>
                                            <div class="stock-items">
                                                ${response.inStockPackaging.map(pkg => `
                                                    <div class="stock-item in">
                                                        <div class="stock-item-name">${pkg.name}</div>
                                                        <div class="stock-item-meta"><span class="stock-pill have">Available <strong>${pkg.available} ${pkg.satuan}</strong></span></div>
                                                    </div>`).join('')}
                                            </div>
                                        </div>` : ''}
                                    ${response.outOfStockProducts && response.outOfStockProducts.length ? `
                                    <div class="stock-actions mt-3 d-flex justify-content-end">
                                        <a href="/production/request/${orderId}" class="btn btn-primary"><i class="bi bi-gear"></i> Request Production</a>
                                    </div>` : ''}
                                </div>`;
                        } else if (response.inStockProducts) {
                            modalBody = `
                                <div class="stock-result">
                                    <div class="stock-banner stock-banner--ok">
                                        <i class="bi bi-check-circle-fill"></i>
                                        <div><div class="stock-banner-title">All Products In Stock</div>
                                        <div class="stock-banner-sub">${response.message || ''}</div></div>
                                    </div>
                                    <div class="stock-section">
                                        <div class="stock-section-head in"><i class="bi bi-check-circle"></i> In Stock — Products</div>
                                        <div class="stock-items">
                                            ${response.inStockProducts.map(product => `
                                                <div class="stock-item in">
                                                    <div class="stock-item-name">${product.name}</div>
                                                    <div class="stock-item-meta"><span class="stock-pill have">Available <strong>${product.available} KG</strong></span></div>
                                                    <div class="stock-item-action">
                                                        <div class="input-group input-group-sm">
                                                            <input type="number" class="form-control quantity-input" data-product-id="${product.id}" data-product-name="${product.name}" placeholder="Quantity (KG)">
                                                            <button class="btn btn-primary submit-check" data-product-id="${product.id}" data-product-name="${product.name}">Submit</button>
                                                        </div>
                                                    </div>
                                                </div>`).join('')}
                                        </div>
                                    </div>
                                </div>`;
                        } else {
                            modalBody = `
                                <div class="stock-result">
                                    <div class="stock-banner stock-banner--warn">
                                        <i class="bi bi-exclamation-circle-fill"></i>
                                        <div><div class="stock-banner-title">No Stock Information</div>
                                        <div class="stock-banner-sub">No stock information is available for this order.</div></div>
                                    </div>
                                </div>`;
                        }
                        document.getElementById('modalBody').innerHTML = modalBody;
                        bootstrap.Modal.getOrCreateInstance(document.getElementById('stockModal')).show();
                    },
                    error: () => {
                        btn.classList.remove('loading'); btn.disabled = false;
                        document.getElementById('modalBody').innerHTML = `
                            <div class="stock-result">
                                <div class="stock-banner stock-banner--fail">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <div><div class="stock-banner-title">Error</div>
                                    <div class="stock-banner-sub">An error occurred while checking stock. Please try again later.</div></div>
                                </div>
                            </div>`;
                        bootstrap.Modal.getOrCreateInstance(document.getElementById('stockModal')).show();
                    }
                });
            });

            // reveal quantity input
            $(document).on('click', '.check-product', function () {
                const btn = $(this);
                btn.siblings('.quantity-input-group').show();
                btn.prop('disabled', true);
            });

            // submit a product check
            $(document).on('click', '.submit-check', function () {
                const btn = $(this);
                const productName = btn.data('product-name');
                const inputGroup = btn.closest('.input-group');
                const quantityInput = inputGroup.find('.quantity-input');
                const quantity = quantityInput.val();
                if (!quantity || quantity <= 0) { alert('Please enter a valid quantity'); return; }
                const productId = btn.data('product-id');
                const productIdNum = parseInt(productId, 10);
                if (isNaN(productIdNum)) { alert('Invalid product ID'); return; }
                btn.prop('disabled', true);
                $.ajax({
                    url: '/products/productCheck/add',
                    type: 'POST',
                    data: { productId: productIdNum, productName: productName, quantity: parseFloat(quantity), qcStatus: 'Pending', qcComment: '' },
                    dataType: 'json',
                    success: function (response) {
                        if (response.success) { alert('Product check submitted successfully'); location.reload(); }
                        else { alert('Failed to submit product check: ' + (response.error || 'Unknown error')); btn.prop('disabled', false); }
                    },
                    error: function (xhr) { alert((xhr.responseJSON && xhr.responseJSON.error) || 'Error submitting product check'); btn.prop('disabled', false); }
                });
            });

            // ---- Complete handlers ----
            $(document).on('click', '.complete-raw-material', function (e) {
                e.preventDefault();
                const btn = $(this); const row = btn.closest('tr'); const id = btn.data('id');
                btn.prop('disabled', true).addClass('loading');
                $.post(`/rawMaterial/complete/${id}`)
                    .done(function () {
                        if (row.length) row.fadeOut(300, function () { $(this).remove(); });
                        const card = btn.closest('.kanban-card'); if (card.length) card.fadeOut(300, function () { $(this).remove(); if (window.ppicUpdateColumnCounts) window.ppicUpdateColumnCounts(); });
                    })
                    .fail(function (xhr) { alert('Error completing raw material request: ' + ((xhr.responseJSON && xhr.responseJSON.error) || 'Unknown error')); btn.prop('disabled', false).removeClass('loading'); });
            });

            $(document).on('click', '.complete-packaging', function () {
                const btn = $(this); const row = btn.closest('tr'); const id = btn.data('id');
                btn.prop('disabled', true).addClass('loading');
                $.post(`/packaging-request/complete/${id}`)
                    .done(function () {
                        if (row.length) row.fadeOut(300, function () { $(this).remove(); });
                        const card = btn.closest('.kanban-card'); if (card.length) card.fadeOut(300, function () { $(this).remove(); if (window.ppicUpdateColumnCounts) window.ppicUpdateColumnCounts(); });
                    })
                    .fail(function (xhr) { alert('Error completing packaging request: ' + ((xhr.responseJSON && xhr.responseJSON.error) || 'Unknown error')); btn.prop('disabled', false).removeClass('loading'); });
            });

            $(document).on('click', '.complete-product-check', function (e) {
                e.preventDefault();
                const btn = $(this); const row = btn.closest('tr'); const id = btn.data('id');
                const data = { qcStatus: btn.data('qc-status'), quantity: btn.data('quantity'), productId: btn.data('product-id') };
                btn.prop('disabled', true).addClass('loading');
                $.post(`/products/productCheck/${id}/complete`, data)
                    .done(function () { if (row.length) row.fadeOut(300, function () { $(this).remove(); }); })
                    .fail(function (xhr) { alert('Error completing product check: ' + ((xhr.responseJSON && xhr.responseJSON.error) || 'Unknown error')); btn.prop('disabled', false).removeClass('loading'); });
            });

            $(document).on('click', '.complete-complain', function () {
                const btn = $(this); const row = btn.closest('tr'); const id = btn.data('id');
                btn.prop('disabled', true).addClass('loading');
                $.post(`/complain/complete/${id}`)
                    .done(function () {
                        if (row.length) row.fadeOut(300, function () { $(this).remove(); });
                        const card = btn.closest('.kanban-card'); if (card.length) card.fadeOut(300, function () { $(this).remove(); if (window.ppicUpdateColumnCounts) window.ppicUpdateColumnCounts(); });
                    })
                    .fail(function (xhr) { alert('Error completing complain: ' + ((xhr.responseJSON && xhr.responseJSON.error) || 'Unknown error')); btn.prop('disabled', false).removeClass('loading'); });
            });

            $(document).on('click', '.update-stock-btn', function (e) {
                e.preventDefault();
                const btn = $(this); const row = btn.closest('tr'); const id = btn.data('id'); const productId = btn.data('product-id');
                const form = $(`#reject-form-${id}`);
                const rejectQuantity = form.find('input[name="rejectQuantity"]').val();
                if (!rejectQuantity || parseFloat(rejectQuantity) <= 0) { alert('Please enter a valid reject quantity'); return; }
                btn.prop('disabled', true).addClass('loading');
                $.post(`/products/productCheck/${id}/updateStock`, { productId: productId, rejectQuantity: rejectQuantity })
                    .done(function (response) {
                        if (response.success) { if (row.length) row.fadeOut(300, function () { $(this).remove(); }); }
                        else { alert(response.message || 'Error updating stock'); btn.prop('disabled', false).removeClass('loading'); }
                    })
                    .fail(function (xhr) { alert('Error updating stock: ' + ((xhr.responseJSON && xhr.responseJSON.error) || 'Unknown error')); btn.prop('disabled', false).removeClass('loading'); });
            });
        });
    </script>

</body>
