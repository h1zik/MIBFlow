<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Warehouse - MIB Flow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #2e7d32;
            --primary-light: #4caf50;
            --primary-dark: #1b5e20;
            --text-color: #2c3e50;
            --background-light: #e8f5e9;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 280px;
            padding: 2rem;
            transition: var(--transition);
            width: calc(100% - 280px);
        }

        /* When sidebar is collapsed */
        body.sidebar-collapsed .main-content {
            margin-left: 70px;
            width: calc(100% - 70px);
        }

        .page-header {
            background: white;
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            animation: slideDown 0.5s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .dashboard-section {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 2rem;
            overflow: hidden;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-header {
            padding: 1.5rem;
            background-color: var(--background-light);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-header:hover {
            background-color: #d7ecd8;
        }

        .section-title {
            margin: 0;
            color: var(--primary-dark);
            font-weight: 600;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-content {
            padding: 1.5rem;
            display: none;
        }

        .section-content.show {
            display: block;
            animation: slideDown 0.3s ease-out;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--background-light);
            color: var(--primary-dark);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0,0,0,0.05);
        }

        .table tbody tr {
            transition: var(--transition);
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .btn-success {
            background-color: var(--primary-color);
            border: none;
        }

        .btn-success:hover {
            background-color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
        }

        .form-control {
            padding: 0.5rem 1rem;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
        }

        .time-interval-form {
            background: var(--background-light);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }

        .time-interval-form .form-group {
            margin-bottom: 1rem;
        }

        .time-interval-form label {
            font-weight: 500;
            color: var(--text-color);
            margin-bottom: 0.5rem;
        }

        /* Loading Animation */
        .loading {
            pointer-events: none;
            position: relative;
        }

        .loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin: -10px 0 0 -10px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .quantity-positive {
            color: var(--primary-color);
            font-weight: 500;
        }

        .quantity-negative {
            color: #dc3545;
            font-weight: 500;
        }

        /* Enhanced Mobile Styles */
        @media (max-width: 768px) {
            /* Layout Improvements */
            .main-content {
                margin-left: 0;
                padding: 0.75rem;
                width: 100%;
            }

            .dashboard-section {
                margin-bottom: 1rem;
                border-radius: 10px;
            }

            .section-header {
                padding: 0.875rem;
            }

            .section-content {
                padding: 0.75rem;
            }

            /* Mobile Table Improvements */
            .table-responsive {
                border-radius: 8px;
                background: white;
                box-shadow: var(--shadow);
                margin-bottom: 1rem;
            }

            .table {
                display: block;
            }

            .table thead {
                display: none; /* Hide headers on mobile */
            }

            .table tbody {
                display: block;
            }

            .table tr {
                display: block;
                margin-bottom: 1rem;
                border: 1px solid var(--background-light);
                border-radius: 8px;
                background: white;
            }

            .table td {
                display: flex;
                padding: 0.75rem;
                align-items: center;
                border: none;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .table td:last-child {
                border-bottom: none;
            }

            .table td::before {
                content: attr(data-label);
                font-weight: 600;
                width: 120px;
                min-width: 120px;
                color: var(--primary-dark);
                font-size: 0.85rem;
            }

            .table td > * {
                flex: 1;
                margin-left: 1rem;
            }

            /* Form Controls */
            .form-control {
                height: 40px;
                font-size: 16px; /* Prevents iOS zoom */
                padding: 0.5rem;
            }

            select.form-control {
                padding-right: 24px;
            }

            /* Time Interval Form */
            .time-interval-form {
                padding: 0.75rem;
                margin: 0.5rem 0;
                border-radius: 8px;
            }

            .time-interval-form .form-group {
                margin-bottom: 0.75rem;
            }

            .time-interval-form .btn {
                width: 100%;
                margin-top: 0.5rem;
            }

            /* Button Improvements */
            .btn {
                height: 40px;
                padding: 0 1rem;
                margin: 0.25rem;
                font-size: 0.9rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 100px;
                touch-action: manipulation;
            }

            /* Modal Improvements */
            .modal-content {
                border-radius: 12px;
            }

            .modal-header {
                padding: 1rem;
            }

            .modal-body {
                padding: 1rem;
            }

            .modal-footer {
                padding: 0.75rem;
                gap: 0.5rem;
            }

            /* Table Scroll Improvements */
            .table-responsive::-webkit-scrollbar {
                height: 6px;
            }

            .table-responsive::-webkit-scrollbar-track {
                background: transparent;
            }

            .table-responsive::-webkit-scrollbar-thumb {
                background-color: var(--primary-light);
                border-radius: 3px;
            }

            .table-responsive::after {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                bottom: 0;
                width: 5px;
                background: linear-gradient(to left, rgba(0,0,0,0.05), transparent);
                pointer-events: none;
            }

            /* Touch-friendly Improvements */
            .btn:active,
            .section-header:active {
                transform: scale(0.98);
            }

            .form-control:focus,
            select:focus {
                outline: none;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 2px rgba(46, 125, 50, 0.2);
            }

            /* Loading State */
            .loading {
                min-height: 40px;
            }

            .loading::after {
                width: 24px;
                height: 24px;
                margin: -12px 0 0 -12px;
                border-width: 2px;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>
    <%- include('../partials/chat', { users: users, userId: userId }) %>
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">
                <i class="bi bi-box-seam"></i>
                Product Warehouse
            </h1>
            <p class="text-muted mb-0">Manage product inventory, inbound and outbound orders</p>
        </div>

        <!-- Approved Orders Section -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#approvedOrders">
                <h2 class="section-title">
                    <i class="bi bi-check-circle"></i>
                    Approved Orders
                    <% if (approvedOrders && approvedOrders.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= approvedOrders.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="approvedOrders" class="section-content collapse">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>SO Number</th>
                                <th>Date</th>
                                <th>Customer Name</th>
                                <th>Products</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (approvedOrders && approvedOrders.length > 0) { %>
                                <% approvedOrders.forEach(function(order) { %>
                                    <tr>
                                        <td data-label="Order ID">#<%= order.id %></td>
                                        <td data-label="SO Number"><%= order.sonumber %></td>
                                        <td data-label="Date"><%= order.deadline ? new Date(order.deadline).toLocaleDateString() : 'No deadline' %></td>
                                        <td data-label="Customer Name"><%= order.customerName %></td>
                                        <td data-label="Products">
                                            <% order.OrderItems.forEach(function(item) { %>
                                                <% if (item.invoicedQuantity !== item.shippedQuantity) { %>
                                                    <div>
                                                        <%= item.Product.name %> - <%= item.Packaging.name %>:
                                                        <% if (item.shippedQuantity !== 0 && item.invoicedQuantity > item.shippedQuantity) { %>
                                                            <%= item.invoicedQuantity - item.shippedQuantity %> PCS
                                                        <% } else { %>
                                                            <%= item.invoicedQuantity %> PCS
                                                        <% } %>
                                                    </div>
                                                <% } %>
                                            <% }); %>
                                        </td>
                                        <td data-label="Action">
                                            <% order.OrderItems.forEach(function(item) { %>
                                              <% if (item.invoicedQuantity !== item.shippedQuantity) { %>
                                                <div class="mt-2">
                                                  • <%= item.Product.name %> - <%= item.Packaging.name %><br>
                                                  &nbsp;&nbsp;Quantity: 
                                                  <% if (item.shippedQuantity !== 0 && item.invoicedQuantity > item.shippedQuantity) { %>
                                                    <%= item.invoicedQuantity - item.shippedQuantity %> PCS
                                                  <% } else { %>
                                                    <%= item.invoicedQuantity %> PCS
                                                  <% } %>
                                                </div>
                                              <% } %>
                                            <% }); %>
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#deliveryModal<%= order.id %>">
                                                    <i class="bi bi-truck"></i>
                                                    Deliver
                                                </button>
                                            </div>

                                            <!-- Delivery Modal -->
                                            <div class="modal fade" id="deliveryModal<%= order.id %>" tabindex="-1" aria-labelledby="deliveryModalLabel<%= order.id %>" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title" id="deliveryModalLabel<%= order.id %>">Confirm Delivery - SO#<%= order.sonumber %></h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <form action="/productWarehouse/deliver" method="POST">
                                                            <div class="modal-body">
                                                                <input type="hidden" name="orderId" value="<%= order.id %>">
                                                                <p>Are you sure you want to change the order status to "On Delivery"?</p>
                                                                <div class="mb-3">
                                                                    <strong>Order Details:</strong><br>
                                                                    <% order.OrderItems.forEach(function(item) { %>
                                                                        <% if (item.invoicedQuantity !== item.shippedQuantity) { %>
                                                                          <div class="mt-2">
                                                                            • <%= item.Product.name %> - <%= item.Packaging.name %><br>
                                                                            &nbsp;&nbsp;Quantity: 
                                                                            <% if (item.shippedQuantity !== 0 && item.invoicedQuantity > item.shippedQuantity) { %>
                                                                              <%= item.invoicedQuantity - item.shippedQuantity %> PCS
                                                                            <% } else { %>
                                                                              <%= item.invoicedQuantity %> PCS
                                                                            <% } %>
                                                                          </div>
                                                                        <% } %>
                                                                      <% }); %>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <button type="submit" class="btn btn-success">
                                                                    <i class="bi bi-truck"></i>
                                                                    Confirm Delivery
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No approved orders found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Inbound Products Section -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#inboundProducts">
                <h2 class="section-title">
                    <i class="bi bi-box-arrow-in-down"></i>
                    Inbound Products
                    <% if (completedProductions && completedProductions.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= completedProductions.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="inboundProducts" class="section-content collapse">
                <form action="/dashboard/productWarehouse" method="GET" class="time-interval-form">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="inboundStartDate">Start Date</label>
                                <input type="date" class="form-control" id="inboundStartDate" name="inboundStartDate" value="<%= inboundStartDate || defaultInboundStartDate %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="inboundEndDate">End Date</label>
                                <input type="date" class="form-control" id="inboundEndDate" name="inboundEndDate" value="<%= inboundEndDate || defaultInboundEndDate %>">
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-calendar-check"></i>
                                Set Time Interval
                            </button>
                        </div>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Receive Date</th>
                                <th>Batch Number</th>
                                <th>SO Number</th>
                                <th>Product Name</th>
                                <th>Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (completedProductions && completedProductions.length > 0) { %>
                                <% completedProductions.forEach(function(production) { %>
                                    <tr>
                                        <td data-label="Receive Date"><%= new Date(production.date).toISOString().split('T')[0] %></td>
                                        <td data-label="Batch Number"><%= production.batchNumber || '-' %></td>
                                        <td data-label="SO Number"><%= production.poSoNumber || '-' %></td>
                                        <td data-label="Product Name"><%= production.item%></td>
                                        <td data-label="Quantity" class="quantity-positive">
                                            <i class="bi bi-plus-circle"></i>
                                            <%= production.quantity %> KG
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No completed productions found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Outbound Products Section -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#outboundProducts">
                <h2 class="section-title">
                    <i class="bi bi-box-arrow-right"></i>
                    Outbound Products
                    <% if (outboundProductDetails && outboundProductDetails.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= outboundProductDetails.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="outboundProducts" class="section-content collapse">
                <form action="/dashboard/productWarehouse" method="GET" class="time-interval-form">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="outboundStartDate">Start Date</label>
                                <input type="date" class="form-control" id="outboundStartDate" name="outboundStartDate" value="<%= outboundStartDate || defaultOutboundStartDate %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="outboundEndDate">End Date</label>
                                <input type="date" class="form-control" id="outboundEndDate" name="outboundEndDate" value="<%= outboundEndDate || defaultOutboundEndDate %>">
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-calendar-check"></i>
                                Set Time Interval
                            </button>
                        </div>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Delivery Date</th>
                                <th>SO Number</th>
                                <th>Customer</th>
                                <th>Product Name</th>
                                <th>Packaging</th>
                                <th>Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (outboundProductDetails && outboundProductDetails.length > 0) { %>
                                <% outboundProductDetails.forEach(function(product) { %>
                                    <tr>
                                        <td data-label="Delivery Date"><%= new Date(product.date).toISOString().split('T')[0] %></td>
                                        <td data-label="SO Number"><%= product.sonumber %></td>
                                        <td data-label="Customer"><%= product.customer %></td>
                                        <td data-label="Product Name"><%= product.item %></td>
                                        <td data-label="Packaging"><%= product.packagingName %><%= product.packagingVolume %></td>
                                        <td data-label="Quantity" class="quantity-negative">
                                            <i class="bi bi-dash-circle"></i>
                                            <%= product.quantity %> PCS
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No outbound products found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Rework Items Section -->
        <div class="dashboard-section">
            <div class="section-header" data-bs-toggle="collapse" data-bs-target="#reworkItems">
                <h2 class="section-title">
                    <i class="bi bi-tools"></i>
                    Rework Items
                    <% if (complainItems && complainItems.length > 0) { %>
                        <span class="badge rounded-pill bg-danger ms-2"><%= complainItems.length %></span>
                    <% } %>
                </h2>
                <i class="bi bi-chevron-down"></i>
            </div>
            <div id="reworkItems" class="section-content collapse">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>SO Number</th>
                                <th>Customer Name</th>
                                <th>Product</th>
                                <th>Quantity Rejected</th>
                                <th>Notes</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (complainItems && complainItems.length > 0) { %>
                                <% complainItems.forEach(function(item) { %>
                                    <tr>
                                        <td data-label="SO Number"><%= item.Complain.Order.sonumber %></td>
                                        <td data-label="Customer Name"><%= item.Complain.Order.customerName %></td>
                                        <td data-label="Product"><%= item.product %></td>
                                        <td data-label="Quantity Rejected"><%= item.quantityRejected %> KG</td>
                                        <td data-label="Notes"><%= item.notes || '-' %></td>
                                        <td data-label="Status"><%= item.status %></td>
                                        <td data-label="Action">
                                            <% if (item.status === 'Ready To Deliver') { %>
                                                <form action="/complain/deliver-rework/<%= item.id %>" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-success">
                                                        <i class="bi bi-truck"></i>
                                                        Deliver
                                                    </button>
                                                </form>
                                            <% } else if (item.status === 'Rework Approved') { %>
                                                <form action="/productWarehouse/proceed-to-ppic" method="POST" class="d-inline">
                                                    <input type="hidden" name="complainItemId" value="<%= item.id %>">
                                                    <button type="submit" class="btn btn-primary">
                                                        <i class="bi bi-forward"></i>
                                                        Forward to PPIC
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <form action="/productWarehouse/proceed-to-qc" method="POST" class="d-inline">
                                                    <input type="hidden" name="complainItemId" value="<%= item.id %>">
                                                    <button type="submit" class="btn btn-primary">
                                                        <i class="bi bi-arrow-right-circle"></i>
                                                        Proceed to QC
                                                    </button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No rework items found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set up SSE for notifications
        const evtSource = new EventSource('/notifications');
        const audio = new Audio('/audio/product.mp3');

        evtSource.onmessage = function(event) {
            const data = JSON.parse(event.data);
            
            if (data.type === 'newDeliveryOrder') {
                // Show notification for new delivery order
                const notification = `New order ready for delivery: ${data.sonumber} (${data.customerName})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }

                // Refresh the page to show the new order
                setTimeout(() => {
                    location.reload();
                }, 3000);
            } else if (data.type === 'newComplain') {
                // Show notification for new complain
                const notification = `New complain received: ${data.sonumber} (${data.customerName})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }

                // Refresh the page to show the new complain
                setTimeout(() => {
                    location.reload();
                }, 3000);
            } else if (data.type === 'rework') {
                // Show notification for rework
                const notification = `New rework approved: ${data.sonumber} - ${data.product} (${data.customerName})`;
                showNotification(notification);
                
                // Play audio if specified
                if (data.audio) {
                    audio.play().catch(e => console.error('Error playing audio:', e));
                }

                // Refresh the page to show the new rework
                setTimeout(() => {
                    location.reload();
                }, 3000);
            }
        };

        function showNotification(message) {
            const notificationDiv = document.createElement('div');
            notificationDiv.className = 'alert alert-info alert-dismissible fade show';
            notificationDiv.style.position = 'fixed';
            notificationDiv.style.top = '20px';
            notificationDiv.style.right = '20px';
            notificationDiv.style.zIndex = '9999';
            notificationDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            document.body.appendChild(notificationDiv);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                notificationDiv.remove();
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        if (sidebar.classList.contains('collapsed')) {
                            document.body.classList.add('sidebar-collapsed');
                        } else {
                            document.body.classList.remove('sidebar-collapsed');
                        }
                    }
                });
            });
            observer.observe(sidebar, { attributes: true });

            // Initialize collapsible sections
            const sections = document.querySelectorAll('.dashboard-section');
            sections.forEach(section => {
                const content = section.querySelector('.section-content');
                const icon = section.querySelector('.bi-chevron-down');

                // Set initial state
                if (content.classList.contains('show')) {
                    icon.style.transform = 'rotate(180deg)';
                }

                // Use Bootstrap's collapse events
                content.addEventListener('show.bs.collapse', () => {
                    icon.style.transform = 'rotate(180deg)';
                });

                content.addEventListener('hide.bs.collapse', () => {
                    icon.style.transform = 'rotate(0)';
                });
            });
        });
    </script>

</body>
</html>
