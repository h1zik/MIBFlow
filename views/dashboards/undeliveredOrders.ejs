<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Undelivered Orders', extraScripts: ['https://code.jquery.com/jquery-3.6.0.min.js'] }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/productWarehouse/undelivered' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const items = (typeof undeliveredItems !== 'undefined' && undeliveredItems) ? undeliveredItems : [];

        /* aggregate remaining units (cosmetic stat) */
        let totalRemaining = 0;
        items.forEach(it => { const rem = (it.unit || 0) - (it.sentQuantity || 0); if (!isNaN(rem)) totalRemaining += rem; });
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Undelivered Orders',
              pageIcon: 'bi-box-seam',
              pageSubtitle: 'Orders with remaining quantities to be delivered' }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Pending Items</div>
                    <div class="stat-value"><%= items.length %></div>
                    <span class="stat-sub">Lines awaiting delivery</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-box2"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Remaining Units</div>
                    <div class="stat-value"><%= totalRemaining %></div>
                    <span class="stat-sub">Packaging units to send</span>
                </div>
            </div>
        </div>

        <!-- ===================== Table ===================== -->
        <div class="table-card fade-in">
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>SO Number</th>
                            <th>Customer Name</th>
                            <th>Product</th>
                            <th>Packaging</th>
                            <th class="text-end">Ordered Quantity</th>
                            <th class="text-end">Sent Quantity</th>
                            <th class="text-end">Remaining</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (undeliveredItems && undeliveredItems.length > 0) { %>
                            <% undeliveredItems.forEach(function(item) { %>
                                <tr>
                                    <td data-label="Order ID"><span class="cell-strong">#<%= item.Order.id %></span></td>
                                    <td data-label="SO Number"><%= item.Order.sonumber %></td>
                                    <td data-label="Customer Name"><%= item.Order.customerName %></td>
                                    <td data-label="Product"><%= item.Product.name %></td>
                                    <td data-label="Packaging">
                                        <%= item.Packaging.name %>
                                        (<%= item.Packaging.volume %> <%= item.satuan %>)
                                    </td>
                                    <td data-label="Ordered Quantity" class="text-end num"><%= item.unit %> units</td>
                                    <td data-label="Sent Quantity" class="text-end num"><%= item.sentQuantity || 0 %> units</td>
                                    <td data-label="Remaining" class="text-end num"><%= item.unit - (item.sentQuantity || 0) %> units</td>
                                    <td data-label="Action" class="text-end">
                                        <div class="action-buttons justify-content-end">
                                            <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#deliveryModal<%= item.id %>">
                                                <i class="bi bi-truck"></i>
                                                Deliver
                                            </button>
                                            <a href="/orders/<%= item.Order.id %>" class="btn btn-sm btn-primary">
                                                <i class="bi bi-eye"></i>
                                                View Order
                                            </a>
                                        </div>

                                        <!-- Delivery Modal -->
                                        <div class="modal fade" id="deliveryModal<%= item.id %>" tabindex="-1" aria-labelledby="deliveryModalLabel<%= item.id %>" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="deliveryModalLabel<%= item.id %>">Delivery Details - SO#<%= item.Order.sonumber %></h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form action="/productWarehouse/deliver-remaining/<%= item.id %>" method="POST">
                                                        <div class="modal-body text-start">
                                                            <div class="mb-4">
                                                                <h6 class="mb-3"><%= item.Product.name %></h6>
                                                                <div class="mb-3">
                                                                    <label class="form-label">
                                                                        <%= item.Product.name %> in <%= item.Packaging.name %>
                                                                        (<%= item.Packaging.volume %> <%= item.satuan %>)
                                                                    </label>
                                                                    <div class="input-group">
                                                                        <input type="number"
                                                                            class="form-control"
                                                                            name="sentQuantity"
                                                                            placeholder="Enter number of packaging units"
                                                                            max="<%= item.unit - (item.sentQuantity || 0) %>"
                                                                            required>
                                                                        <span class="input-group-text">units</span>
                                                                    </div>
                                                                    <small class="form-text">
                                                                        Total packaging units needed: <%= item.unit - (item.sentQuantity || 0) %>
                                                                    </small>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                                                            <button type="submit" class="btn btn-success">
                                                                <i class="bi bi-truck"></i>
                                                                Confirm Delivery
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="9">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No undelivered orders</h4>
                                        <p>Orders with remaining quantities to deliver will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
