<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Returned Packaging History' }) %>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/purchase/returned-packaging-history' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const returnedList = (typeof returnedPackaging !== 'undefined' && returnedPackaging) ? returnedPackaging : [];
        const noReturnList = (typeof noReturnPackaging !== 'undefined' && noReturnPackaging) ? noReturnPackaging : [];

        /* status badge helper */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };

        const pkgName = (i) => (i && i.PackagingRequest && i.PackagingRequest.packagingName) ? i.PackagingRequest.packagingName : '—';
        const vName   = (i) => (i && i.Vendor && i.Vendor.name) ? i.Vendor.name : '—';
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Returned Packaging History',
              pageIcon: 'bi-box-seam',
              pageSubtitle: 'History of returned and no-return packaging requests',
              actionsHtml: '<a href="/dashboard/purchase" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-box-arrow-in-left"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Returned Packaging</div>
                    <div class="stat-value"><%= returnedList.length %></div>
                    <span class="stat-sub">Items returned to vendor</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-danger"><i class="bi bi-x-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">No Return Packaging</div>
                    <div class="stat-value"><%= noReturnList.length %></div>
                    <span class="stat-sub">Items kept without return</span>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="toolbar">
            <div class="search">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Search by PO, packaging or vendor…" autocomplete="off">
            </div>
        </div>

        <!-- Returned Section -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-check-circle"></i> Returned Packaging</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle searchable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>PO Number</th>
                            <th>Packaging Name</th>
                            <th>Vendor</th>
                            <th>Split Quantity</th>
                            <th>Tax</th>
                            <th>Payment Type</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Reject Quantity</th>
                            <th>Reject Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (returnedList.length > 0) { %>
                            <% returnedList.forEach(item => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= item.id %></span></td>
                                    <td data-label="PO Number"><%= item.ponumber || '—' %></td>
                                    <td data-label="Packaging Name"><%= pkgName(item) %></td>
                                    <td data-label="Vendor"><%= vName(item) %></td>
                                    <td data-label="Split Quantity" class="num"><%= item.splitQuantity %> pcs</td>
                                    <td data-label="Tax"><%= item.tax %></td>
                                    <td data-label="Payment Type"><%= item.paymentType %></td>
                                    <td data-label="QC Status"><span class="status-badge <%= sb(item.qcStatus) %>"><%= item.qcStatus || '—' %></span></td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= item.qcComment || '—' %></span></td>
                                    <td data-label="Reject Quantity" class="num"><%= item.rejectQuantity %> pcs</td>
                                    <td data-label="Reject Comment"><span class="cell-sub"><%= item.rejectComment || '—' %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No returned packaging</h4>
                                        <p>Returned packaging records will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- No Return Section -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-x-circle"></i> No Return Packaging</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle searchable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>PO Number</th>
                            <th>Packaging Name</th>
                            <th>Vendor</th>
                            <th>Split Quantity</th>
                            <th>Tax</th>
                            <th>Payment Type</th>
                            <th>QC Status</th>
                            <th>QC Comment</th>
                            <th>Reject Quantity</th>
                            <th>Reject Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (noReturnList.length > 0) { %>
                            <% noReturnList.forEach(item => { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= item.id %></span></td>
                                    <td data-label="PO Number"><%= item.ponumber || '—' %></td>
                                    <td data-label="Packaging Name"><%= pkgName(item) %></td>
                                    <td data-label="Vendor"><%= vName(item) %></td>
                                    <td data-label="Split Quantity" class="num"><%= item.splitQuantity %> pcs</td>
                                    <td data-label="Tax"><%= item.tax %></td>
                                    <td data-label="Payment Type"><%= item.paymentType %></td>
                                    <td data-label="QC Status"><span class="status-badge <%= sb(item.qcStatus) %>"><%= item.qcStatus || '—' %></span></td>
                                    <td data-label="QC Comment"><span class="cell-sub"><%= item.qcComment || '—' %></span></td>
                                    <td data-label="Reject Quantity" class="num"><%= item.rejectQuantity %> pcs</td>
                                    <td data-label="Reject Comment"><span class="cell-sub"><%= item.rejectComment || '—' %></span></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No no-return packaging</h4>
                                        <p>No-return packaging records will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Live search across both tables
        document.addEventListener('DOMContentLoaded', function () {
            const input = document.getElementById('searchInput');
            if (!input) return;
            const rows = document.querySelectorAll('table.searchable tbody tr');
            input.addEventListener('input', function () {
                const q = this.value.trim().toLowerCase();
                rows.forEach(row => {
                    if (row.classList.contains('is-empty-row')) return;
                    row.style.display = (!q || row.textContent.toLowerCase().includes(q)) ? '' : 'none';
                });
            });
        });
    </script>
</body>
</html>
