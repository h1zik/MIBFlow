<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schedule Production</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .form-control:disabled {
            background-color: var(--background-light);
            cursor: not-allowed;
        }

        .raw-materials-list {
            margin-top: 0.5rem;
        }

        .raw-material-item {
            padding: 0.75rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .raw-material-item:last-child {
            border-bottom: none;
        }

        .raw-material-info {
            color: #6c757d;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }

        .tanks-grid {
            display: grid;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }

        .tank-card {
            background-color: var(--background-light);
            padding: 1rem;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .tank-card.selected {
            background-color: #e8f5e9;
            border-color: var(--primary-color);
        }

        .tank-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .tank-name {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-color);
        }

        .tank-volume {
            color: #6c757d;
            font-size: 0.75rem;
        }

        .stir-sequence {
            display: none;
            margin-top: 0.5rem;
            max-width: 150px;
        }

        .stir-sequence.visible {
            display: block;
            animation: slideDown 0.3s ease-out;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .alert {
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .alert-danger {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .tanks-grid {
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            }

            .tank-card {
                flex-direction: row;
                align-items: center;
            }

            .tank-header {
                flex: 1;
            }

            .stir-sequence {
                margin-top: 0;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .tanks-grid {
                grid-template-columns: 1fr;
            }

            .raw-material-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-calendar-check"></i>
                Schedule Production
            </h1>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger fade-in">
                <i class="bi bi-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/production/schedule/<%= productionRequest.id %>" method="POST" id="scheduleForm">
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-calendar-date"></i>
                        Schedule Details
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="startDate">Start Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" 
                                    value="<%= new Date().toISOString().split('T')[0] %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="deadlineDate">Deadline Date</label>
                                <input type="date" class="form-control" id="deadlineDate" name="deadlineDate" 
                                    value="<%- deadlineDate ? new Date(deadlineDate).toISOString().split('T')[0] : '' %>" required>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-box-seam"></i>
                        Production Details
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="product">Product</label>
                                <input type="text" class="form-control" id="product" name="product" value="<%- productionRequest.product %>" readonly>
                                <input type="hidden" name="productId" value="<%- productionRequest.productId %>">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="quantity">Quantity to Produce (KG)</label>
                                <input type="number" class="form-control" id="quantity" name="quantity" value="<%= productionRequest.quantity %>" required>
                                <% if (typeof product !== 'undefined' && product && product.density) { %>
                                <small class="form-text text-muted">
                                    Volume in Liters: <span id="volumeInLiters"><%= (productionRequest.quantity / product.density).toFixed(2) %></span>L 
                                    (Density: <%= product.density %> kg/L)
                                </small>
                                <input type="hidden" id="productDensity" name="productDensity" value="<%= product.density %>">
                                <% } else { %>
                                <small class="form-text text-muted">
                                    Product density information not available
                                </small>
                                <input type="hidden" id="productDensity" name="productDensity" value="1">
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-box2"></i>
                        Raw Materials
                    </h2>
                </div>
                <div class="card-body">
                    <div class="raw-materials-list">
                        <% rawMaterials.forEach(rawMaterial => { %>
                            <div class="raw-material-item">
                                <div>
                                    <div class="raw-material-name"><%- rawMaterial.name || (rawMaterial.RawMaterial ? rawMaterial.RawMaterial.name : 'Unknown') %></div>
                                    <div class="raw-material-info">
                                        Available: <%- rawMaterial.stock || (rawMaterial.RawMaterial ? rawMaterial.RawMaterial.stock : 0) %> KG / Required: <%- rawMaterial.requestedQuantity || rawMaterial.quantity || 0 %> KG
                                    </div>
                                </div>
                                <input type="hidden" name="rawMaterials[]" value="<%- rawMaterial.id || (rawMaterial.RawMaterial ? rawMaterial.RawMaterial.id : '') %>">
                                <input type="hidden" name="rawMaterialQuantities[]" value="<%- rawMaterial.requestedQuantity || rawMaterial.quantity || 0 %>">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-water"></i>
                        Tank Selection
                    </h2>
                    <% if (typeof product !== 'undefined' && product && product.density) { %>
                    <div class="tank-volume-info">
                        Required Volume: <span id="requiredVolumeDisplay"><%= (productionRequest.quantity / product.density).toFixed(2) %></span>L
                    </div>
                    <% } else { %>
                    <div class="tank-volume-info">
                        Product density information not available. Tank volume requirements cannot be calculated.
                    </div>
                    <% } %>
                </div>
                <div class="card-body">
                    <div class="tanks-grid">
                        <% tanks.forEach((tank, index) => { %>
                            <div class="tank-card" id="tankCard-<%- index %>">
                                <div class="tank-header">
                                    <div class="form-check">
                                        <input class="form-check-input tank-checkbox" type="checkbox" name="selectedTanks[]" value="<%- tank.id %>" 
                                            id="tank-<%- index %>" data-index="<%- index %>">
                                    </div>
                                    <div>
                                        <div class="tank-name"><%- tank.name %></div>
                                        <div class="tank-volume"><%- tank.volume %> L</div>
                                    </div>
                                </div>
                                <input type="number" class="form-control stir-sequence" name="stirSequences[]" 
                                    placeholder="Stir Sequence" min="1" value="1" id="stirSequence-<%- index %>" 
                                    data-index="<%- index %>">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i>
                    Schedule Production
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);

            // Set min date for start date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').setAttribute('min', today);

            // Update deadline date min value when start date changes
            document.getElementById('startDate').addEventListener('change', function() {
                document.getElementById('deadlineDate').setAttribute('min', this.value);
                if (document.getElementById('deadlineDate').value < this.value) {
                    document.getElementById('deadlineDate').value = this.value;
                }
            });
            // Update volume calculation when quantity changes
            const quantityInput = document.getElementById('quantity');
            const volumeDisplay = document.getElementById('volumeInLiters');
            const productDensity = <%- typeof product !== 'undefined' && product && product.density ? product.density : 1 %>;
            
            if (quantityInput && volumeDisplay) {
                quantityInput.addEventListener('input', function() {
                    const quantity = parseFloat(this.value) || 0;
                    const volumeInLiters = quantity / productDensity;
                    volumeDisplay.textContent = volumeInLiters.toFixed(2);
                    
                    // Also update the required volume display in the tank selection section
                    const requiredVolumeDisplay = document.getElementById('requiredVolumeDisplay');
                    if (requiredVolumeDisplay) {
                        requiredVolumeDisplay.textContent = volumeInLiters.toFixed(2);
                    }
                });
            }

            // Handle tank selection
            document.querySelectorAll('.tank-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const index = this.dataset.index;
                    const tankCard = document.getElementById(`tankCard-${index}`);
                    const stirSequenceInput = document.getElementById(`stirSequence-${index}`);

                    if (this.checked) {
                        tankCard.classList.add('selected');
                        stirSequenceInput.classList.add('visible');
                    } else {
                        tankCard.classList.remove('selected');
                        stirSequenceInput.classList.remove('visible');
                        stirSequenceInput.value = '1';
                    }
                });
            });
        });

        // Form validation
        document.getElementById('scheduleForm').addEventListener('submit', function(event) {
            const startDate = document.getElementById('startDate').value;
            const deadlineDate = document.getElementById('deadlineDate').value;
            const today = new Date().toISOString().split('T')[0];
            const quantity = parseFloat(document.getElementById('quantity').value);
            const maxAllowedCapacity = quantity * 1.1; // 10% more than required quantity

            if (startDate < today) {
                event.preventDefault();
                alert('Start date cannot be before today');
                return;
            }

            if (deadlineDate < startDate) {
                event.preventDefault();
                alert('Deadline date cannot be before start date');
                return;
            }

            // Check if any tanks are selected
            const checkedTanks = document.querySelectorAll('.tank-checkbox:checked');
            if (checkedTanks.length === 0) {
                event.preventDefault();
                alert('Please select at least one tank for production');
                return;
            }

            // Get selected tanks and their capacities
            const selectedTanks = [];
            document.querySelectorAll('.tank-checkbox:checked').forEach(function(checkbox) {
                const index = checkbox.getAttribute('data-index');
                const tankCard = document.getElementById(`tankCard-${index}`);
                const tankVolume = parseFloat(tankCard.querySelector('.tank-volume').textContent);
                const stirCount = parseInt(document.getElementById(`stirSequence-${index}`).value) || 1;
                
                // Add each tank's capacity for each stir
                for (let i = 0; i < stirCount; i++) {
                    selectedTanks.push(tankVolume);
                }
            });

            // Sort tanks by volume (ascending)
            selectedTanks.sort((a, b) => a - b);

            // Get product density from the form
            const productDensity = parseFloat(document.getElementById('productDensity').value || 1);
            
            // Convert quantity (weight in kg) to volume in liters
            const volumeInLiters = quantity / productDensity;
            
            // Calculate minimum required tanks
            let remainingVolume = volumeInLiters;
            let minimumTanks = 0;
            let totalCapacity = 0;

            for (const tankVolume of selectedTanks) {
                if (remainingVolume > 0) {
                    minimumTanks++;
                    totalCapacity += tankVolume;
                    remainingVolume -= tankVolume;
                }
            }

            if (totalCapacity < volumeInLiters) {
                event.preventDefault();
                alert(`Selected tanks do not have enough capacity (${totalCapacity.toFixed(2)}L) for the production volume (${volumeInLiters.toFixed(2)}L)`);
                return;
            }

            // Allow only one extra tank for overflow
            if (selectedTanks.length > minimumTanks + 1) {
                event.preventDefault();
                alert(`Too many tanks selected. The production requires ${minimumTanks} tank(s) with some overflow. Additional tanks would be unused.`);
                return;
            }

            // Disable unchecked tanks' stir sequence inputs
            document.querySelectorAll('input[name="stirSequences[]"]').forEach(function(input) {
                const index = input.getAttribute('data-index');
                const checkbox = document.getElementById(`tank-${index}`);

                if (!checkbox.checked) {
                    input.disabled = true;
                }
            });
        });
    </script>
</body>
</html>
