<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Productions History' }) %>
    <style>
        /* Productions History — page-scoped flourishes (built on --mib-* tokens) */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .filter-card { margin-bottom: 1.4rem; }
        .filter-card .card-body { padding: 1.1rem 1.25rem; }
        .ph-table thead th { background: var(--mib-surface-2); white-space: nowrap; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/productions/stock-updated' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const prodList  = (typeof productions !== 'undefined' && productions) ? productions : [];
        const sd        = (typeof startDate !== 'undefined' && startDate) ? startDate : '';
        const ed        = (typeof endDate !== 'undefined' && endDate) ? endDate : '';

        /* status badge helper (shared design system) */
        const KNOWN_STATUS = new Set(['pending','processing','onprod','on-production','production-completed','completed','approved','paid','delivered','on-delivery','ready-to-deliver','partially-delivered','open','printed','scheduled','cancelled','declined','rejected','neutral']);
        const sb = (s) => { const k = String(s || '').toLowerCase().replace(/\s+/g, '-'); return 'status-' + (KNOWN_STATUS.has(k) ? k : 'neutral'); };
        const fmtDate = (d) => {
            if (!d) return '—';
            try { return new Date(d).toISOString().split('T')[0]; }
            catch (e) { return '—'; }
        };
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Productions History',
              pageIcon: 'bi-box-seam-fill',
              pageSubtitle: 'Productions whose stock has been updated — filter by date range to review past batches.',
              actionsHtml: '<a href="/dashboard/production" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-success"><i class="bi bi-check2-circle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Stock-Updated Batches</div>
                    <div class="stat-value"><%= prodList.length %></div>
                    <span class="stat-sub">In the current selection</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-calendar-range"></i></div>
                <div class="stat-body">
                    <div class="stat-label">From</div>
                    <div class="stat-value" style="font-size:1.35rem"><%= sd || 'Earliest' %></div>
                    <span class="stat-sub">Start date filter</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-body">
                    <div class="stat-label">To</div>
                    <div class="stat-value" style="font-size:1.35rem"><%= ed || 'Latest' %></div>
                    <span class="stat-sub">End date filter</span>
                </div>
            </div>
        </div>

        <!-- ===================== Filter ===================== -->
        <div class="card filter-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-funnel"></i> Filter by Date Range</h2>
            </div>
            <div class="card-body">
                <form action="/productions/stock-updated" method="GET">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label" for="startDate">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= sd %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="endDate">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= ed %>">
                        </div>
                        <div class="col-md-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-funnel"></i> Apply Filter</button>
                            <% if (sd || ed) { %>
                                <a href="/productions/stock-updated" class="btn btn-light"><i class="bi bi-x-lg"></i> Clear</a>
                            <% } %>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===================== Production list ===================== -->
        <div class="table-card">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-table"></i> Production List</h2>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle ph-table">
                    <thead>
                        <tr>
                            <th>PREQ ID</th>
                            <th>Batch Number</th>
                            <th>Product Name</th>
                            <th class="text-end">Quantity</th>
                            <th>Start Date</th>
                            <th>Deadline Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (prodList.length > 0) { %>
                            <% prodList.forEach(function(production) { %>
                                <tr>
                                    <td data-label="PREQ ID"><span class="cell-strong">#<%= production.productionRequestId %></span></td>
                                    <td data-label="Batch Number"><%= production.batchNumber || 'Not Generated' %></td>
                                    <td data-label="Product Name"><span class="cell-strong"><%= production.Product ? production.Product.name : '—' %></span></td>
                                    <td data-label="Quantity" class="text-end num"><%= production.quantity %> Kg</td>
                                    <td data-label="Start Date"><%= fmtDate(production.startDate) %></td>
                                    <td data-label="Deadline Date"><%= fmtDate(production.deadlineDate) %></td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= sb(production.status) %>">
                                            <i class="bi bi-check-circle"></i> <%= production.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="7">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No productions found</h4>
                                        <p>No stock-updated productions match the selected date range.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</body>
</html>
