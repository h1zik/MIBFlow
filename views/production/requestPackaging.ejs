<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Request Packaging' }) %>
    <style>
        /* Page-scoped flourishes, built on the shared --mib-* tokens */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .volume-info {
            color: var(--mib-text-muted);
            font-size: 0.8rem;
            margin-top: 0.4rem;
            min-height: 1.1rem;
        }
        .form-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }
        @media (max-width: 575.98px) {
            .form-actions { flex-direction: column; }
            .form-actions .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/packaging-request/requestPackaging' }) %>

    <div class="content content-narrow">
        <%# Page header — markup mirrors partials/page-header.ejs (inlined to avoid that partial's doc-comment parse bug) %>
        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-box2"></i> Request Packaging</h1>
                <p class="page-subtitle">Fill in the details below to request packaging materials</p>
            </div>
            <div class="page-actions">
                <a href="/dashboard/ppic" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            </div>
        </div>

        <form action="/packaging-request/requestPackaging" method="POST" class="fade-in">
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-clipboard-data"></i> Packaging Details</h2>
                <p class="form-section-desc">Choose the packaging type and the number of pieces required.</p>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label" for="packagingSelect">Packaging</label>
                        <select class="form-select" id="packagingSelect" name="packagingId" required>
                            <option value="">Select Packaging</option>
                            <% packagings.forEach(function(packaging) { %>
                                <option value="<%= packaging.id %>" data-volume="<%= packaging.volume %>">
                                    <%= packaging.name %>
                                </option>
                            <% }); %>
                        </select>
                        <div id="volumeInfo" class="volume-info"></div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label" for="quantity">Quantity (pcs)</label>
                        <input type="number" class="form-control" id="quantity" name="quantity" required min="1">
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i>
                    Submit Request
                </button>
                <a href="/dashboard/ppic" class="btn btn-soft">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('packagingSelect').addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const volume = selectedOption.dataset.volume;
            const volumeInfo = document.getElementById('volumeInfo');

            if (volume) {
                volumeInfo.textContent = `Volume: ${volume} ml`;
            } else {
                volumeInfo.textContent = '';
            }
        });
    </script>
</body>
</html>
