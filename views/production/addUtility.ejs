<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Add Utilities' }) %>
    <style>
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .form-section-title i { color: var(--mib-primary); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/overhead/utility/add' }) %>

    <div class="content content-narrow">
        <%- include('../partials/page-header', {
              pageTitle: 'Add Utilities',
              pageIcon: 'bi-lightning-charge',
              pageSubtitle: 'Record a recurring monthly utility expense for overhead calculation.',
              actionsHtml: '<a href="/dashboard/finance" class="btn btn-light"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
            }) %>

        <form action="/overhead/utility/add" method="POST">
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-gear"></i> Utility Information</h2>
                <p class="form-section-desc">All fields are required.</p>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="name">Utility Name</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="e.g. Electricity" required>
                    </div>

                    <div class="col-12">
                        <label class="form-label" for="price">Price per Month (Rp)</label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input type="number" class="form-control" id="price" name="price" step="0.01" placeholder="0.00" required>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg"></i> Add Utility
                    </button>
                    <a href="/dashboard/finance" class="btn btn-light">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                </div>
            </div>
        </form>
    </div>
</body>
</html>
