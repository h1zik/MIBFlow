<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', {
          pageTitle: 'Productions Schedule',
          extraStylesheets: ['https://cdn.jsdelivr.net/npm/fullcalendar@5.10.1/main.min.css']
    }) %>
    <style>
        /* Productions Schedule — page-scoped flourishes (built on --mib-* tokens) */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }

        /* Calendar shell */
        .calendar-card { padding: 1.5rem; }
        #calendar { background: transparent; }

        /* FullCalendar themed to the design system */
        .fc .fc-button-primary {
            background-color: var(--mib-primary) !important;
            border-color: var(--mib-primary) !important;
            box-shadow: none;
        }
        .fc .fc-button-primary:hover,
        .fc .fc-button-primary:not(:disabled).fc-button-active,
        .fc .fc-button-primary:not(:disabled):active {
            background-color: var(--mib-primary-dark) !important;
            border-color: var(--mib-primary-dark) !important;
        }
        .fc .fc-button-primary:focus { box-shadow: var(--mib-ring) !important; }
        .fc .fc-button-primary:disabled { background-color: var(--mib-primary-light) !important; border-color: var(--mib-primary-light) !important; }
        .fc-event {
            border-radius: var(--mib-radius-sm);
            padding: 2px 4px;
            margin: 1px 0;
            border: none;
            background-color: var(--mib-primary);
            color: #fff;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .fc-event:hover { transform: translateY(-1px); box-shadow: var(--mib-shadow-md); }
        .fc .fc-toolbar-title { color: var(--mib-text); font-weight: 650; }
        .fc .fc-col-header-cell-cushion { color: var(--mib-text); font-weight: 600; padding: 8px; }
        .fc .fc-day-today { background-color: var(--mib-primary-soft) !important; }
        .fc-scrollgrid { border-radius: var(--mib-radius-sm); overflow: hidden; }
        .fc-theme-standard td, .fc-theme-standard th { border-color: var(--mib-border); }

        /* Modal detail rows */
        #productionModal .detail-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.75rem 0; border-bottom: 1px solid var(--mib-border); gap: 1rem;
        }
        #productionModal .detail-row:last-child { border-bottom: none; }
        #productionModal .detail-row span:first-child { color: var(--mib-text-muted); font-weight: 500; }
        #productionModal .detail-row span:last-child { font-weight: 650; color: var(--mib-text); text-align: right; }

        .tooltip-inner { white-space: pre-line; }

        @media (max-width: 576px) {
            #productionModal .detail-row { flex-direction: column; align-items: flex-start; gap: 0.35rem; }
            #productionModal .detail-row span:last-child { text-align: left; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/productionSchedule' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const events = (typeof productionEvents !== 'undefined' && productionEvents) ? productionEvents : [];
    %>

    <div class="content content-wide">

        <%- include('../partials/page-header', {
              pageTitle: 'Productions Schedule',
              pageIcon: 'bi-calendar-week',
              pageSubtitle: 'Manage and view all your production schedules in one place.'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-calendar-event"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Scheduled Productions</div>
                    <div class="stat-value"><%= events.length %></div>
                    <span class="stat-sub">Events on the calendar</span>
                </div>
            </div>
        </div>

        <!-- ===================== Calendar ===================== -->
        <div class="card calendar-card fade-in">
            <div id="calendar"></div>
        </div>
    </div>

    <!-- Modal to display production details -->
    <div class="modal fade" id="productionModal" tabindex="-1" role="dialog" aria-labelledby="productionModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="productionModalLabel"><i class="bi bi-clipboard-data"></i> Production Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="detail-row">
                        <span>Batch Number:</span>
                        <span id="batchNumber"></span>
                    </div>
                    <div class="detail-row">
                        <span>Quantity:</span>
                        <span id="quantity"></span>
                    </div>
                    <div class="detail-row">
                        <span>QC Status:</span>
                        <span id="qcStatus"></span>
                    </div>
                    <div class="detail-row">
                        <span>Stir Sequence:</span>
                        <span id="stirSequence"></span>
                    </div>
                    <div class="detail-row">
                        <span>Sample Retained:</span>
                        <span id="sampleRetained"></span>
                    </div>
                    <div class="detail-row">
                        <span>Retained Sample Volume:</span>
                        <span id="retainedSampleVolume"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ensure jQuery is loaded first -->
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.9.2/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.10.1/main.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            let events = [];
            try {
                events = JSON.parse('<%- JSON.stringify(productionEvents || []) %>'.replace(/&quot;/g, '"'));
            } catch (error) {
                console.error('Error parsing production events:', error);
            }

            // Initialize FullCalendar with enhanced options
            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: events,
                eventDisplay: 'block',
                displayEventTime: true,
                eventTimeFormat: {
                    hour: '2-digit',
                    minute: '2-digit',
                    meridiem: false,
                    hour12: false
                },
                eventClick: function(info) {
                    const event = info.event.extendedProps;

                    // Update modal with formatted data
                    document.getElementById('batchNumber').textContent = event.batchNumber || 'N/A';
                    document.getElementById('quantity').textContent = event.quantity ? `${event.quantity} Kg` : 'N/A';
                    document.getElementById('qcStatus').textContent = event.qcStatus || 'Not Available';
                    document.getElementById('stirSequence').textContent = event.stirSequence || 'N/A';
                    document.getElementById('sampleRetained').textContent = event.sampleRetained ? 'Yes' : 'No';
                    document.getElementById('retainedSampleVolume').textContent =
                        event.retainedSampleVolume ? `${event.retainedSampleVolume} L` : 'N/A';

                    // Show the modal using Bootstrap 5 syntax
                    const modal = new bootstrap.Modal(document.getElementById('productionModal'));
                    modal.show();
                },
                eventDidMount: function(info) {
                    // Add tooltip with basic information
                    $(info.el).tooltip({
                        title: `Batch: ${info.event.extendedProps.batchNumber || 'N/A'}\nQuantity: ${info.event.extendedProps.quantity || 'N/A'} Kg`,
                        placement: 'top',
                        trigger: 'hover',
                        container: 'body'
                    });
                }
            });

            // Render the calendar
            calendar.render();

            // Handle window resize
            window.addEventListener('resize', function() {
                calendar.updateSize();
            });
        });
    </script>
</body>
</html>
