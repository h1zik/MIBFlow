<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Request Raw Material' }) %>
    <style>
        /* Page-scoped flourishes, built on the shared --mib-* tokens */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .density-note {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            background: var(--mib-info-soft);
            border: 1px solid var(--mib-border);
            border-left: 4px solid var(--mib-info, #2563eb);
            color: var(--mib-text);
            border-radius: var(--mib-radius-sm);
            padding: 0.8rem 1rem;
            font-size: 0.85rem;
            margin-top: 1rem;
        }
        .density-note i { color: var(--mib-info, #2563eb); font-size: 1.05rem; line-height: 1.3; }
        .form-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }
        @media (max-width: 575.98px) {
            .form-actions { flex-direction: column; }
            .form-actions .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/rawMaterial/requestRawMaterial' }) %>

    <div class="content content-narrow">
        <%# Page header — markup mirrors partials/page-header.ejs (inlined to avoid that partial's doc-comment parse bug) %>
        <div class="page-header fade-in">
            <div class="page-header__main">
                <h1 class="page-title"><i class="bi bi-box-seam"></i> Request Raw Material</h1>
                <p class="page-subtitle">Fill in the details below to request a raw material</p>
            </div>
            <div class="page-actions">
                <a href="/dashboard/production" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            </div>
        </div>

        <form action="/rawMaterial/requestRawMaterial" method="POST" class="fade-in">
            <div class="form-section">
                <h2 class="form-section-title"><i class="bi bi-clipboard-data"></i> Material Details</h2>
                <p class="form-section-desc">Select the material and the amount your production line needs.</p>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="materialName">Material Name</label>
                        <select class="form-select" id="materialName" name="materialName" required>
                            <option value="" selected disabled>Select a material</option>
                            <% rawmaterial.forEach(material => { %>
                                <option value="<%= material.name %>"
                                        data-form="<%= material.form %>"
                                        data-density="<%= material.density %>">
                                    <%= material.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label" for="quantity">Quantity</label>
                        <input type="number" class="form-control" id="quantity" name="quantity" min="0" step="0.01" required>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label" for="unit">Unit</label>
                        <select class="form-select" id="unit" name="unit" required>
                            <option value="KG">KG</option>
                            <option value="L">L</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label" for="orderId">Order ID <span class="text-muted-2">(Optional)</span></label>
                        <input type="text" class="form-control" id="orderId" name="orderId" placeholder="Enter order ID if applicable">
                    </div>
                </div>

                <div class="density-note" id="densityInfo" style="display: none;">
                    <i class="bi bi-info-circle-fill"></i>
                    <span id="densityMessage"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i>
                    Submit Request
                </button>
                <a href="/dashboard/production" class="btn btn-soft">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('materialName').addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const form = selectedOption.getAttribute('data-form');
            const density = parseFloat(selectedOption.getAttribute('data-density')); // Ensure it's a number
            const unitSelect = document.getElementById('unit');
            const densityInfo = document.getElementById('densityInfo');
            const densityMessage = document.getElementById('densityMessage');

            if (form === 'Liquid') {
                unitSelect.value = 'L'; // Default to L for liquids
                densityInfo.style.display = 'flex';
                densityMessage.textContent = `This material has a density of ${density} kg/L. The quantity will be automatically converted to KG for storage.`;
            } else {
                unitSelect.value = 'KG'; // Default to KG for solids
                densityInfo.style.display = 'none';
            }
        });

        // Handle form submission
        document.querySelector('form').addEventListener('submit', function(e) {
            const selectedOption = document.getElementById('materialName').options[document.getElementById('materialName').selectedIndex];
            const form = selectedOption.getAttribute('data-form');
            const density = parseFloat(selectedOption.getAttribute('data-density'));
            const quantity = parseFloat(document.getElementById('quantity').value);
            const unit = document.getElementById('unit').value;

            if (form === 'Liquid' && unit === 'L' && !isNaN(density) && !isNaN(quantity)) {
                // Just show informational message about the conversion that will happen
                document.getElementById('densityMessage').textContent = `This material has a density of ${density} kg/L. The quantity will be converted to KG in the backend.`;
            }
        });
    </script>
</body>
</html>
