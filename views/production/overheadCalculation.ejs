<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Overhead Calculation' }) %>
    <style>
        /* Legacy-var bridge so shared partials stay on-brand */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }

        /* Result summary cards */
        .oc-result { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
        .oc-result-card {
            background: var(--mib-grad-surface);
            border: 1px solid var(--mib-border);
            border-left: 4px solid var(--mib-primary);
            border-radius: var(--mib-radius);
            box-shadow: var(--mib-shadow-xs);
            padding: 1.15rem 1.25rem;
        }
        .oc-result-label { color: var(--mib-text-muted); font-size: 0.82rem; font-weight: 600; display: flex; align-items: center; gap: 0.4rem; }
        .oc-result-value { color: var(--mib-text); font-size: 1.5rem; font-weight: 750; letter-spacing: -0.01em; margin-top: 0.35rem; font-variant-numeric: tabular-nums; }
        .form-section-title i { color: var(--mib-primary); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/overhead/calculate-overhead' }) %>

    <%
        /* ---- Defensive normalisation (page rendered from two routes) ---- */
        const fmtNum = (v) => {
            const n = Number(v);
            return Number.isFinite(n) ? n : 0;
        };
        const indirectLabor   = fmtNum(typeof totalIndirectLabor !== 'undefined' ? totalIndirectLabor : 0);
        const directLabor     = fmtNum(typeof totalDirectLabor !== 'undefined' ? totalDirectLabor : 0);
        const utilitiesPrice  = fmtNum(typeof totalUtilitiesPrice !== 'undefined' ? totalUtilitiesPrice : 0);
        const result          = (typeof calculationResult !== 'undefined' && calculationResult) ? calculationResult : null;
        const rupiah = (v) => 'Rp' + fmtNum(v).toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Overhead Calculation',
              pageIcon: 'bi-calculator',
              pageSubtitle: 'Calculate production overhead per batch — fixed, variable and equipment depreciation.'
            }) %>

        <form action="/overhead/calculate-overhead" method="POST">
            <div class="stagger">
                <!-- Fixed Overheads -->
                <div class="form-section">
                    <h2 class="form-section-title"><i class="bi bi-building"></i> Fixed Overheads</h2>
                    <p class="form-section-desc">Standing monthly costs that don't change with output.</p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="rent">Rent (Rp)</label>
                            <input type="number" class="form-control" id="rent" name="rent" step="0.01" value="10000000" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="indirectLabor">Indirect Labor (Rp/Hour)</label>
                            <input type="number" class="form-control" id="indirectLabor" name="indirectLabor" step="0.01" value="<%= indirectLabor %>" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="insurance">Insurance (Rp)</label>
                            <input type="number" class="form-control" id="insurance" name="insurance" step="0.01" value="5000000" readonly>
                        </div>
                    </div>
                </div>

                <!-- Variable Overheads -->
                <div class="form-section">
                    <h2 class="form-section-title"><i class="bi bi-graph-up"></i> Variable Overheads</h2>
                    <p class="form-section-desc">Costs that scale with production activity.</p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="directLabor">Direct Labor (Rp/Hour)</label>
                            <input type="number" class="form-control" id="directLabor" name="directLabor" step="0.01" value="<%= directLabor %>" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="utilities">Utilities (Rp/month)</label>
                            <input type="number" class="form-control" id="utilities" name="utilities" step="0.01" value="<%= utilitiesPrice %>" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="handling">Handling (Rp/batch)</label>
                            <input type="number" class="form-control" id="handling" name="handling" step="0.01" value="100000" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="transport">Transport (Rp/batch)</label>
                            <input type="number" class="form-control" id="transport" name="transport" step="0.01" value="150000" readonly>
                        </div>
                    </div>
                </div>

                <!-- Equipment Usage -->
                <div class="form-section">
                    <h2 class="form-section-title"><i class="bi bi-tools"></i> Equipment Usage</h2>
                    <p class="form-section-desc">Hours of equipment used per batch (drives depreciation cost).</p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="blendingTankHours">Blending Tank Usage (hours)</label>
                            <input type="number" class="form-control" id="blendingTankHours" name="blendingTankHours" step="0.01" value="1" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="balanceHours">Balance Usage (hours)</label>
                            <input type="number" class="form-control" id="balanceHours" name="balanceHours" step="0.01" value="0.5" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="forkliftHours">Hand Forklift Usage (hours)</label>
                            <input type="number" class="form-control" id="forkliftHours" name="forkliftHours" step="0.01" value="0.5" readonly>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-calculator"></i> Calculate Overhead Cost
                </button>
            </div>
        </form>

        <% if (result) { %>
            <div class="form-section fade-in">
                <h2 class="form-section-title"><i class="bi bi-check-circle-fill"></i> Calculation Result</h2>
                <p class="form-section-desc">Overhead figures for one standard batch (1000 Kg/L).</p>
                <div class="oc-result">
                    <div class="oc-result-card">
                        <div class="oc-result-label"><i class="bi bi-cash-stack"></i> Total Overhead Cost</div>
                        <div class="oc-result-value"><%= typeof result.totalOverheadCost !== 'undefined' ? rupiah(result.totalOverheadCost) : '—' %></div>
                    </div>
                    <div class="oc-result-card">
                        <div class="oc-result-label"><i class="bi bi-rulers"></i> Overhead Cost per Kg/L</div>
                        <div class="oc-result-value"><%= typeof result.overheadCostPerUnit !== 'undefined' ? rupiah(result.overheadCostPerUnit) : '—' %></div>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>
