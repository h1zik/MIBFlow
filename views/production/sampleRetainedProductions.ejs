<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Retained Sample' }) %>
    <style>
        /* Retained Sample — page-specific flourishes, built on mibflow.css tokens */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .quick-stats { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .filter-card .card-body { padding-top: 1.1rem; }
        .tank-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
        .expiry-note { display: block; margin-top: 0.25rem; font-size: 0.72rem; color: var(--mib-text-muted); }
        .table-card .table { margin: 0; }
        .table-card .table-responsive { border: 0; box-shadow: none; border-radius: 0; }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/qc/sampleRetainedProductions' }) %>

    <%
        /* ---- Defensive normalisation (rendered from two controllers with slightly different locals) ---- */
        const activeList   = (typeof productions !== 'undefined' && productions) ? productions : [];
        const expiredList  = (typeof expiredProductions !== 'undefined' && expiredProductions) ? expiredProductions : [];
        const startVal     = (typeof startDate !== 'undefined' && startDate) ? startDate : (typeof defaultStartDate !== 'undefined' ? defaultStartDate : '');
        const endVal       = (typeof endDate !== 'undefined' && endDate) ? endDate : (typeof defaultEndDate !== 'undefined' ? defaultEndDate : '');

        /* helpers */
        const fmtDate = (d) => {
            if (!d) return '-';
            const dt = (d instanceof Date) ? d : new Date(d);
            return isNaN(dt) ? '-' : dt.toISOString().split('T')[0];
        };
        const soNumber = (p) => {
            const pr = p.ProductionRequest;
            if (pr && pr.orderId && pr.Order) return pr.Order.sonumber;
            if (pr && pr.prodreqnumber) return pr.prodreqnumber;
            return '-';
        };

        /* stat counts */
        const today = new Date();
        let expiringSoon = 0;
        activeList.forEach(p => {
            if (p.expiredDate) {
                const months = (new Date(p.expiredDate) - today) / (1000 * 60 * 60 * 24 * 30);
                if (months <= 6) expiringSoon++;
            }
        });
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Retained Sample',
              pageIcon: 'bi-archive-fill',
              pageSubtitle: 'View and manage retained production samples',
              actionsHtml: '<a href="/dashboard/qc" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- ===================== Quick stats ===================== -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon"><i class="bi bi-archive"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Active Samples</div>
                    <div class="stat-value"><%= activeList.length %></div>
                    <span class="stat-sub">Retained &amp; in storage</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon <%= expiringSoon > 0 ? 'is-warning' : 'is-success' %>"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Expiring Soon</div>
                    <div class="stat-value"><%= expiringSoon %></div>
                    <span class="stat-sub">Within 6 months</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon <%= expiredList.length > 0 ? 'is-danger' : 'is-success' %>"><i class="bi bi-calendar-x"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Expired Samples</div>
                    <div class="stat-value"><%= expiredList.length %></div>
                    <span class="stat-sub">Past expiry date</span>
                </div>
            </div>
        </div>

        <!-- ===================== Date filter ===================== -->
        <div class="card filter-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-calendar-range"></i> Filter by Date Range</h2>
            </div>
            <div class="card-body">
                <form action="/qc/sampleRetainedProductions" method="GET">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label" for="startDate">Start Date</label>
                            <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startVal %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="endDate">End Date</label>
                            <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endVal %>">
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-funnel"></i> Apply Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- ===================== Active production samples ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-table"></i> Active Production Samples</h2>
                <span class="pill"><i class="bi bi-archive"></i> <%= activeList.length %></span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Production Date</th>
                            <th>Batch Number</th>
                            <th>SO Number</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Tanks</th>
                            <th>No Rack</th>
                            <th>Expired Date</th>
                            <th>BG Scan</th>
                            <th class="text-end">Retained Volume</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (activeList.length > 0) { %>
                            <% activeList.forEach(function(production) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= production.id %></span></td>
                                    <td data-label="Production Date"><%= fmtDate(production.startDate) %></td>
                                    <td data-label="Batch Number"><%= production.batchNumber || '-' %></td>
                                    <td data-label="SO Number"><%= soNumber(production) %></td>
                                    <td data-label="Product"><span class="cell-strong"><%= production.Product ? production.Product.name : '-' %></span></td>
                                    <td data-label="Quantity"><%= production.quantity %> Kg</td>
                                    <td data-label="Tanks">
                                        <div class="tank-chips">
                                            <% (production.Tanks || []).forEach(function(tank) { %>
                                                <span class="chip"><i class="bi bi-water"></i> <%= tank.name %> (<%= tank.volume %> L)</span>
                                            <% }) %>
                                            <% if (!production.Tanks || production.Tanks.length === 0) { %>-<% } %>
                                        </div>
                                    </td>
                                    <td data-label="No Rack"><%= production.noRack || '-' %></td>
                                    <td data-label="Expired Date">
                                        <%
                                        if (production.expiredDate) {
                                            const expiryDate = new Date(production.expiredDate);
                                            const monthsUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24 * 30);
                                            if (monthsUntilExpiry <= 1) {
                                                const daysUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24);
                                        %>
                                            <span class="status-badge status-pending"><i class="bi bi-exclamation-triangle"></i> <%= fmtDate(production.expiredDate) %></span>
                                            <span class="expiry-note">Expires in <%= Math.ceil(daysUntilExpiry) %> days</span>
                                        <% } else if (monthsUntilExpiry <= 6) { %>
                                            <span class="status-badge status-pending"><i class="bi bi-exclamation-triangle"></i> <%= fmtDate(production.expiredDate) %></span>
                                            <span class="expiry-note">Expires in <%= Math.ceil(monthsUntilExpiry) %> months</span>
                                        <% } else { %>
                                            <%= fmtDate(production.expiredDate) %>
                                        <% } } else { %>
                                            -
                                        <% } %>
                                    </td>
                                    <td data-label="BG Scan">
                                        <% if (production.bgscan) { %>
                                            <a href="/uploads/BGScan/<%= production.bgscan %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-earmark-text"></i> View Scan</a>
                                        <% } else { %>
                                            <span class="text-muted-2">-</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Retained Volume" class="text-end"><span class="num"><%= production.retainedSampleVolume %> ml</span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h4>No retained samples</h4>
                                        <p>Productions with a retained sample will appear here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ===================== Expired production samples ===================== -->
        <div class="table-card fade-in">
            <div class="card-header">
                <h2 class="card-title"><i class="bi bi-exclamation-triangle"></i> Expired Production Samples</h2>
                <span class="pill"><i class="bi bi-calendar-x"></i> <%= expiredList.length %></span>
            </div>
            <div class="table-responsive">
                <table class="table table-cards align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Production Date</th>
                            <th>Batch Number</th>
                            <th>SO Number</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Tanks</th>
                            <th>No Rack</th>
                            <th>Expired Date</th>
                            <th>BG Scan</th>
                            <th class="text-end">Retained Volume</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (expiredList.length > 0) { %>
                            <% expiredList.forEach(function(production) { %>
                                <tr>
                                    <td data-label="ID"><span class="cell-strong">#<%= production.id %></span></td>
                                    <td data-label="Production Date"><%= fmtDate(production.startDate) %></td>
                                    <td data-label="Batch Number"><%= production.batchNumber || '-' %></td>
                                    <td data-label="SO Number"><%= soNumber(production) %></td>
                                    <td data-label="Product"><span class="cell-strong"><%= production.Product ? production.Product.name : '-' %></span></td>
                                    <td data-label="Quantity"><%= production.quantity %> Kg</td>
                                    <td data-label="Tanks">
                                        <div class="tank-chips">
                                            <% (production.Tanks || []).forEach(function(tank) { %>
                                                <span class="chip"><i class="bi bi-water"></i> <%= tank.name %> (<%= tank.volume %> L)</span>
                                            <% }) %>
                                            <% if (!production.Tanks || production.Tanks.length === 0) { %>-<% } %>
                                        </div>
                                    </td>
                                    <td data-label="No Rack"><%= production.noRack || '-' %></td>
                                    <td data-label="Expired Date">
                                        <span class="status-badge status-declined"><i class="bi bi-exclamation-circle"></i> <%= fmtDate(production.expiredDate) %></span>
                                    </td>
                                    <td data-label="BG Scan">
                                        <% if (production.bgscan) { %>
                                            <a href="/uploads/BGScan/<%= production.bgscan %>" target="_blank" class="btn btn-sm btn-soft"><i class="bi bi-file-earmark-text"></i> View Scan</a>
                                        <% } else { %>
                                            <span class="text-muted-2">-</span>
                                        <% } %>
                                    </td>
                                    <td data-label="Retained Volume" class="text-end"><span class="num"><%= production.retainedSampleVolume %> ml</span></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr class="is-empty-row">
                                <td colspan="11">
                                    <div class="empty-state">
                                        <i class="bi bi-check2-circle"></i>
                                        <h4>No expired samples</h4>
                                        <p>Expired retained samples will be listed here.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
