<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sample Retained Productions</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .page-subtitle {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .badge {
            padding: 0.35rem 0.65rem;
            font-size: 0.75rem;
            font-weight: 500;
            border-radius: 2rem;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            margin: 0.125rem;
        }

        .badge-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .badge-scheduled {
            background-color: #d4edda;
            color: #155724;
        }

        .badge-declined,
        .badge-fail {
            background-color: #f8d7da;
            color: #721c24;
        }

        .badge-pass {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .form-label {
                font-size: 1rem;
            }

            .form-control {
                font-size: 1rem;
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .btn-group {
                display: flex;
                gap: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            .table-responsive {
                margin: 0 -1rem;
            }

            .table {
                margin: 0 1rem;
            }

            .table td {
                white-space: normal;
                min-width: 120px;
            }

            .table td:first-child {
                position: sticky;
                left: 0;
                background-color: white;
                z-index: 1;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-archive"></i>
                Sample Retained Productions
            </h1>
            <p class="page-subtitle">View and manage retained production samples</p>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-calendar-range"></i>
                    Filter by Date Range
                </h2>
            </div>
            <div class="card-body">
                <form action="/qc/sampleRetainedProductions" method="GET">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label" for="startDate">Start Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" value="<%= startDate || defaultStartDate %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label" for="endDate">End Date</label>
                                <input type="date" class="form-control" id="endDate" name="endDate" value="<%= endDate || defaultEndDate %>">
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-funnel"></i>
                                Apply Filter
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-table"></i>
                    Active Production Samples
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Production Date</th>
                                <th>Batch Number</th>
                                <th>SO Number</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Tanks</th>
                                <th>No Rack</th>
                                <th>Expired Date</th>
                                <th>BG Scan</th>
                                <th>Retained Volume</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (productions && productions.length > 0) { %>
                                <% productions.forEach(function(production) { %>
                                    <tr>
                                        <td>#<%= production.id %></td>
                                        <td><%= production.startDate.toISOString().split('T')[0] %></td>
                                        <td><%= production.batchNumber %></td>
                                        <td>
                                            <% if (production.ProductionRequest?.orderId && production.ProductionRequest.Order) { %>
                                                <%= production.ProductionRequest.Order.sonumber %>
                                            <% } else if (production.ProductionRequest?.prodreqnumber) { %>
                                                <%= production.ProductionRequest.prodreqnumber %>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= production.Product.name %></td>
                                        <td><%= production.quantity %> Kg</td>
                                        <td>
                                            <% production.Tanks.forEach(tank => { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-water"></i>
                                                    <%= tank.name %> (<%= tank.volume %> L)
                                                </span>
                                            <% }) %>
                                        </td>
                                        <td><%= production.noRack || '-' %></td>
                                        <td>
                                            <% 
                                            if (production.expiredDate) {
                                                const expiryDate = new Date(production.expiredDate);
                                                const today = new Date();
                                                const monthsUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24 * 30);
                                                
                                                if (monthsUntilExpiry <= 1) {
                                                    const daysUntilExpiry = (expiryDate - today) / (1000 * 60 * 60 * 24); %>
                                                    <span class="badge badge-pending">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        <%= production.expiredDate.toISOString().split('T')[0] %>
                                                        <br>
                                                        Expires in <%= Math.ceil(daysUntilExpiry) %> days
                                                    </span>
                                                <% } else if (monthsUntilExpiry <= 6) { %>
                                                    <span class="badge badge-pending">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        <%= production.expiredDate.toISOString().split('T')[0] %>
                                                        <br>
                                                        Expires in <%= Math.ceil(monthsUntilExpiry) %> months
                                                    </span>
                                                <% } else { %>
                                                    <%= production.expiredDate.toISOString().split('T')[0] %>
                                                <% }
                                            } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (production.bgscan) { %>
                                                <a href="/uploads/BGScan/<%= production.bgscan %>" target="_blank" class="badge badge-pass">
                                                    <i class="bi bi-file-earmark-text"></i>
                                                    View Scan
                                                </a>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= production.retainedSampleVolume %> ml</td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="text-center text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No productions with sample retained found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card fade-in mt-4">
            <div class="card-header bg-warning bg-opacity-10">
                <h2 class="card-title">
                    <i class="bi bi-exclamation-triangle"></i>
                    Expired Production Samples
                </h2>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Production Date</th>
                                <th>Batch Number</th>
                                <th>SO Number</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Tanks</th>
                                <th>No Rack</th>
                                <th>Expired Date</th>
                                <th>BG Scan</th>
                                <th>Retained Volume</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (expiredProductions && expiredProductions.length > 0) { %>
                                <% expiredProductions.forEach(function(production) { %>
                                    <tr class="text-muted">
                                        <td>#<%= production.id %></td>
                                        <td><%= production.startDate.toISOString().split('T')[0] %></td>
                                        <td><%= production.batchNumber %></td>
                                        <td>
                                            <% if (production.ProductionRequest?.orderId && production.ProductionRequest.Order) { %>
                                                <%= production.ProductionRequest.Order.sonumber %>
                                            <% } else if (production.ProductionRequest?.prodreqnumber) { %>
                                                <%= production.ProductionRequest.prodreqnumber %>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= production.Product.name %></td>
                                        <td><%= production.quantity %> Kg</td>
                                        <td>
                                            <% production.Tanks.forEach(tank => { %>
                                                <span class="badge badge-pending">
                                                    <i class="bi bi-water"></i>
                                                    <%= tank.name %> (<%= tank.volume %> L)
                                                </span>
                                            <% }) %>
                                        </td>
                                        <td><%= production.noRack || '-' %></td>
                                        <td>
                                            <span class="badge badge-fail">
                                                <i class="bi bi-exclamation-circle"></i>
                                                <%= production.expiredDate ? production.expiredDate.toISOString().split('T')[0] : '-' %>
                                            </span>
                                        </td>
                                        <td>
                                            <% if (production.bgscan) { %>
                                                <a href="/uploads/BGScan/<%= production.bgscan %>" target="_blank" class="badge badge-pass">
                                                    <i class="bi bi-file-earmark-text"></i>
                                                    View Scan
                                                </a>
                                            <% } else { %>
                                                -
                                            <% } %>
                                        </td>
                                        <td><%= production.retainedSampleVolume %> ml</td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="text-center text-muted">
                                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                        No expired production samples found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a href="/dashboard/qc" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i>
                Back to Dashboard
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
