<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Production Request Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .info-grid {
            display: grid;
            gap: 1rem;
        }

        .info-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .info-label {
            font-size: 0.75rem;
            color: #6c757d;
            font-weight: 500;
        }

        .info-value {
            font-size: 0.875rem;
            color: var(--text-color);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .status-badge.pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .status-badge.completed {
            background-color: #d4edda;
            color: #155724;
        }

        .status-badge.not-tested {
            background-color: #e2e3e5;
            color: #383d41;
        }

        .table {
            margin: 0;
        }

        .table thead th {
            background-color: var(--primary-color);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            padding: 1rem;
            border: none;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-color: rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
        }

        .table tbody tr:hover {
            background-color: var(--background-light);
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background-color: #6c757d;
            border: none;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-1px);
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Desktop styles */
        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .page-header {
                padding: 1.5rem;
                margin-bottom: 2rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-header {
                padding: 1.5rem;
            }

            .card-title {
                font-size: 1.2rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .info-grid {
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            }

            .btn {
                font-size: 1rem;
                width: auto;
            }

            .btn-group {
                display: flex;
                gap: 1rem;
            }
        }

        /* Mobile styles */
        @media (max-width: 768px) {
            .btn-group {
                display: grid;
                gap: 0.5rem;
            }

            .table-responsive {
                margin: 0 -1rem;
            }

            .table {
                margin: 0 1rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-clipboard-data"></i>
                Production Request Details
            </h1>
        </div>

        <div class="card fade-in">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="bi bi-box-seam"></i>
                    Production Request #<%= productionRequest.id %>
                </h2>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Product</span>
                        <span class="info-value"><%= productionRequest.product %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Quantity</span>
                        <span class="info-value"><%= productionRequest.quantity %> KG</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Status</span>
                        <span class="status-badge <%= productionRequest.status.toLowerCase() %>">
                            <i class="bi bi-circle-fill"></i>
                            <%= productionRequest.status %>
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">QC Status</span>
                        <span class="status-badge <%= productionRequest.qcStatus ? productionRequest.qcStatus.toLowerCase() : 'not-tested' %>">
                            <i class="bi bi-circle-fill"></i>
                            <%= productionRequest.qcStatus || 'Not Tested Yet' %>
                        </span>
                    </div>
                </div>

                <div class="btn-group mt-4">
                    <a href="/uploads/<%= productionRequest.formula %>" target="_blank" class="btn btn-primary">
                        <i class="bi bi-download"></i>
                        Download Formula
                    </a>
                </div>
            </div>
        </div>

        <% if (order) { %>
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-cart-check"></i>
                        Associated Order Details
                    </h2>
                </div>
                <div class="card-body">
                    <div class="info-grid mb-4">
                        <div class="info-item">
                            <span class="info-label">Order ID</span>
                            <span class="info-value">#<%= order.sonumber %></span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Customer Name</span>
                            <span class="info-value"><%= order.customerName %></span>
                        </div>
                    </div>

                    <!-- Consumables Section -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="bi bi-box2"></i>
                                Consumables Used
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <% const orderConsumables = (order && order.OrderConsumables) ? order.OrderConsumables : []; %>
                                <% if (orderConsumables.length > 0) { %>
                                    <% orderConsumables.forEach(consumable => { %>
                                        <div class="col-md-4 mb-2">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <span class="d-flex align-items-center">
                                                    <i class="bi bi-check-circle-fill text-success me-2"></i>
                                                    <span><%= consumable.name %></span>
                                                </span>
                                                <span class="text-muted">Rp <%= consumable.fee.toLocaleString() %></span>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="col-12"><span class="text-muted">No consumables selected.</span></div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Total Quantity</th>
                                    <th>Packaging Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% productPackagingMap.forEach((packagingDetails, productName) => { %>
                                    <tr>
                                        <td><%= productName %></td>
                                        <td>
                                            <% 
                                            let totalQuantity = 0;
                                            packagingDetails.forEach(packaging => {
                                                totalQuantity += packaging.quantity;
                                            });
                                            %>
                                            <%= totalQuantity %> KG
                                        </td>
                                        <td>
                                            <% packagingDetails.forEach(packaging => { %>
                                                <div class="mb-1">
                                                    <%= packaging.packaging %>, <%= packaging.volume %> L, <%= packaging.unit %>
                                                </div>
                                            <% }) %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <% if (order.notes) { %>
                        <div class="mt-4">
                            <span class="info-label">Notes</span>
                            <p class="info-value mt-2"><%= order.notes %></p>
                        </div>
                    <% } %>

                    <div class="btn-group mt-4">
                        <a href="/uploads/<%= order.po %>" target="_blank" class="btn btn-primary">
                            <i class="bi bi-download"></i>
                            Download PO
                        </a>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-exclamation-circle"></i>
                        No Associated Order
                    </h2>
                </div>
                <div class="card-body">
                    <p class="text-muted">This production request is not associated with any order.</p>
                </div>
            </div>
        <% } %>

        <div class="mt-4">
            <% if (userRole === 'Production') { %>
                <a href="/dashboard/production" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to Production Dashboard
                </a>
            <% } else if (userRole === 'PPIC') { %>
                <a href="/dashboard/ppic" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i>
                    Back to PPIC Dashboard
                </a>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);
        });
    </script>
</body>
</html>
