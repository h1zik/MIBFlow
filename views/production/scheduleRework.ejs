<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schedule Rework</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Reuse the same styles from schedule.ejs */
        :root {
            --primary-color: #1b5e20;
            --primary-light: #388E3C;
            --background-light: #f4f6f8;
            --text-color: #333;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background-light);
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
            width: 100%;
            transition: var(--transition);
        }

        .page-header {
            background: white;
            padding: 1rem;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
        }

        .page-title {
            margin: 0;
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card {
            background: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            margin-bottom: 1rem;
            border: none;
            overflow: hidden;
        }

        .card-header {
            background-color: var(--background-light);
            padding: 1rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--primary-color);
            font-weight: 600;
            font-size: 1rem;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-body {
            padding: 1rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: var(--primary-color);
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(27, 94, 32, 0.25);
        }

        .form-control:disabled {
            background-color: var(--background-light);
            cursor: not-allowed;
        }

        .raw-materials-list {
            margin-top: 0.5rem;
        }

        .raw-material-item {
            padding: 0.75rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .raw-material-item:last-child {
            border-bottom: none;
        }

        .raw-material-info {
            color: #6c757d;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }

        .tanks-grid {
            display: grid;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }

        .tank-card {
            background-color: var(--background-light);
            padding: 1rem;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            transition: var(--transition);
            border: 2px solid transparent;
        }

        .tank-card.selected {
            background-color: #e8f5e9;
            border-color: var(--primary-color);
        }

        .tank-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .tank-name {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-color);
        }

        .tank-volume {
            color: #6c757d;
            font-size: 0.75rem;
        }

        .stir-sequence {
            display: none;
            margin-top: 0.5rem;
            max-width: 150px;
        }

        .stir-sequence.visible {
            display: block;
            animation: slideDown 0.3s ease-out;
        }

        .btn {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            font-size: 0.875rem;
            width: 100%;
            justify-content: center;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-light);
            transform: translateY(-1px);
        }

        .alert {
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .alert-danger {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }

        @media (min-width: 769px) {
            .main-content {
                margin-left: 280px;
                padding: 2rem;
                width: calc(100% - 280px);
            }

            body:has(.sidebar.collapsed) .main-content {
                margin-left: 70px;
                width: calc(100% - 70px);
            }

            .tanks-grid {
                grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            }

            .tank-card {
                flex-direction: row;
                align-items: center;
            }

            .tank-header {
                flex: 1;
            }
        }

        @media (max-width: 768px) {
            .tanks-grid {
                grid-template-columns: 1fr;
            }

            .raw-material-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { userRole: userRole }) %>

    <div class="main-content">
        <div class="page-header fade-in">
            <h1 class="page-title">
                <i class="bi bi-calendar-check"></i>
                Schedule Rework
            </h1>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger fade-in">
                <i class="bi bi-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/complain/scheduleRework/<%= complainItem.id %>" method="POST" id="scheduleForm">
            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-calendar-date"></i>
                        Schedule Details
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="startDate">Start Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate" 
                                    value="<%= new Date().toISOString().split('T')[0] %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="deadlineDate">Deadline Date</label>
                                <input type="date" class="form-control" id="deadlineDate" name="deadlineDate" required>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-box-seam"></i>
                        Rework Details
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="product">Product</label>
                                <input type="text" class="form-control" id="product" name="product" value="<%- complainItem.product %>" readonly>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label" for="quantity">Quantity</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" id="quantity" name="quantity" value="<%- complainItem.quantityRejected %>" readonly>
                                    <span class="input-group-text">KG</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-box2"></i>
                        Raw Materials
                    </h2>
                </div>
                <div class="card-body">
                    <div class="raw-materials-list">
                        <% complainItemsRawMaterials.forEach(rawMaterial => { %>
                            <div class="raw-material-item">
                                <div>
                                    <div class="raw-material-name"><%- rawMaterial.name %></div>
                                    <div class="raw-material-info">
                                        Available: <%- rawMaterial.stock %> KG / Required: <%- rawMaterial.quantity %> KG
                                    </div>
                                </div>
                                <input type="hidden" name="rawMaterials[]" value="<%- rawMaterial.id %>">
                                <input type="hidden" name="rawMaterialQuantities[]" value="<%- rawMaterial.quantity %>">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="bi bi-water"></i>
                        Tank Selection
                    </h2>
                </div>
                <div class="card-body">
                    <div class="tanks-grid">
                        <% tanks.forEach((tank, index) => { %>
                            <div class="tank-card" id="tankCard-<%- index %>">
                                <div class="tank-header">
                                    <div class="form-check">
                                        <input class="form-check-input tank-checkbox" type="checkbox" name="tanks[]" value="<%- tank.id %>" 
                                            id="tank-<%- index %>" data-index="<%- index %>">
                                    </div>
                                    <div>
                                        <div class="tank-name"><%- tank.name %></div>
                                        <div class="tank-volume"><%- tank.volume %> L</div>
                                    </div>
                                </div>
                                <input type="number" class="form-control stir-sequence" name="stirSequences[]" 
                                    placeholder="Stir Sequence" min="1" value="1" id="stirSequence-<%- index %>" 
                                    data-index="<%- index %>">
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i>
                    Schedule Rework
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle sidebar state changes
            const sidebar = document.querySelector('.sidebar');
            const mainContent = document.querySelector('.main-content');

            function updateContentWidth() {
                if (window.innerWidth > 768) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '70px';
                        mainContent.style.width = 'calc(100% - 70px)';
                    } else {
                        mainContent.style.marginLeft = '280px';
                        mainContent.style.width = 'calc(100% - 280px)';
                    }
                } else {
                    mainContent.style.marginLeft = '0';
                    mainContent.style.width = '100%';
                }
            }

            // Initial width update
            updateContentWidth();

            // Watch for sidebar class changes
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        updateContentWidth();
                    }
                });
            });

            observer.observe(sidebar, { attributes: true });

            // Handle window resize
            window.addEventListener('resize', updateContentWidth);

            // Set min date for start date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('startDate').setAttribute('min', today);

            // Update deadline date min value when start date changes
            document.getElementById('startDate').addEventListener('change', function() {
                document.getElementById('deadlineDate').setAttribute('min', this.value);
                if (document.getElementById('deadlineDate').value < this.value) {
                    document.getElementById('deadlineDate').value = this.value;
                }
            });
            
            // Handle tank selection
            document.querySelectorAll('.tank-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const index = this.dataset.index;
                    const tankCard = document.getElementById(`tankCard-${index}`);
                    const stirSequenceInput = document.getElementById(`stirSequence-${index}`);

                    if (this.checked) {
                        tankCard.classList.add('selected');
                        stirSequenceInput.classList.add('visible');
                    } else {
                        tankCard.classList.remove('selected');
                        stirSequenceInput.classList.remove('visible');
                        stirSequenceInput.value = '1';
                    }
                });
            });
        });

        // Form validation
        document.getElementById('scheduleForm').addEventListener('submit', function(event) {
            const startDate = document.getElementById('startDate').value;
            const deadlineDate = document.getElementById('deadlineDate').value;
            const today = new Date().toISOString().split('T')[0];

            if (startDate < today) {
                event.preventDefault();
                alert('Start date cannot be before today');
                return;
            }

            if (deadlineDate < startDate) {
                event.preventDefault();
                alert('Deadline date cannot be before start date');
                return;
            }

            // Validate tank selection
            const selectedTanks = document.querySelectorAll('input[name="tanks[]"]:checked');
            if (selectedTanks.length === 0) {
                event.preventDefault();
                alert('Please select at least one tank');
                return;
            }

            // Disable unchecked tanks' stir sequence inputs
            document.querySelectorAll('input[name="stirSequences[]"]').forEach(function(input) {
                const index = input.getAttribute('data-index');
                const checkbox = document.getElementById(`tank-${index}`);

                if (!checkbox.checked) {
                    input.disabled = true;
                }
            });
        });
    </script>
</body>
</html>
