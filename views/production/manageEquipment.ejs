<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { pageTitle: 'Manage Equipment' }) %>
    <style>
        /* Manage Equipment — page-scoped flourishes on the shared mibflow.css system */
        :root {
            --primary-color: var(--mib-primary);
            --primary-light: var(--mib-primary-light);
            --primary-dark: var(--mib-primary-dark);
        }
        .stagger > * { opacity: 0; animation: fadeIn 0.5s ease forwards; }
        .stagger > *:nth-child(1) { animation-delay: 0.04s; }
        .stagger > *:nth-child(2) { animation-delay: 0.10s; }
        .stagger > *:nth-child(3) { animation-delay: 0.16s; }
        .stagger > *:nth-child(4) { animation-delay: 0.22s; }
        .quick-stats { margin-bottom: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
    </style>
</head>
<body class="app-shell">
    <%- include('../partials/sidebar', { userRole: userRole, path: '/equipment' }) %>

    <%
        /* ---- Defensive normalisation ---- */
        const balanceList  = (typeof balances  !== 'undefined' && balances)  ? balances  : [];
        const forkliftList = (typeof forklifts !== 'undefined' && forklifts) ? forklifts : [];
        const fmtRp = (v) => {
            const n = Number(v);
            return isNaN(n) ? '0.00' : n.toLocaleString('id-ID', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        };
    %>

    <div class="content content-wide">
        <%- include('../partials/page-header', {
              pageTitle: 'Manage Equipment',
              pageIcon: 'bi-tools',
              pageSubtitle: 'Add and manage balances and forklifts used in production cost calculations.',
              actionsHtml: '<a href="/dashboard/finance" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>'
        }) %>

        <!-- Quick stats -->
        <div class="quick-stats stagger">
            <div class="stat-card">
                <div class="stat-icon is-info"><i class="bi bi-calculator"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Balances</div>
                    <div class="stat-value"><%= balanceList.length %></div>
                    <span class="stat-sub">Registered weighing balances</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon is-warning"><i class="bi bi-truck"></i></div>
                <div class="stat-body">
                    <div class="stat-label">Forklifts</div>
                    <div class="stat-value"><%= forkliftList.length %></div>
                    <span class="stat-sub">Registered forklifts</span>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- ===================== Add Balance ===================== -->
            <div class="col-lg-6">
                <div class="form-section fade-in">
                    <h2 class="form-section-title"><i class="bi bi-calculator"></i> Add Balance</h2>
                    <p class="form-section-desc">Register a new weighing balance and its price.</p>
                    <form action="/add-balance" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="balanceName">Balance Name</label>
                                <input type="text" class="form-control" id="balanceName" name="name" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="balancePrice">Price (Rp)</label>
                                <div class="input-group">
                                    <span class="input-group-text">Rp</span>
                                    <input type="number" class="form-control" id="balancePrice" name="price" step="0.01" required>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-lg"></i> Add Balance
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Existing balances list -->
                <div class="table-card fade-in">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-list-ul"></i> Existing Balances</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Name</th><th class="text-end">Price (Rp)</th></tr>
                            </thead>
                            <tbody>
                                <% if (balanceList.length > 0) { %>
                                    <% balanceList.forEach(balance => { %>
                                        <tr>
                                            <td data-label="Name"><span class="cell-strong"><%= balance.name %></span><div class="cell-sub">#<%= balance.id %></div></td>
                                            <td data-label="Price (Rp)" class="text-end num">Rp <%= fmtRp(balance.price) %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="2"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No balances yet</h4><p>Balances you add will appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ===================== Add Forklift ===================== -->
            <div class="col-lg-6">
                <div class="form-section fade-in">
                    <h2 class="form-section-title"><i class="bi bi-truck"></i> Add Forklift</h2>
                    <p class="form-section-desc">Register a new forklift and its price.</p>
                    <form action="/add-forklift" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="forkliftName">Forklift Name</label>
                                <input type="text" class="form-control" id="forkliftName" name="name" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="forkliftPrice">Price (Rp)</label>
                                <div class="input-group">
                                    <span class="input-group-text">Rp</span>
                                    <input type="number" class="form-control" id="forkliftPrice" name="price" step="0.01" required>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-lg"></i> Add Forklift
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Existing forklifts list -->
                <div class="table-card fade-in">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-list-ul"></i> Existing Forklifts</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-cards align-middle">
                            <thead>
                                <tr><th>Name</th><th class="text-end">Price (Rp)</th></tr>
                            </thead>
                            <tbody>
                                <% if (forkliftList.length > 0) { %>
                                    <% forkliftList.forEach(forklift => { %>
                                        <tr>
                                            <td data-label="Name"><span class="cell-strong"><%= forklift.name %></span><div class="cell-sub">#<%= forklift.id %></div></td>
                                            <td data-label="Price (Rp)" class="text-end num">Rp <%= fmtRp(forklift.price) %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr class="is-empty-row"><td colspan="2"><div class="empty-state"><i class="bi bi-inbox"></i><h4>No forklifts yet</h4><p>Forklifts you add will appear here.</p></div></td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
